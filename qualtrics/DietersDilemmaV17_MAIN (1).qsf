 \/>\nDAG Alert Count 1:&nbsp;${e:\/\/Field\/DAGAlertCount2_1}<br \/>\nDAG2 Time 1: ${e:\/\/Field\/subjDAGTime2_1}<br \/>\nDAG Confidence Time 1:&nbsp;${e:\/\/Field\/dagConfidenceTime2_1}<br \/>\n<br \/>\nDAG2 3: ${e:\/\/Field\/subjDAG2_3}<br \/>\nDAG Confidence 3:&nbsp;${e:\/\/Field\/dagConfidence2_3}<br \/>\nDAG Alert Count 3:&nbsp;${e:\/\/Field\/DAGAlertCount2_3}<br \/>\nDAG2 Time 3: ${e:\/\/Field\/subjDAGTime2_3}<br \/>\nDAG Confidence Time 3:&nbsp;${e:\/\/Field\/dagConfidenceTime2_3}<\/p>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"DAG2 1: ${e:\/\/Field\/subjDAG2_1} DAG Confidence 1:\u00a0${e:\/\/Field\/dagConfidence2_1} DAG Alert Count 1...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<p>DAG2 1: ${e:\/\/Field\/subjDAG2_1}<br \/>\nDAG Confidence 1:&nbsp;${e:\/\/Field\/dagConfidence2_1}<br \/>\nDAG Alert Count 1:&nbsp;${e:\/\/Field\/DAGAlertCount2_1}<br \/>\nDAG2 Time 1: ${e:\/\/Field\/subjDAGTime2_1}<br \/>\nDAG Confidence Time 1:&nbsp;${e:\/\/Field\/dagConfidenceTime2_1}<br \/>\n<br \/>\nDAG2 3: ${e:\/\/Field\/subjDAG2_3}<br \/>\nDAG Confidence 3:&nbsp;${e:\/\/Field\/dagConfidence2_3}<br \/>\nDAG Alert Count 3:&nbsp;${e:\/\/Field\/DAGAlertCount2_3}<br \/>\nDAG2 Time 3: ${e:\/\/Field\/subjDAGTime2_3}<br \/>\nDAG Confidence Time 3:&nbsp;${e:\/\/Field\/dagConfidenceTime2_3}<\/p>","DataExportTag":"Q577","QuestionID":"QID577"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID578","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","DefaultChoices":false,"DataExportTag":"Q571","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID578","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tjQuery(\"#\"+this.questionId+\" .InputText:eq(0)\").on(\"cut copy paste\",function(e) {\n   e.preventDefault();\n  });\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\tconst rationalInference = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('rationalInference_' + id));\n\t\n\tconst beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n\tconst beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n\t\n\tfunction percentageToCategory(value) {\n\t\tif (value >= 0 && value <= 10) return 1;\n\t\tif (value > 10 && value <= 20) return 2;\n\t\tif (value > 20 && value <= 30) return 3;\n\t\tif (value > 30 && value <= 40) return 4;\n\t\tif (value > 40 && value <= 50) return 5;\n\t\tif (value > 50 && value <= 60) return 6;\n\t\tif (value > 60 && value <= 70) return 7;\n\t\tif (value > 70 && value <= 80) return 8;\n\t\tif (value > 80 && value <= 90) return 9;\n\t\tif (value > 90 && value <= 100) return 10;\n\t\treturn null;\n\t}\n\t\n\tconst verbalVariables = ['dieterPA', 'dieterPX', 'dieterPY', 'dieterSameYes', 'dieterSameNo'];\n\tconst verbalPayments = [];\n\t\n\tfor (let i = 0; i < verbalVariables.length; i++) {\n\t\tconst varName = verbalVariables[i];\n\t\tconst userAnswer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData(varName + '_' + id));\n\t\tconst correctValue = rationalInference[varName];\n\t\tconst correctCategory = percentageToCategory(correctValue);\n\t\tconst difference = Math.abs(correctCategory - userAnswer);\n\t\tconst payment = beliefPaymentMax - (difference * beliefPaymentIncentive);\n\t\tverbalPayments.push(payment);\n\t\tconsole.log(varName + ' - Correct:', correctValue, 'Category:', correctCategory, 'Answer:', userAnswer, 'Payment:', payment);\n\t}\n\t\n\t\/\/ --- Correct DAG (same for all 3 elicitations) ---\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tlet correctDAG;\n\tif (causal == 0) {\n\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"},{\"from\":\"Y\",\"to\":\"X\"}]';\n\t} else if (causal == 1) {\n\t\tif (id == 31) {\n\t\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"}]';\n\t\t}\n\t\telse if (id == 33) {\n\t\t\tcorrectDAG = '[{\"from\":\"X\",\"to\":\"Y\"}]';\n\t\t}\n\t\telse {\n\t\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"},{\"from\":\"X\",\"to\":\"Y\"}]';\n\t\t}\n\t}\n\t\n\t\/\/ --- DAG payments for subjDAG0, subjDAG1, subjDAG2 ---\n\tfor (let idx = 0; idx <= 2; idx++) {\n\t\tconst subjDAG_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG' + idx + '_' + id);\n\t\tconst dagPayment = (subjDAG_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tverbalPayments.push(dagPayment);\n\t\tconsole.log('subjDAG' + idx + ' - Answer:', subjDAG_answer, 'Correct:', correctDAG, 'Payment:', dagPayment);\n\t}\n\t\n\t\/\/ --- Confidence DAG payments for dagConfidence1, dagConfidence2 ---\n\tfor (let idx = 1; idx <= 2; idx++) {\n\t\tconst confidenceDAG = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('dagConfidence' + idx + '_' + id));\n\t\tconst subjDAG_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG' + idx + '_' + id);\n\t\t\n\t\tconst X = Math.random() * 100;\n\t\tlet confidenceDAGPayment;\n\t\t\n\t\tif (X > confidenceDAG) {\n\t\t\tconst randomChance = Math.random() * 100;\n\t\t\tconfidenceDAGPayment = (randomChance < X) ? beliefPaymentMax : 0;\n\t\t\tconsole.log('dagConfidence' + idx + ' - X:', X, '> confidence:', confidenceDAG, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment);\n\t\t} else {\n\t\t\tconfidenceDAGPayment = (subjDAG_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\t\tconsole.log('dagConfidence' + idx + ' - X:', X, '<= confidence:', confidenceDAG, ', DAG correct:', (subjDAG_answer === correctDAG), ', Payment:', confidenceDAGPayment);\n\t\t}\n\t\t\n\t\tverbalPayments.push(confidenceDAGPayment);\n\t}\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('verbalPayment_' + id, JSON.stringify(verbalPayments));\n\tconsole.log('Verbal Payments:', verbalPayments);\n\tjQuery(\"#NextButton\").click();\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID579","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;","DefaultChoices":false,"DataExportTag":"Q572","QuestionType":"Captcha","Selector":"V2","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Align":"left","Theme":"light"},"QuestionDescription":" ","GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID579","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]<br>","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function () {\n  const meta             = JSON.parse(`\\${lm:\/\/Field\/1}`);\n  const causalElicitType = meta.causalElicit;\n  const exoButton        = meta.exoButton;\n  const id               = meta.id;\n\n  \/* -------- fallback helper without ?? operator -------- *\/\n  const pick = (key, fallback) => {\n    const v = Qualtrics.SurveyEngine.getEmbeddedData(key);\n    if (v !== null && v !== '') return v;\n    if (fallback !== undefined && fallback !== null && fallback !== '') return fallback;\n    return '';\n  };\n\n  const playerName1    = pick('playerName1',    meta.playerName1   || 'Player A');\n  const playerName2    = pick('playerName2',    meta.playerName2   || 'Player B');\n  const playerPronoun1 = pick('playerPronoun1', meta.playerPronoun1|| 'their');\n  const playerPronoun2 = pick('playerPronoun2', meta.playerPronoun2|| 'their');\n\n  \/* ---------- remember which causal types have shown ---------- *\/\n  let shown = [];\n  try { shown = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownCausalElicitTypes') || '[]'); } catch (_) {}\n  const causalElicitTypeAlreadyShown = shown.indexOf(causalElicitType) !== -1;\n  if (!causalElicitTypeAlreadyShown) {\n    shown.push(causalElicitType);\n    Qualtrics.SurveyEngine.setEmbeddedData('shownCausalElicitTypes', JSON.stringify(shown));\n  }\n\n  \/* ------------------- build instructions ------------------- *\/\n  let instructionTitle = '', instructionText = '';\n\n  let instructionHeader = '<\/strong><\/span><\/div><br>In the next ${e:\/\/Field\/nRoundsCausalBeliefs} rounds, you will continue to play the game <br> <div style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/div> that you have played in the previous ${e:\/\/Field\/nRounds} rounds. You will continue to play with the same two other players, ' + playerName1 + ' and ' + playerName2 + ', who choose in the same way as before. <br><br>'\n\n\n  if (causalElicitType === 'AX') {\n    const bobForced =\n      exoButton == 1\n        ? playerName2 + ' is forced to press ' + playerPronoun2 + ' button'\n        : playerName2 + ' is forced NOT to press ' + playerPronoun2 + ' button';\n\n    instructionTitle =\n      '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>Your payoff now depends on ' +\n      playerName1 + '\\'s choice and ' + bobForced + '!<\/strong><\/span><\/div>' +\n      '<ul><li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>' + playerName1 + '<\/b> presses ' +\n      playerPronoun1 + ' button.<\/u><\/li><li><u>' + bobForced + '.<\/u><\/li><\/ul>';\n\n    instructionText = causalElicitTypeAlreadyShown\n      ? 'The next ${e:\/\/Field\/nRoundsCausalBeliefs} rounds proceed exactly like the previous ones, except that ' + bobForced + '.'\n      : '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>Your payoff now depends on ' +\n        playerName1 + '\\'s choice and ' + bobForced + '!<\/strong><\/span><\/div><br>' +\n        instructionHeader  + 'However, there are two important changes:' +\n        '<ol><li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>' + playerName1 + '<\/b> presses ' + playerPronoun1 +\n        ' button, rather than if ' + playerName2 + ' presses ' + playerPronoun2 + '.<\/u><\/li><li><u>' + bobForced +\n        '<\/u>, regardless of your or ' + playerName1 + '\\'s choice.<\/li><\/ol><u>The cost of pressing your button will change from round to round. <\/u>' +\n        'Sometimes, pressing the button is costly. Other times, not pressing it is costly. Your decision will not affect the cost in future rounds.<br><br>' +\n        'While ' + playerName1 + '\\'s choice determines your bonus if one of these rounds is chosen for payment, you will not see ' +\n        playerPronoun1 + ' choice. Only at the end, if one of these rounds determines your payoffs, will you find out what ' +\n        playerName1 + ' chose in that round.';\n  }\n\n  else if (causalElicitType === 'XY') {\n    const youForced = exoButton == 1\n      ? 'You are forced to press your button'\n      : 'You are forced NOT to press your button';\n\n    instructionTitle =\n      '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>' + youForced +\n      ' and you can now control ' + playerName1 + '\\'s button!<\/strong><\/span><\/div>' +\n      '<ul><li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>' + playerName2 + '<\/b> presses ' + playerPronoun2 +\n      ' button.<\/u><\/li><li><u>' + youForced + '.<\/u><\/li><\/ul>';\n\n    instructionText = causalElicitTypeAlreadyShown\n      ? 'The next ${e:\/\/Field\/nRoundsCausalBeliefs} rounds proceed exactly like the previous ones, except that ' + youForced + '.'\n      : '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>' + youForced +\n        ' and you can now control ' + playerName1 + '\\'s button!<\/strong><\/span><\/div><br>' +\n        instructionHeader  + 'However, there are two important changes:' +\n        '<ol><li><u>' + youForced + '.<\/u><\/li><li><u>You will choose whether to press ' + playerName1 +\n        '\\'s button.<\/u> You will receive a bonus of $${e:\/\/Field\/win} if <b>' + playerName2 + '<\/b> presses ' +\n        playerPronoun2 + ' button.<\/li><\/ol>The cost of pressing ' + playerName1 +\n        '\\'s button will change from round to round. Sometimes, pressing the button is costly. Other times, not pressing it is costly. ' +\n        'Your decision will not affect the cost in future rounds.<br><br>While ' + playerName2 +\n        '\\'s choice determines your bonus if one of these rounds is chosen for payment, you will not see ' +\n        playerPronoun2 + ' choice. Only at the end, if one of these rounds determines your payoff, will you find out what ' +\n        playerName2 + ' chose in that round.';\n  }\n\n  else if (causalElicitType === 'AY') {\n    const annForced = exoButton == 1\n      ? playerName1 + ' is forced to press ' + playerPronoun1 + ' button'\n      : playerName1 + ' is forced NOT to press ' + playerPronoun1 + ' button';\n\n    instructionTitle =\n      '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>' + annForced +\n      '!<\/strong><\/span><\/div><ul><li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>' + playerName2 +\n      '<\/b> presses ' + playerPronoun2 + ' button.<\/u><\/li><li><u>' + annForced + '.<\/u><\/li><\/ul>';\n\n    instructionText = causalElicitTypeAlreadyShown\n      ? 'The next ${e:\/\/Field\/nRoundsCausalBeliefs} rounds proceed exactly like the previous ones, except that ' + annForced + '.'\n      : '<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>' + annForced +\n      '!<\/strong><\/span><\/div><br>' + instructionHeader  + '<br> However, there is one important change: ' +\n        '<u>' + annForced + ', regardless of your or ' + playerName2 +\n        '\\'s choice.<\/u> As before, you will receive a bonus of $${e:\/\/Field\/win} if <b>' + playerName2 +\n        '<\/b> presses ' + playerPronoun2 + ' button.<br><br>The cost of pressing your button will change from round to round. ' +\n        'Sometimes, pressing the button is costly. Other times, not pressing it is costly. Your decision will not affect the cost in future rounds.<br><br>' +\n        'While ' + playerName2 + '\\'s choice determines your bonus if one of these rounds is chosen for payment, you will not see ' +\n        playerPronoun2 + ' choice. Only at the end, if one of these rounds determines your payoff, will you find out what ' +\n        playerName2 + ' chose in that round.';\n  }\n\n  \/* --------------- save embedded data & advance --------------- *\/\n  Qualtrics.SurveyEngine.setEmbeddedData('instructionTitle', instructionTitle);\n  Qualtrics.SurveyEngine.setEmbeddedData('instructionText',  instructionText);\n  Qualtrics.SurveyEngine.setEmbeddedData('playerName1',      playerName1);\n  Qualtrics.SurveyEngine.setEmbeddedData('playerName2',      playerName2);\n  Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun1',   playerPronoun1);\n  Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun2',   playerPronoun2);\n  Qualtrics.SurveyEngine.setEmbeddedData('id',               id);\n\n  jQuery('#NextButton').click();\n});","DefaultChoices":false,"DataExportTag":"Q51","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID58"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID580","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q573","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID580"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID583","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dagElicitationV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1300px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DefaultChoices":false,"DataExportTag":"Q576","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID583","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var completed = false;\n    var id = parseInt(\"${e:\/\/Field\/id}\");\n\n    function sendInit() {\n        var iframe = document.getElementById('dietersGame');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                gameConfig: {\n                    playerName0: \"${e:\/\/Field\/playerName0}\",\n                    playerName1: \"${e:\/\/Field\/playerName1}\",\n                    playerIcon0: \"${e:\/\/Field\/playerIcon0}\",\n                    noConfirmation: 1,\n                    themeColor: \"${e:\/\/Field\/color}\"\n                }\n            }, '*');\n            console.log('Sent INIT to DAG iframe');\n        }\n    }\n\n    var messageHandler = function(event) {\n        var data = event.data;\n        if (!data || typeof data !== 'object') return;\n\n        if (data.type === 'DAG_DATA' && data.dataType === 'DAG_COMPLETE') {\n            if (completed) return;\n            completed = true;\n\n            var dagData = data.data;\n\n            Qualtrics.SurveyEngine.setEmbeddedData('subjDAG2_' + id, JSON.stringify(dagData.initialDAG));\n            Qualtrics.SurveyEngine.setEmbeddedData('dagConfidence2_' + id, dagData.confidence);\n            Qualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount2_' + id, dagData.DAGAlertCount);\n            Qualtrics.SurveyEngine.setEmbeddedData('subjDAGTime2_' + id, JSON.stringify(dagData.initialDAGTime));\n            Qualtrics.SurveyEngine.setEmbeddedData('dagConfidenceTime2_' + id, JSON.stringify(dagData.confidenceTime));\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedDAG_' + id, JSON.stringify(event.data.configReceived ? '1' : '0'));\n\n            console.log('DAG saved:', dagData);\n\n            window.removeEventListener('message', messageHandler);\n            setTimeout(function() {\n                jQuery(\"#NextButton\").click();\n            }, 500);\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ Lifetime handler: IFRAME_READY handshake\n    window.addEventListener('message', function(event) {\n        if (event.data && event.data.type === 'IFRAME_READY') {\n            sendInit();\n        }\n    });\n\n    \/\/ Safety net in case IFRAME_READY was posted before this listener attached.\n    setTimeout(sendInit, 500);\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">order<\/span> <span class=\"OpDesc\">Is Not Equal to<\/span> <span class=\"RightOpDesc\"> AY <\/span>","LeftOperand":"order","LogicType":"EmbeddedField","Operator":"NotEqualTo","RightOperand":"AY","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"Survey