QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"One last question: How many elements does the largest sporadic simple group have? If you do not k...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"One last question: How many elements does the largest sporadic simple group have?&nbsp;If you do not know it, answer \"don't know\".","DataExportTag":"Q1","QuestionID":"QID1218941776"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218941777","SecondaryAttribute":"We would greatly appreciate any general comments you may have for the study. Did you feel comfort...","TertiaryAttribute":null,"Payload":{"QuestionText":"We would greatly appreciate any general comments you may have for the study. Did you feel comfortable with the instructions? Were you ever confused at any point in the survey? If so, we would be grateful to hear about which aspects were confusing and what we could do better. Thank you once again for your effort and participation.","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We would greatly appreciate any general comments you may have for the study. Did you feel comfort...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tjQuery(\"#\"+this.questionId+\" .InputText:eq(0)\").on(\"cut copy paste\",function(e) {\n   e.preventDefault();\n  });\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst exchangeRate = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('exchange_rate'));\n\tconst totalPoints = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('total_points'));\n\t\n\tconst costArray = [];\n\tconst choiceArray = [];\n\tconst transferArray = [];\n\tconst timeArray = [];\n\tconst loopArray = [];\n\t\n\tfor (let i = 1; i <= 22; i++) {\n\t\tlet cost = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('cost_' + i));\n\t\tlet productionChoice = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('productionChoice_' + i));\n\t\tlet transfer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('transfer_' + i));\n\t\tlet time = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('time_' + i));\n\t\tlet loop = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('loop_' + i));\n\t\tcostArray.push(cost);\n\t\tchoiceArray.push(productionChoice);\n\t\ttransferArray.push(transfer);\n\t\ttimeArray.push(time);\n\t\tloopArray.push(loop);\n\t}\n\t\n\t\/\/ Calculate totalCost as the sum of costArray\n\tconst randomIndex = Math.floor(Math.random() * costArray.length);\n\tconst totalCost = costArray[randomIndex];\n\t\n\tconsole.log('Cost array:', costArray);\n\tconsole.log('Choice array:', choiceArray);\n\tconsole.log('Transfer array:', transferArray);\n\tconsole.log('Time array:', timeArray);\n\tconsole.log('Loop array:', loopArray);\n\tconsole.log('Total cost:', totalCost);\n\t\n\tlet payment = (totalPoints - totalCost) \/ exchangeRate; \n\tQualtrics.SurveyEngine.setEmbeddedData('taskPayment', payment.toFixed(2));\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('costArray', JSON.stringify(costArray));\n\tQualtrics.SurveyEngine.setEmbeddedData('choiceArray', JSON.stringify(choiceArray));\n\tQualtrics.SurveyEngine.setEmbeddedData('transferArray', JSON.stringify(transferArray));\n\tQualtrics.SurveyEngine.setEmbeddedData('timeArray', JSON.stringify(timeArray));\n\tQualtrics.SurveyEngine.setEmbeddedData('loopArray', JSON.stringify(loopArray));\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"We would greatly appreciate any general comments you may have for the study. Did you feel comfortable with the instructions? Were you ever confused at any point in the survey? If so, we would be grateful to hear about which aspects were confusing and what we could do better. Thank you once again for your effort and participation.","DataExportTag":"Q2","QuestionID":"QID1218941777"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218941778","SecondaryAttribute":"Congratulations! You have finished this study! Your bonus payment from completing the tasks is\u00a0$$..","TertiaryAttribute":null,"Payload":{"QuestionText":"Congratulations! You have finished this study! <br><br>Your bonus payment from completing the tasks is&nbsp;$${e:\/\/Field\/taskPayment}.&nbsp;<br><br>You will receive your completion payment of $${e:\/\/Field\/completion_fee}, your bonus payment from correctly answering the questions, and your bonus payment from completing the tasks.&nbsp;<br><br>Please click the button below to be redirected back to Prolific and register your submission.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Congratulations! You have finished this study! Your bonus payment from completing the tasks is\u00a0$$...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":