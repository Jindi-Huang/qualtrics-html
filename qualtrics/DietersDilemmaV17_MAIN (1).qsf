t\">panel A<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\n    const allMetaData = [\n        JSON.parse('${e:\/\/Field\/mainCausal1}'),\n        JSON.parse('${e:\/\/Field\/mainCausal2}'),\n        JSON.parse('${e:\/\/Field\/mainCausal3}'),\n        JSON.parse('${e:\/\/Field\/mainCausal4}'),\n        JSON.parse('${e:\/\/Field\/mainCausal5}'),\n        JSON.parse('${e:\/\/Field\/mainCausal6}'),\n\t\tJSON.parse('${e:\/\/Field\/mainCausal7}'),\n        JSON.parse('${e:\/\/Field\/mainCausal8}'),\n\t\tJSON.parse('${e:\/\/Field\/mainCausal9}'),\n        JSON.parse('${e:\/\/Field\/mainCausal10}')\n\t\t\n    ];\n\t\n    \n    let currentMetaIndex = 0;\n    let metaData = allMetaData[currentMetaIndex];\n    let causalElicitType = metaData.causalElicit;\n    let exoButton = metaData.exoButton;\n\tconst idCausal = metaData.id;\n    const nRounds = allMetaData.length;\n\tlet correctAnswerList = metaData.correct;\n    const playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1');\n    const playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2');\n    const playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1');\n    const playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2');\n    const noise = Qualtrics.SurveyEngine.getEmbeddedData('noise');\n    const causal = Qualtrics.SurveyEngine.getEmbeddedData('causal');\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    \n    let roundCounter = 0;\n    let X, A, Y;\n    let history = [];\n    let roundTimes = [];\n    let payment = [];\n\tlet beliefs = []; \n\tlet beliefsText = []; \n\tlet correctAnswers = [];\n\tlet beliefPayment = [];\n    let roundStartTime = 0;\n    let xReady = false;\n    let colorDisplayed = false;\n\t\n\n    \/\/ Store messages to be assigned later\n    let aMessage = '';\n    let xMessage = '';\n    let yMessage = '';\n    let aBackgroundColor = 'white';\n    let xBackgroundColor = 'white';\n    let yBackgroundColor = 'white';\n\n    \/\/ Store the submit handler function so we can remove it\n    let currentSubmitHandler = null;\n\n    \/\/ Create understand button\n    const understandButton = document.createElement('button');\n    understandButton.id = 'understandButton';\n    understandButton.className = 'actionButton';\n    understandButton.innerHTML = \"I understand my choice options\";\n    understandButton.style.display = 'none';\n    understandButton.style.margin = '20px auto';\n    understandButton.style.fontSize = '16px';\n    understandButton.style.padding = '10px 20px';\n    understandButton.style.backgroundColor = '#28a745';\n    understandButton.style.color = 'white';\n    understandButton.style.minWidth = '300px';\n    understandButton.style.whiteSpace = 'nowrap';\n\n    \/\/ Create lock icon SVG\n    function createLockIcon() {\n        const lockSvg = document.createElement('div');\n        lockSvg.className = 'lock-icon';\n        lockSvg.innerHTML = `\n            <svg class=\"svg-icon\" style=\"width: 2.5em; height: 2.5em; vertical-align: middle; overflow: hidden;\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n                <path d=\"M824.888889 426.666667v-85.333334c0-173.511111-139.377778-312.888889-312.888889-312.888889S199.111111 167.822222 199.111111 341.333333v85.333334H85.333333v455.111111h853.333334V426.666667h-113.777778z m-284.444445 219.022222V739.555556h-56.888888v-93.866667c-17.066667-8.533333-28.444444-28.444444-28.444445-48.355556 0-31.288889 25.6-56.888889 56.888889-56.888889s56.888889 25.6 56.888889 56.888889c0 19.911111-11.377778 39.822222-28.444445 48.355556zM512 426.666667h-199.111111v-85.333334c0-110.933333 88.177778-199.111111 199.111111-199.111111s199.111111 88.177778 199.111111 199.111111v85.333334h-199.111111z\" fill=\"\" \/>\n            <\/svg>\n        `;\n        return lockSvg;\n    }\n\n    \/\/ Create buttons dynamically\n    const btnNo = document.createElement('button');\n    btnNo.id = 'btnNo';\n    btnNo.className = 'actionButton red';\n    btnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n    \n    const btnYes = document.createElement('button');\n    btnYes.id = 'btnYes';\n    btnYes.className = 'actionButton green';\n    btnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n\n\n    const buttonContainer = document.createElement('div');\n    buttonContainer.className = 'button-container';\n    buttonContainer.appendChild(btnNo);\n    buttonContainer.appendChild(btnYes);\n\n    const panelXinfo = document.getElementById(\"panelXinfo\");\n    const panelYinfo = document.getElementById(\"panelYinfo\");\n    const panelAinfo = document.getElementById(\"panelAinfo\");\n    const YText = document.getElementById(\"YText\");\n    const XText = document.getElementById(\"XText\");\n    const AText = document.getElementById(\"AText\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n\n    \/\/ Insert understand button after instruction title\n    const instructionElement = document.getElementById('instructionTitle');\n    if (instructionElement && instructionElement.parentNode) {\n        instructionElement.parentNode.insertBefore(understandButton, instructionElement.nextSibling);\n    }\n\n    btnYes.addEventListener(\"click\", () => handleDecision('y'));\n    btnNo.addEventListener(\"click\", () => handleDecision('n'));\n    understandButton.addEventListener(\"click\", () => {\n        understandButton.style.display = 'none';\n        showActionPanels();\n    });\n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    function handleDecision(decision) {\n        const decisionPanel = (causalElicitType === \"XY\") ? panelXinfo : \n                             (causalElicitType === \"YX\") ? panelYinfo : panelAinfo;\n        \n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\n        correctAnswers.push(correctAnswerList[id-1]);\n\t\tconsole.log(\"Ahhh\")\n\t\tconsole.log(\"why?\");\n\t\tconsole.log(correctAnswers);\n\t\tconsole.log(correctAnswerList);\n\t\t\n        if (causalElicitType === \"XY\") {\n            A = exoButton;\n            X = decision === 'y' ? 1 : 0;\n            if (causal === 0) {\n                Y = Math.random() < pY ? 1 : 0;\n            } else {\n                const pY = [noise, 1-noise];\n                Y = Math.random() < pY[X] ? 1 : 0;\n            }\n            \n            payment.push(-X * aCost + yBonus * Y);\n\n        }\n        \n        if (causalElicitType === \"AX\") {\n            A = decision === 'y' ? 1 : 0;\n            if (exoButton == null) {\n                \/\/ For AX with null exoButton, generate X and Y randomly\n                if (causal === 0) {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                    Y = Math.random() < pY ? 1 : 0;\n                } else {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                    const pY = [noise, 1-noise];\n                    Y = Math.random() < pY[X] ? 1 : 0;\n                }\n            } else {\n                Y = exoButton;\n                if (causal === 0) {\n                    const pX = [noise, 1-noise, 1-noise, 1-noise];\n                    X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n                } else {\n                    const pX = [noise, 1-noise];\n                    X = Math.random() < pX[A] ? 1 : 0;\n                }\n            }\n            \n            payment.push(-A * aCost + yBonus * X);\n        }\n        \n        if (causalElicitType === \"AY\") {\n            A = decision === 'y' ? 1 : 0;\n            if (exoButton == null) {\n                \/\/ For AY with null exoButton, generate X and Y randomly\n                if (causal === 0) {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                    Y = Math.random() < pY ? 1 : 0;\n                } else {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                    const pY = [noise, 1-noise];\n                    Y = Math.random() < pY[X] ? 1 : 0;\n                }\n            } else {\n                X = exoButton;\n                if (causal === 0) {\n                    Y = Math.random() < pY ? 1 : 0;\n                } else {\n                    const pY = [noise, 1-noise];\n                    Y = Math.random() < pY[X] ? 1 : 0;\n                }\n            }\n            \n            payment.push(-A * aCost + yBonus * Y);\n        }\n        \n        if (causalElicitType === \"YX\") {\n            Y = decision === 'y' ? 1 : 0;\n            A = exoButton;\n            if (causal === 0) {\n                const pX = [noise, 1-noise, 1-noise, 1-noise];\n                X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            } else {\n                const pX = [noise, 1-noise];\n                X = Math.random() < pX[Y] ? 1 : 0;\n            }\n            \n            payment.push(-Y * aCost + yBonus * X);\n        }\n\n        history.push([A, X, Y]);\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            if (causalElicitType === \"XY\") {\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                colorDisplayed = true; \n            } else if (causalElicitType === \"YX\") {\n                AText.innerHTML = aMessage;\n                panelAinfo.style.backgroundColor = aBackgroundColor;\n                xReady = true;\n            } else if ((causalElicitType === \"AY\" || causalElicitType === \"AX\") && exoButton == null) {\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                xReady = true;\n            } else {\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                xReady = true; \n            }\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        if (['y','n'].includes(e.key) && !btnYes.disabled && ((causalElicitType === \"XY\" && xReady) || (causalElicitType === \"YX\" && !xReady) || (causalElicitType !== \"XY\" && causalElicitType !== \"YX\"))) handleDecision(e.key);\n       else if (e.key === 'c') {\n\t\t\tif ((causalElicitType === \"XY\") && !xReady && !colorDisplayed) {\n\t\t\t\t\/\/ Only XY here now\n\t\t\t\tXText.innerHTML = xMessage;\n\t\t\t\tpanelXinfo.style.backgroundColor = xBackgroundColor;\n\t\t\t\txReady = true;\n\t\t\t\tpanelXinfo.appendChild(buttonContainer);\n\t\t\t}\n\t\t\telse if (xReady && (causalElicitType === \"YX\" || causalElicitType !== \"XY\")) {\n\t\t\t\t\/\/ YX now follows same pattern as AX\/AY - requires xReady = true\n\t\t\t\tif (causalElicitType === \"YX\") {\n\t\t\t\t\tXText.innerHTML = xMessage;\n\t\t\t\t\tpanelXinfo.style.backgroundColor = xBackgroundColor;\n\t\t\t\t\txReady = false;\n\t\t\t\t\tcolorDisplayed = true;\n\t\t\t\t}\n\t\t\t\telse if (causalElicitType !== \"XY\") {\n\t\t\t\t\t\/\/ AX\/AY logic\n\t\t\t\t\tYText.innerHTML = yMessage;\n\t\t\t\t\tpanelYinfo.style.backgroundColor = yBackgroundColor;\n\t\t\t\t\txReady = false;\n\t\t\t\t\tcolorDisplayed = true;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\t\telse if (e.key === ' ' && colorDisplayed) {\n            let roundEnd = Date.now();\n            roundTimes.push((roundEnd - roundStartTime) \/ 1000);\n            \n            \/\/ Show verbal elicitation after each choice\n            showVerbalElicitation();\n            colorDisplayed = false;\n        }\n    }\n\n    function clearLockIcons() {\n        const existingLocks = document.querySelectorAll('.lock-icon');\n        existingLocks.forEach(lock => lock.remove());\n    }\n\n    function initiateRound() {\n        roundDisplay.style.display = \"none\";\n        \n        \/\/ Clear all remnants from previous round\n        clearLockIcons();\n        \n        \/\/ Force reset all panel backgrounds and remove any leftover styling\n        panelAinfo.style.backgroundColor = \"white\";\n        panelXinfo.style.backgroundColor = \"white\";\n        panelYinfo.style.backgroundColor = \"white\";\n        \n        document.querySelector('.panel-wrapper').style.display = 'none';\n        \n        \/\/ Hide understand button initially\n        understandButton.style.display = 'none';\n        \n        \/\/ Clear all text content\n        AText.innerHTML = \"\";\n        XText.innerHTML = \"\";\n        YText.innerHTML = \"\";\n        \n        \/\/ Remove button containers from all panels\n        if (panelXinfo.contains(buttonContainer)) {\n            panelXinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelAinfo.contains(buttonContainer)) {\n            panelAinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelYinfo.contains(buttonContainer)) {\n            panelYinfo.removeChild(buttonContainer);\n        }\n        \n        \/\/ Reset button states\n        btnYes.disabled = btnNo.disabled = false;\n        btnYes.classList.remove(\"flash\");\n        btnNo.classList.remove(\"flash\");\n        \n        \/\/ Reset state variables\n        xReady = false;\n        colorDisplayed = false;\n        \n        setTimeout(() => {\n            understandButton.style.display = 'block';\n        }, 5000);\n    }\n\n\n    function updateInstructionTitle() {\n        const instructionElement = document.getElementById('instructionTitle');\n        \n        if (!instructionElement) return;\n        \n        let instructionTitle = '';\n        \n               const instructionConfigs = {\n            AX: {\n                forcedText: exoButton == 1 \n                    ? \"${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button\"\n                    : exoButton == 0\n                    ? \"${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button\"\n                    : \"\",\n                getTitle: function() { \n                    return exoButton == null\n                        ? \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>Your payoff now depends on ${e:\/\/Field\/playerName1}'s choice!<\/strong><\/span><\/div>\"\n                        : \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong> Your payoff now depends on ${e:\/\/Field\/playerName1}'s choice and \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return exoButton == null\n                        ? \"<ul><li>Unlike before, <b>${e:\/\/Field\/playerName1} (the player in the middle of the screen) determines your bonus<\/b>, it's no longer ${e:\/\/Field\/playerName2} (the player at the bottom of the screen). You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName1} presses ${e:\/\/Field\/playerPronoun1} button. ${e:\/\/Field\/playerName1} decides in the same way as before.<\/li><li>No player is forced to press or not press their button.<\/li><\/ul>\"\n                        : \"<ul><li>Unlike before, <b>${e:\/\/Field\/playerName1} (the player in the middle of the screen) determines your bonus<\/b>, it's no longer ${e:\/\/Field\/playerName2} (the player at the bottom of the screen). You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName1} presses ${e:\/\/Field\/playerPronoun1} button.  ${e:\/\/Field\/playerName1} decides in the same way as before.<\/li><li>\" + this.forcedText + \".<\/li><\/ul>\";\n                }\n            },\n            XY: {\n                forcedText: exoButton == 1 \n                    ? \"are forced to press your own button\" \n                    : \"are forced NOT to press your own button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong> You control ${e:\/\/Field\/playerName1}'s button but you \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>Unlike before, <b>you control ${e:\/\/Field\/playerName1}'s button (the player in the middle of the screen).<\/b> You \" + this.forcedText + \". <\/li><li>As before, you will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName2} (the player at the bottom of the screen) presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            AY: {\n                forcedText: exoButton == 1\n                    ? \"${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button\"\n                    : exoButton == 0\n                    ? \"${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button\"\n                    : \"${e:\/\/Field\/playerName1}'s choice will not be shown\",\n                getTitle: function() { \n                    return exoButton == null\n                        ? \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>Your payoff depend on ${e:\/\/Field\/playerName2}'s choices!<\/strong><\/span><\/div>\"\n                        : \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>\" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return exoButton == null\n                        ? \"<ul><li>As before, you will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if ${e:\/\/Field\/playerName2} (the player at the bottom of the screen) presses ${e:\/\/Field\/playerPronoun2} button.<\/li><li>No player is forced to press or not press their button.<\/li><\/ul>\"\n                        : \"<ul><li>Unlike before, <b>\" + this.forcedText + \".<\/b><\/li><li>As before, you will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if ${e:\/\/Field\/playerName2} (the player at the bottom of the screen) presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            YX: {\n                forcedText: exoButton == 1\n                    ? \"you are forced to press your own button\"\n                    : \"you are forced NOT to press your own button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>You control ${e:\/\/Field\/playerName2}'s button but \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>Unlike before, <b>you control ${e:\/\/Field\/playerName2}'s button (the player at the bottom)<\/b> but \" + this.forcedText + \". <\/li><li>Unlike before, <b>${e:\/\/Field\/playerName1} (the player in the middle of the screen) determines your bonus<\/b>, it's no longer ${e:\/\/Field\/playerName2} (the player at the bottom of the screen). You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName1} presses ${e:\/\/Field\/playerPronoun1} button.<\/li><\/ul>\";\n                }\n            }\n        };\n        \n        const instructionConfig = instructionConfigs[causalElicitType];\n        if (instructionConfig) {\n            instructionTitle = instructionConfig.getTitle() + instructionConfig.getContent();\n        }\n        \n        instructionElement.innerHTML = instructionTitle;\n    }\n\n    function nextRound() {\n        if (roundCounter < nRounds) {\n            roundCounter++;\n\n            \/\/ Update to next metadata\n            currentMetaIndex = roundCounter - 1;\n            metaData = allMetaData[currentMetaIndex];\n            causalElicitType = metaData.causalElicit;\n            exoButton = metaData.exoButton;\n\t\t\tcorrectAnswerList = metaData.correct;\n\n            \/\/ Update instruction title and round number dynamically\n            updateInstructionTitle();\n            document.getElementById('roundNr').textContent = roundCounter;\n        \n\n            \/\/ Set up messages based on causalElicitType\n             const configs = {\n                AX: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == null\n                        ? '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"c\" to continue)'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"c\" to continue)',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: exoButton == 1 \n                        ? '${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)'\n                        : exoButton == 0\n                        ? '${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\"\n                },\n                AY: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == 1\n                        ? '${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button<br>(press \"c\" to continue)'\n                        : exoButton == 0\n                        ? '${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button<br>(press \"c\" to continue)'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"c\" to continue)',\n                    xBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\",\n                    yMessage: exoButton == null\n                        ? '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                XY: {\n                    aMessage: exoButton == 1\n                        ? 'You are forced to press your own button.<br>(press \"c\" to continue)'\n                        : 'You are forced NOT to press your own button.<br>(press \"c\" to continue)',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: \"Press ${e:\/\/Field\/playerName1}'s button?\",\n                    xBackgroundColor: \"white\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                YX: {\n                    aMessage: exoButton == 1\n                        ? 'You are forced to press your own button.<br>(press \"c\" to continue)'\n                        : 'You are forced NOT to press your own button.<br>(press \"c\" to continue)',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: \"Press ${e:\/\/Field\/playerName2}'s button?\",\n                    yBackgroundColor: \"white\"\n                }\n            };\n            \n\n\n            \n            const config = configs[causalElicitType];\n            aMessage = config.aMessage;\n            aBackgroundColor = config.aBackgroundColor;\n            xMessage = config.xMessage;\n            xBackgroundColor = config.xBackgroundColor;\n            yMessage = config.yMessage;\n            yBackgroundColor = config.yBackgroundColor;\n\n            \/\/ Add bonus indicator to panel headers\n            document.querySelectorAll('.panel-name').forEach(el => {\n                el.textContent = el.textContent.replace(' (determines your bonus)', '');\n            });\n            \n            if (causalElicitType === \"AX\" || causalElicitType === \"YX\") {\n                const nameElement = document.querySelector('#panelXinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            } else if (causalElicitType === \"AY\" || causalElicitType === \"XY\") {\n                const nameElement = document.querySelector('#panelYinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            }\n\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n    }\n\n    function showActionPanels() {\n        \/\/ Show all panels again\n        document.querySelector('.panel-wrapper').style.display = '';\n\t\tif (causalElicitType === 'XY' || causalElicitType === 'YX') {\n\t\t\t\/\/ When controlling other people's buttons\n\t\t\tbtnYes.innerHTML = \"Yes (no cost for you)\";\n\t\t\tbtnNo.innerHTML = \"No (no cost for you)\";\n\t\t} else {\n\t\t\t\/\/ When pressing your own button (AX, AY treatments)\n\t\t\tbtnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n\t\t\tbtnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n\t\t}\n        \n        if (causalElicitType === 'YX') {\n            YText.innerHTML = yMessage;\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n            \n            const lockIcon = createLockIcon();\n            panelAinfo.appendChild(lockIcon);\n        } else {\n            AText.innerHTML = aMessage;\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            \n            if (causalElicitType === 'XY') {\n                const lockIcon = createLockIcon();\n                panelAinfo.appendChild(lockIcon);\n            }\n            \n            if (causalElicitType === 'AX' && exoButton != null) {\n                const lockIcon = createLockIcon();\n                panelYinfo.appendChild(lockIcon);\n            }\n            \n            if (causalElicitType === 'AY' && exoButton != null) {\n                const lockIcon = createLockIcon();\n                panelXinfo.appendChild(lockIcon);\n            }\n\n            if (causalElicitType !== \"XY\") {\n                panelAinfo.appendChild(buttonContainer);\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    function showVerbalElicitation() {\n        const verbalSection = document.getElementById('verbalElicitationSection');\n        const questionDiv = document.getElementById('verbalQuestion');\n        const optionsDiv = document.getElementById('verbalOptions');\n        const submitButton = document.getElementById('verbalSubmit');\n\n        \/\/ Determine question text based on treatment\n        let questionText = '';\n        let affectedPlayer = '';\n        let affectedPronoun = '';\n        \n\n        const questionConfigs = {\n            AX: {\n                questionText: exoButton == 1\n                    ? \"If ${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : exoButton == 0\n                    ? \"If ${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : \"How does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: '${e:\/\/Field\/playerName1}',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            },\n            AY: {\n                questionText: exoButton == 1\n                    ?  \"If ${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : exoButton == 0\n                    ? \"If ${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"How does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: '${e:\/\/Field\/playerName2}',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            XY: {\n                questionText: exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: '${e:\/\/Field\/playerName2}',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            YX: {\n                questionText: exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: '${e:\/\/Field\/playerName1}',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            }\n        };\n        \n        const questionConfig = questionConfigs[causalElicitType];\n        questionText = questionConfig.questionText;\n        affectedPlayer = questionConfig.affectedPlayer;\n        affectedPronoun = questionConfig.affectedPronoun;\n\n        \/\/ Create options array\n        const options = [\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"No change in the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\"\n        ];\n\n        \/\/ If increasingOrder is 0, reverse the options order\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        \/\/ Show the section and set question\n        verbalSection.style.display = 'block';\n        questionDiv.textContent = questionText;\n        \n        \/\/ Clear existing options\n        optionsDiv.innerHTML = '';\n        \n        \/\/ Build options\n        displayOptions.forEach(function(option, index) {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n            \n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'verbalResponse';\n            radio.value = index;\n            radio.id = 'option' + index;\n            \n            const label = document.createElement('label');\n            label.setAttribute('for', 'option' + index);\n            label.textContent = option;\n            \n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n        });\n        \n        \/\/ Reset submit button\n        submitButton.disabled = true;\n        \n        \/\/ Add smooth scroll to verbal section after ensuring it's fully rendered\n        \/\/ Use requestAnimationFrame to wait for DOM to be fully painted\n        requestAnimationFrame(() => {\n            requestAnimationFrame(() => {\n                verbalSection.scrollIntoView({ \n                    behavior: 'smooth', \n                    block: 'start' \n                });\n            });\n        });\n        \n        \/\/ Add event listeners to options\n        const optionElements = verbalSection.querySelectorAll('.verbal-option');\n        \n        optionElements.forEach(function(option) {\n            option.addEventListener('click', function() {\n\n                \/\/ Remove selected class from all options\n                optionElements.forEach(function(opt) {\n                    opt.classList.remove('selected');\n                });\n                \n                \/\/ Add selected class to clicked option\n                this.classList.add('selected');\n                \n                \/\/ Check the radio button\n                const radio = this.querySelector('input[type=\"radio\"]');\n                radio.checked = true;\n                \n                \/\/ Enable submit button - get fresh reference\n                const currentSubmitButton = document.getElementById('verbalSubmit');\n                currentSubmitButton.disabled = false;\n            });\n        });\n        \n        \/\/ Also add event listeners to radio buttons directly\n        const radioElements = verbalSection.querySelectorAll('input[type=\"radio\"]');\n        radioElements.forEach(function(radio) {\n            radio.addEventListener('change', function() {\n                if (this.checked) {\n                    const currentSubmitButton = document.getElementById('verbalSubmit');\n                    currentSubmitButton.disabled = false;\n                }\n            });\n        });\n        \n        \/\/ Create the submit handler function\n\t\tconst handleSubmit = function() {\n\t\t\tconst selectedOption = verbalSection.querySelector('input[name=\"verbalResponse\"]:checked');\n\t\t\tif (selectedOption) {\n\t\t\t\tconst selectedIndex = parseInt(selectedOption.value);\n\t\t\t\tconst selectedText = displayOptions[selectedIndex];\n\t\t\t\t\n\t\t\t\tconst originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\n\t\t\t\tbeliefs.push(originalIndex);\n\t\t\t\tbeliefsText.push(selectedText);\n\n\t\t\t\t\/\/ Store as JSON arrays with id suffix\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(beliefs));\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(beliefsText));\n\n\t\t\t\t\/\/ Hide verbal section\n\t\t\t\tverbalSection.style.display = 'none';\n\n\t\t\t\t\/\/ Continue to next round or finish\n\t\t\t\tif (roundCounter < nRounds) {\n\t\t\t\t\tnextRound();\n\t\t\t\t} else {\n\t\t\t\t\t\n\t\t\t\t\tbeliefPayment = correctAnswers.map((correct, index) => {\n\t\t\t\t\t\tconst absoluteDifference = Math.abs(correct - beliefs[index]);\n\t\t\t\t\t\treturn 25 - (absoluteDifference * 2);\n\t\t\t\t\t});\n\t\t\t\t\t\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefHistory_' + id, JSON.stringify(history));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefRoundTimes_' + id, JSON.stringify(roundTimes));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefPayment_' + id, JSON.stringify(beliefPayment));\n\t\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('beliefCorrectAnswer_' + id, JSON.stringify(correctAnswers));\n        \n\t\t\t\t\tconsole.log(\"History:\", history);\n\t\t\t\t\tconsole.log(\"Times:\", roundTimes);\n\t\t\t\t\tconsole.log(\"Beliefs:\", beliefs);\n\t\t\t\t\tconsole.log(\"Beliefs Text:\", beliefsText);\n\t\t\t\t\tconsole.log(\"Correct Answers\", correctAnswers);\n\t\t\t\t\tconsole.log(\"Belief Payment\", beliefPayment);\n\t\t\t\t\t\/\/ Move to next page\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tif (document.getElementById('NextButton')) {\n\t\t\t\t\t\t\tjQuery(\"#NextButton\").click();\n\t\t\t\t\t\t}\n\t\t\t\t\t}, 100);\n\t\t\t\t}\n\t\t\t}\n\t\t};\n        \/\/ Remove existing event listener if any, then add new one\n        if (currentSubmitHandler) {\n            submitButton.removeEventListener('click', currentSubmitHandler);\n        }\n        currentSubmitHandler = handleSubmit;\n        submitButton.addEventListener('click', currentSubmitHandler);\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Variant of Game Game ${e:\/\/Field\/currentSymbol} You panel A ${e:\/\/Field\/playerName1} panel X ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"\n<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> dieter <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"dieter","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q13","QuestionID":"QID1218862985"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862986","SecondaryAttribute":"Variant of Game Game ${e:\/\/Field\/currentSymbol} ${e:\/\/Field\/playerName1} panel X You panel A ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n\t\t\t<div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n\t\t\t\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\n    const allMetaData = [\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines1}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines2}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines3}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines4}'),\n\t\tJSON.parse('${e:\/\/Field\/mainCausalMigraines5}')\n\t\t\n    ];\n\t\n    \n    let currentMetaIndex = 0;\n    let metaData = allMetaData[currentMetaIndex];\n    const costArray = [0.5];\n    let causalElicitType = metaData.causalElicit;\n    let exoButton = metaData.exoButton;\n    const nRounds = allMetaData.length;\n\tlet correctAnswerList = metaData.correct;\n    const noise = Qualtrics.SurveyEngine.getEmbeddedData('noise');\n    const causal = Qualtrics.SurveyEngine.getEmbeddedData('causal');\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    \n    let roundCounter = 0;\n    let X, A, Y;\n    let history = [];\n    let roundTimes = [];\n    let payment = [];\n    let beliefs = []; \n    let beliefsText = []; \n\tlet correctAnswers = [];\n\tlet beliefPayment = [];\n\n    let roundStartTime = 0;\n    let xReady = false;\n    let colorDisplayed = false;\n\n    \/\/ Store messages to be assigned later\n    let aMessage = '';\n    let xMessage = '';\n    let yMessage = '';\n    let aBackgroundColor = 'white';\n    let xBackgroundColor = 'white';\n    let yBackgroundColor = 'white';\n\n    \/\/ Store the submit handler function so we can remove it\n    let currentSubmitHandler = null;\n\n    \/\/ Create lock icon SVG\n    function createLockIcon() {\n        const lockSvg = document.createElement('div');\n        lockSvg.className = 'lock-icon';\n        lockSvg.innerHTML = `\n            <svg class=\"svg-icon\" style=\"width: 2.5em; height: 2.5em; vertical-align: middle; overflow: hidden;\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n                <path d=\"M824.888889 426.666667v-85.333334c0-173.511111-139.377778-312.888889-312.888889-312.888889S199.111111 167.822222 199.111111 341.333333v85.333334H85.333333v455.111111h853.333334V426.666667h-113.777778z m-284.444445 219.022222V739.555556h-56.888888v-93.866667c-17.066667-8.533333-28.444444-28.444444-28.444445-48.355556 0-31.288889 25.6-56.888889 56.888889-56.888889s56.888889 25.6 56.888889 56.888889c0 19.911111-11.377778 39.822222-28.444445 48.355556zM512 426.666667h-199.111111v-85.333334c0-110.933333 88.177778-199.111111 199.111111-199.111111s199.111111 88.177778 199.111111 199.111111v85.333334h-199.111111z\" fill=\"\" \/>\n            <\/svg>\n        `;\n        return lockSvg;\n    }\n\n    \/\/ Create buttons dynamically\n    const btnNo = document.createElement('button');\n    btnNo.id = 'btnNo';\n    btnNo.className = 'actionButton red';\n    \n    const btnYes = document.createElement('button');\n    btnYes.id = 'btnYes';\n    btnYes.className = 'actionButton green';\n\n    function updateButtonText() {\n        \/\/ Update button text based on current X value\n        if (causalElicitType === \"AY\") {\n            \/\/ For AY treatment, X is determined by exoButton, not user decision\n            if (exoButton === 0) {\n                btnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines0}\";\n                btnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines0}\";\n            } else {\n                btnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines1}\";\n                btnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines1}\";\n            }\n        } else {\n            \/\/ Default text when X is not yet determined or for other treatments\n            btnNo.innerHTML = \"No (no cost for you)\";\n            btnYes.innerHTML = \"Yes (no cost for you)\";\n        }\n    }\n        \n    const buttonContainer = document.createElement('div');\n    buttonContainer.className = 'button-container';\n    buttonContainer.appendChild(btnNo);\n    buttonContainer.appendChild(btnYes);\n\t\n\tconst understandButton = document.createElement('button');\n\tunderstandButton.id = 'understandButton';\n\tunderstandButton.className = 'actionButton';\n\tunderstandButton.innerHTML = \"I understand my choice options\";\n\tunderstandButton.style.display = 'none';\n\tunderstandButton.style.margin = '20px auto';\n\tunderstandButton.style.fontSize = '16px';\n\tunderstandButton.style.padding = '10px 20px';\n\tunderstandButton.style.backgroundColor = '#28a745';\n\tunderstandButton.style.color = 'white';\n\tunderstandButton.style.minWidth = '300px';\n\tunderstandButton.style.whiteSpace = 'nowrap';\n\tunderstandButton.style.position = 'relative'; \/\/ Add this\n\tunderstandButton.style.zIndex = '1000'; \/\/ Add this\n\n\t\/\/ Insert it after the instructionTitle instead of body\n\tdocument.getElementById('instructionTitle').insertAdjacentElement('afterend', understandButton);\n\n\t\/\/ Add click handler\n\tunderstandButton.addEventListener('click', function() {\n\t\tunderstandButton.style.display = 'none';\n\t\tdocument.querySelector('.panel-wrapper').style.display = '';\n\t\tshowActionPanels();\n\t});\n\n    const panelXinfo = document.getElementById(\"panelXinfo\");\n    const panelYinfo = document.getElementById(\"panelYinfo\");\n    const panelAinfo = document.getElementById(\"panelAinfo\");\n    const YText = document.getElementById(\"YText\");\n    const XText = document.getElementById(\"XText\");\n    const AText = document.getElementById(\"AText\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n\n    btnYes.addEventListener(\"click\", () => handleDecision('y'));\n    btnNo.addEventListener(\"click\", () => handleDecision('n'));\n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    function handleDecision(decision) {\n        const decisionPanel = (causalElicitType === \"XY\") ? panelXinfo : \n                             (causalElicitType === \"YX\") ? panelYinfo : panelAinfo;\n        \n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tcorrectAnswers.push(correctAnswerList[id-1]);\n\t\tconsole.log(\"Ahhh\")\n\t\tconsole.log(\"why?\");\n\t\tconsole.log(correctAnswers);\n\t\tconsole.log(correctAnswerList);\n\t\t\n\n        const currentCost = aCost;\n\t\t\n        \n        if (causalElicitType === \"XY\") {\n            A = exoButton;\n            X = decision === 'y' ? 1 : 0;\n            if (causal === 0) {\n                Y = Math.random() < pY ? 1 : 0;\n            } else {\n                const pY = [noise, 1-noise];\n                Y = Math.random() < pY[X] ? 1 : 0;\n            }\n            \n            payment.push(-X * currentCost + yBonus * Y);\n        }\n        \n        if (causalElicitType === \"AX\") {\n            A = decision === 'y' ? 1 : 0;\n            Y = exoButton;\n            if (causal === 0) {\n                const pX = [noise, 1-noise, 1-noise, 1-noise];\n                X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            } else {\n                const pX = [noise, 1-noise];\n                X = Math.random() < pX[A] ? 1 : 0;\n            }\n            \n            payment.push(-A * currentCost + yBonus * X);\n        }\n        \n        if (causalElicitType === \"AY\") {\n            A = decision === 'y' ? 1 : 0;\n            X = exoButton;\n            if (causal === 0) {\n                Y = Math.random() < pY ? 1 : 0;\n            } else {\n                const pY = [noise, 1-noise];\n                Y = Math.random() < pY[X] ? 1 : 0;\n            }\n            \n            payment.push(-A * currentCost + yBonus * Y);\n        }\n        \n        if (causalElicitType === \"YX\") {\n            Y = decision === 'y' ? 1 : 0;\n            if (exoButton == null) {\n                \/\/ For YX with null exoButton, generate A and X randomly\n                A = Math.random() < 0.5 ? 1 : 0;\n                if (causal === 0) {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                } else {\n                    const pX = [noise, 1-noise];\n                    X = Math.random() < pX[Y] ? 1 : 0;\n                }\n            } else {\n                A = exoButton;\n                if (causal === 0) {\n                    const pX = [noise, 1-noise, 1-noise, 1-noise];\n                    X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n                } else {\n                    const pX = [noise, 1-noise];\n                    X = Math.random() < pX[Y] ? 1 : 0;\n                }\n            }\n            \n            payment.push(-Y * currentCost + yBonus * X);\n        }\n\n        history.push([A, X, Y]);\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            if (causalElicitType === \"XY\") {\n                AText.innerHTML = aMessage;\n                panelAinfo.style.backgroundColor = aBackgroundColor;\n                colorDisplayed = true; \n            } else if (causalElicitType === \"AY\") {\n                \/\/ For AY, after decision show Y panel (X status already shown)\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                colorDisplayed = true;\n            } else if (causalElicitType === \"YX\" && exoButton == null) {\n                \/\/ For YX with null exoButton, show X panel after Y decision\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                colorDisplayed = true;\n            } else {\n                \/\/ For AX, show X panel\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                xReady = true; \n            }\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        if (['y','n'].includes(e.key) && !btnYes.disabled && \n           ((causalElicitType === \"XY\") || \n            (causalElicitType === \"AY\" && xReady) || \n            (causalElicitType === \"YX\" && !xReady) || \n            (causalElicitType === \"AX\"))) handleDecision(e.key);\n        else if (e.key === 'c') {\n            if (causalElicitType === \"XY\" && colorDisplayed) {\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                yReady = true;\n            } else if (causalElicitType === \"AY\" && !xReady && !colorDisplayed) {\n                \/\/ This case should not occur anymore since AY shows everything immediately\n                \/\/ Keeping for safety but should not be triggered\n                const playerActionText = exoButton === 1 \n                    ? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button\"\n                    : \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button\";\n                AText.innerHTML = aMessage + \"<br>(\" + playerActionText + \")\";\n                panelAinfo.style.backgroundColor = aBackgroundColor;\n                updateButtonText();\n                panelAinfo.appendChild(buttonContainer);\n                xReady = true;\n            } else if (xReady && causalElicitType === \"AX\") {\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                xReady = false;\n                colorDisplayed = true;\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n            let roundEnd = Date.now();\n            roundTimes.push((roundEnd - roundStartTime) \/ 1000);\n            \n            \/\/ Show verbal elicitation after each choice\n            showVerbalElicitation();\n            colorDisplayed = false;\n        }\n    }\n\n    function clearLockIcons() {\n        const existingLocks = document.querySelectorAll('.lock-icon');\n        existingLocks.forEach(lock => lock.remove());\n    }\n\n    function initiateRound() {\n        roundDisplay.style.display = \"none\";\n\t\tdocument.querySelector('.panel-wrapper').style.display = 'none';\n\t\tsetTimeout(() => {\n\t\t\tunderstandButton.style.display = 'block';\n\t\t}, 5000);\n\n        \/\/ Clear all remnants from previous round\n        clearLockIcons();\n        \n        \/\/ Force reset all panel backgrounds and remove any leftover styling\n        panelAinfo.style.backgroundColor = \"white\";\n        panelXinfo.style.backgroundColor = \"white\";\n        panelYinfo.style.backgroundColor = \"white\";\n        \n        \/\/ Also clear any other potential background styles\n        panelAinfo.style.background = \"\";\n        panelXinfo.style.background = \"\";\n        panelYinfo.style.background = \"\";\n        \n        \/\/ Clear all text content\n        AText.innerHTML = \"\";\n        XText.innerHTML = \"\";\n        YText.innerHTML = \"\";\n        \n        \/\/ Remove button containers from all panels\n        if (panelXinfo.contains(buttonContainer)) {\n            panelXinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelAinfo.contains(buttonContainer)) {\n            panelAinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelYinfo.contains(buttonContainer)) {\n            panelYinfo.removeChild(buttonContainer);\n        }\n        \n        \/\/ Reset button states\n        btnYes.disabled = btnNo.disabled = false;\n        btnYes.classList.remove(\"flash\");\n        btnNo.classList.remove(\"flash\");\n        \n        \/\/ Reset state variables\n        xReady = false;\n        colorDisplayed = false;\n        \n        \/\/ Handle panel visibility and styling for different treatments\n        if (causalElicitType === \"AY\") {\n            panelXinfo.style.display = 'none';\n        } else {\n            panelXinfo.style.display = '';\n            panelAinfo.style.display = '';\n            \/\/ For XY treatment, make panel X transparent with no border\n            if (causalElicitType === \"XY\") {\n                panelXinfo.style.backgroundColor = 'transparent';\n                panelXinfo.style.border = 'none';\n            }\n        }\n        \n        \/\/ Force a repaint by temporarily hiding and showing panels\n        const panelsToRepaint = [];\n        if (causalElicitType !== \"AY\") panelsToRepaint.push(panelAinfo);\n        panelsToRepaint.push(panelXinfo);\n        panelsToRepaint.push(panelYinfo);\n        \n        panelsToRepaint.forEach(panel => {\n            const originalDisplay = panel.style.display;\n            panel.style.display = 'none';\n            panel.offsetHeight; \/\/ Force reflow\n            panel.style.display = originalDisplay || '';\n        });\n        \n\n    }\n\n    function updateInstructionTitle() {\n        const instructionElement = document.getElementById('instructionTitle');\n        \n        if (!instructionElement) return;\n        \n        const instructionConfigs = {\n            AX: {\n                forcedText: exoButton == 1\n                    ? \"${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button\"\n                    : \"${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>Your payoff now depends on ${e:\/\/Field\/playerName1}'s choice and \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>You will receive a <u>bonus if <b>${e:\/\/Field\/playerName1}<\/b> presses ${e:\/\/Field\/playerPronoun1} button.<\/u><\/li><li><u>\" + this.forcedText + \".<\/u><\/li><\/ul>\";\n                }\n            },\n            XY: {\n                forcedText: exoButton == 1\n                    ? \"are forced to press your own button\"\n                    : \"are forced NOT to press your own button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong> You can now control ${e:\/\/Field\/playerName1}'s button but you \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li><b>Unlike before, you control ${e:\/\/Field\/playerName1}'s button (the player who usually determines whether pressing your own button is free)<\/b>. You \" + this.forcedText + \".<\/li><li>As before, you will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            AY: {\n                forcedText: exoButton == 1\n                    ? \"${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button\"\n                    : \"${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>\" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>\" + this.forcedText + \".<\/li><li>As before, You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            YX: {\n                forcedText: exoButton == null \n                    ? \" \"\n                    : exoButton == 1\n                    ? \"you are forced to press your own button\"\n                    : \"you are forced NOT to press your own button\",\n                getTitle: function() { \n                    return exoButton == null\n                        ? \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>You control ${e:\/\/Field\/playerName2}'s button and your payoff depends on ${e:\/\/Field\/playerName1}'s choice!<\/strong><\/span><\/div>\"\n                        : \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>You control ${e:\/\/Field\/playerName2}'s button and \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return exoButton == null\n                        ? \"<ul><li>Unlike before, <b>${e:\/\/Field\/playerName1} (the first player) determines your bonus<\/b>, it's no longer ${e:\/\/Field\/playerName2} (the player at the bottom). You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName1} presses ${e:\/\/Field\/playerPronoun1} button. ${e:\/\/Field\/playerName1} decides in the same way as before.<\/li><li>Unlike before, <b>you control ${e:\/\/Field\/playerName2}'s button<\/b>.<\/li><\/ul>\"\n                        : \"<ul><li>You will receive a <u>bonus if <b>${e:\/\/Field\/playerName1}<\/b> presses ${e:\/\/Field\/playerPronoun1} button. ${e:\/\/Field\/playerName1} decides in the same way as before.<\/u><\/li><li><u>\" + this.forcedText + \".<\/u><\/li><\/ul>\";\n                }\n            }\n        };\n\n        \n        const instructionConfig = instructionConfigs[causalElicitType];\n        if (instructionConfig) {\n            const instructionTitle = instructionConfig.getTitle() + instructionConfig.getContent();\n            instructionElement.innerHTML = instructionTitle;\n        }\n    }\n\n    function nextRound() {\n\n        \n        if (roundCounter < nRounds) {\n            roundCounter++;\n\n            \/\/ Update to next metadata\n            currentMetaIndex = roundCounter - 1;\n            metaData = allMetaData[currentMetaIndex];\n            causalElicitType = metaData.causalElicit;\n            exoButton = metaData.exoButton;\n\t\t\tcorrectAnswerList = metaData.correct;\n\n            \/\/ Update instruction title and round number dynamically\n            updateInstructionTitle();\n            document.getElementById('roundNr').textContent = roundCounter;\n\n            \/\/ Set up messages based on causalElicitType\n           const configs = {\n                AX: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"c\" to continue)',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: exoButton == 1 \n                        ? '${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)',\n                    yBackgroundColor: exoButton == 1 ? \"green\" : \"red\"\n                },\n                AY: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '', \/\/ Not used in AY treatment since panel X is hidden\n                    xBackgroundColor: 'white',\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                XY: {\n                    aMessage: exoButton == 1\n                        ? 'You are forced to press your button<br>(press \"c\" to continue)'\n                        : 'You are forced NOT to press your button<br>(press \"c\" to continue)',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: \"Press ${e:\/\/Field\/playerName1}'s button?\",\n                    xBackgroundColor: \"transparent\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                YX: {\n                    aMessage: '', \/\/ Not used in YX null treatment but panel A is still visible\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == null\n                        ? '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    xBackgroundColor: exoButton == null ? 'transparent' : 'lightgray',\n                    yMessage: \"Press ${e:\/\/Field\/playerName2}'s button?\",\n                    yBackgroundColor: \"white\"\n                }\n            };       \n            \n            const config = configs[causalElicitType];\n            aMessage = config.aMessage;\n            aBackgroundColor = config.aBackgroundColor;\n            xMessage = config.xMessage;\n            xBackgroundColor = config.xBackgroundColor;\n            yMessage = config.yMessage;\n            yBackgroundColor = config.yBackgroundColor;\n\n            \/\/ Add bonus indicator to panel headers\n            document.querySelectorAll('.panel-name').forEach(el => {\n                el.textContent = el.textContent.replace(' (determines your bonus)', '');\n            });\n            \n            if (causalElicitType === \"AX\" || causalElicitType === \"YX\") {\n                const nameElement = document.querySelector('#panelXinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            } else if (causalElicitType === \"AY\" || causalElicitType === \"XY\") {\n                const nameElement = document.querySelector('#panelYinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            }\n\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n    }\n\n    function showActionPanels() {\n        \/\/ For YX null treatment, start with Y panel and make X transparent\n        if (causalElicitType === 'YX' && exoButton == null) {\n            \/\/ Show panel A as normal (empty but visible)\n            AText.innerHTML = '';\n            panelAinfo.style.backgroundColor = 'white';\n            \n            \/\/ Make panel X transparent with no border\n            XText.innerHTML = '';\n            panelXinfo.style.backgroundColor = 'transparent';\n            panelXinfo.style.border = 'none';\n            \n            \/\/ Start with Y panel and buttons\n            YText.innerHTML = yMessage;\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n        }\n        \/\/ For AY treatment, don't show panel X at all\n        else if (causalElicitType !== 'AY') {\n            XText.innerHTML = xMessage;\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            if (causalElicitType === \"XY\") {\n                panelXinfo.style.border = \"none\";\n            }\n        }\n        \n        const lockIcon = createLockIcon();\n        \n        \/\/ Add lock icons to appropriate panels\n        if (causalElicitType === 'XY') {\n            panelAinfo.appendChild(lockIcon);\n        }       \n        if (causalElicitType === 'AX') {\n            panelYinfo.appendChild(lockIcon);\n        }\n        \/\/ For AY, no lock icon on panel X since it's hidden\n        \/\/ For YX null, no lock icons needed\n        \n        \/\/ For AY treatment, show X status immediately in Panel A\n        if (causalElicitType === 'AY') {\n            const playerActionText = exoButton === 1 \n                ? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button\"\n                : \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button\";\n            AText.innerHTML = aMessage + \"<br>(\" + playerActionText + \")\";\n            panelAinfo.style.backgroundColor = aBackgroundColor; \/\/ Use white background\n            updateButtonText();\n            panelAinfo.appendChild(buttonContainer);\n            xReady = true; \/\/ Ready to accept decisions immediately\n        }\n    \n        \/\/ Update button text for initial display\n        updateButtonText();\n    \n        if (causalElicitType === \"XY\") {\n            \/\/ For XY, add buttons to X panel immediately\n            panelXinfo.appendChild(buttonContainer);\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    function showVerbalElicitation() {\n        const verbalSection = document.getElementById('verbalElicitationSection');\n        const questionDiv = document.getElementById('verbalQuestion');\n        const optionsDiv = document.getElementById('verbalOptions');\n        const submitButton = document.getElementById('verbalSubmit');\n\n        \/\/ Determine question text based on treatment\n        const questionConfigs = {\n            AX: {\n                questionText: \"How does pressing your button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName1}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun1}\"\n            },\n            AY: {\n                questionText: exoButton == 1\n                    ? \"If ${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"If ${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName2}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun2}\"\n            },\n            XY: {\n                questionText: exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName2}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun2}\"\n            },\n            YX: {\n                questionText: exoButton == null\n                    ? \"How does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName1}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun1}\"\n            }\n        };\n        \n        const questionConfig = questionConfigs[causalElicitType];\n        const questionText = questionConfig.questionText;\n        const affectedPlayer = questionConfig.affectedPlayer;\n        const affectedPronoun = questionConfig.affectedPronoun;\n\n        \/\/ Create options array\n        const options = [\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"No change in the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\"\n        ];\n\n        \/\/ If increasingOrder is 0, reverse the options order\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        \/\/ Show the section and set question\n        verbalSection.style.display = 'block';\n        questionDiv.textContent = questionText;\n        \n        \/\/ Clear existing options\n        optionsDiv.innerHTML = '';\n        \n        \/\/ Build options\n        displayOptions.forEach(function(option, index) {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n            \n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'verbalResponse';\n            radio.value = index;\n            radio.id = 'option' + index;\n            \n            const label = document.createElement('label');\n            label.setAttribute('for', 'option' + index);\n            label.textContent = option;\n            \n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n        });\n        \n        \/\/ Reset submit button\n        submitButton.disabled = true;\n        \n        \/\/ Add smooth scroll to verbal section after ensuring it's fully rendered\n        \/\/ Use requestAnimationFrame to wait for DOM to be fully painted\n        requestAnimationFrame(() => {\n            requestAnimationFrame(() => {\n                verbalSection.scrollIntoView({ \n                    behavior: 'smooth', \n                    block: 'start' \n                });\n            });\n        });\n        \n        \/\/ Add event listeners to options\n        const optionElements = verbalSection.querySelectorAll('.verbal-option');\n        \n        optionElements.forEach(function(option) {\n            option.addEventListener('click', function() {\n\n                \/\/ Remove selected class from all options\n                optionElements.forEach(function(opt) {\n                    opt.classList.remove('selected');\n                });\n                \n                \/\/ Add selected class to clicked option\n                this.classList.add('selected');\n                \n                \/\/ Check the radio button\n                const radio = this.querySelector('input[type=\"radio\"]');\n                radio.checked = true;\n                \n                \/\/ Enable submit button - get fresh reference\n                const currentSubmitButton = document.getElementById('verbalSubmit');\n                currentSubmitButton.disabled = false;\n            });\n        });\n        \n        \/\/ Also add event listeners to radio buttons directly\n        const radioElements = verbalSection.querySelectorAll('input[type=\"radio\"]');\n        radioElements.forEach(function(radio) {\n            radio.addEventListener('change', function() {\n                if (this.checked) {\n                    const currentSubmitButton = document.getElementById('verbalSubmit');\n                    currentSubmitButton.disabled = false;\n                }\n            });\n        });\n        \n        \/\/ Create the submit handler function\n        const handleSubmit = function() {\n            const selectedOption = verbalSection.querySelector('input[name=\"verbalResponse\"]:checked');\n            if (selectedOption) {\n                const selectedIndex = parseInt(selectedOption.value);\n                const selectedText = displayOptions[selectedIndex];\n\t\t\t\t\n\t\t\t\tconst originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\t\t\t\tbeliefs.push(originalIndex);\n                beliefsText.push(selectedText);\n                \n                \/\/ Store as JSON arrays with id suffix\n                Qualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(beliefs));\n                Qualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(beliefsText));\n                \n                \/\/ Hide verbal section\n                verbalSection.style.display = 'none';\n                \n                \/\/ Continue to next round or finish\n                if (roundCounter < nRounds) {\n                    nextRound();\n                } else {\n                    beliefPayment = correctAnswers.map((correct, index) => {\n\t\t\t\t\t\tconst absoluteDifference = Math.abs(correct - beliefs[index]);\n\t\t\t\t\t\treturn 25 - (absoluteDifference * 2);\n\t\t\t\t\t});\n\t\t\t\t\t\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefHistory_' + id, JSON.stringify(history));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefRoundTimes_' + id, JSON.stringify(roundTimes));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefPayment_' + id, JSON.stringify(beliefPayment));\n\t\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('beliefCorrectAnswer_' + id, JSON.stringify(correctAnswers));\n        \n\t\t\t\t\tconsole.log(\"History:\", history);\n\t\t\t\t\tconsole.log(\"Times:\", roundTimes);\n\t\t\t\t\tconsole.log(\"Beliefs:\", beliefs);\n\t\t\t\t\tconsole.log(\"Beliefs Text:\", beliefsText);\n\t\t\t\t\tconsole.log(\"Correct Answers\", correctAnswers);\n\t\t\t\t\tconsole.log(\"Belief Payment\", beliefPayment);\n                    \/\/ Move to next page\n                    document.getElementById('NextButton').click();\n                }\n            }\n        };\n        \n        \/\/ Remove existing event listener if any, then add new one\n        if (currentSubmitHandler) {\n            submitButton.removeEventListener('click', currentSubmitHandler);\n        }\n        currentSubmitHandler = handleSubmit;\n        submitButton.addEventListener('click', currentSubmitHandler);\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Variant of Game Game ${e:\/\/Field\/currentSymbol} ${e:\/\/Field\/playerName1} panel X You panel A ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> migraines <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"migraines","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n\t\t\t<div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n\t\t\t\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","DataExportTag":"Q14","QuestionID":"QID1218862986"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862987","SecondaryAttribute":"Belief History 1: ${e:\/\/Field\/beliefHistory_1} Belief Round Times 1: ...","TertiaryAttribute":null,"Payload":{"QuestionText":"Belief History 1: ${e:\/\/Field\/beliefHistory_1}<br \/>\nBelief Round Times 1: ${e:\/\/Field\/beliefRoundTimes_1}<br \/>\nBelief Payment 1: ${e:\/\/Field\/beliefPayment_1}<br \/>\nBeliefs 1: ${e:\/\/Field\/beliefs_1}<br \/>\n<br \/>\nBelief History 2: ${e:\/\/Field\/beliefHistory_2}<br \/>\nBelief Round Times 2: ${e:\/\/Field\/beliefRoundTimes_2}<br \/>\nBelief Payment 2: ${e:\/\/Field\/beliefPayment_2}<br \/>\nBeliefs 2: ${e:\/\/Field\/beliefs_2}<br \/>\n<br \/>\nBelief History 3: ${e:\/\/Field\/beliefHistory_3}<br \/>\nBelief Round Times 3: ${e:\/\/Field\/beliefRoundTimes_3}<br \/>\nBelief Payment 3: ${e:\/\/Field\/beliefPayment_3}<br \/>\nBeliefs 3: ${e:\/\/Field\/beliefs_3}<br \/>\n<br \/>\nBelief History 4: ${e:\/\/Field\/beliefHistory_4}<br \/>\nBelief Round Times 4: ${e:\/\/Field\/beliefRoundTimes_4}<br \/>\nBelief Payment 4: ${e:\/\/Field\/beliefPayment_4}<br \/>\nBeliefs 4: ${e:\/\/Field\/beliefs_4}<br \/>\n<br \/>\nBelief History 5: ${e:\/\/Field\/beliefHistory_5}<br \/>\nBelief Round Times 5: ${e:\/\/Field\/beliefRoundTimes_5}<br \/>\nBelief Payment 5: ${e:\/\/Field\/beliefPayment_5}<br \/>\nBeliefs 5: ${e:\/\/Field\/beliefs_5}<br \/>\n<br \/>\nBelief History 6: ${e:\/\/Field\/beliefHistory_6}<br \/>\nBelief Round Times 6: ${e:\/\/Field\/beliefRoundTimes_6}<br \/>\nBelief Payment 6: ${e:\/\/Field\/beliefPayment_6}<br \/>\nBeliefs 6: ${e:\/\/Field\/beliefs_6}<br \/>\n<br \/>\nBelief History 7: ${e:\/\/Field\/beliefHistory_7}<br \/>\nBelief Round Times 7: ${e:\/\/Field\/beliefRoundTimes_7}<br \/>\nBelief Payment 7: ${e:\/\/Field\/beliefPayment_7}<br \/>\nBeliefs 7: ${e:\/\/Field\/beliefs_7}<br \/>\n<br \/>\nBelief History 8: ${e:\/\/Field\/beliefHistory_8}<br \/>\nBelief Round Times 8: ${e:\/\/Field\/beliefRoundTimes_8}<br \/>\nBelief Payment 8: ${e:\/\/Field\/beliefPayment_8}<br \/>\nBeliefs 8: ${e:\/\/Field\/beliefs_8}<br \/>\n<br \/>\nBelief History 9: ${e:\/\/Field\/beliefHistory_9}<br \/>\nBelief Round Times 9: ${e:\/\/Field\/beliefRoundTimes_9}<br \/>\nBelief Payment 9: ${e:\/\/Field\/beliefPayment_9}<br \