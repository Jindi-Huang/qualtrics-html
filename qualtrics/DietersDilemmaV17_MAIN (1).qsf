        \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCount\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswers\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"DataExportTag":"Q158","QuestionType":"MC","Selector":"MACOL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2},"QuestionDescription":"Comprehension check To make sure you have understood these instructions, please select all correc...","Choices":{"1":{"Display":"If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this means that Ann decided before Bob"},"2":{"Display":"If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this does <u>not<\/u> mean that Ann decided before Bob"},"3":{"Display":"Whether I press my button or not does <u>not<\/u> affect my payment"},"4":{"Display":"My overall payment will be the sum of all the payments I collect over the various games and rounds of each game I play."},"5":{"Display":"My overall payment will be determined by one randomly selected round from one randomly selected game."},"6":{"Display":"Pressing my button will cost $${e:\/\/Field\/aCost}"}},"ChoiceOrder":["1","2","3","4","5","6"],"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","MinChoices":"1","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/6","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span clas