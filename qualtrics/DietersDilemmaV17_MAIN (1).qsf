urn 1;\n\t\tif (value > 10 && value <= 20) return 2;\n\t\tif (value > 20 && value <= 30) return 3;\n\t\tif (value > 30 && value <= 40) return 4;\n\t\tif (value > 40 && value <= 50) return 5;\n\t\tif (value > 50 && value <= 60) return 6;\n\t\tif (value > 60 && value <= 70) return 7;\n\t\tif (value > 70 && value <= 80) return 8;\n\t\tif (value > 80 && value <= 90) return 9;\n\t\tif (value > 90 && value <= 100) return 10;\n\t\treturn null;\n\t}\n\t\n\t\/\/ Variables to process\n\tconst verbalVariables = ['dieterPA', 'dieterPX', 'dieterPY', 'dieterSameYes', 'dieterSameNo'];\n\tconst verbalPayments = [];\n\t\n\t\/\/ Loop through each variable\n\tfor (let i = 0; i < verbalVariables.length; i++) {\n\t\tconst varName = verbalVariables[i];\n\t\t\n\t\t\/\/ Get user's answer (should be category 1-10)\n\t\tconst userAnswer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData(varName + '_' + id));\n\t\t\n\t\t\/\/ Get correct value (percentage) and convert to category\n\t\tconst correctValue = rationalInference[varName];\n\t\tconst correctCategory = percentageToCategory(correctValue);\n\t\t\n\t\t\/\/ Calculate payment\n\t\tconst difference = Math.abs(correctCategory - userAnswer);\n\t\tconst payment = beliefPaymentMax - (difference * beliefPaymentIncentive);\n\t\t\n\t\t\/\/ Store payment in array\n\t\tverbalPayments.push(payment);\n\t\t\n\t\tconsole.log(varName + ' - Correct:', correctValue, 'Category:', correctCategory, 'Answer:', userAnswer, 'Payment:', payment);\n\t}\n\t\n\tconst subjDAG1_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG1_' + id);\n\tconst subjDAG2_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG2_' + id);\n\tconsole.log(id);\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tlet correctDAG;\n\tif (causal == 0){\n\t\tcorrectDAG = '[{\"source\":\"you\",\"target\":\"p1\"},{\"source\":\"p2\",\"target\":\"p1\"}]';\n\t}\n\telse if (causal == 1){\n\t\tcorrectDAG = '[{\"source\":\"you\",\"target\":\"p1\"},{\"source\":\"p1\",\"target\":\"p2\"}]';\n\t}\n\t\n\t\/\/ Calculate DAG payment\n\tconst dagPayment1 = (subjDAG1_answer === correctDAG) ? beliefPaymentMax : 0;\n\tconst dagPayment2 = (subjDAG2_answer === correctDAG) ? beliefPaymentMax : 0;\n\tverbalPayments.push(dagPayment1);\n\tverbalPayments.push(dagPayment2);\n\tconsole.log('subjDAG - Answer:', subjDAG1_answer, 'Correct:', correctDAG, 'Payment:', dagPayment1);\n\tconsole.log('subjDAG - Answer:', subjDAG2_answer, 'Correct:', correctDAG, 'Payment:', dagPayment2);\n\t\n\t\/\/ Calculate confidence DAG payment\n\tconst confidenceDAG1 = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('confidenceDAG1_' + id));\n\tconst confidenceDAG2 = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('confidenceDAG2_' + id));\n\t\n\t\/\/ Step 1: Randomly draw X from 0 to 100\n\tconst X = Math.random() * 100;\n\t\n\tlet confidenceDAGPayment1;\n\tlet confidenceDAGPayment2;\n\t\n\tif (X > confidenceDAG1) {\n\t\t\/\/ Step 2: Give max payment with X% chance\n\t\tconst randomChance = Math.random() * 100;\n\t\tconfidenceDAGPayment1 = (randomChance < X) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '> confidence1:', confidenceDAG1, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment1);\n\t} else {\n\t\t\/\/ Step 3: Give max payment if DAG answer is correct\n\t\tconfidenceDAGPayment1 = (subjDAG1_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '<= confidence1:', confidenceDAG1, ', DAG correct:', (subjDAG1_answer === correctDAG), ', Payment:', confidenceDAGPayment1);\n\t}\n\t\n\t\n\tif (X > confidenceDAG2) {\n\t\t\/\/ Step 2: Give max payment with X% chance\n\t\tconst randomChance = Math.random() * 100;\n\t\tconfidenceDAGPayment2 = (randomChance < X) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '> confidence2:', confidenceDAG2, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment2);\n\t} else {\n\t\t\/\/ Step 3: Give max payment if DAG answer is correct\n\t\tconfidenceDAGPayment2 = (subjDAG2_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '<= confidence1:', confidenceDAG2, ', DAG correct:', (subjDAG2_answer === correctDAG), ', Payment:', confidenceDAGPayment2);\n\t}\n\t\n\tverbalPayments.push(confidenceDAGPayment1);\n\tverbalPayments.push(confidenceDAGPayment2);\n\t\n\t\/\/ Calculate dieterVersion payment\n\tconst dieterVersion_answer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('dieterVersion_' + id));\n\t\n\t\/\/ Determine correct answer based on causal\n\tconst dieterVersion_correct = (causal == 0) ? 10 : 1;\n\t\n\t\/\/ Calculate payment\n\tconst dieterVersion_difference = Math.abs(dieterVersion_correct - dieterVersion_answer);\n\tconst dieterVersion_payment = beliefPaymentMax - (dieterVersion_difference * beliefPaymentIncentive);\n\t\n\tverbalPayments.push(dieterVersion_payment);\n\tconsole.log('dieterVersion - Causal:', causal, 'Correct:', dieterVersion_correct, 'Answer:', dieterVersion_answer, 'Payment:', dieterVersion_payment);\n\t\n\t\/\/ Save the payment array to embedded data\n\tQualtrics.SurveyEngine.setEmbeddedData('verbalPayment_' + id, JSON.stringify(verbalPayments));\n\tconsole.log('Verbal Payments:', verbalPayments);\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":600,"InputHeight":113},"QuestionDescription":"In your own words, please describe how you usually chose between \"Yes\" and \"No\" in game Game...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"In your own words, please describe how you usually chose between &quot;Yes&quot; and &quot;No&quot; in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span>. How did your decision making evolve over time?","DataExportTag":"dieterOwnWords","QuestionID":"QID326","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID327","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>  <\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    \n    window.allBeliefs = [];\n    window.allBeliefsText = [];\n    window.allSlider1Values = [];\n    window.allSlider2Values = [];\n    \n    const storedBeliefs = Qualtrics.SurveyEngine.getEmbeddedData('beliefs_' + id);\n    if (storedBeliefs) {\n        window.allBeliefs = JSON.parse(storedBeliefs);\n    }\n    \n    const storedBeliefsText = Qualtrics.SurveyEngine.getEmbeddedData('beliefsText_' + id);\n    if (storedBeliefsText) {\n        window.allBeliefsText = JSON.parse(storedBeliefsText);\n    }\n    \n    const storedSlider1 = Qualtrics.SurveyEngine.getEmbeddedData('slider1Values_' + id);\n    if (storedSlider1) {\n        window.allSlider1Values = JSON.parse(storedSlider1);\n    }\n    \n    const storedSlider2 = Qualtrics.SurveyEngine.getEmbeddedData('slider2Values_' + id);\n    if (storedSlider2) {\n        window.allSlider2Values = JSON.parse(storedSlider2);\n    }\n\n    const question1Div = document.getElementById('beliefQuestion1');\n    const question2Div = document.getElementById('beliefQuestion2');\n    const question3Div = document.getElementById('beliefQuestion3');\n    const optionsDiv = document.getElementById('beliefOptions');\n    \n    const question1Container = document.getElementById('question1Container');\n    const question2Container = document.getElementById('question2Container');\n    const question3Container = document.getElementById('question3Container');\n    \n    const pieChart1 = document.getElementById('pieChart1');\n    const pieChart2 = document.getElementById('pieChart2');\n    \n    const submitQuestion1 = document.getElementById('submitQuestion1');\n    const submitQuestion2 = document.getElementById('submitQuestion2');\n    const submitButton = document.getElementById('beliefSubmit');\n    \n    let currentSlider1Value = null;\n    let currentSlider2Value = null;\n\n    const UNFILLED_COLOR = '#e0e0e0';\n    const FILLED_COLOR = '#2196F3';\n\n    function createPieChart(svgElement, onSelect) {\n        svgElement.innerHTML = '';\n        \n        const segments = [];\n        let filledCount = 0;\n        \n        const centerLabel = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n        centerLabel.setAttribute('class', 'pie-center-label');\n        centerLabel.setAttribute('x', '0');\n        centerLabel.setAttribute('y', '0');\n        centerLabel.textContent = '?%';\n        \n        for (let i = 0; i < 10; i++) {\n            const startAngle = (i * 36) - 90;\n            const endAngle = ((i + 1) * 36) - 90;\n            \n            const path = createPieSegment(startAngle, endAngle, 0, 200);\n            path.setAttribute('fill', UNFILLED_COLOR);\n            path.setAttribute('stroke', 'white');\n            path.setAttribute('stroke-width', '2');\n            path.setAttribute('class', 'pie-segment');\n            path.setAttribute('data-index', i);\n            \n            path.addEventListener('click', function() {\n                const clickedIndex = parseInt(this.getAttribute('data-index'));\n                \n                if (filledCount === 1 && clickedIndex === 0) {\n                    filledCount = 0;\n                    segments.forEach(seg => {\n                        seg.setAttribute('fill', UNFILLED_COLOR);\n                    });\n                    centerLabel.textContent = '0%';\n                    onSelect(0);\n                } else {\n                    filledCount = clickedIndex + 1;\n                    \n                    segments.forEach((seg, idx) => {\n                        if (idx < filledCount) {\n                            seg.setAttribute('fill', FILLED_COLOR);\n                        } else {\n                            seg.setAttribute('fill', UNFILLED_COLOR);\n                        }\n                    });\n                    \n                    const percentage = filledCount * 10;\n                    centerLabel.textContent = percentage + '%';\n                    onSelect(percentage);\n                }\n            });\n            \n            segments.push(path);\n            svgElement.appendChild(path);\n            \n            const labelAngle = (startAngle + endAngle) \/ 2;\n            const labelRadius = 130;\n            const labelX = Math.cos(labelAngle * Math.PI \/ 180) * labelRadius;\n            const labelY = Math.sin(labelAngle * Math.PI \/ 180) * labelRadius;\n            \n            const label = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n            label.setAttribute('x', labelX);\n            label.setAttribute('y', labelY);\n            label.setAttribute('text-anchor', 'middle');\n            label.setAttribute('dominant-baseline', 'middle');\n            label.setAttribute('fill', '#666');\n            label.setAttribute('font-size', '16');\n            label.setAttribute('font-weight', 'bold');\n            label.setAttribute('pointer-events', 'none');\n            label.textContent = ((i + 1) * 10) + '%';\n            svgElement.appendChild(label);\n        }\n        \n        svgElement.appendChild(centerLabel);\n        \n        return {\n            reset: function() {\n                filledCount = 0;\n                segments.forEach(seg => {\n                    seg.setAttribute('fill', UNFILLED_COLOR);\n                });\n                centerLabel.textContent = '?%';\n            }\n        };\n    }\n\n    function createPieSegment(startAngle, endAngle, innerRadius, outerRadius) {\n        const start = polarToCartesian(0, 0, outerRadius, endAngle);\n        const end = polarToCartesian(0, 0, outerRadius, startAngle);\n        \n        const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';\n        \n        let d;\n        if (innerRadius === 0) {\n            d = [\n                'M', 0, 0,\n                'L', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'Z'\n            ].join(' ');\n        } else {\n            const startInner = polarToCartesian(0, 0, innerRadius, endAngle);\n            const endInner = polarToCartesian(0, 0, innerRadius, startAngle);\n            \n            d = [\n                'M', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'L', endInner.x, endInner.y,\n                'A', innerRadius, innerRadius, 0, largeArcFlag, 1, startInner.x, startInner.y,\n                'Z'\n            ].join(' ');\n        }\n        \n        const path = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'path');\n        path.setAttribute('d', d);\n        return path;\n    }\n\n    function polarToCartesian(centerX, centerY, radius, angleInDegrees) {\n        const angleInRadians = (angleInDegrees) * Math.PI \/ 180.0;\n        return {\n            x: centerX + (radius * Math.cos(angleInRadians)),\n            y: centerY + (radius * Math.sin(angleInRadians))\n        };\n    }\n\n    let pie1Controller, pie2Controller;\n\n    window.updateBeliefQuestion = function() {\n        const data = window.currentBeliefData;\n        \n        question1Container.style.display = 'block';\n        question2Container.style.display = 'none';\n        question3Container.style.display = 'none';\n        submitQuestion1.style.display = 'block';\n        submitQuestion2.style.display = 'block';\n        currentSlider1Value = null;\n        currentSlider2Value = null;\n        submitQuestion1.disabled = true;\n        submitQuestion2.disabled = true;\n        \n        pie1Controller = createPieChart(pieChart1, function(value) {\n            currentSlider1Value = value;\n            submitQuestion1.disabled = false;\n        });\n        \n        pie2Controller = createPieChart(pieChart2, function(value) {\n            currentSlider2Value = value;\n            submitQuestion2.disabled = false;\n        });\n        \n        const questionConfigs = {\n            AX: {\n                prefix: data.exoButton == null \n                    ? \" the <b>Bonus Player chooses freely<\/b>?\" \n                    : \" the <b>Bonus Player must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing <b>your own button<\/b> change the <b>Co-Player\\'s choice<\/b>',\n                affectedPlayer: 'the Co-Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            },\n            AY: {\n                prefix: data.exoButton == null \n                    ? \" the <b>Co-Player chooses freely<\/b>?\" \n                    : \" the <b>Co-Player must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing <b>your own button<\/b> change the <b>Bonus Player\\'s choice<\/b>',\n                affectedPlayer: 'the Bonus Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            XY: {\n                prefix: data.exoButton == null \n                    ? \"\" \n                    : \" <b>you must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if the <b>Co-Player must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if the <b>Co-Player must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing the <b>Co-Player\\'s button<\/b> change the <b>Bonus Player\\'s choice<\/b>',\n                affectedPlayer: 'the Bonus Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            YX: {\n                prefix: data.exoButton == null \n                    ? \"\" \n                    : \" <b>you must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if the <b>Bonus Player must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if the <b>Bonus Player must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does <b>pressing the Bonus Player\\'s button<\/b> change the <b>Co-Player\\'s choice<\/b>',\n                affectedPlayer: 'the Co-Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            }\n        };\n        \n        const config = questionConfigs[data.causalElicitType];\n        question1Div.innerHTML = 'Question 1: <br><br>' + config.question1 + ' and ' + config.prefix;\n        question2Div.innerHTML = 'Question 2: <br><br>' + config.question2 + ' and ' + config.prefix;\n        question3Div.innerHTML = 'Question 3: <br><br>' + config.question3 + ' if ' + config.prefix;\n\n        const options = [\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'No change in the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.'\n        ];\n\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        optionsDiv.innerHTML = '';\n        submitButton.disabled = true;\n\n        displayOptions.forEach((option, index) => {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n\n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'beliefResponse';\n            radio.value = index;\n            radio.id = 'beliefOption' + index;\n\n            const label = document.createElement('label');\n            label.setAttribute('for', 'beliefOption' + index);\n            label.textContent = option;\n\n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n\n            optionDiv.addEventListener('click', function() {\n                \/\/ Remove selected class from all options\n                document.querySelectorAll('#beliefOptions .verbal-option').forEach(opt => {\n                    opt.classList.remove('selected');\n                });\n\n                \/\/ Add selected class to clicked option\n                this.classList.add('selected');\n                radio.checked = true;\n                submitButton.disabled = false;\n            });\n        });\n\n        \/\/ setTimeout(() => {\n        \/\/     const beliefBlock = document.querySelector('.belief-block');\n        \/\/     if (beliefBlock) {\n        \/\/         beliefBlock.scrollTop = 0;\n        \/\/         beliefBlock.scrollTo({ top: 0, behavior: 'auto' });\n        \/\/     }\n        \/\/ }, 150);\n        \n        \/\/ NEW: Add glow to No button when first question appears\n        const btnNo = document.getElementById('btnNo');\n        const btnYes = document.getElementById('btnYes');\n        if (btnNo) {\n            btnNo.classList.add('active-choice');\n        }\n        if (btnYes) {\n            btnYes.classList.remove('active-choice');\n            btnYes.style.backgroundColor = 'gray';\n        }\n    };\n\n    submitQuestion1.addEventListener('click', function() {\n        submitQuestion1.style.display = 'none';\n        question2Container.style.display = 'block';\n\t\tsetTimeout(() => {\n            question2Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n        }, 100);\n        \n        \/\/ NEW: Move glow from No button to Yes button\n        const btnNo = document.getElementById('btnNo');\n        const btnYes = document.getElementById('btnYes');\n        if (btnNo) {\n            btnNo.classList.remove('active-choice');\n            btnNo.style.backgroundColor = 'gray'; \n        }\n        if (btnYes) {\n            btnYes.classList.add('active-choice');\n            btnYes.style.backgroundColor = '';\n        }\n    });\n\n    submitQuestion2.addEventListener('click', function() {\n\t\tsubmitQuestion2.style.display = 'none';\n\t\tquestion3Container.style.display = 'block';\n\t\tsetTimeout(() => {\n\t\t\tquestion3Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n\t\t}, 100);\n\n\t\t\/\/ Remove button glow\n\t\tconst btnYes = document.getElementById('btnYes');\n\t\tconst btnNo = document.getElementById('btnNo');\n\t\tif (btnYes) {\n\t\t\tbtnYes.classList.remove('active-choice');\n\t\t}\n\t\tif (btnNo) {\n\t\t\tbtnNo.classList.remove('active-choice');\n\t\t\tbtnNo.style.backgroundColor = '';\n\t\t}\n\n\t\t\/\/ NEW: Highlight the panel with buttons\n\t\tconst buttonContainer = document.querySelector('.button-container');\n\t\tif (buttonContainer) {\n\t\t\tconst panelWithButtons = buttonContainer.closest('.panel');\n\t\t\tif (panelWithButtons) {\n\t\t\t\tpanelWithButtons.classList.add('active-choice');\n\t\t\t}\n\t\t}\n\t});\n\n    submitButton.addEventListener('click', function() {\n        const selected = document.querySelector('input[name=\"beliefResponse\"]:checked');\n        if (selected) {\n            const selectedIndex = parseInt(selected.value);\n            const selectedText = selected.parentElement.querySelector('label').textContent;\n            const originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\n            window.allBeliefs.push(originalIndex);\n            window.allBeliefsText.push(selectedText);\n            window.allSlider1Values.push(currentSlider1Value);\n            window.allSlider2Values.push(currentSlider2Value);\n\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(window.allBeliefs));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(window.allBeliefsText));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider1Values_' + id, JSON.stringify(window.allSlider1Values));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider2Values_' + id, JSON.stringify(window.allSlider2Values));\n\n            if (window.onBeliefSubmitted) {\n                window.onBeliefSubmitted(selectedIndex, selectedText);\n            }\n        }\n    });\n});","DefaultChoices":false,"DataExportTag":"Q320","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID327","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID328","SecondaryAttribute":"Click on the pie to make your prediction Next Click on the pie to make your prediction Next Submi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div> \n<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    \n    \/\/ Initialize storage arrays\n    window.allBeliefs = [];\n    window.allBeliefsText = [];\n    window.allSlider1Values = [];\n    window.allSlider2Values = [];\n    \n    \/\/ Load existing data if available\n    const storedBeliefs = Qualtrics.SurveyEngine.getEmbeddedData('beliefs_' + id);\n    if (storedBeliefs) {\n        window.allBeliefs = JSON.parse(storedBeliefs);\n    }\n    \n    const storedBeliefsText = Qualtrics.SurveyEngine.getEmbeddedData('beliefsText_' + id);\n    if (storedBeliefsText) {\n        window.allBeliefsText = JSON.parse(storedBeliefsText);\n    }\n    \n    const storedSlider1 = Qualtrics.SurveyEngine.getEmbeddedData('slider1Values_' + id);\n    if (storedSlider1) {\n        window.allSlider1Values = JSON.parse(storedSlider1);\n    }\n    \n    const storedSlider2 = Qualtrics.SurveyEngine.getEmbeddedData('slider2Values_' + id);\n    if (storedSlider2) {\n        window.allSlider2Values = JSON.parse(storedSlider2);\n    }\n\n    const question1Div = document.getElementById('beliefQuestion1');\n    const question2Div = document.getElementById('beliefQuestion2');\n    const question3Div = document.getElementById('beliefQuestion3');\n    const optionsDiv = document.getElementById('beliefOptions');\n    \n    const question1Container = document.getElementById('question1Container');\n    const question2Container = document.getElementById('question2Container');\n    const question3Container = document.getElementById('question3Container');\n    \n    const pieChart1 = document.getElementById('pieChart1');\n    const pieChart2 = document.getElementById('pieChart2');\n    \n    const submitQuestion1 = document.getElementById('submitQuestion1');\n    const submitQuestion2 = document.getElementById('submitQuestion2');\n    const submitButton = document.getElementById('beliefSubmit');\n    \n    let currentSlider1Value = null;\n    let currentSlider2Value = null;\n\n    const UNFILLED_COLOR = '#e0e0e0';\n    const FILLED_COLOR = '#2196F3';\n\n    function createPieChart(svgElement, onSelect) {\n        svgElement.innerHTML = '';\n        \n        const segments = [];\n        let filledCount = 0;\n        \n        const centerLabel = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n        centerLabel.setAttribute('class', 'pie-center-label');\n        centerLabel.setAttribute('x', '0');\n        centerLabel.setAttribute('y', '0');\n        centerLabel.textContent = '?%';\n        \n        for (let i = 0; i < 10; i++) {\n            const startAngle = (i * 36) - 90;\n            const endAngle = ((i + 1) * 36) - 90;\n            \n            const path = createPieSegment(startAngle, endAngle, 0, 200);\n            path.setAttribute('fill', UNFILLED_COLOR);\n            path.setAttribute('stroke', 'white');\n            path.setAttribute('stroke-width', '2');\n            path.setAttribute('class', 'pie-segment');\n            path.setAttribute('data-index', i);\n            \n            path.addEventListener('click', function() {\n                const clickedIndex = parseInt(this.getAttribute('data-index'));\n                \n                if (filledCount === 1 && clickedIndex === 0) {\n                    filledCount = 0;\n                    segments.forEach(seg => {\n                        seg.setAttribute('fill', UNFILLED_COLOR);\n                    });\n                    centerLabel.textContent = '0%';\n                    onSelect(0);\n                } else {\n                    filledCount = clickedIndex + 1;\n                    \n                    segments.forEach((seg, idx) => {\n                        if (idx < filledCount) {\n                            seg.setAttribute('fill', FILLED_COLOR);\n                        } else {\n                            seg.setAttribute('fill', UNFILLED_COLOR);\n                        }\n                    });\n                    \n                    const percentage = filledCount * 10;\n                    centerLabel.textContent = percentage + '%';\n                    onSelect(percentage);\n                }\n            });\n            \n            segments.push(path);\n            svgElement.appendChild(path);\n            \n            const labelAngle = (startAngle + endAngle) \/ 2;\n            const labelRadius = 130;\n            const labelX = Math.cos(labelAngle * Math.PI \/ 180) * labelRadius;\n            const labelY = Math.sin(labelAngle * Math.PI \/ 180) * labelRadius;\n            \n            const label = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n            label.setAttribute('x', labelX);\n            label.setAttribute('y', labelY);\n            label.setAttribute('text-anchor', 'middle');\n            label.setAttribute('dominant-baseline', 'middle');\n            label.setAttribute('fill', '#666');\n            label.setAttribute('font-size', '16');\n            label.setAttribute('font-weight', 'bold');\n            label.setAttribute('pointer-events', 'none');\n            label.textContent = ((i + 1) * 10) + '%';\n            svgElement.appendChild(label);\n        }\n        \n        svgElement.appendChild(centerLabel);\n        \n        return {\n            reset: function() {\n                filledCount = 0;\n                segments.forEach(seg => {\n                    seg.setAttribute('fill', UNFILLED_COLOR);\n                });\n                centerLabel.textContent = '?%';\n            }\n        };\n    }\n\n    function createPieSegment(startAngle, endAngle, innerRadius, outerRadius) {\n        const start = polarToCartesian(0, 0, outerRadius, endAngle);\n        const end = polarToCartesian(0, 0, outerRadius, startAngle);\n        \n        const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';\n        \n        let d;\n        if (innerRadius === 0) {\n            d = [\n                'M', 0, 0,\n                'L', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'Z'\n            ].join(' ');\n        } else {\n            const startInner = polarToCartesian(0, 0, innerRadius, endAngle);\n            const endInner = polarToCartesian(0, 0, innerRadius, startAngle);\n            \n            d = [\n                'M', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'L', endInner.x, endInner.y,\n                'A', innerRadius, innerRadius, 0, largeArcFlag, 1, startInner.x, startInner.y,\n                'Z'\n            ].join(' ');\n        }\n        \n        const path = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'path');\n        path.setAttribute('d', d);\n        return path;\n    }\n\n    function polarToCartesian(centerX, centerY, radius, angleInDegrees) {\n        const angleInRadians = (angleInDegrees) * Math.PI \/ 180.0;\n        return {\n            x: centerX + (radius * Math.cos(angleInRadians)),\n            y: centerY + (radius * Math.sin(angleInRadians))\n        };\n    }\n\n    let pie1Controller, pie2Controller;\n\n    window.updateBeliefQuestion = function() {\n        const data = window.currentBeliefData;\n        \n        \/\/ Show question 1, hide others\n        question1Container.style.display = 'block';\n        question2Container.style.display = 'none';\n        question3Container.style.display = 'none';\n\t\tsubmitQuestion1.style.display = 'block';\n        submitQuestion2.style.display = 'block';\n        currentSlider1Value = null;\n        currentSlider2Value = null;\n        submitQuestion1.disabled = true;\n        submitQuestion2.disabled = true;\n        \n        \/\/ Create pie charts\n        pie1Controller = createPieChart(pieChart1, function(value) {\n            currentSlider1Value = value;\n            submitQuestion1.disabled = false;\n        });\n        \n        pie2Controller = createPieChart(pieChart2, function(value) {\n            currentSlider2Value = value;\n            submitQuestion2.disabled = false;\n        });\n        \n        \/\/ Determine question texts based on treatment\n        const questionConfigs = {\n            AX: {\n                question1: data.exoButton == 1\n                    ? 'If ' + data.playerName2 + ' is forced to press ' + data.playerPronoun2 + ' button, and you did NOT press your own button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : data.exoButton == 0\n                    ? 'If ' + data.playerName2 + ' is forced NOT to press ' + data.playerPronoun2 + ' button, and you did NOT press your own button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : 'If you did NOT press your own button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?',\n                question2: data.exoButton == 1\n                    ? 'If ' + data.playerName2 + ' is forced to press ' + data.playerPronoun2 + ' button, and you pressed your own button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : data.exoButton == 0\n                    ? 'If ' + data.playerName2 + ' is forced NOT to press ' + data.playerPronoun2 + ' button, and you pressed your own button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : 'If you pressed your own button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?',\n                question3: data.exoButton == 1\n                    ? 'If ' + data.playerName2 + ' is forced to press ' + data.playerPronoun2 + ' button, how does pressing your own button (\"Yes\") change ' + data.playerName1 + '\\'s choice?'\n                    : data.exoButton == 0\n                    ? 'If ' + data.playerName2 + ' is forced NOT to press ' + data.playerPronoun2 + ' button, how does pressing your own button (\"Yes\") change ' + data.playerName1 + '\\'s choice?'\n                    : 'How does pressing your own button (\"Yes\") change ' + data.playerName1 + '\\'s choice?',\n                affectedPlayer: data.playerName1,\n                affectedPronoun: data.playerPronoun1\n            },\n            AY: {\n                question1: data.exoButton == 1\n                    ? 'When pressing your button is free, <b>what is the chance that ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button if you are forced to press <span style=\"color: #f44336;\">\"No\"<\/span><\/b> (regardless of whether you would have chosen to do so)?' \n                    : 'When pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, <b>what is the chance that ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button if you are forced to press <span style=\"color: #f44336;\">\"No\"<\/span><\/b> (regardless of whether you would have chosen to do so)?' ,\n                question2: data.exoButton == 1\n                    ? 'When pressing your button is free, <b>what is the chance that ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button if you are forced to press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b> (regardless of whether you would have chosen to do so)?' \n                    : 'When pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, <b>what is the chance that ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button if you are forced to press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b> (regardless of whether you would have chosen to do so)?' ,\n                question3: data.exoButton == 1\n\t\t\t\t? 'When pressing your button is free,  <b>how does pressing your button \"Yes\" change ${e:\/\/Field\/playerName2}\\'s choice<\/b>?'\n\t\t\t\t: 'When pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, <b>how does pressing your button \"Yes\" change ${e:\/\/Field\/playerName2}\\'s choice<\/b>?',\n                affectedPlayer: data.playerName2,\n                affectedPronoun: data.playerPronoun2\n            },\n            XY: {\n                question1: data.exoButton == 1\n                    ? 'If you are forced to press your own button, and you did NOT press ' + data.playerName1 + '\\'s button (\"No\"), what is the chance that ' + data.playerName2 + ' presses ' + data.playerPronoun2 + ' button?'\n                    : 'If you are forced NOT to press your own button, and you did NOT press ' + data.playerName1 + '\\'s button (\"No\"), what is the chance that ' + data.playerName2 + ' presses ' + data.playerPronoun2 + ' button?',\n                question2: data.exoButton == 1\n                    ? 'If you are forced to press your own button, and you pressed ' + data.playerName1 + '\\'s button (\"Yes\"), what is the chance that ' + data.playerName2 + ' presses ' + data.playerPronoun2 + ' button?'\n                    : 'If you are forced NOT to press your own button, and you pressed ' + data.playerName1 + '\\'s button (\"Yes\"), what is the chance that ' + data.playerName2 + ' presses ' + data.playerPronoun2 + ' button?',\n                question3: data.exoButton == 1\n                    ? 'If you are forced to press your own button, how does pressing ' + data.playerName1 + '\\'s button (\"Yes\") change ' + data.playerName2 + '\\'s choice?'\n                    : 'If you are forced NOT to press your own button, how does pressing ' + data.playerName1 + '\\'s button (\"Yes\") change ' + data.playerName2 + '\\'s choice?',\n                affectedPlayer: data.playerName2,\n                affectedPronoun: data.playerPronoun2\n            },\n            YX: {\n                question1: data.exoButton == null\n                    ? 'If you did NOT press ' + data.playerName2 + '\\'s button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : data.exoButton == 1\n                    ? 'If you are forced to press your own button, and you did NOT press ' + data.playerName2 + '\\'s button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : 'If you are forced NOT to press your own button, and you did NOT press ' + data.playerName2 + '\\'s button (\"No\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?',\n                question2: data.exoButton == null\n                    ? 'If you pressed ' + data.playerName2 + '\\'s button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : data.exoButton == 1\n                    ? 'If you are forced to press your own button, and you pressed ' + data.playerName2 + '\\'s button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?'\n                    : 'If you are forced NOT to press your own button, and you pressed ' + data.playerName2 + '\\'s button (\"Yes\"), what is the chance that ' + data.playerName1 + ' presses ' + data.playerPronoun1 + ' button?',\n                question3: data.exoButton == null\n                    ? 'How does pressing ' + data.playerName2 + '\\'s button (\"Yes\") change ' + data.playerName1 + '\\'s choice?'\n                    : data.exoButton == 1\n                    ? 'If you are forced to press your own button, how does pressing ' + data.playerName2 + '\\'s button (\"Yes\") change ' + data.playerName1 + '\\'s choice?'\n                    : 'If you are forced NOT to press your own button, how does pressing ' + data.playerName2 + '\\'s button (\"Yes\") change ' + data.playerName1 + '\\'s choice?',\n                affectedPlayer: data.playerName1,\n                affectedPronoun: data.playerPronoun1\n            }\n        };\n\n        const config = questionConfigs[data.causalElicitType];\n        question1Div.innerHTML = 'Question 1: <br><br>' + config.question1;\n        question2Div.innerHTML = 'Question 2: <br><br>' + config.question2;\n        question3Div.innerHTML = 'Question 3: <br><br>' + config.question3;\n\n        \/\/ Create options for question 3\n        const options = [\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'No change in the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.'\n        ];\n\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        optionsDiv.innerHTML = '';\n        submitButton.disabled = true;\n\n        displayOptions.forEach(function(option, index) {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n\n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'beliefResponse';\n            radio.value = index;\n            radio.id = 'beliefOption' + index;\n\n            const label = document.createElement('label');\n            label.setAttribute('for', 'beliefOption' + index);\n            label.textContent = option;\n\n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n\n            optionDiv.addEventListener('click', function() {\n                document.querySelectorAll('#beliefOptions .verbal-option').forEach(function(opt) {\n                    opt.classList.remove('selected');\n                });\n\n                this.classList.add('selected');\n                radio.checked = true;\n                submitButton.disabled = false;\n            });\n        });\n    };\n\n    \/\/ Question 1 submit handler\n    submitQuestion1.addEventListener('click', function() {\n        question2Container.style.display = 'block';\n\t\tsubmitQuestion1.style.display = 'none';\n\t\t\n\t\tsetTimeout(() => {\n    question2Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n}, 100);\n    });\n\n    \/\/ Question 2 submit handler\n    submitQuestion2.addEventListener('click', function() {\n        question3Container.style.display = 'block';\n\t\tsubmitQuestion2.style.display = 'none';\n\t\t\n\t\tsetTimeout(() => {\n    question3Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n}, 100);\n    });\n\n    \/\/ Final submit handler\n    submitButton.addEventListener('click', function() {\n        const selected = document.querySelector('input[name=\"beliefResponse\"]:checked');\n        if (selected) {\n            const selectedIndex = parseInt(selected.value);\n            const selectedText = selected.parentElement.querySelector('label').textContent;\n            const originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\n            \/\/ Store all values\n            window.allBeliefs.push(originalIndex);\n            window.allBeliefsText.push(selectedText);\n            window.allSlider1Values.push(currentSlider1Value);\n            window.allSlider2Values.push(currentSlider2Value);\n\n            \/\/ Save to embedded data\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(window.allBeliefs));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(window.allBeliefsText));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider1Values_' + id, JSON.stringify(window.allSlider1Values));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider2Values_' + id, JSON.stringify(window.allSlider2Values));\n\n            \/\/ Hide belief container\n            document.getElementById('beliefQuestionContainer').style.display = 'none';\n\n            \/\/ Notify main script\n            if (window.onBeliefSubmitted) {\n                window.onBeliefSubmitted(selectedIndex, selectedText);\n            }\n        }\n    });\n});","DefaultChoices":false,"DataExportTag":"Q321","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click on the pie to make your prediction Next Click on the pie to make your prediction Next Submi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID328"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID329","SecondaryAttribute":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span><\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three players below. An arrow from one player to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a player, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.<\/li>\n<\/ul>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  var q = this;\n\n  \/\/ ---------- DOM scaffold ----------\n  var qc = this.getQuestionContainer();\n  var qt = qc.querySelector('.QuestionText');\n  var wrap = document.createElement('div');\n  wrap.id = 'dag-wrap';\n  wrap.innerHTML = [\n    '<style>',\n    '  #dag-wrap{font-family:system-ui,Arial,sans-serif;}',\n    '  #dag-stage{width:100%;height:60vh;background:#f7f7f7;border:1px solid #ddd;border-radius:8px;}',\n    '  .label{font-size:20px;text-anchor:middle;dominant-baseline:middle;pointer-events:none;}',\n    '  .edge{stroke:#c00;stroke-width:2.5;fill:none;cursor:pointer;pointer-events:stroke;}',\n    '  .node-box{fill:#fff;stroke:#222;stroke-width:2;}',\n    '  #dag-controls{margin-top:6px;display:flex;gap:8px;align-items:center;font-size:12px;color:#555;}',\n    '  #dag-reset{padding:6px 10px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;}',\n    '<\/style>',\n    '<svg id=\"dag-stage\" viewBox=\"0 0 800 600\"><\/svg>',\n    '<div id=\"dag-controls\">',\n    '  <button id=\"dag-reset\" type=\"button\">Reset<\/button>',\n    '  <span>Drag from a node to another to add an arrow. Double-click an arrow to delete.<\/span>',\n    '<\/div>'\n  ].join('');\n  qt.appendChild(wrap);\n\n  \/\/ ---------- Core state ----------\n  var svg = document.getElementById('dag-stage');\n  var resetBtn = document.getElementById('dag-reset');\n  var PADX = 50, PADY = 35, CORNER = 30;\n  var GAP_LEAVE = 6, GAP_RING = 2, HEAD_LEN = 14;\n\n  var nodes = [\n    { id:'p1',  lines:['${e:\/\/Field\/playerName1}'],  x:200, y:120 },\n    { id:'p2',  lines:['${e:\/\/Field\/playerName2}'], x:600, y:120 },\n    { id:'you', lines:['You', '(chooses first)'],    x:400, y:460 }\n  ];\n  var edges = [];\n  var alertCount = 0;\n  var hasAddedEdge = false;\n\n  \/\/ ---------- Layers ----------\n  var defs  = el('defs');\n  var gNodes= el('g');\n  var gTemp = el('g');\n  var gEdges= el('g');\n  svg.append(defs,gNodes,gTemp,gEdges);\n\n  \/\/ Arrowhead marker (bigger + red)\n  var marker = el('marker',{\n    id:'arrowhead', viewBox:'0 0 12 12', refX:12, refY:6,\n    markerWidth:18, markerHeight:18, orient:'auto-start-reverse',\n    markerUnits:'userSpaceOnUse'\n  });\n  marker.appendChild(el('path',{ d:'M 0 0 L 12 6 L 0 12 z', fill:'#c00' }));\n  defs.appendChild(marker);\n\n  \/\/ Nodes\n  nodes.forEach(function(n){\n    var g = el('g',{ class:'node','data-id':n.id });\n\n    var tg = el('g');\n    n.lines.forEach(function(t,i){\n      tg.appendChild(el('text',{\n        class:'label', x:n.x, y:n.y - (n.lines.length-1)*9 + i*18\n      }, t));\n    });\n    g.appendChild(tg); gNodes.appendChild(g);\n\n    var bb = tg.getBBox(), w=bb.width+2*PADX, h=bb.height+2*PADY;\n    var x = n.x-w\/2, y = n.y-h\/2;\n    g.insertBefore(el('rect',{class:'node-box', x:x, y:y, width:w, height:h, rx:CORNER, ry:CORNER}), tg);\n\n    n.box = {x:x,y:y,w:w,h:h};\n    n.anchorR = Math.min(w,h)\/2 - 2;\n  });\n\n  var centroid = { x: avg(nodes.map(function(n){return n.x;})), y: avg(nodes.map(function(n){return n.y;})) };\n\n  \/\/ ---------- Interaction ----------\n  var dragStart=null, dragging=false, tempPath=null;\n\n  gNodes.addEventListener('mousedown', function(e){\n    var id = nodeAt(e); if(!id) return;\n    dragStart = getNode(id); dragging=true;\n    tempPath = el('path',{class:'edge','marker-end':'url(#arrowhead)',strokeDasharray:'4 4'});\n    gTemp.appendChild(tempPath);\n  });\n\n  svg.addEventListener('mousemove', function(e){\n    if(!dragging||!dragStart||!tempPath) return;\n    var p = svgPoint(e);\n    tempPath.setAttribute('d', curve(dragStart, {x:p.x,y:p.y}, null, 46));\n  });\n\n  svg.addEventListener('mouseup', function(e){\n    if(!dragging) return cleanup();\n    var id = nodeAt(e);\n    if(id && id!==dragStart.id) addEdge(dragStart.id,id);\n    cleanup();\n    persist();\n  });\n\n  gEdges.addEventListener('dblclick', function(e){\n    var p = e.target.closest('path.edge'); if(!p) return;\n    var key = p.getAttribute('data-key');\n    var i = edges.findIndex(function(ed){return keyOf(ed)===key;});\n    if(i>=0){ edges.splice(i,1); p.remove(); persist(); }\n  });\n\n  resetBtn.addEventListener('click', function(){\n    edges = [];\n    drawEdges();\n    persist();\n  });\n\n  function cleanup(){ dragging=false; dragStart=null; if(tempPath) tempPath.remove(); tempPath=null; }\n\n  function addEdge(s,t){\n\t  \/\/ Show warning for invalid connections but still allow them\n\t  if(s === 'p1' && t === 'you'){\n\t\talertCount++;\n\t\talert(\"Alert #\" + alertCount + \": You did not know the Co-Player's choice when making yours. Hence, the Co-Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n\t  }\n\t  if(s === 'p2' && t === 'you'){\n\t\talertCount++;\n\t\talert(\"Alert #\" + alertCount + \": You did not know the Bonus Player's choice when making yours. Hence, the Bonus Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n\t  }\n\n\t  if(edges.some(function(e){return e.source===s && e.target===t;})) return;\n\t  edges.push({source:s,target:t}); drawEdges();\n\t  hasAddedEdge = true;\n\t}\n\t\n  function drawEdges(){\n    gEdges.innerHTML='';\n    for(var i=0;i<edges.length;i++){\n      var e = edges[i];\n      var s=getNode(e.source), t=getNode(e.target);\n      var d = curve(s,t, dir(s.id,t.id), 54);\n      gEdges.appendChild(el('path',{class:'edge', d:d, 'marker-end':'url(#arrowhead)', 'data-key':keyOf(e)}));\n    }\n  }\n\n  \/\/ ---------- Geometry ----------\n  function curve(src, tgt, dirType, offset){\n    var sx=src.x, sy=src.y;\n    var tx=('x' in tgt)?tgt.x:getNode(tgt).x;\n    var ty=('y' in tgt)?tgt.y:getNode(tgt).y;\n\n    var theta = Math.atan2(ty-sy, tx-sx);\n    var start = {\n      x: sx + Math.cos(theta) * (src.anchorR + GAP_LEAVE),\n      y: sy + Math.sin(theta) * (src.anchorR + GAP_LEAVE)\n    };\n\n    var end;\n    if('x' in tgt){\n      end = {x:tx,y:ty};\n    } else {\n      var tn = getNode(tgt);\n      var tip = {\n        x: tn.x + Math.cos(theta+Math.PI) * (tn.anchorR - GAP_RING),\n        y: tn.y + Math.sin(theta+Math.PI) * (tn.anchorR - GAP_RING)\n      };\n      var ux = Math.cos(theta+Math.PI), uy = Math.sin(theta+Math.PI);\n      var sep = 6, tanx = -uy, tany = ux, sgn = (src.id < tn.id)?1:-1;\n      end = { x: tip.x - ux*HEAD_LEN + tanx*sep*sgn,\n              y: tip.y - uy*HEAD_LEN + tany*sep*sgn };\n    }\n\n    var dx=end.x-start.x, dy=end.y-start.y, L=Math.hypot(dx,dy)||1;\n    var mx=(start.x+end.x)\/2, my=(start.y+end.y)\/2;\n    var nx=-dy\/L, ny=dx\/L;\n    var outward = ((mx-centroid.x)*nx + (my-centroid.y)*ny) > 0 ? 1 : -1;\n    var sign = dirType==='ccw' ? -outward : outward;\n\n    var cx = mx + nx*offset*sign;\n    var cy = my + ny*offset*sign;\n    return 'M '+start.x+' '+start.y+' Q '+cx+' '+cy+' '+end.x+' '+end.y;\n  }\n\n  function dir(s,t){\n    var o=['p1','p2','you']; var i=o.indexOf(s), j=o.indexOf(t);\n    return ((i+1)%3===j)?'cw':'ccw';\n  }\n\n  function nodeAt(e){\n    var p = svgPoint(e);\n    var n = nodes.find(function(n){\n      return p.x>=n.box.x && p.x<=n.box.x+n.box.w && p.y>=n.box.y && p.y<=n.box.y+n.box.h;\n    });\n    return n ? n.id : null;\n  }\n\n  \/\/ ---------- Utils ----------\n  function el(tag, attrs, text){\n    if(!attrs) attrs={};\n    var E = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', tag);\n    Object.keys(attrs).forEach(function(k){ E.setAttribute(k, attrs[k]); });\n    if(text!=null) E.textContent = text;\n    return E;\n  }\n  function getNode(id){ return nodes.find(function(n){return n.id===id;}); }\n  function keyOf(e){ return e.source+'->'+e.target; }\n  function avg(a){ return a.reduce(function(s,v){return s+v;},0)\/a.length; }\n  function svgPoint(e){ var p=svg.createSVGPoint(); p.x=e.clientX; p.y=e.clientY; return p.matrixTransform(svg.getScreenCTM().inverse()); }\n\n  \/\/ ---------- Persist + Next gating ----------\n  function persist(){\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id'); \n    Qualtrics.SurveyEngine.setEmbeddedData('subjDAG2_' + id, JSON.stringify(edges));\n\tQualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount2_' + id, alertCount);\n    updateNextVisibility();\n  }\n\n  function updateNextVisibility(){\n  if(hasAddedEdge){ q.showNextButton(); }  \n}\n\n  \/\/ Hide Next until at least one edge exists\n  q.hideNextButton();\n  updateNextVisibility();\n\n  \/\/ Save on page leave and on Next\n  Qualtrics.SurveyEngine.addOnUnload(persist);\n  var nb = document.getElementById('NextButton');\n  if (nb) nb.addEventListener('click', persist, {capture:true});\n\n  \/\/ Initial draw\n  drawEdges();\n  persist();\n});","DefaultChoices":false,"DataExportTag":"DAG2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID329","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","TertiaryAttribute":null,"Payload":{"QuestionText":"\t<div style=\"text-align: center; position: absolute; bottom: 10px; margin: 0; padding: 0;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work. One round will randomly be selected for payment.<\/span><\/div>\n\t","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"\t<div style=\"text-align: center; position: absolute; bottom: 10px; margin: 0; padding: 0;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work. One round will randomly be selected for payment.<\/span><\/div>\n\t","DataExportTag":"Q33","QuestionID":"QID33"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID330","SecondaryAttribute":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;\n<ul>\n<\/ul>\n\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span>.<\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three nodes below. An arrow from one node to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a node, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.&nbsp;<\/li>\n<\/ul>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  var q = this;\n\n  \/\/ ---------- DOM scaffold ----------\n  var qc = this.getQuestionContainer();\n  var qt = qc.querySelector('.QuestionText');\n  var wrap = document.createElement('div');\n  wrap.id = 'dag-wrap';\n  wrap.innerHTML = [\n    '<style>',\n    '  #dag-wrap{font-family:system-ui,Arial,sans-serif;}',\n    '  #dag-stage{width:100%;height:60vh;background:#f7f7f7;border:1px solid #ddd;border-radius:8px;}',\n    '  .label{font-size:14px;text-anchor:middle;dominant-baseline:middle;pointer-events:none;}',\n    '  .edge{stroke:#c00;stroke-width:2.5;fill:none;cursor:pointer;pointer-events:stroke;}', \/* red edges *\/\n    '  .node-box{fill:#fff;stroke:#222;stroke-width:2;}',\n    '  #dag-controls{margin-top:6px;display:flex;gap:8px;align-items:center;font-size:12px;color:#555;}',\n    '  #dag-reset{padding:6px 10px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;}',\n    '<\/style>',\n    '<svg id=\"dag-stage\" viewBox=\"0 0 800 600\"><\/svg>',\n    '<div id=\"dag-controls\">',\n    '  <button id=\"dag-reset\" type=\"button\">Reset<\/button>',\n    '  <span>Drag from a node to another to add an arrow. Double-click an arrow to delete.<\/span>',\n    '<\/div>'\n  ].join('');\n  qt.appendChild(wrap);\n\n  \/\/ ---------- Core state ----------\n  var svg = document.getElementById('dag-stage');\n  var resetBtn = document.getElementById('dag-reset');\n  var PADX = 16, PADY = 12, CORNER = 18;\n  var GAP_LEAVE = 6, GAP_RING = 2, HEAD_LEN = 14; \/\/ larger head offset\n\n  var nodes = [\n    { id:'p1',  lines:['Your cost of pressing your button', '(free or ${e:\/\/Field\/currency}${e:\/\/Field\/aCost})'],  x:200, y:120 },\n    { id:'p2',  lines:['${e:\/\/Field\/playerName2}'], x:600, y:120 },\n    { id:'you', lines:['You'],    x:400, y:460 }\n  ];\n  var edges = []; \/\/ [{source:'p1', target:'you'}, ...]\n\n  \/\/ ---------- Layers ----------\n  var defs  = el('defs');\n  var gNodes= el('g');\n  var gTemp = el('g');\n  var gEdges= el('g');\n  svg.append(defs,gNodes,gTemp,gEdges);\n\n  \/\/ Arrowhead marker (bigger + red)\n  var marker = el('marker',{\n    id:'arrowhead', viewBox:'0 0 12 12', refX:12, refY:6,\n    markerWidth:18, markerHeight:18, orient:'auto-start-reverse',\n    markerUnits:'userSpaceOnUse'\n  });\n  marker.appendChild(el('path',{ d:'M 0 0 L 12 6 L 0 12 z', fill:'#c00' })); \/\/ red head\n  defs.appendChild(marker);\n\n  \/\/ Nodes\n  nodes.forEach(function(n){\n    var g = el('g',{ class:'node','data-id':n.id });\n\n    var tg = el('g');\n    n.lines.forEach(function(t,i){\n      tg.appendChild(el('text',{\n        class:'label', x:n.x, y:n.y - (n.lines.length-1)*9 + i*18\n      }, t));\n    });\n    g.appendChild(tg); gNodes.appendChild(g);\n\n    var bb = tg.getBBox(), w=bb.width+2*PADX, h=bb.height+2*PADY;\n    var x = n.x-w\/2, y = n.y-h\/2;\n    g.insertBefore(el('rect',{class:'node-box', x:x, y:y, width:w, height:h, rx:CORNER, ry:CORNER}), tg);\n\n    n.box = {x:x,y:y,w:w,h:h};\n    n.anchorR = Math.min(w,h)\/2 - 2;\n  });\n\n  var centroid = { x: avg(nodes.map(function(n){return n.x;})), y: avg(nodes.map(function(n){return n.y;})) };\n\n  \/\/ ---------- Interaction ----------\n  var dragStart=null, dragging=false, tempPath=null;\n\n  gNodes.addEventListener('mousedown', function(e){\n    var id = nodeAt(e); if(!id) return;\n    dragStart = getNode(id); dragging=true;\n    tempPath = el('path',{class:'edge','marker-end':'url(#arrowhead)',strokeDasharray:'4 4'});\n    gTemp.appendChild(tempPath);\n  });\n\n  svg.addEventListener('mousemove', function(e){\n    if(!dragging||!dragStart||!tempPath) return;\n    var p = svgPoint(e);\n    tempPath.setAttribute('d', curve(dragStart, {x:p.x,y:p.y}, null, 46));\n  });\n\n  svg.addEventListener('mouseup', function(e){\n    if(!dragging) return cleanup();\n    var id = nodeAt(e);\n    if(id && id!==dragStart.id) addEdge(dragStart.id,id);\n    cleanup();\n    persist();\n  });\n\n  gEdges.addEventListener('dblclick', function(e){\n    var p = e.target.closest('path.edge'); if(!p) return;\n    var key = p.getAttribute('data-key');\n    var i = edges.findIndex(function(ed){return keyOf(ed)===key;});\n    if(i>=0){ edges.splice(i,1); p.remove(); persist(); }\n  });\n\n  resetBtn.addEventListener('click', function(){\n    edges = [];\n    drawEdges();\n    persist();\n  });\n\n  function cleanup(){ dragging=false; dragStart=null; if(tempPath) tempPath.remove(); tempPath=null; }\n\n  function addEdge(s,t){\n    \/\/ Show warning for invalid connections but still allow them\n    if(s === 'you' && t === 'p1'){\n      alert(\"Your cost of pressing Yes was determined before you made a choice. Hence, your choice cannot have affected that cost within any given round. You can double-click an arrow to delete it.\");\n    }\n    if(s === 'p2' && t === 'you'){\n      alert(\"You did not know the Bonus Player\u2019s choice when making yours. Hence, the Bonus Player\u2019s choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n    }\n    \n    if(edges.some(function(e){return e.source===s && e.target===t;})) return;\n    edges.push({source:s,target:t}); drawEdges();\n  }\n  function drawEdges(){\n    gEdges.innerHTML='';\n    for(var i=0;i<edges.length;i++){\n      var e = edges[i];\n      var s=getNode(e.source), t=getNode(e.target);\n      var d = curve(s,t, dir(s.id,t.id), 54);\n      gEdges.appendChild(el('path',{class:'edge', d:d, 'marker-end':'url(#arrowhead)', 'data-key':keyOf(e)}));\n    }\n  }\n\n  \/\/ ---------- Geometry ----------\n  function curve(src, tgt, dirType, offset){\n    var sx=src.x, sy=src.y;\n    var tx=('x' in tgt)?tgt.x:getNode(tgt).x;\n    var ty=('y' in tgt)?tgt.y:getNode(tgt).y;\n\n    var theta = Math.atan2(ty-sy, tx-sx);\n    var start = {\n      x: sx + Math.cos(theta) * (src.anchorR + GAP_LEAVE),\n      y: sy + Math.sin(theta) * (src.anchorR + GAP_LEAVE)\n    };\n\n    var end;\n    if('x' in tgt){\n      end = {x:tx,y:ty};\n    } else {\n      var tn = getNode(tgt);\n      var tip = {\n        x: tn.x + Math.cos(theta+Math.PI) * (tn.anchorR - GAP_RING),\n        y: tn.y + Math.sin(theta+Math.PI) * (tn.anchorR - GAP_RING)\n      };\n      var ux = Math.cos(theta+Math.PI), uy = Math.sin(theta+Math.PI);\n      var sep = 6, tanx = -uy, tany = ux, sgn = (src.id < tn.id)?1:-1;\n      end = { x: tip.x - ux*HEAD_LEN + tanx*sep*sgn,\n              y: tip.y - uy*HEAD_LEN + tany*sep*sgn };\n    }\n\n    var dx=end.x-start.x, dy=end.y-start.y, L=Math.hypot(dx,dy)||1;\n    var mx=(start.x+end.x)\/2, my=(start.y+end.y)\/2;\n    var nx=-dy\/L, ny=dx\/L;\n    var outward = ((mx-centroid.x)*nx + (my-centroid.y)*ny) > 0 ? 1 : -1;\n    var sign = dirType==='ccw' ? -outward : outward;\n\n    var cx = mx + nx*offset*sign;\n    var cy = my + ny*offset*sign;\n    return 'M '+start.x+' '+start.y+' Q '+cx+' '+cy+' '+end.x+' '+end.y;\n  }\n\n  function dir(s,t){\n    var o=['p1','p2','you']; var i=o.indexOf(s), j=o.indexOf(t);\n    return ((i+1)%3===j)?'cw':'ccw';\n  }\n\n  function nodeAt(e){\n    var p = svgPoint(e);\n    var n = nodes.find(function(n){\n      return p.x>=n.box.x && p.x<=n.box.x+n.box.w && p.y>=n.box.y && p.y<=n.box.y+n.box.h;\n    });\n    return n ? n.id : null;\n  }\n\n  \/\/ ---------- Utils ----------\n  function el(tag, attrs, text){\n    if(!attrs) attrs={};\n    var E = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', tag);\n    Object.keys(attrs).forEach(function(k){ E.setAttribute(k, attrs[k]); });\n    if(text!=null) E.textContent = text;\n    return E;\n  }\n  function getNode(id){ return nodes.find(function(n){return n.id===id;}); }\n  function keyOf(e){ return e.source+'->'+e.target; }\n  function avg(a){ return a.reduce(function(s,v){return s+v;},0)\/a.length; }\n  function svgPoint(e){ var p=svg.createSVGPoint(); p.x=e.clientX; p.y=e.clientY; return p.matrixTransform(svg.getScreenCTM().inverse()); }\n\n  \/\/ ---------- Persist + Next gating ----------\n  function persist(){\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    Qualtrics.SurveyEngine.setEmbeddedData('subjDAG_' + id, JSON.stringify(edges));\n    updateNextVisibility();\n  }\n\n  function updateNextVisibility(){\n    if(edges.length>0){ q.showNextButton(); }\n    else { q.hideNextButton(); }\n  }\n\n  \/\/ Hide Next until at least one edge exists\n  q.hideNextButton();\n  updateNextVisibility();\n\n  \/\/ Save on page leave and on Next\n  Qualtrics.SurveyEngine.addOnUnload(persist);\n  var nb = document.getElementById('NextButton');\n  if (nb) nb.addEventListener('click', persist, {capture:true});\n\n  \/\/ Initial draw\n  drawEdges();\n  persist(); \/\/ initialize embedded data and Next state\n});","DefaultChoices":false,"DataExportTag":"Q323","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID330"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID331","SecondaryAttribute":"${e:\/\/Field\/subjDAG_5} ${e:\/\/Field\/subjDAG_6}","TertiaryAttribute":null,"Payload":{"QuestionText":"${e:\/\/Field\/subjDAG_5}<br><br>${e:\/\/Field\/subjDAG_6}<br>","DefaultChoices":false,"DataExportTag":"Q324","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${e:\/\/Field\/subjDAG_5} ${e:\/\/Field\/subjDAG_6}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID331","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"testing","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID332","SecondaryAttribute":"${e:\/\/Field\/subjDAG_1}${e:\/\/Field\/subjDAG_2}${e:\/\/Field\/subjDAG_3}${e:\/\/Field\/subjDAG_4}...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-size:11px;\">${e:\/\/Field\/subjDAG_1}${e:\/\/Field\/subjDAG_2}${e:\/\/Field\/subjDAG_3}${e:\/\/Field\/subjDAG_4}${e:\/\/Field\/subjDAG_5}${e:\/\/Field\/subjDAG_6}${e:\/\/Field\/subjDAG_7}${e:\/\/Field\/subjDAG_8}${e:\/\/Field\/subjDAG_9}${e:\/\/Field\/subjDAG_10}${e:\/\/Field\/subjDAG_11}${e:\/\/Field\/subjDAG_12}${e:\/\/Field\/subjDAG_13}${e:\/\/Field\/subjDAG_14}${e:\/\/Field\/subjDAG_15}<\/span><br \/>\n&nbsp;<\/p>\n\n<p><span style=\"font-size:11px;\"><code>${e:\/\/Field\/DAGAlertCount_1}<br \/>\n${e:\/\/Field\/DAGAlertCount_2}<br \/>\n${e:\/\/Field\/DAGAlertCount_3}<br \/>\n${e:\/\/Field\/DAGAlertCount_4}<br \/>\n${e:\/\/Field\/DAGAlertCount_5}<br \/>\n${e:\/\/Field\/DAGAlertCount_6}<br \/>\n${e:\/\/Field\/DAGAlertCount_7}<br \/>\n${e:\/\/Field\/DAGAlertCount_8}<br \/>\n${e:\/\/Field\/DAGAlertCount_9}<br \/>\n${e:\/\/Field\/DAGAlertCount_10}<br \/>\n${e:\/\/Field\/DAGAlertCount_11}<br \/>\n${e:\/\/Field\/DAGAlertCount_12}<br \/>\n${e:\/\/Field\/DAGAlertCount_13}<br \/>\n${e:\/\/Field\/DAGAlertCount_14}<br \/>\n${e:\/\/Field\/DAGAlertCount_15}<\/code>&nbsp;<\/span><\/p>","DefaultChoices":false,"DataExportTag":"Q325","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${e:\/\/Field\/subjDAG_1}${e:\/\/Field\/subjDAG_2}${e:\/\/Field\/subjDAG_3}${e:\/\/Field\/subjDAG_4}...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID332","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID333","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q326","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID333","SubSelector":"WTXB","Graphics":"IM_9NsmX4FFUOvso3s","GraphicsDescription":"Yes free"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID334","SecondaryAttribute":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q12","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","QuestionID":"QID334","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong>This is the end of this study<\/strong><\/span><br>\n<br>\nThank you for your participation!<br>\n<br>\nFrom your choices and luck, calculated exactly as stated in the instructions, one round of the study was randomly selected to determine your bonus. You earn ${e:\/\/Field\/currency}${e:\/\/Field\/payoff}. You will receive this in addition to the completion payment on prolific. \n<br>\n\t<br>\nPlease click Next to finish this study.&nbsp;<\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\"><span style=\"font-size:22px;\"><strong>This is the end of this study!<\/strong><\/span><\/div>\n<br \/>\nOne round of the study was randomly selected to determine your bonus. Your bonus is $${e:\/\/Field\/payoff}. You will receive this in addition to the base payment on prolific.<br \/>\n<br \/>\nPlease click Next to finish this study.&nbsp;","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"History: ${e:\/\/Field\/history} Round Times:\u00a0${e:\/\/Field\/roundTimes}","TertiaryAttribute":null,"Payload":{"QuestionText":"History: ${e:\/\/Field\/history}<br>Round Times:&nbsp;${e:\/\/Field\/roundTimes}<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"History: ${e:\/\/Field\/history} Round Times:\u00a0${e:\/\/Field\/roundTimes}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"BooleanValue","Value":"False","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span><span> False<\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"History: ${e:\/\/Field\/history}<br>Round Times:&nbsp;${e:\/\/Field\/roundTimes}<br>","DataExportTag":"Q34","QuestionID":"QID34"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID344","SecondaryAttribute":"In general,\u00a0does pressing your button \"work\"? That is, do you think you could affect ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>In general,&nbsp;does pressing your button \"work\"? <\/b>That is, do you think you could affect ${e:\/\/Field\/playerName2}\u2019s choice with your button choice?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DataExportTag":"migrainesButtonWork","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In general,\u00a0does pressing your button \"work\"? That is, do you think you could affect ...","Choices":{"2":{"Display":"Definitely not"},"3":{"Display":"Probably not"},"4":{"Display":"Possibly"},"5":{"Display":"Probably yes"},"6":{"Display":"Definitely yes"}},"ChoiceOrder":["2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"RecodeValues":{"2":"1","3":"2","4":"3","5":"4","6":"5"},"Language":[],"NextChoiceId":11,"NextAnswerId":1,"QuestionID":"QID344"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID345","SecondaryAttribute":"In this game, you will always see the Co-Player\u2019s choice before the Bonus Player\u2019s choice, regar","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">In this game, <b>you will always see the Co-Player\u2019s choice before the Bonus Player\u2019s choice,<\/b> regardless of who actually moved when.&nbsp;<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tif (loopNum != 1){\n\t\tvar loopPrev = loopNum - 1;\n\t\tvar name1prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopPrev);\n\t\tvar name2prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopPrev);\n\t\tjQuery(this.questionContainer).find(\"#D2\").html(\"They may play differently than \" +  name1prev + \" and \" + name2prev +\", with whom you played the previous game.\");\n\t}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q338","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this game, you will always see the Co-Player\u2019s choice before the Bonus Player\u2019s choice, regard...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID345","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"order","Operator":"EqualTo","RightOperand":"AXY","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">order<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> AXY <\/span>","Conjuction":"And"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":