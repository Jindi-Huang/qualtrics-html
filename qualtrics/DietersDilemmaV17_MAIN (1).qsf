ualTo","RightOperand":"AYX","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">order<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> AYX <\/span>","Conjuction":"And"},"Type":"If"},"1":{"0":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>"},"1":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","Conjuction":"And"},"2":{"LogicType":"EmbeddedField","LeftOperand":"order","Operator":"EqualTo","RightOperand":"AYX","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">order<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> AYX <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\">In this game, <b>you will always see the Bonus Player\u2019s choice before the Co-Player\u2019s choice<\/b>, regardless of who actually moved when.&nbsp;<\/div>","DataExportTag":"Q498","QuestionID":"QID498"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID499","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q499","QuestionID":"QID499"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Ann's Choice Matters Now! In the next few rounds, you will play the same version of the game as b...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong style=\"color:inherit;\" id=\"clickableWord\">Ann's Choice Matters Now!<\/strong><\/span><\/div>\n<br>\nIn the next few rounds, you will play the same version of the game as before. However, there are two important changes:<ol>\n\t<li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>Ann<\/b> presses her button, rather than if Bob presses his.<\/u><\/li>\n\t<li>Bob is forced NOT to press his button regardless of your or Ann's choice. <\/li>\n<\/ol>\n<br>\nThe cost of pressing your button may vary across rounds. In each round, you will decide whether to press your button under the given cost. Your choice can not influence the cost in the next rounds.<br>\n<br>\nYou will not observe Bob's choice immediately after your choice, but you'll be shown their choice of that round is randomly selected for your payment.","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst chartData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconsole.log(chartData);\n\tconst test = chartData.causalElicit\n\tconsole.log(test);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q43","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Ann's Choice Matters Now! In the next few rounds, you will play the same version of the game as b...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID50"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID500","SecondaryAttribute":"You will play this game with ${e:\/\/Field\/playerNameDisplay1} and ${e:\/\/Field\/playerNameDisplay2}....","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">\n\nYou will play this game with ${e:\/\/Field\/playerNameDisplay1} and ${e:\/\/Field\/playerNameDisplay2}. <span id=\"D2\">&nbsp;<\/span>\n\n<table align=\"center\" border=\"0\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:300px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon1}\"><\/td>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon2}\"><\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\t<br> \n\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will play this game with ${e:\/\/Field\/playerNameDisplay1} and ${e:\/\/Field\/playerNameDisplay2}....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tif (loopNum != 1){\n\t\tvar loopPrev = loopNum - 1;\n\t\tvar name1prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopPrev);\n\t\tvar name2prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopPrev);\n\t\tjQuery(this.questionContainer).find(\"#D2\").html(\"They may play differently than \" +  name1prev + \" and \" + name2prev +\", with whom you played the previous game.\");\n\t}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<div style=\"text-align: center;\">\n\nYou will play this game with ${e:\/\/Field\/playerNameDisplay1} and ${e:\/\/Field\/playerNameDisplay2}. <span id=\"D2\">&nbsp;<\/span>\n\n<table align=\"center\" border=\"0\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:300px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon1}\"><\/td>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon2}\"><\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\t<br> \n\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>"},"1":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q500","QuestionID":"QID500"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID501","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q501","QuestionID":"QID501"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID502","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    \/* Expand this page layout so the question can use full width *\/\n    .SkinInner {\n      max-width: none !important;\n      width: 100% !important;\n    }\n    .QuestionBody {\n      width: 100% !important;\n      max-width: none !important;\n    }\n\n    \/* Optional: reduce extra padding around the question *\/\n    #dd-wrapper {\n      padding-left: 0 !important;\n      padding-right: 0 !important;\n    }\n\n    \/* Make iframe responsive *\/\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n    }\n  <\/style>\n\n<iframe\n  id=\"dietersGame\"\n  src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dietersDilemma.html\"\n  style=\"width:100%; height:900px; border:0;\"\n  scrolling=\"yes\">\n<\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Fallback height so it doesn't start at 0 before first message arrives\n      iframe.style.height = \"700px\";\n\n      window.addEventListener(\"message\", function (event) {\n        \/\/ Basic validation: accept only messages that look like ours\n        if (!event.data || typeof event.data !== \"object\") return;\n        if (!(\"iframeHeight\" in event.data)) return;\n\n        const h = parseInt(event.data.iframeHeight, 10);\n        if (!isNaN(h) && h > 0) {\n          iframe.style.height = h + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hidePreviousButton();\n    this.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\tjQuery(\"#NextButton\").hide();\n\n\n   \n\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n\tconst buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\tconst linkfn = Qualtrics.SurveyEngine.getEmbeddedData('linkfn');\n\tconst basePay = parseFloat(\"${e:\/\/Field\/basePay}\");\n\tconst halfRounds = Math.floor(nRounds \/ 2);\n\n\t\/\/ Determine panel order and configure content\n\tconst isYFirst = order === \"AYX\";\n\n\tlet roundCounter    = parseInt(\"${e:\/\/Field\/roundCounter}\");\n\tlet X, A, Y;\n\tlet history         = [];\n\tlet roundTimes      = [];\n\tlet payment         = [];\n\tlet roundStartTime  = 0;\n    let firstPanelStartTime = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n\tlet xReady          = false;\n\tlet colorDisplayed  = false;\n\n\tconst btnNo        = document.getElementById(\"btnNo\");\n\tconst btnYes       = document.getElementById(\"btnYes\");\n\tconst panelXinfo   = document.getElementById(\"panelXinfo\");\n\tconst panelYinfo   = document.getElementById(\"panelYinfo\");\n\tconst panelAchoice = document.getElementById(\"panelAchoice\");\n\tconst resultText   = document.getElementById(\"resultText\");\n\tconst riskText     = document.getElementById(\"riskText\");\n\tconst roundDisplay = document.getElementById(\"roundDisplay\");\n\tconst actionPrompt = document.getElementById(\"actionPrompt\"); \n\n\t\/\/ Set up first and second panels based on order\n\tconst firstPanel = isYFirst ? panelYinfo : panelXinfo;\n\tconst secondPanel = isYFirst ? panelXinfo : panelYinfo;\n\tconst firstPanelText = isYFirst ? resultText : riskText;\n\tconst secondPanelText = isYFirst ? riskText : resultText;\n\t\n\t\n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n\t\/\/ Function to get panel content\n\tfunction getPanelContent(panelType, value, isPlayerChoice) {\n\t\tif (panelType === 'X') {\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value \n\t\t\t\t\t? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t};\n\t\t} else { \/\/ Y panel\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value\n\t\t\t\t\t? \"${e:\/\/Field\/playerName2} pressed ${e:\/\/Field\/playerPronoun2} button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!).\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).\"\n\t\t\t};\n\t\t}\n\t}\n\n\t\/\/ Swap visual order if needed\n\tif (isYFirst) {\n\t\tconst parent = panelXinfo.parentNode;\n\t\tparent.insertBefore(panelYinfo, panelXinfo);\n\t}\n    \n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\n    [panelAchoice, panelXinfo, panelYinfo].forEach(p => p.style.border = \"1px solid black\");\n\n    btnYes.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('y');\n        }\n    });\n    btnNo.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('n');\n        }\n    });\n    \n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    const causal = parseInt(\"${e:\/\/Field\/causal}\");\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst sigma0 = parseFloat(\"${e:\/\/Field\/sigma0}\");\n\tconst sigma1 = parseFloat(\"${e:\/\/Field\/sigma1}\");\n\tconst rho0 = parseFloat(\"${e:\/\/Field\/rho0}\");\n\tconst rho1 = parseFloat(\"${e:\/\/Field\/rho1}\");\n\tconst beta00 = parseFloat(\"${e:\/\/Field\/beta00}\");\n\tconst beta01 = parseFloat(\"${e:\/\/Field\/beta01}\");\n\tconst beta10 = parseFloat(\"${e:\/\/Field\/beta10}\");\n\tconst beta11 = parseFloat(\"${e:\/\/Field\/beta11}\");\n    function handleDecision(decision) {\n        if (!panelAchoice || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tlet pX = [0, 0, 0, 0];\n        A = decision === 'y' ? 1 : 0;\n        if (causal === 0) {\n\t\t\tpX = [beta00, beta01, beta10, beta11];\n\t\t\tY = Math.random() < pY ? 1 : 0;\n\t\t\tX = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            \n        } else {\n            const pX = [sigma0, sigma1];\n            const pY = [rho0, rho1];\n            X = Math.random() < pX[A] ? 1 : 0;\n            Y = Math.random() < pY[X] ? 1 : 0;\n        }\n\n        history.push([A, X, Y]);\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        payment.push(-aCost*A + yBonus*Y + basePay);\n\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n            \/\/ Show first panel\n            const firstPanelType = isYFirst ? 'Y' : 'X';\n            const firstValue = isYFirst ? Y : X;\n            const content = getPanelContent(firstPanelType, firstValue, isPlayerChoiceRound);\n\n            firstPanel.style.backgroundColor = content.color;\n            firstPanelText.innerHTML = content.text + \" <br>(press 'c' to continue)\";\n            secondPanel.style.backgroundColor = \"white\";\n            xReady = true;\n            firstPanelStartTime = Date.now(); \/\/ ADD THIS LINE\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        const yesVisible = btnYes.style.display !== \"none\" && !btnYes.disabled;\n        const noVisible = btnNo.style.display !== \"none\" && !btnNo.disabled;\n        \n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound) {\n            if (e.key === 'y' && yesVisible) {\n                handleDecision('y');\n            }\n            else if (e.key === 'n' && noVisible) {\n                handleDecision('n');\n            }\n        }\n        \n        \/\/ Continue key always works regardless of round type\n        if (e.key === 'c' && xReady) {\n            const firstTimeRemaining = (firstPanelStartTime + 500) - Date.now();\n            \n            if (firstTimeRemaining > 0) {\n                setTimeout(() => {\n                    showSecondPanel();\n                }, firstTimeRemaining);\n            } else {\n                showSecondPanel();\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tresultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function showSecondPanel() {\n    const currentRoundIndex = roundCounter - 1;\n    const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n    \/\/ Show second panel\n    const secondPanelType = isYFirst ? 'X' : 'Y';\n    const secondValue = isYFirst ? X : Y;\n    const content = getPanelContent(secondPanelType, secondValue, isPlayerChoiceRound);\n\n    secondPanel.style.backgroundColor = content.color;\n    secondPanelText.innerHTML = content.text + \" <br>(press 'space' to continue)\";\n    xReady = false;\n    colorDisplayed = true;\n    resultPanelStartTime = Date.now();\n}\n\n    function initiateRound() {\n        panelAchoice.style.display =\n        panelXinfo.style.display =\n        panelYinfo.style.display = \"none\";\n        setTimeout(() => {\n            showActionPanels();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history1_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes1_' + id, JSON.stringify(roundTimes));\n        Qualtrics.SurveyEngine.setEmbeddedData('payment1_' + id, JSON.stringify(payment));\n\t\tQualtrics.SurveyEngine.setEmbeddedData('roundCounter', roundCounter);\n        if (roundCounter < halfRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === halfRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n            \n            jQuery(\"#NextButton\").click();\n        }\n    }\n\n    function showActionPanels() {\n        panelAchoice.style.display = \"flex\";\n        panelXinfo.style.display   = \"flex\";\n        panelYinfo.style.display   = \"flex\";\n        panelXinfo.style.backgroundColor =\n        panelYinfo.style.backgroundColor = \"white\";\n        riskText.textContent = resultText.textContent = \"\";\n\n        const showBothButtons = treatment === \"endog\" ? 1 : buttonConfig[roundCounter - 1];\n        \n        if (showBothButtons === 1) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            \n            if (Math.random() < pA) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = \"You must press \\\"Yes\\\" in this round. <br> Press your button? (Use your mouse)\";\n            } else {\n                \/\/ Force No\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = \"You must press \\\"No\\\" in this round. <br> Press your button? (Use your mouse)\";\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n\n <div class=\"panel-wrapper\">\n\n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n\n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n    <\/div>\n<\/body>","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q502","QuestionID":"QID502"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID503","SecondaryAttribute":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: -20px; text-align: center;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: -20px; text-align: center;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q503","QuestionID":"QID503"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID504","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":64,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q504","QuestionID":"QID504"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID505","SecondaryAttribute":"Please indicate below who you think had an influence on whom in game Game...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span><\/strong><\/div>\n<ul>\n\t<li>Please draw arrows between the three players below. An arrow from one player to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a player, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.<\/li>\n<\/ul>\n\n<div id=\"dag-wrap\">\n  <style>\n    #dag-wrap{font-family:system-ui,Arial,sans-serif;}\n    #dag-container{display:flex;gap:20px;align-items:flex-start;justify-content:center;}\n    #dag-container.with-gap{margin-top:20px;}\n    #dag-left{flex:0 0 auto;}\n    #dag-stage{width:100%;height:60vh;background:#f7f7f7;border:1px solid #ddd;border-radius:8px;}\n    .label{font-size:20px;text-anchor:middle;dominant-baseline:middle;pointer-events:none;}\n    .edge{stroke:#c00;stroke-width:2.5;fill:none;cursor:pointer;pointer-events:stroke;}\n    .node-box{fill:#fff;stroke:#222;stroke-width:2;}\n    #dag-controls{margin-top:6px;display:flex;gap:8px;align-items:center;font-size:12px;color:#555;}\n    .dag-btn{padding:6px 12px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;font-size:13px;}\n    .dag-btn:disabled{opacity:0.5;cursor:not-allowed;}\n    #dag-confirm-wrap{margin-top:12px;text-align:center;}\n    #dag-confirm{padding:12px 32px;font-size:16px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;}\n    #dag-confirm:disabled{opacity:0.5;cursor:not-allowed;}\n    #dag-confirm:hover:not(:disabled){background:#f5f5f5;}\n    #dag-right{flex:0 0 350px;width:350px;display:none;padding:16px;background:#f0f7ff;border:1px solid #b3d4fc;border-radius:8px;height:60vh;box-sizing:border-box;overflow-y:auto;}\n    #dag-right.visible{display:block;}\n    #confirm-progress{font-size:12px;color:#666;margin-bottom:8px;}\n    #confirm-question{font-size:16px;line-height:1.5;margin-bottom:16px;}\n    .confirm-btns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;justify-content:center;}\n    .confirm-btns button{padding:8px 16px;font-size:13px;border-radius:6px;cursor:pointer;border:1px solid #aaa;background:#fff;}\n    .confirm-btns button:hover{background:#f5f5f5;}\n    .confirm-btns button:disabled{opacity:0.5;cursor:not-allowed;}\n    .btn-confirm{background:#4CAF50 !important;color:#fff;border-color:#4CAF50 !important;}\n    .btn-confirm:hover:not(:disabled){background:#45a049 !important;}\n    .btn-change{background:#ff9800 !important;color:#fff;border-color:#ff9800 !important;}\n    .btn-change:hover:not(:disabled){background:#f57c00 !important;}\n    #change-options{display:none;margin-top:12px;padding-top:12px;border-top:1px solid #ddd;}\n    #change-options-label{font-size:14px;color:#555;margin-bottom:8px;}\n    .confirm-options{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}\n    .confirm-option{display:flex;align-items:center;gap:8px;padding:10px 12px;border:2px solid #ddd;border-radius:6px;cursor:pointer;background:#fff;transition:all 0.2s;font-size:16px;}\n    .confirm-option:hover{background:#f5f5f5;border-color:#aaa;}\n    .confirm-option.selected{background:#e3f2fd;border-color:#2196F3;}\n    .confirm-option input{margin:0;}\n    .confirm-option label{cursor:pointer;flex:1;}\n    .highlight-edge{stroke:#c00;stroke-width:4;fill:none;pointer-events:none;stroke-dasharray:8 4;}\n    .highlight-node{stroke:#FFD700 !important;stroke-width:4 !important;}\n    #confirm-questions-wrap{display:block;}\n    #confirm-questions-wrap.hidden{display:none;}\n  <\/style>\n  <div id=\"dag-container\">\n    <div id=\"dag-left\">\n      <svg id=\"dag-stage\" viewBox=\"0 0 800 600\"><\/svg>\n      <div id=\"dag-controls\">\n        <button id=\"dag-reset\" class=\"dag-btn\" type=\"button\">Reset<\/button>\n        <span>Drag from a node to another to add an arrow. Double-click an arrow to delete.<\/span>\n      <\/div>\n      <div id=\"dag-confirm-wrap\">\n        <button id=\"dag-confirm\" type=\"button\" disabled>Confirm Choices<\/button>\n      <\/div>\n    <\/div>\n    <div id=\"dag-right\">\n      <div id=\"confirm-questions-wrap\">\n        <div id=\"confirm-progress\"><\/div>\n        <div id=\"confirm-question\"><\/div>\n        <div class=\"confirm-btns\">\n          <button id=\"btn-confirm\" class=\"btn-confirm\">Confirm<\/button>\n          <button id=\"btn-change\" class=\"btn-change\">Change<\/button>\n        <\/div>\n        <div id=\"change-options\">\n          <div id=\"change-options-label\">Select the correct relationship:<\/div>\n          <div id=\"confirm-options\" class=\"confirm-options\"><\/div>\n          <div class=\"confirm-btns\">\n            <button id=\"btn-apply\" class=\"btn-confirm\">Confirm Change<\/button>\n            <button id=\"btn-cancel\" class=\"dag-btn\">Cancel<\/button>\n          <\/div>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  this.hidePreviousButton();\n  this.hideNextButton();\n  var q = this;\n\n  \/\/ ---------- Core state ----------\n  var qc = this.getQuestionContainer();\n  var qt = qc.querySelector('.QuestionText');\n  var svg = document.getElementById('dag-stage');\n  var resetBtn = document.getElementById('dag-reset');\n  var confirmBtn = document.getElementById('dag-confirm');\n  var dagContainer = document.getElementById('dag-container');\n  var dagRight = document.getElementById('dag-right');\n  var confirmQuestionsWrap = document.getElementById('confirm-questions-wrap');\n  var progressEl = document.getElementById('confirm-progress');\n  var questionEl = document.getElementById('confirm-question');\n  var optionsEl = document.getElementById('confirm-options');\n  var changeOptionsDiv = document.getElementById('change-options');\n  var btnConfirm = document.getElementById('btn-confirm');\n  var btnChange = document.getElementById('btn-change');\n  var btnApply = document.getElementById('btn-apply');\n  var btnCancel = document.getElementById('btn-cancel');\n  \n  \/\/ Find the instructions UL in the question text\n  var instructionsUL = qt.querySelector('ul');\n  \n  var PADX = 50, PADY = 35, CORNER = 30;\n  var GAP_LEAVE = 6, GAP_RING = 2, HEAD_LEN = 14;\n\n  var nodes = [\n    { id:'p1',  lines:['${e:\/\/Field\/playerName1}'],  x:200, y:120 },\n    { id:'p2',  lines:['${e:\/\/Field\/playerName2}'], x:600, y:120 },\n    { id:'you', lines:['You', '(chooses first)'],    x:400, y:460 }\n  ];\n  var edges = [];\n  var initialEdges = null; \/\/ Store initial DAG before confirmation\n  var alertCount = 0;\n  var hasAddedEdge = false;\n  var isConfirmed = false;\n  var inConfirmMode = false;\n\n  \/\/ Node display names for confirmation messages\n  var nodeNames = {\n    'p1': '${e:\/\/Field\/playerName1}',\n    'p2': '${e:\/\/Field\/playerName2}',\n    'you': 'You'\n  };\n\n  \/\/ Three pairs of nodes to confirm\n  var nodePairs = [\n    {nodeA: 'p1', nodeB: 'p2'},\n    {nodeA: 'p1', nodeB: 'you'},\n    {nodeA: 'p2', nodeB: 'you'}\n  ];\n\n  var confirmIndex = 0;\n  var selectedOption = null;\n  var currentPairState = null;\n\n  \/\/ ---------- Layers ----------\n  var defs  = el('defs');\n  var gHighlight = el('g');\n  var gNodes= el('g');\n  var gTemp = el('g');\n  var gEdges= el('g');\n  svg.append(defs, gNodes, gTemp, gEdges, gHighlight);\n\n  \/\/ Arrowhead marker (red)\n  var marker = el('marker',{\n    id:'arrowhead', viewBox:'0 0 12 12', refX:12, refY:6,\n    markerWidth:18, markerHeight:18, orient:'auto-start-reverse',\n    markerUnits:'userSpaceOnUse'\n  });\n  marker.appendChild(el('path',{ d:'M 0 0 L 12 6 L 0 12 z', fill:'#c00' }));\n  defs.appendChild(marker);\n\n  \/\/ Red highlight marker for dashed preview arrows\n  var markerHighlight = el('marker',{\n    id:'arrowhead-highlight', viewBox:'0 0 12 12', refX:12, refY:6,\n    markerWidth:18, markerHeight:18, orient:'auto-start-reverse',\n    markerUnits:'userSpaceOnUse'\n  });\n  markerHighlight.appendChild(el('path',{ d:'M 0 0 L 12 6 L 0 12 z', fill:'#c00' }));\n  defs.appendChild(markerHighlight);\n\n  \/\/ Nodes\n  nodes.forEach(function(n){\n    var g = el('g',{ class:'node','data-id':n.id });\n\n    var tg = el('g');\n    n.lines.forEach(function(t,i){\n      tg.appendChild(el('text',{\n        class:'label', x:n.x, y:n.y - (n.lines.length-1)*9 + i*18\n      }, t));\n    });\n    g.appendChild(tg); gNodes.appendChild(g);\n\n    var bb = tg.getBBox(), w=bb.width+2*PADX, h=bb.height+2*PADY;\n    var x = n.x-w\/2, y = n.y-h\/2;\n    var rect = el('rect',{class:'node-box', x:x, y:y, width:w, height:h, rx:CORNER, ry:CORNER});\n    g.insertBefore(rect, tg);\n\n    n.box = {x:x,y:y,w:w,h:h};\n    n.anchorR = Math.min(w,h)\/2 - 2;\n    n.element = g;\n    n.rect = rect;\n  });\n\n  var centroid = { x: avg(nodes.map(function(n){return n.x;})), y: avg(nodes.map(function(n){return n.y;})) };\n\n  \/\/ ---------- Interaction ----------\n  var dragStart=null, dragging=false, tempPath=null;\n\n  gNodes.addEventListener('mousedown', function(e){\n    if(isConfirmed || inConfirmMode) return;\n    var id = nodeAt(e); if(!id) return;\n    dragStart = getNode(id); dragging=true;\n    tempPath = el('path',{class:'edge','marker-end':'url(#arrowhead)',strokeDasharray:'4 4'});\n    gTemp.appendChild(tempPath);\n  });\n\n  svg.addEventListener('mousemove', function(e){\n    if(!dragging||!dragStart||!tempPath) return;\n    var p = svgPoint(e);\n    tempPath.setAttribute('d', curve(dragStart, {x:p.x,y:p.y}, null, 46));\n  });\n\n  svg.addEventListener('mouseup', function(e){\n    if(!dragging) return cleanup();\n    var id = nodeAt(e);\n    if(id && id!==dragStart.id) addEdge(dragStart.id,id);\n    cleanup();\n    persist();\n  });\n\n  gEdges.addEventListener('dblclick', function(e){\n    if(isConfirmed || inConfirmMode) return;\n    var p = e.target.closest('path.edge'); if(!p) return;\n    var key = p.getAttribute('data-key');\n    var i = edges.findIndex(function(ed){return keyOf(ed)===key;});\n    if(i>=0){ edges.splice(i,1); p.remove(); persist(); }\n  });\n\n  resetBtn.addEventListener('click', function(){\n    if(isConfirmed || inConfirmMode) return;\n    edges = [];\n    hasAddedEdge = false;\n    drawEdges();\n    persist();\n  });\n\n  \/\/ ---------- Page Width Control ----------\n  function setPageWide(wide){\n    var skinElements = [\n      '.Skin .SkinInner',\n      '.Skin #SkinContent', \n      '.Skin #Questions',\n      '.Skin .QuestionOuter',\n      '.Skin .QuestionBody',\n      '.Skin .QuestionText'\n    ];\n    \n    var maxWidth = wide ? '1400px' : '';\n    \n    skinElements.forEach(function(selector){\n      var elements = document.querySelectorAll(selector);\n      elements.forEach(function(el){\n        el.style.maxWidth = maxWidth;\n        if(wide){\n          el.style.width = '100%';\n        } else {\n          el.style.width = '';\n        }\n      });\n    });\n  }\n\n  \/\/ ---------- Confirmation Flow ----------\n  confirmBtn.addEventListener('click', function(){\n    startConfirmation();\n  });\n\n  btnConfirm.addEventListener('click', function(){\n    confirmIndex++;\n    showCurrentConfirmation();\n  });\n\n  btnChange.addEventListener('click', function(){\n    showChangeOptions();\n  });\n\n  btnApply.addEventListener('click', function(){\n    if(selectedOption === null) return;\n    applySelectedOption();\n    changeOptionsDiv.style.display = 'none';\n    confirmIndex++;\n    showCurrentConfirmation();\n  });\n\n  btnCancel.addEventListener('click', function(){\n    changeOptionsDiv.style.display = 'none';\n    selectedOption = null;\n    var pair = nodePairs[confirmIndex];\n    highlightPairNodesOnly(pair);\n  });\n\n  function startConfirmation(){\n    confirmIndex = 0;\n    inConfirmMode = true;\n    confirmBtn.disabled = true;\n    resetBtn.disabled = true;\n    \n    \/\/ Save initial DAG before any confirmation changes\n    initialEdges = JSON.parse(JSON.stringify(edges)); \/\/ Deep copy\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    Qualtrics.SurveyEngine.setEmbeddedData('subjDAGInitial_' + id, JSON.stringify(initialEdges));\n    \n    setPageWide(true);\n    \n    if(instructionsUL){\n      instructionsUL.style.display = 'none';\n    }\n    dagContainer.classList.add('with-gap');\n    \n    dagRight.classList.add('visible');\n    confirmQuestionsWrap.classList.remove('hidden');\n    document.getElementById('dag-confirm-wrap').style.display = 'none';\n    \n    showCurrentConfirmation();\n    \n    setTimeout(function(){\n        svg.scrollIntoView({\n            behavior: 'smooth',\n            block: 'center'\n        });\n    }, 100);\n  }\n\n  function getCurrentPairState(pair){\n    var hasAtoB = edges.some(function(e){ return e.source === pair.nodeA && e.target === pair.nodeB; });\n    var hasBtoA = edges.some(function(e){ return e.source === pair.nodeB && e.target === pair.nodeA; });\n    \n    if(hasAtoB && hasBtoA) return 'both';\n    if(hasAtoB) return 'AtoB';\n    if(hasBtoA) return 'BtoA';\n    return 'none';\n  }\n\n  function showCurrentConfirmation(){\n    if(confirmIndex >= nodePairs.length){\n      finishConfirmation();\n      return;\n    }\n\n    selectedOption = null;\n    changeOptionsDiv.style.display = 'none';\n\n    var pair = nodePairs[confirmIndex];\n    currentPairState = getCurrentPairState(pair);\n    var nameA = nodeNames[pair.nodeA];\n    var nameB = nodeNames[pair.nodeB];\n\n    progressEl.textContent = 'Question ' + (confirmIndex + 1) + ' of ' + nodePairs.length;\n    \n    highlightPairNodesOnly(pair);\n\n    var questionText = 'You indicated: <strong>';\n    \n    switch(currentPairState){\n      case 'none':\n        questionText += nameA + ' and ' + nameB + ' cannot influence each other<\/strong> (no arrows).';\n        break;\n      case 'AtoB':\n        questionText += nameA + ' can influence ' + nameB + '<\/strong> (arrow: ' + nameA + ' \u2192 ' + nameB + ').';\n        break;\n      case 'BtoA':\n        questionText += nameB + ' can influence ' + nameA + '<\/strong> (arrow: ' + nameB + ' \u2192 ' + nameA + ').';\n        break;\n      case 'both':\n        questionText += nameA + ' and ' + nameB + ' can influence each other<\/strong> (arrows in both directions).';\n        break;\n    }\n    \n    questionEl.innerHTML = questionText;\n  }\n\n  function showChangeOptions(){\n    var pair = nodePairs[confirmIndex];\n    var nameA = nodeNames[pair.nodeA];\n    var nameB = nodeNames[pair.nodeB];\n\n    optionsEl.innerHTML = '';\n    \n    var allOptions = [\n      { value: 'none', boldPart: nameA + ' and ' + nameB + ' cannot influence each other', normalPart: ' (no arrows)' },\n      { value: 'AtoB', boldPart: nameA + ' can influence ' + nameB, normalPart: ' (arrow: ' + nameA + ' \u2192 ' + nameB + ')' },\n      { value: 'BtoA', boldPart: nameB + ' can influence ' + nameA, normalPart: ' (arrow: ' + nameB + ' \u2192 ' + nameA + ')' },\n      { value: 'both', boldPart: nameA + ' and ' + nameB + ' can influence each other', normalPart: ' (arrows in both directions)' }\n    ];\n\n    var options = allOptions.filter(function(opt){ return opt.value !== currentPairState; });\n\n    selectedOption = null;\n    btnApply.disabled = true;\n\n    options.forEach(function(opt){\n      var div = document.createElement('div');\n      div.className = 'confirm-option';\n      \n      var input = document.createElement('input');\n      input.type = 'radio';\n      input.name = 'change-choice';\n      input.value = opt.value;\n      input.id = 'opt-' + opt.value;\n      \n      var label = document.createElement('label');\n      label.htmlFor = 'opt-' + opt.value;\n      label.innerHTML = '<strong>' + opt.boldPart + '<\/strong>' + opt.normalPart;\n      \n      div.appendChild(input);\n      div.appendChild(label);\n      \n      div.addEventListener('click', function(){\n        document.querySelectorAll('.confirm-option').forEach(function(el){ el.classList.remove('selected'); });\n        div.classList.add('selected');\n        input.checked = true;\n        selectedOption = opt.value;\n        btnApply.disabled = false;\n        \n        highlightPairWithDashedArrows(pair, opt.value);\n      });\n      \n      optionsEl.appendChild(div);\n    });\n\n    changeOptionsDiv.style.display = 'block';\n  }\n\n  function applySelectedOption(){\n    var pair = nodePairs[confirmIndex];\n    \n    if(selectedOption === currentPairState || selectedOption === null) return;\n    \n    edges = edges.filter(function(e){\n      return !((e.source === pair.nodeA && e.target === pair.nodeB) || \n               (e.source === pair.nodeB && e.target === pair.nodeA));\n    });\n    \n    if(selectedOption === 'AtoB' || selectedOption === 'both'){\n      edges.push({source: pair.nodeA, target: pair.nodeB});\n    }\n    if(selectedOption === 'BtoA' || selectedOption === 'both'){\n      edges.push({source: pair.nodeB, target: pair.nodeA});\n    }\n    \n    drawEdges();\n    persist();\n  }\n\n  function highlightPairNodesOnly(pair){\n    clearHighlight();\n    \n    var nodeA = getNode(pair.nodeA);\n    var nodeB = getNode(pair.nodeB);\n    nodeA.rect.classList.add('highlight-node');\n    nodeB.rect.classList.add('highlight-node');\n  }\n\n  function highlightPairWithDashedArrows(pair, state){\n    clearHighlight();\n    \n    var nodeA = getNode(pair.nodeA);\n    var nodeB = getNode(pair.nodeB);\n    nodeA.rect.classList.add('highlight-node');\n    nodeB.rect.classList.add('highlight-node');\n    \n    if(state === 'AtoB' || state === 'both'){\n      var d1 = curve(nodeA, nodeB, dir(nodeA.id, nodeB.id), 54);\n      var path1 = el('path',{\n        class: 'highlight-edge',\n        d: d1,\n        'marker-end': 'url(#arrowhead-highlight)'\n      });\n      gHighlight.appendChild(path1);\n    }\n    \n    if(state === 'BtoA' || state === 'both'){\n      var d2 = curve(nodeB, nodeA, dir(nodeB.id, nodeA.id), 54);\n      var path2 = el('path',{\n        class: 'highlight-edge',\n        d: d2,\n        'marker-end': 'url(#arrowhead-highlight)'\n      });\n      gHighlight.appendChild(path2);\n    }\n  }\n\n  function clearHighlight(){\n    gHighlight.innerHTML = '';\n    nodes.forEach(function(n){\n      n.rect.classList.remove('highlight-node');\n    });\n  }\n\n  function finishConfirmation(){\n    clearHighlight();\n    \n    dagRight.classList.remove('visible');\n    setPageWide(false);\n    dagContainer.classList.remove('with-gap');\n    \n    if(instructionsUL){\n      instructionsUL.style.display = '';\n    }\n    \n    isConfirmed = true;\n    inConfirmMode = false;\n\n    \n    jQuery('.confidence-question').css({\n        'visibility': 'visible',\n        'position': 'relative',\n        'pointer-events': 'auto'\n    });\n    \n    setTimeout(function(){\n        jQuery('.confidence-question')[0].scrollIntoView({\n            behavior: 'smooth',\n            block: 'start'\n        });\n    }, 100);\n    \n    persist();\n  }\n\n  function cleanup(){ dragging=false; dragStart=null; if(tempPath) tempPath.remove(); tempPath=null; }\n\n  function addEdge(s,t){\n    if(isConfirmed || inConfirmMode) return;\n    \n    if(s === 'p1' && t === 'you'){\n      alertCount++;\n      alert(\"Alert #\" + alertCount + \": You did not know the Co-Player's choice when making yours. Hence, the Co-Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n    }\n    if(s === 'p2' && t === 'you'){\n      alertCount++;\n      alert(\"Alert #\" + alertCount + \": You did not know the Bonus Player's choice when making yours. Hence, the Bonus Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n    }\n\n    if(edges.some(function(e){return e.source===s && e.target===t;})) return;\n    edges.push({source:s,target:t}); drawEdges();\n    hasAddedEdge = true;\n  }\n\t\n  function drawEdges(){\n    gEdges.innerHTML='';\n    for(var i=0;i<edges.length;i++){\n      var e = edges[i];\n      var s=getNode(e.source), t=getNode(e.target);\n      var d = curve(s,t, dir(s.id,t.id), 54);\n      gEdges.appendChild(el('path',{class:'edge', d:d, 'marker-end':'url(#arrowhead)', 'data-key':keyOf(e)}));\n    }\n  }\n\n  \/\/ ---------- Geometry ----------\n  function curve(src, tgt, dirType, offset){\n    var sx=src.x, sy=src.y;\n    var tx=('x' in tgt)?tgt.x:getNode(tgt).x;\n    var ty=('y' in tgt)?tgt.y:getNode(tgt).y;\n\n    var theta = Math.atan2(ty-sy, tx-sx);\n    var start = {\n      x: sx + Math.cos(theta) * (src.anchorR + GAP_LEAVE),\n      y: sy + Math.sin(theta) * (src.anchorR + GAP_LEAVE)\n    };\n\n    var end;\n    if('x' in tgt){\n      end = {x:tx,y:ty};\n    } else {\n      var tn = getNode(tgt);\n      var tip = {\n        x: tn.x + Math.cos(theta+Math.PI) * (tn.anchorR - GAP_RING),\n        y: tn.y + Math.sin(theta+Math.PI) * (tn.anchorR - GAP_RING)\n      };\n      var ux = Math.cos(theta+Math.PI), uy = Math.sin(theta+Math.PI);\n      var sep = 6, tanx = -uy, tany = ux, sgn = (src.id < tn.id)?1:-1;\n      end = { x: tip.x - ux*HEAD_LEN + tanx*sep*sgn,\n              y: tip.y - uy*HEAD_LEN + tany*sep*sgn };\n    }\n\n    var dx=end.x-start.x, dy=end.y-start.y, L=Math.hypot(dx,dy)||1;\n    var mx=(start.x+end.x)\/2, my=(start.y+end.y)\/2;\n    var nx=-dy\/L, ny=dx\/L;\n    var outward = ((mx-centroid.x)*nx + (my-centroid.y)*ny) > 0 ? 1 : -1;\n    var sign = dirType==='ccw' ? -outward : outward;\n\n    var cx = mx + nx*offset*sign;\n    var cy = my + ny*offset*sign;\n    return 'M '+start.x+' '+start.y+' Q '+cx+' '+cy+' '+end.x+' '+end.y;\n  }\n\n  function dir(s,t){\n    var o=['p1','p2','you']; var i=o.indexOf(s), j=o.indexOf(t);\n    return ((i+1)%3===j)?'cw':'ccw';\n  }\n\n  function nodeAt(e){\n    var p = svgPoint(e);\n    var n = nodes.find(function(n){\n      return p.x>=n.box.x && p.x<=n.box.x+n.box.w && p.y>=n.box.y && p.y<=n.box.y+n.box.h;\n    });\n    return n ? n.id : null;\n  }\n\n  \/\/ ---------- Utils ----------\n  function el(tag, attrs, text){\n    if(!attrs) attrs={};\n    var E = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', tag);\n    Object.keys(attrs).forEach(function(k){ E.setAttribute(k, attrs[k]); });\n    if(text!=null) E.textContent = text;\n    return E;\n  }\n  function getNode(id){ return nodes.find(function(n){return n.id===id;}); }\n  function keyOf(e){ return e.source+'->'+e.target; }\n  function avg(a){ return a.reduce(function(s,v){return s+v;},0)\/a.length; }\n  function svgPoint(e){ var p=svg.createSVGPoint(); p.x=e.clientX; p.y=e.clientY; return p.matrixTransform(svg.getScreenCTM().inverse()); }\n\n  \/\/ ---------- Persist + Next gating ----------\n  function persist(){\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id'); \n    Qualtrics.SurveyEngine.setEmbeddedData('subjDAG1_' + id, JSON.stringify(edges));\n    Qualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount1_' + id, alertCount);\n    updateButtonStates();\n  }\n\n  function updateButtonStates(){\n    confirmBtn.disabled = !hasAddedEdge || isConfirmed || inConfirmMode;\n    resetBtn.disabled = isConfirmed || inConfirmMode;\n  }\n\n  updateButtonStates();\n\n  Qualtrics.SurveyEngine.addOnUnload(persist);\n  var nb = document.getElementById('NextButton');\n  if (nb) nb.addEventListener('click', persist, {capture:true});\n\n  drawEdges();\n  persist();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please indicate below who you think had an influence on whom in game Game...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span><\/strong><\/div>\n<ul>\n\t<li>Please draw arrows between the three players below. An arrow from one player to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a player, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.<\/li>\n<\/ul>\n\n<div id=\"dag-wrap\">\n  <style>\n    #dag-wrap{font-family:system-ui,Arial,sans-serif;}\n    #dag-container{display:flex;gap:20px;align-items:flex-start;justify-content:center;}\n    #dag-container.with-gap{margin-top:20px;}\n    #dag-left{flex:0 0 auto;}\n    #dag-stage{width:100%;height:60vh;background:#f7f7f7;border:1px solid #ddd;border-radius:8px;}\n    .label{font-size:20px;text-anchor:middle;dominant-baseline:middle;pointer-events:none;}\n    .edge{stroke:#c00;stroke-width:2.5;fill:none;cursor:pointer;pointer-events:stroke;}\n    .node-box{fill:#fff;stroke:#222;stroke-width:2;}\n    #dag-controls{margin-top:6px;display:flex;gap:8px;align-items:center;font-size:12px;color:#555;}\n    .dag-btn{padding:6px 12px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;font-size:13px;}\n    .dag-btn:disabled{opacity:0.5;cursor:not-allowed;}\n    #dag-confirm-wrap{margin-top:12px;text-align:center;}\n    #dag-confirm{padding:12px 32px;font-size:16px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;}\n    #dag-confirm:disabled{opacity:0.5;cursor:not-allowed;}\n    #dag-confirm:hover:not(:disabled){background:#f5f5f5;}\n    #dag-right{flex:0 0 350px;width:350px;display:none;padding:16px;background:#f0f7ff;border:1px solid #b3d4fc;border-radius:8px;height:60vh;box-sizing:border-box;overflow-y:auto;}\n    #dag-right.visible{display:block;}\n    #confirm-progress{font-size:12px;color:#666;margin-bottom:8px;}\n    #confirm-question{font-size:16px;line-height:1.5;margin-bottom:16px;}\n    .confirm-btns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;justify-content:center;}\n    .confirm-btns button{padding:8px 16px;font-size:13px;border-radius:6px;cursor:pointer;border:1px solid #aaa;background:#fff;}\n    .confirm-btns button:hover{background:#f5f5f5;}\n    .confirm-btns button:disabled{opacity:0.5;cursor:not-allowed;}\n    .btn-confirm{background:#4CAF50 !important;color:#fff;border-color:#4CAF50 !important;}\n    .btn-confirm:hover:not(:disabled){background:#45a049 !important;}\n    .btn-change{background:#ff9800 !important;color:#fff;border-color:#ff9800 !important;}\n    .btn-change:hover:not(:disabled){background:#f57c00 !important;}\n    #change-options{display:none;margin-top:12px;padding-top:12px;border-top:1px solid #ddd;}\n    #change-options-label{font-size:14px;color:#555;margin-bottom:8px;}\n    .confirm-options{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}\n    .confirm-option{display:flex;align-items:center;gap:8px;padding:10px 12px;border:2px solid #ddd;border-radius:6px;cursor:pointer;background:#fff;transition:all 0.2s;font-size:16px;}\n    .confirm-option:hover{background:#f5f5f5;border-color:#aaa;}\n    .confirm-option.selected{background:#e3f2fd;border-color:#2196F3;}\n    .confirm-option input{margin:0;}\n    .confirm-option label{cursor:pointer;flex:1;}\n    .highlight-edge{stroke:#c00;stroke-width:4;fill:none;pointer-events:none;stroke-dasharray:8 4;}\n    .highlight-node{stroke:#FFD700 !important;stroke-width:4 !important;}\n    #confirm-questions-wrap{display:block;}\n    #confirm-questions-wrap.hidden{display:none;}\n  <\/style>\n  <div id=\"dag-container\">\n    <div id=\"dag-left\">\n      <svg id=\"dag-stage\" viewBox=\"0 0 800 600\"><\/svg>\n      <div id=\"dag-controls\">\n        <button id=\"dag-reset\" class=\"dag-btn\" type=\"button\">Reset<\/button>\n        <span>Drag from a node to another to add an arrow. Double-click an arrow to delete.<\/span>\n      <\/div>\n      <div id=\"dag-confirm-wrap\">\n        <button id=\"dag-confirm\" type=\"button\" disabled>Confirm Choices<\/button>\n      <\/div>\n    <\/div>\n    <div id=\"dag-right\">\n      <div id=\"confirm-questions-wrap\">\n        <div id=\"confirm-progress\"><\/div>\n        <div id=\"confirm-question\"><\/div>\n        <div class=\"confirm-btns\">\n          <button id=\"btn-confirm\" class=\"btn-confirm\">Confirm<\/button>\n          <button id=\"btn-change\" class=\"btn-change\">Change<\/button>\n        <\/div>\n        <div id=\"change-options\">\n          <div id=\"change-options-label\">Select the correct relationship:<\/div>\n          <div id=\"confirm-options\" class=\"confirm-options\"><\/div>\n          <div class=\"confirm-btns\">\n            <button id=\"btn-apply\" class=\"btn-confirm\">Confirm Change<\/button>\n            <button id=\"btn-cancel\" class=\"dag-btn\">Cancel<\/button>\n          <\/div>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","DataExportTag":"Q505","QuestionID":"QID505"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID506","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"&nbsp;","DataExportTag":"Q506","QuestionID":"QID506"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID507","SecondaryAttribute":"How confident are you in your diagram? That is, what is the chance it correctly shows who can inf...","TertiaryAttribute":null,"Payload":{"QuestionText":"<script>\nfunction toggleDetails(btn) {\n    var content = document.getElementById('detailsContent');\n    if (content.style.display === 'none' || content.style.display === '') {\n        content.style.display = 'block';\n        btn.textContent = 'Hide details';\n    } else {\n        content.style.display = 'none';\n        btn.textContent = 'Show details';\n    }\n}\n<\/script>\n\n<p><b>\nHow confident are you in your diagram? That is, what is the chance it correctly shows who can influence whom?<\/b>  \n<\/p>\n<p style=\"font-size: 12pt\">The payment mechanism is set up such that you will earn the most by answering truthfully. <button onclick=\"toggleDetails(this)\" class=\"show-details-btn\">\n    Show details\n<\/button>\n<\/p>\n<div class=\"details-content\" id=\"detailsContent\" style=\"display: none;\">\n  <p>\n  Here's how the payment system works:\n  <\/p>\n  <ol>\n    <li>After you enter your confidence, we will randomly draw a number <b>X<\/b> between 0 and 100.<\/li>\n    <li>If your stated confidence is <b>greater than X%<\/b>:\n      <ul>\n        <li>You will receive a <b>${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus<\/b> if the \"who influences whom\" relationship you provided in the previous question is correct.<\/li>\n      <\/ul>\n    <\/li>\n    <li>If your stated confidence is <b>less than X<\/b>:\n      <ul>\n        <li>You will have a <b>X% chance<\/b> of receiving the ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus, regardless of whether your answer was correct.<\/li>\n      <\/ul>\n    <\/li>\n  <\/ol>\n  <p>\n  This setup ensures that <b>you maximize your expected payment by reporting your true confidence<\/b>.  \n  Overstating or understating your confidence will only reduce your chance of earning the bonus. Hence, it is in your own best interest to state what you truly think. \n  <\/p>\n\t<br>\n<\/div>\n\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    jQuery(\"#\"+this.questionId).closest('.QuestionOuter')\n        .addClass('confidence-question')\n        .css({\n            'visibility': 'hidden',\n            'position': 'absolute',\n            'pointer-events': 'none'\n        });\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;  \/\/ Capture Qualtrics context HERE, at the top\n    \n    this.hideNextButton();\n    jQuery(\"#\"+this.questionId+\" .numbers li\").each(function(){\n        jQuery(this).text((jQuery(this).text()+\"%\").trim().replace(\" \",\"\"));\n    });\n    \n    var q = jQuery(\"#\"+this.questionId);\n    q.find(\".handle\").css('visibility', 'hidden');\n    q.find(\".track\").css('cursor', 'pointer');\n    \n    q.find(\".track\").on(\"click touchstart\", function() {\n        jQuery(this).find(\".handle\").css('visibility', 'visible');\n        jQuery('#continue-btn-wrap').fadeIn(400);\n    });\n    \n    for (var i = 0; i <= 100; i += 10) {\n        var percentage = i + \"%\";\n        jQuery(\"#\" + this.questionId + \" .numbers li:eq(\" + (i \/ 10) + \")\").html(percentage);\n    }\n    \n    \/\/ Continue button clicks the hidden Next button\n    jQuery('#continue-game-btn').on('click', function(){\n        const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n        var answer = that.getChoiceValue(1);  \/\/ 'that' now correctly refers to Qualtrics question\n        Qualtrics.SurveyEngine.setEmbeddedData(\"confidenceDAG1_\" + id, answer);\n        console.log('confidenceDAG1_' + id + ':', answer);\n        jQuery('#NextButton').click();\n    });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you in your diagram? That is, what is the chance it correctly shows who can inf...","Choices":{"1":{"Display":"&nbsp;"}},"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"<script>\nfunction toggleDetails(btn) {\n    var content = document.getElementById('detailsContent');\n    if (content.style.display === 'none' || content.style.display === '') {\n        content.style.display = 'block';\n        btn.textContent = 'Hide details';\n    } else {\n        content.style.display = 'none';\n        btn.textContent = 'Show details';\n    }\n}\n<\/script>\n\n<p><b>\nHow confident are you in your diagram? That is, what is the chance it correctly shows who can influence whom?<\/b>  \n<\/p>\n<p style=\"font-size: 12pt\">The payment mechanism is set up such that you will earn the most by answering truthfully. <button onclick=\"toggleDetails(this)\" class=\"show-details-btn\">\n    Show details\n<\/button>\n<\/p>\n<div class=\"details-content\" id=\"detailsContent\" style=\"display: none;\">\n  <p>\n  Here's how the payment system works:\n  <\/p>\n  <ol>\n    <li>After you enter your confidence, we will randomly draw a number <b>X<\/b> between 0 and 100.<\/li>\n    <li>If your stated confidence is <b>greater than X%<\/b>:\n      <ul>\n        <li>You will receive a <b>${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus<\/b> if the \"who influences whom\" relationship you provided in the previous question is correct.<\/li>\n      <\/ul>\n    <\/li>\n    <li>If your stated confidence is <b>less than X<\/b>:\n      <ul>\n        <li>You will have a <b>X% chance<\/b> of receiving the ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus, regardless of whether your answer was correct.<\/li>\n      <\/ul>\n    <\/li>\n  <\/ol>\n  <p>\n  This setup ensures that <b>you maximize your expected payment by reporting your true confidence<\/b>.  \n  Overstating or understating your confidence will only reduce your chance of earning the bonus. Hence, it is in your own best interest to state what you truly think. \n  <\/p>\n\t<br>\n<\/div>\n\n","DataExportTag":"Q507","QuestionID":"QID507"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID508","SecondaryAttribute":"Continue to the game","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"continue-btn-wrap\" style=\"display: none; text-align: center; margin-top: 20px;\">\n  <button id=\"continue-game-btn\" style=\"padding: 12px 32px; font-size: 16px; cursor: pointer; border: 1px solid #aaa; border-radius: 6px; background: #4CAF50; color: white;\">\n    Continue to the game\n  <\/button>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Continue to the game","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<div id=\"continue-btn-wrap\" style=\"display: none; text-align: center; margin-top: 20px;\">\n  <button id=\"continue-game-btn\" style=\"padding: 12px 32px; font-size: 16px; cursor: pointer; border: 1px solid #aaa; border-radius: 6px; background: #4CAF50; color: white;\">\n    Continue to the game\n  <\/button>\n<\/div>","DataExportTag":"Q508","QuestionID":"QID508"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID509","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Validation":"None","GradingData":[],"Language":[],"NextChoiceId":16,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q509","QuestionID":"QID509"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"You can now press Ann's button (and must press yours)! In the next ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong style=\"color:inherit;\" id=\"clickableWord\">You can now press Ann's button (and must press yours)!<\/strong><\/span><\/div>\n<br>\nIn the next ${e:\/\/Field\/nRoundsCausalBeliefs} rounds, you will play the same version of the game as before. However, there are two important changes:\n<ol>\n\t<li><u>You must&nbsp;press your button.<\/u><\/li>\n\t<li><u>You will choose whether to press Ann's button.<\/u>&nbsp;You&nbsp;will receive a bonus of $${e:\/\/Field\/win} if <b>Bob<\/b> presses his button.<\/li>\n<\/ol>\nThe cost of pressing Ann's button will change from round to round. Sometimes, pressing the button is costly. Other times, not pressing it is costly. Your decision will not affect the cost in future rounds.<br>\n<br>\nWhile Bob's choice determines your bonus if one of these rounds is chosen for payment, you will not see his choice. Only at the end, if one of these rounds determines your payoff, will you find out what Bob chose in that round.","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst chartData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconsole.log(chartData);\n\tconst test = chartData.causalElicit\n\tconsole.log(test);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"instructionXY","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can now press Ann's button (and must press yours)! In the next ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID51"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID510","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DataExportTag":"Q510","QuestionID":"QID510"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID511","SecondaryAttribute":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n\n <div class=\"panel-wrapper\">\n\n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n\n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hidePreviousButton();\n    this.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\tjQuery(\"#NextButton\").hide();\n    \n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n   \n\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n\tconst buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\tconst linkfn = Qualtrics.SurveyEngine.getEmbeddedData('linkfn');\n\tconst basePay = parseFloat(\"${e:\/\/Field\/basePay}\");\n\n\t\/\/ Determine panel order and configure content\n\tconst isYFirst = order === \"AYX\";\n\n\tlet roundCounter    = parseInt(\"${e:\/\/Field\/roundCounter}\");\n\tlet X, A, Y;\n\tlet history         = [];\n\tlet roundTimes      = [];\n\tlet payment         = [];\n\tlet roundStartTime  = 0;\n    let firstPanelStartTime = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n\tlet xReady          = false;\n\tlet colorDisplayed  = false;\n\n\tconst btnNo        = document.getElementById(\"btnNo\");\n\tconst btnYes       = document.getElementById(\"btnYes\");\n\tconst panelXinfo   = document.getElementById(\"panelXinfo\");\n\tconst panelYinfo   = document.getElementById(\"panelYinfo\");\n\tconst panelAchoice = document.getElementById(\"panelAchoice\");\n\tconst resultText   = document.getElementById(\"resultText\");\n\tconst riskText     = document.getElementById(\"riskText\");\n\tconst roundDisplay = document.getElementById(\"roundDisplay\");\n\tconst actionPrompt = document.getElementById(\"actionPrompt\"); \n\n\t\/\/ Set up first and second panels based on order\n\tconst firstPanel = isYFirst ? panelYinfo : panelXinfo;\n\tconst secondPanel = isYFirst ? panelXinfo : panelYinfo;\n\tconst firstPanelText = isYFirst ? resultText : riskText;\n\tconst secondPanelText = isYFirst ? riskText : resultText;\n\n\t\/\/ Function to get panel content\n\tfunction getPanelContent(panelType, value, isPlayerChoice) {\n\t\tif (panelType === 'X') {\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value \n\t\t\t\t\t? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t};\n\t\t} else { \/\/ Y panel\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value\n\t\t\t\t\t? \"${e:\/\/Field\/playerName2} pressed ${e:\/\/Field\/playerPronoun2} button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!).\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).\"\n\t\t\t};\n\t\t}\n\t}\n\n\t\/\/ Swap visual order if needed\n\tif (isYFirst) {\n\t\tconst parent = panelXinfo.parentNode;\n\t\tparent.insertBefore(panelYinfo, panelXinfo);\n\t}\n    \n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\n    [panelAchoice, panelXinfo, panelYinfo].forEach(p => p.style.border = \"1px solid black\");\n\n    btnYes.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('y');\n        }\n    });\n    btnNo.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('n');\n        }\n    });\n    \n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    const causal = parseInt(\"${e:\/\/Field\/causal}\");\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst sigma0 = parseFloat(\"${e:\/\/Field\/sigma0}\");\n\tconst sigma1 = parseFloat(\"${e:\/\/Field\/sigma1}\");\n\tconst rho0 = parseFloat(\"${e:\/\/Field\/rho0}\");\n\tconst rho1 = parseFloat(\"${e:\/\/Field\/rho1}\");\n\tconst beta00 = parseFloat(\"${e:\/\/Field\/beta00}\");\n\tconst beta01 = parseFloat(\"${e:\/\/Field\/beta01}\");\n\tconst beta10 = parseFloat(\"${e:\/\/Field\/beta10}\");\n\tconst beta11 = parseFloat(\"${e:\/\/Field\/beta11}\");\n    function handleDecision(decision) {\n        if (!panelAchoice || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tlet pX = [0, 0, 0, 0];\n        A = decision === 'y' ? 1 : 0;\n        if (causal === 0) {\n\t\t\tpX = [beta00, beta01, beta10, beta11];\n\t\t\tY = Math.random() < pY ? 1 : 0;\n\t\t\tX = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            \n        } else {\n            const pX = [sigma0, sigma1];\n            const pY = [rho0, rho1];\n            X = Math.random() < pX[A] ? 1 : 0;\n            Y = Math.random() < pY[X] ? 1 : 0;\n        }\n\n        history.push([A, X, Y]);\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        payment.push(-aCost*A + yBonus*Y + basePay);\n\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n            \/\/ Show first panel\n            const firstPanelType = isYFirst ? 'Y' : 'X';\n            const firstValue = isYFirst ? Y : X;\n            const content = getPanelContent(firstPanelType, firstValue, isPlayerChoiceRound);\n\n            firstPanel.style.backgroundColor = content.color;\n            firstPanelText.innerHTML = content.text + \" <br>(press 'c' to continue)\";\n            secondPanel.style.backgroundColor = \"white\";\n            xReady = true;\n            firstPanelStartTime = Date.now(); \/\/ ADD THIS LINE\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        const yesVisible = btnYes.style.display !== \"none\" && !btnYes.disabled;\n        const noVisible = btnNo.style.display !== \"none\" && !btnNo.disabled;\n        \n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound) {\n            if (e.key === 'y' && yesVisible) {\n                handleDecision('y');\n            }\n            else if (e.key === 'n' && noVisible) {\n                handleDecision('n');\n            }\n        }\n        \n        \/\/ Continue key always works regardless of round type\n        if (e.key === 'c' && xReady) {\n            const firstTimeRemaining = (firstPanelStartTime + 500) - Date.now();\n            \n            if (firstTimeRemaining > 0) {\n                setTimeout(() => {\n                    showSecondPanel();\n                }, firstTimeRemaining);\n            } else {\n                showSecondPanel();\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tresultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function showSecondPanel() {\n    const currentRoundIndex = roundCounter - 1;\n    const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n    \/\/ Show second panel\n    const secondPanelType = isYFirst ? 'X' : 'Y';\n    const secondValue = isYFirst ? X : Y;\n    const content = getPanelContent(secondPanelType, secondValue, isPlayerChoiceRound);\n\n    secondPanel.style.backgroundColor = content.color;\n    secondPanelText.innerHTML = content.text + \" <br>(press 'space' to continue)\";\n    xReady = false;\n    colorDisplayed = true;\n    resultPanelStartTime = Date.now();\n}\n\n    function initiateRound() {\n        panelAchoice.style.display =\n        panelXinfo.style.display =\n        panelYinfo.style.display = \"none\";\n        setTimeout(() => {\n            showActionPanels();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history2_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes2_' + id, JSON.stringify(roundTimes));\n        Qualtrics.SurveyEngine.setEmbeddedData('payment2_' + id, JSON.stringify(payment));\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === nRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n            \n            jQuery(\"#NextButton\").click();\n        }\n    }\n\n    function showActionPanels() {\n        panelAchoice.style.display = \"flex\";\n        panelXinfo.style.display   = \"flex\";\n        panelYinfo.style.display   = \"flex\";\n        panelXinfo.style.backgroundColor =\n        panelYinfo.style.backgroundColor = \"white\";\n        riskText.textContent = resultText.textContent = \"\";\n\n        const showBothButtons = treatment === \"endog\" ? 1 : buttonConfig[roundCounter - 1];\n        \n        if (showBothButtons === 1) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            \n            if (Math.random() < pA) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = \"You must press \\\"Yes\\\" in this round. <br> Press your button? (Use your mouse)\";\n            } else {\n                \/\/ Force No\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = \"You must press \\\"No\\\" in this round. <br> Press your button? (Use your mouse)\";\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n\n <div class=\"panel-wrapper\">\n\n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n\n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n    <\/div>\n<\/body>","DataExportTag":"Q511","QuestionID":"QID511"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID512","SecondaryAttribute":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: 0px; text-align: center;\"><span style=\"font-size:13px;\">You can press &quot;n&quot; on your keyboard to select the No button and &quot;y&quot; to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: 0px; text-align: center;\"><span style=\"font-size:13px;\">You can press &quot;n&quot; on your keyboard to select the No button and &quot;y&quot; to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DataExportTag":"Q512","QuestionID":"QID512"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID513","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":64,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q513","QuestionID":"QID513"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID514","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\tvar history = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('history_' + id));\n\tvar roundTimes = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('roundTimes_' + id));\n\tvar payment = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('payment_' + id));\n\tvar buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\n\tbuttonConfig = buttonConfig.map(x => parseInt(x));\n\t\n\t\n\tif (treatment === \"exo\") {\n\t\thistory = history.filter((row, index) => buttonConfig[index] === 0);\n\t\tconsole.log('Filtered history for exo treatment:', history);\n\t}\n\t\n\t\/\/ Filter by A value\n\tvar a0Cases = history.filter(row => row[0] === 0);\n\tvar a1Cases = history.filter(row => row[0] === 1);\n\t\n\t\/\/ Calculate conditional probabilities\n\tvar dieterSameNo = a0Cases.filter(row => row[1] === row[2]).length \/ a0Cases.length;\n\tvar dieterSameYes = a1Cases.filter(row => row[1] === row[2]).length \/ a1Cases.length;\n\t\n\t\/\/ Calculate marginal probabilities\n\tvar dieterPA = history.filter(row => row[0] === 1).length \/ history.length;\n\tvar dieterPX = history.filter(row => row[1] === 1).length \/ history.length;\n\tvar dieterPY = history.filter(row => row[2] === 1).length \/ history.length;\n\t\n\t\/\/ Count all 8 combinations of AXY (lowercase = 0, uppercase = 1)\n\tvar count_axy = history.filter(row => row[0] === 0 && row[1] === 0 && row[2] === 0).length;\n\tvar count_axY = history.filter(row => row[0] === 0 && row[1] === 0 && row[2] === 1).length;\n\tvar count_aXy = history.filter(row => row[0] === 0 && row[1] === 1 && row[2] === 0).length;\n\tvar count_aXY = history.filter(row => row[0] === 0 && row[1] === 1 && row[2] === 1).length;\n\tvar count_Axy = history.filter(row => row[0] === 1 && row[1] === 0 && row[2] === 0).length;\n\tvar count_AxY = history.filter(row => row[0] === 1 && row[1] === 0 && row[2] === 1).length;\n\tvar count_AXy = history.filter(row => row[0] === 1 && row[1] === 1 && row[2] === 0).length;\n\tvar count_AXY = history.filter(row => row[0] === 1 && row[1] === 1 && row[2] === 1).length;\n\t\n\t\/\/ Calculate conditional probabilities for effects\n\tvar pY_A = (count_AxY + count_AXY) \/ (count_Axy + count_AxY + count_AXy + count_AXY);\n\tvar pY_a = (count_axY + count_aXY) \/ (count_axy + count_axY + count_aXy + count_aXY);\n\t\n\tvar pY_X = (count_AXY + count_aXY) \/ (count_AXy + count_AXY + count_aXy + count_aXY);\n\tvar pY_x = (count_AxY + count_axY) \/ (count_Axy + count_AxY + count_axy + count_axY);\n\t\n\tvar pX_A = (count_AXy + count_AXY) \/ (count_Axy + count_AxY + count_AXy + count_AXY);\n\tvar pX_a = (count_aXy + count_aXY) \/ (count_axy + count_axY + count_aXy + count_aXY);\n\t\n\t\/\/ Conditional probabilities: P(Y | A, X)\n\tvar pY_Ax = count_AxY \/ (count_Axy + count_AxY);  \/\/ P(Y | A, x)\n\tvar pY_ax = count_axY \/ (count_axy + count_axY);  \/\/ P(Y | a, x)\n\tvar pY_AX = count_AXY \/ (count_AXy + count_AXY);  \/\/ P(Y | A, X)\n\tvar pY_aX = count_aXY \/ (count_aXy + count_aXY);  \/\/ P(Y | a, X)\n\n\t\/\/ Conditional probabilities: P(X | A, Y)\n\tvar pX_AY = count_AXY \/ (count_AXY + count_AxY);  \/\/ P(X | A, Y)\n\tvar pX_Ay = count_AXy \/ (count_AXy + count_Axy);  \/\/ P(X | A, y)\n\tvar pX_aY = count_aXY \/ (count_aXY + count_axY);  \/\/ P(X | a, Y)\n\tvar pX_ay = count_aXy \/ (count_aXy + count_axy);  \/\/ P(X | a, y)\n\n\t\n\tvar pNo_AY = pY_a;\n\tvar pYes_AY = pY_A;\n\tvar pNo_AY0 = pY_a;\n\tvar pYes_AY0 = pY_A;\n\tvar pNo_AY1 = pY_a;\n\tvar pYes_AY1 = pY_A;\n\tvar pNo_AX = pX_a;\n\tvar pYes_AX = pY_A;\n\tvar pNo_AX0 = pX_ay;\n\tvar pYes_AX0 = pX_Ay;\n\tvar pNo_AX1 = pX_aY;\n\tvar pYes_AX1 = pX_AY;\n\tvar pNo_XY0 = pY_a;\n\tvar pYes_XY0 = pY_a;\n\tvar pNo_XY1 = pY_A;\n\tvar pYes_XY1 = pY_A;\n\tvar pNo_YX0 = pX_ay;\n\tvar pYes_YX0 = pX_aY;\n\tvar pNo_YX1 = pX_Ay;\n\tvar pYes_YX1 = pX_AY;\n\t\n\tif (causal == 1){\n\t\tvar pNo_AY0 = pY_ax;\n\t\tvar pYes_AY0 = pY_Ax;\n\t\tvar pNo_AY1 = pY_aX;\n\t\tvar pYes_AY1 = pY_AX;\n\t\tvar pNo_AX0 = pX_a;\n\t\tvar pYes_AX0 = pX_A;\n\t\tvar pNo_AX1 = pX_a;\n\t\tvar pYes_AX1 = pX_A;\t\n\t\tvar pNo_XY0 = pY_ax;\n\t\tvar pYes_XY0 = pY_aX;\n\t\tvar pNo_XY1 = pY_Ax;\n\t\tvar pYes_XY1 = pY_AX;\n\t\tvar pNo_YX0 = pX_a;\n\t\tvar pYes_YX0 = pX_a;\n\t\tvar pNo_YX1 = pX_A;\n\t\tvar pYes_YX1 = pX_A;\n\t\t\n\t}\n\t\n\t\n\t\/\/ Save as JSON string \n\tvar results = {\n\t\t\"dieterSameNo\": dieterSameNo * 100,\n\t\t\"dieterSameYes\": dieterSameYes * 100,\n\t\t\"dieterPA\": dieterPA * 100,\n\t\t\"dieterPX\": dieterPX * 100,\n\t\t\"dieterPY\": dieterPY * 100,\n\t\t\n\t\t\"causal_AY\": (pYes_AY - pNo_AY) * 100,\n\t\t\"causal_AY0\": (pYes_AY0 - pNo_AY0) * 100,\n\t\t\"causal_AY1\": (pYes_AY1 - pNo_AY1) * 100,\n\t\t\"causal_AX\": (pYes_AX - pNo_AX) * 100,\n\t\t\"causal_AX0\": (pYes_AX0 - pNo_AX0) * 100,\n\t\t\"causal_AX1\": (pYes_AX1 - pNo_AX1) * 100,\n\t\t\"causal_XY0\": (pYes_XY0 - pNo_XY0) * 100,\n\t\t\"causal_XY1\": (pYes_XY1 - pNo_XY1) * 100,\n\t\t\"causal_YX1\": (pYes_YX1 - pNo_YX1) * 100,\n\t\t\"causal_YX0\": (pYes_YX0 - pNo_YX0) * 100,\n\n\t\t\"pNo_AY\": pNo_AY * 100,\n\t\t\"pNo_AY0\": pNo_AY0 * 100,\n\t\t\"pNo_AY1\": pNo_AY1 * 100,\n\t\t\"pNo_AX\": pNo_AX * 100,\n\t\t\"pNo_AX1\": pNo_AX1 * 100,\n\t\t\"pNo_AX0\": pNo_AX0 * 100,\n\t\t\"pNo_XY1\": pNo_XY1 * 100,\n\t\t\"pNo_XY0\": pNo_XY0 * 100,\n\t\t\"pNo_YX1\": pNo_YX1 * 100,\n\t\t\"pNo_YX0\": pNo_YX0 * 100,\n\n\t\t\"pYes_AY\": pYes_AY * 100,\n\t\t\"pYes_AY0\": pYes_AY0 * 100,\n\t\t\"pYes_AY1\": pYes_AY1 * 100,\n\t\t\"pYes_AX\": pYes_AX * 100,\n\t\t\"pYes_AX1\": pYes_AX1 * 100,\n\t\t\"pYes_AX0\": pYes_AX0 * 100,\n\t\t\"pYes_XY1\": pYes_XY1 * 100,\n\t\t\"pYes_XY0\": pYes_XY0 * 100,\n\t\t\"pYes_YX1\": pYes_YX1 * 100,\n\t\t\"pYes_YX0\": pYes_YX0 * 100,\n\t\t\n\t};\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('rationalInference_' + id, JSON.stringify(results));\n\tconsole.log(results);\n\tconsole.log(history);\n\tconsole.log(roundTimes);\n\tconsole.log(payment);\n\t\n\tjQuery(\"#NextButton\").click();\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm