ages":"default","Type":"InsufficientDetail"},{"Messages":"default","Type":"Gibberish"}]}}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"lab","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">lab<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"tInstructions2","QuestionID":"QID24","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID244","SecondaryAttribute":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong>This is the end of this study<\/strong><\/span><br>\n<br>\nThank you for your participation!<br>\n<br>\nFrom your choices and luck, calculated exactly as stated in the instructions, you earn ${e:\/\/Field\/currency}${e:\/\/Field\/bonusPayment}. In addition, you receive the completion payment of&nbsp;${e:\/\/Field\/currency}${e:\/\/Field\/basePay}. This yields a total pay of<br>\n<br>\n<span style=\"font-size:32px;\"><strong>${e:\/\/Field\/currency}&nbsp;${e:\/\/Field\/payoff}<\/strong><\/span><br>\n<br>\n<em>Please raise your hand. Somebody from the experiment team will come by and help you with your payment.&nbsp;<\/em><\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function ()\n{\n\t\/\/hides the next button on a page\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    var shown   = true,\n        $body   = jQuery('body'),\n        $stored = $body.children();          \/\/ keep original content in memory\n\n    jQuery(document).on('keydown.toggleWhite', function (e) {\n        if (e.keyCode === 32) {              \/\/ space bar\n            e.preventDefault();\n            if (shown) {\n                $stored.detach();            \/\/ hide everything\n                $body.css('background', '#fff');\n            } else {\n                $body.append($stored).css('background', ''); \/\/ restore\n            }\n            shown = !shown;\n        }\n    });\n});","DefaultChoices":false,"DataExportTag":"Q237","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID244","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"lab","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">lab<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID245","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q238","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2000,"MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":52,"NextAnswerId":1,"QuestionID":"QID245"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID246","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q239","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID246","SubSelector":"WTXB","Graphics":"IM_6hYnntshUHXDGlM","GraphicsDescription":"Migraines"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID247","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q240","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswer