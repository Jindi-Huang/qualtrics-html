ing of a game, and will stay fixed for all ${e:\/\/Field\/nRounds} rounds of that game. The next game may be the same or a different version.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID555\/SelectableChoice\/3","LogicType":"Question","Operator":"Selected","QuestionID":"QID555","QuestionIDFromLocator":"QID555","QuestionIsInLoop":"no","Type":"Expression"},"2":{"ChoiceLocator":"q:\/\/QID555\/SelectableChoice\/1","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Which of the following statements about the game versions and the display order are correct? Sele...<\/span> <span class=\"LeftOpDesc\">If I'm playing with Ann and Bob and I see Bob's choice after Ann\u2019s, this means that Bob decided after Ann.<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> ","LeftOperand":"q:\/\/QID555\/SelectableChoice\/1","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID555","QuestionIDFromLocator":"QID555","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"Error Text","libraryID":"UR_3aR5mUbLuJDsnRk","messageID":"MS_DNxHsyzJJgI7EBS","subMessageID":"VE_ERROR"}}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    var correctAnswer = \"2,3\";  \/\/ Change this to your correct answer\n    var wrongCount = Number(Qualtrics.SurveyEngine.getEmbeddedData(\"wrongCountMigrainesQ2\")) || 0;\n    var allAnswers = Qualtrics.SurveyEngine.getEmbeddedData(\"allAnswersMigrainesQ2\") || \"\";\n    \n    var nextBtn = document.getElementById(\"NextButton\");\n    nextBtn.addEventListener(\"click\", function(e)\n    {\n        var userAnswer = that.getSelectedChoices() || \"none\";\n        \n        \/\/ Add this answer to history\n        if (allAnswers === \"\") {\n            allAnswers = userAnswer;\n        } else {\n            allAnswers = allAnswers + \"||\" + userAnswer;\n        }\n        \n        \/\/ Check if correct\n        if (userAnswer === correctAnswer) {\n            \/\/ Correct!\n        } else {\n            \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCountMigrainesQ2\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswersMigrainesQ2\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"<b>Which of the following statements about the game versions and the display order are correct?<\/b> Select all that apply.","DataExportTag":"Q555","QuestionID":"QID555"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID556","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":28,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q556","QuestionID":"QID556"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID557","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dieterInstructionsV3.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DefaultChoices":false,"DataExportTag":"Q550","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID557","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var completed = false;\n    var currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n    var currentGameId = 'dieterInstructions';\n\n    function sendInit() {\n        var iframe = document.querySelector('iframe');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                participantId: currentParticipantId,\n                gameId: currentGameId,\n                gameConfig: {\n                    currency: '${e:\/\/Field\/currency}',\n                    basePay: parseFloat('${e:\/\/Field\/basePay}'),\n                    aCost: parseFloat('${e:\/\/Field\/aCost}'),\n                    yBonus: parseFloat('${e:\/\/Field\/yBonus}'),\n                    nRounds: parseInt('${e:\/\/Field\/nRounds}'),\n                    playerName0_1: '${e:\/\/Field\/playerName0_1}',\n                    playerName1_1: '${e:\/\/Field\/playerName1_1}',\n                    playerIcon0_1: '${e:\/\/Field\/playerIcon0_1}',\n                    playerName0_2: '${e:\/\/Field\/playerName0_2}',\n                    playerName1_2: '${e:\/\/Field\/playerName1_2}',\n                    playerIcon0_2: '${e:\/\/Field\/playerIcon0_2}',\n                    playerName0_3: '${e:\/\/Field\/playerName0_3}',\n                    playerName1_3: '${e:\/\/Field\/playerName1_3}',\n                    playerIcon0_3: '${e:\/\/Field\/playerIcon0_3}',\n                    color_1: '${e:\/\/Field\/color_1}',\n                    color_2: '${e:\/\/Field\/color_2}',\n                    color_3: '${e:\/\/Field\/color_3}'\n                }\n            }, '*');\n            console.log('Sent INIT to instructions iframe');\n        }\n    }\n\n    var messageHandler = function(event) {\n        if (event.data.type !== 'GAME_DATA') return;\n        if (completed) return;\n\n        var dataType = event.data.dataType;\n        var data = event.data.data;\n\n        console.log('Received:', dataType, data);\n\n        switch (dataType) {\n            case 'INSTRUCTIONS_COMPLETE':\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionsCompleted', data.completed);\n                Qualtrics.SurveyEngine.setEmbeddedData('attentionCheck', data.attentionCheck);\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehension', JSON.stringify(data.comprehension));\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountDieterQ1', data.wrongCountDieterQ1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountDieterQ2', data.wrongCountDieterQ2 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersDieterQ1', JSON.stringify(data.allAnswersDieterQ1 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersDieterQ2', JSON.stringify(data.allAnswersDieterQ2 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionTimes', JSON.stringify(data.pageTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehTimes', JSON.stringify(data.comprehTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderDieter1', data.gameVersionsDescriptionOrderDieter1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderDieter2', data.gameVersionsDescriptionOrderDieter2 || 0);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedInstructions', JSON.stringify(event.data.configReceived ? '1' : '0'));\n\n                completed = true;\n                window.removeEventListener('message', messageHandler);\n                setTimeout(function() {\n                    jQuery(\"#NextButton\").click();\n                }, 500);\n                break;\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ Iframe height listener\n    window.addEventListener('message', function(event) {\n        if (event.data && typeof event.data === 'object' && 'iframeHeight' in event.data) {\n            var h = Number(event.data.iframeHeight);\n            var iframe = document.getElementById('dietersGame');\n            if (iframe && Number.isFinite(h) && h > 300) {\n                iframe.style.height = Math.ceil(h) + 'px';\n            }\n        }\n    });\n\n    \/\/ Lifetime handlers: IFRAME_READY handshake + SCROLL_TO_TOP\n    window.addEventListener('message', function(event) {\n        if (!event.data) return;\n\n        if (event.data.type === 'IFRAME_READY') {\n            sendInit();\n        } else if (event.data.type === 'SCROLL_TO_TOP') {\n            window.scrollTo({ top: 0, behavior: 'smooth' });\n        }\n    });\n\n    \/\/ Safety net: fire once shortly after load in case IFRAME_READY\n    \/\/ was posted before this listener attached.\n    setTimeout(sendInit, 500);\n});"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID558","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q551","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID558"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID559","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dieterAdditionalQuestionsV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"2000px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var id = parseInt(\"${e:\/\/Field\/id}\");\n    var completed = false;\n    var currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n    var currentGameId = 'additionalQuestions';\n    var playerName0 = '${e:\/\/Field\/playerName0}';\n    var playerName1 = '${e:\/\/Field\/playerName1}';\n    var playerName2Pos = '${e:\/\/Field\/playerName2Pos}';\n    var playerName2 = '${e:\/\/Field\/playerName2}';\n    var playerPronoun2 = '${e:\/\/Field\/playerPronoun2}';\n    var playerIcon0 = '${e:\/\/Field\/playerIcon0}';\n    var nRounds = '${e:\/\/Field\/nRounds}';\n    var gameCounter = '${e:\/\/Field\/gameCounter}';\n    var gameVersionsDescriptionOrderDieter1 = '${e:\/\/Field\/gameVersionsDescriptionOrderDieter1}';\n    var gameVersionsDescriptionOrderDieter2 = '${e:\/\/Field\/gameVersionsDescriptionOrderDieter2}';\n    var order = '${e:\/\/Field\/order}';\n    var themeColor = '${e:\/\/Field\/color}';\n\n    function sendInit() {\n        var iframe = document.querySelector('iframe');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                participantId: currentParticipantId,\n                gameId: currentGameId,\n                gameConfig: {\n                    playerName0: playerName0,\n                    playerName1: playerName1,\n                    playerName2: playerName2,\n                    playerName2Pos: playerName2Pos,\n                    playerPronoun2: playerPronoun2,\n                    playerIcon0: playerIcon0,\n                    gameCounter: gameCounter,\n                    nRounds: parseInt(nRounds),\n                    gameVersionsDescriptionOrderDieter1: gameVersionsDescriptionOrderDieter1,\n                    gameVersionsDescriptionOrderDieter2: gameVersionsDescriptionOrderDieter2,\n                    order: order,\n                    themeColor: themeColor\n                }\n            }, '*');\n            console.log('Sent INIT to additional-questions iframe');\n        }\n    }\n\n    var messageHandler = function(event) {\n        if (event.data.type !== 'GAME_DATA') return;\n        if (completed) return;\n\n        var dataType = event.data.dataType;\n        var data = event.data.data;\n\n        console.log('Received:', dataType, data);\n\n        switch (dataType) {\n            case 'QUESTIONS_START':\n                console.log('Additional questions started');\n                break;\n\n            case 'QUESTIONS_COMPLETE':\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterPA_' + id, data.dieterPA);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterPX_' + id, data.dieterPX);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterPY_' + id, data.dieterPY);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterSameNo_' + id, data.dieterSameNo);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterSameYes_' + id, data.dieterSameYes);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterVersion_' + id, data.dieterVersion);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterOwnWords_' + id, data.dieterOwnWords);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterOwnWordsDAG_' + id, data.dieterOwnWordsDAG);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterKeyLogOwnWords_' + id, data.keylogOwnWords);\n                Qualtrics.SurveyEngine.setEmbeddedData('dieterKeyLogOwnWordsDAG_' + id, data.keylogOwnWordsDAG);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedVerbal_' + id, JSON.stringify(event.data.configReceived ? '1' : '0'));\n                console.log('Saved all additional question responses');\n\n                completed = true;\n                window.removeEventListener('message', messageHandler);\n                setTimeout(function() {\n                    jQuery(\"#NextButton\").click();\n                }, 500);\n                break;\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ Lifetime handlers: IFRAME_READY handshake + SCROLL_TO_TOP\n    window.addEventListener('message', function(event) {\n        if (!event.data) return;\n\n        if (event.data.type === 'IFRAME_READY') {\n            sendInit();\n        } else if (event.data.type === 'SCROLL_TO_TOP') {\n            window.scrollTo({ top: 0, behavior: 'smooth' });\n        }\n    });\n\n    \/\/ Safety net: fire once shortly after load in case IFRAME_READY\n    \/\/ was posted before this listener attached.\n    setTimeout(sendInit, 500);\n});","DefaultChoices":false,"DataExportTag":"Q552","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID559"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"Your payoff now depends on Ann's choice and Bob must press his button! In the next ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong id=\"clickableWord\" style=\"color:inherit;\">Your payoff now depends on Ann&#39;s choice and Bob must press his button!<\/strong><\/span><\/div>\n<br \/>\nIn the next ${e:\/\/Field\/nRoundsCausalBeliefs}&nbsp;rounds, you will play the same version of the game as before. However, there are two important changes:\n<ol>\n\t<li>You will receive a <u>bonus of $${e:\/\/Field\/win} if <b>Ann<\/b> presses her button, rather than if Bob presses his.<\/u><\/li>\n\t<li><u>Bob is forced to press his button<\/u>, regardless of your or Ann&#39;s choice.<\/li>\n<\/ol>\nThe cost of pressing your button will change from round to round. Sometimes, pressing the button is costly. Other times, not pressing it is costly. Your decision will not affect the cost in future rounds.<br \/>\n<br \/>\nWhile Ann&#39;s choice determines your bonus if one of these rounds is chosen for payment, you will not see her choice. Only at the end, if one of these rounds determines your payoffs, will you find out what Ann chose in that round.","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst chartData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconsole.log(chartData);\n\tconst test = chartData.instruction;\n\tconsole.log(test);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q49","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your payoff now depends on Ann's choice and Bob must press his button! In the next ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID56"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID560","SecondaryAttribute":"${e:\/\/Field\/comprehension} ${e:\/\/Field\/wrongCountDieterQ1} ${e:\/\/Field\/wrongCountDieterQ2} ...","TertiaryAttribute":null,"Payload":{"QuestionText":"${e:\/\/Field\/co