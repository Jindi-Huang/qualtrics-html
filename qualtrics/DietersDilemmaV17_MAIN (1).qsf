"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"History 1: ${e:\/\/Field\/history_1} Round Times 1: ${e:\/\/Field\/roundTimes_1} Payment 1: ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"History 1: ${e:\/\/Field\/history_1}<br \/>\nRound Times 1: ${e:\/\/Field\/roundTimes_1}<br \/>\nPayment 1: ${e:\/\/Field\/payment_1}<br \/>\nTracking 1:&nbsp;${e:\/\/Field\/tracking_1}<br \/>\nHigh Stake 1:&nbsp;${e:\/\/Field\/highStake_1}<br \/>\nPayment High Stake 1: ${e:\/\/Field\/paymentHighStake_1}<br \/>\nBelief Round 10 1:&nbsp;${e:\/\/Field\/beliefRound10_1}<br \/>\nConfig Received 1:&nbsp;${e:\/\/Field\/configReceivedMain_1}<br \/>\n<br \/>\nHistory 1: ${e:\/\/Field\/history_3}<br \/>\nRound Times 1: ${e:\/\/Field\/roundTimes_3}<br \/>\nPayment 1: ${e:\/\/Field\/payment_3}<br \/>\nTracking 1:&nbsp;${e:\/\/Field\/tracking_3}<br \/>\nHigh Stake 1:&nbsp;${e:\/\/Field\/highStake_3}<br \/>\nPayment High Stake 1: ${e:\/\/Field\/paymentHighStake_3}<br \/>\nBelief Round 10 1:&nbsp;${e:\/\/Field\/beliefRound10_3}<br \/>\nConfig Received 1:&nbsp;${e:\/\/Field\/configReceivedMain_3}<br \/>\n<br \/>\nHistory 41: ${e:\/\/Field\/history_41}<br \/>\nRound Times 41: ${e:\/\/Field\/roundTimes_41}<br \/>\nPayment 41: ${e:\/\/Field\/payment_41}<br \/>\nHigh Stake 41: ${e:\/\/Field\/highStake_41}<br \/>\nPayment High Stake 41: ${e:\/\/Field\/paymentHighStake_41}<br \/>\nBelief Round 10 41: ${e:\/\/Field\/beliefRound10_41}<br \/>\nConfig Received 41: ${e:\/\/Field\/configReceive