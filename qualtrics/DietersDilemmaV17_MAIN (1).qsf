oat(\"${e:\/\/Field\/payment41}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment42}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment43}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment44}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment45}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment46}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment47}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment48}\"));\n\tpayment.push(parseFloat(\"${e:\/\/Field\/payment49}\"));\n\n\tpayment = payment.filter(item => typeof item === 'number' && !isNaN(item));\n\n\t\n\tvar paymentAmbiguity = [];\n\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity1}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity2}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity3}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity4}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity5}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity6}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity7}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity8}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity9}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity10}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity11}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity12}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity12}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity13}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity14}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity15}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity16}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity17}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity18}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity19}\"));\n\tpaymentAmbiguity.push(parseFloat(\"${e:\/\/Field\/paymentAmbiguity20}\"));\n\n\tpaymentAmbiguity = paymentAmbiguity.filter(item => typeof item === 'number' && !isNaN(item));\n\t\n\n\tlet payAmbiguityStandard1 = parseFloat(\"${e:\/\/Field\/payAmbiguity1}\");\n\tlet payAmbiguityStandard2 = parseFloat(\"${e:\/\/Field\/payAmbiguity2}\");\n\n\tpaymentAmbiguity = paymentAmbiguity.concat([payAmbiguityStandard1, payAmbiguityStandard2]);\n\n\n\tvar riskPay1high = JSON.parse(\"${e:\/\/Field\/riskPay1high}\")\n\tvar riskPay1low = JSON.parse(\"${e:\/\/Field\/riskPay1low}\")\n\tvar riskPay2high = JSON.parse(\"${e:\/\/Field\/riskPay2high}\")\n\tvar riskPay2low = JSON.parse(\"${e:\/\/Field\/riskPay2low}\")\n\t\n\tvar winRisk = Math.random() < 0.6666 ? 1 : 0;\n\n\tvar riskChoice1 = parseInt(\"${q:\/\/QID80\/SelectedChoicesRecode}\") - 1;\n\tvar riskChoice2 = parseInt(\"${q:\/\/QID81\/SelectedChoicesRecode}\") - 1;\n\n\n\tif (winRisk == 1) {\n\t\tvar paymentRisk = [riskPay1high[riskChoice1], riskPay2high[riskChoice2]];\n\t}\n\telse {\n\t\tvar paymentRisk = [riskPay1low[riskChoice1], riskPay2low[riskChoice2]];\n\t}\n\t\n\tpayment = payment.concat(paymentAmbiguity);\n\tpayment = payment.concat(paymentRisk);\n\n\tconsole.log(\"paymentAmbiguity\")\n\tconsole.log(paymentAmbiguity);\n\tconsole.log(\"paymentRisk\");\n\tconsole.log(paymentRisk);\n\tconsole.log(\"payment\");\n\tconsole.log(payment);\n\t\n\tvar rndRound = Math.floor(Math.random() * (payment.length));\n\n\tconsole.log(\"Random round\");\n\tconsole.log(rndRound);\n\n\tvar dagPay = Math.max(payment[rndRound], 0);\n\tconsole.log(\"dagPay\");\n\tconsole.log(dagPay);\n\n\t\n    Qualtrics.SurveyEngine.setEmbeddedData(\"dagPay\",dagPay);\n\n\n\n\n\t\/\/ Overall payment; \n\n\tvar completionPay = parseFloat(\"${e:\/\/Field\/completionPay}\");\n\t\t\t\n\tvar p = 1; \n\t\n\tvar incentivePay = dagPay;\n\tvar overallPay = incentivePay + completionPay;\t\t\n\tvar payExplanation = \"Your earnings are determined by one of your decisions about which advisor to follow\";\n\tQualtrics.SurveyEngine.setEmbeddedData(\"payExplanation\",payExplanation);\n\tQualtrics.SurveyEngine.setEmbeddedData(\"incentivePay\",roundToTwo(incentivePay));\n\tQualtrics.SurveyEngine.setEmbeddedData(\"overallPay\",roundToTwo(overallPay));\n\t\n\t\n\tconsole.log(incentivePay)\n\tconsole.log(payExplanation)\n\t\n\t\n    jQuery(\"#NextButton\").click();\n\n\tfunction roundToTwo(num) {\n  \t\tconst factor = 1 \/ 0.05;\n    \treturn (Math.round(num * factor) \/ factor).toFixed(2);\n    }\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"[Calculating payment]<br>\n<br><br><br>","DataExportTag":"Q1","QuestionID":"QID1218799881"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218799882","SecondaryAttribute":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong>This is the end of this study<\/strong><\/span><br \/>\n<br \/>\nThank you for your participation!<br \/>\n<br \/>\nFrom your choices and luck, calculated exactly as stated in the instructions, you earn ${e:\/\/Field\/currency}${e:\/\/Field\/incentivePay}. In addition, you receive the completion payment of&nbsp;${e:\/\/Field\/currency}${e:\/\/Field\/completionPay}. This yields a total pay of<br \/>\n<br \/>\n<span style=\"font-size:32px;\"><strong>${e:\/\/Field\/currency}&nbsp;${e:\/\/Field\/overallPay}<\/strong><\/span><br \/>\n<br \/>\n<em>Please raise your hand. Somebody from the experiment team will come by and help you with your payment.&nbsp;<\/em><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This is the end of this study Thank you for your participation! From your choices and luck, calcu...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function ()\n{\n\t\/\/hides the next button on a page\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function () {\n    var shown   = true,\n        $body   = jQuery('body'),\n        $stored = $body.children();          \/\/ keep original content in memory\n\n    jQuery(document).on('keydown.toggleWhite', function (e) {\n        if (e.keyCode === 32) {              \/\/ space bar\n            e.preventDefault();\n            if (shown) {\n                $stored.detach();            \/\/ hide everything\n                $body.css('background', '#fff');\n            } else {\n                $body.append($stored).css('background', ''); \/\/ restore\n            }\n            shown = !shown;\n        }\n    });\n});","QuestionText_Unsafe":"<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong>This is the end of this study<\/strong><\/span><br \/>\n<br \/>\nThank you for your participation!<br \/>\n<br \/>\nFrom your choices and luck, calculated exactly as stated in the instructions, you earn ${e:\/\/Field\/currency}${e:\/\/Field\/incentivePay}. In addition, you receive the completion payment of&nbsp;${e:\/\/Field\/currency}${e:\/\/Field\/completionPay}. This yields a total pay of<br \/>\n<br \/>\n<span style=\"font-size:32px;\"><strong>${e:\/\/Field\/currency}&nbsp;${e:\/\/Field\/overallPay}<\/strong><\/span><br \/>\n<br \/>\n<em>Please raise your hand. Somebody from the experiment team will come by and help you with your payment.&nbsp;<\/em><\/div>","DataExportTag":"Q2","QuestionID":"QID1218799882"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218799883","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2000,"MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":52,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q3","QuestionID":"QID1218799883"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218804974","SecondaryAttribute":"This question is about the first batch of four games that you played (where you always chose firs...","TertiaryAttribute":null,"Payload":{"QuestionText":"This question is about the first batch of four games that you played (where you always chose first), which looked like this:","QuestionJS":false,"DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This question is about the first batch of four games that you played (where you always chose firs...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"This question is about the second batch of four games that you played. Recall:&nbsp;\n<ul>\n\t<li>Player 2 determined whether you would get the bonus.&nbsp;<\/li>\n\t<li>Player 1 did not directly affect your payments.&nbsp;<\/li>\n\t<li>There were several potential versions of the game that differed in who moved first, second, and last. You might have seen one or several versions.&nbsp;<\/li>\n<\/ul>\n\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in the first of these four games.<\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three nodes labeled &ldquo;player 1&rdquo;, &ldquo;player 2&rdquo; and &ldquo;You&rdquo; that you can see below. An arrow from Player A to Player B means that A can influence B.&nbsp;<\/li>\n\t<li>To draw an arrow from A to B, press your mouse button on A, keep it pressed, move the mouse to B, then release the mouse button at B.&nbsp;<\/li>\n\t<li>To delete an arrow, double-click it.&nbsp;<\/li>\n<\/ul>","DataExportTag":"Q1","QuestionID":"QID1218804974","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">dieterFirst<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"dieterFirst","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218804975","SecondaryAttribute":"${e:\/\/Field\/subjDAGdieters}","TertiaryAttribute":null,"Payload":{"QuestionText":"${e:\/\/Field\/subjDAGdieters}","DefaultChoices":false,"DataExportTag":"Q2","QuestionID":"QID1218804975","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${e:\/\/Field\/subjDAGdieters}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218804976","SecondaryAttribute":"This question is about the second batch of four games that you played (where someone else always...","TertiaryAttribute":null,"Payload":{"QuestionText":"This question is about the second batch of four games that you played&nbsp;(where someone else always chose before you), which looked like this:","QuestionJS":false,"DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This question is about the second batch of four games that you played (where someone else always...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"This question is about the first four games that you played. Recall:&nbsp;\n<ul>\n\t<li>Player 1 determined the cost of pressing your own button.&nbsp;<\/li>\n\t<li>Player 2 determined whether you would get the bonus.&nbsp;<\/li>\n\t<li>There were several potential versions of the game that differed in who moved first, second, and last. You might have seen one or several versions.&nbsp;<\/li>\n<\/ul>\n\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in the first of these four games.<\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three nodes labeled &ldquo;player 1&rdquo;, &ldquo;player 2&rdquo; and &ldquo;You&rdquo; that you can see below. An arrow from Player A to Player B means that A can influence B.&nbsp;<\/li>\n\t<li>To draw an arrow from A to B, press your mouse button on A, keep it pressed, move the mouse to B, then release the mouse button at B.&nbsp;<\/li>\n\t<li>To delete an arrow, double-click it.&nbsp;<\/li>\n<\/ul>","DataExportTag":"Q1","QuestionID":"QID1218804976","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">dieterFirst<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"dieterFirst","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm",