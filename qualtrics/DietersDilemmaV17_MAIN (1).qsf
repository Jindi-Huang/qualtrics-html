      });\n    })();\n  <\/script>\n<\/div>\n","DataExportTag":"dagElicitation","QuestionID":"QID599"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"Was anything about this study confusing? If yes, please let us know what.","TertiaryAttribute":null,"Payload":{"QuestionText":"Was anything about this study confusing? If yes, please let us know what.","DefaultChoices":false,"DataExportTag":"confusing","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":584,"InputHeight":91},"QuestionDescription":"Was anything about this study confusing? If yes, please let us know what.","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID6","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n\tthis.hidePreviousButton();\n\tjQuery(\"#\"+this.questionId+\" .InputText:eq(0)\").on(\"cut copy paste\",function(e) {\n\t   e.preventDefault();\n\t  });\n\t\n    \n    var keylog = [];\n\n    \/\/ Keystroke logging\n    document.addEventListener(\"keydown\", function (e) {\n        const event = { key: e.key, time: Date.now() };\n        keylog.push(event);\n    });\n\n    \/\/ Detect and log large input jumps\n    const inputField = document.querySelector(\"textarea\");\n    let lastLen = inputField ? inputField.value.length : 0;\n\n    if (inputField) {\n        inputField.addEventListener(\"input\", function () {\n            const len = inputField.value.length;\n            const jump = len - lastLen;\n\n            if (jump > 10) {\n                keylog.push({\n                    key: \"INPUT_JUMP\",\n                    time: Date.now(),\n                    jump: jump,\n                    total: len\n                });\n            }\n\n            lastLen = len;\n        });\n    }\n\n    \/\/ Save everything when page submits\n    Qualtrics.SurveyEngine.addOnPageSubmit(function () {\n\t\tconsole.log(\"key_log\", JSON.stringify(keylog));\n\n    \/\/ Set Embedded Data fields\n    Qualtrics.SurveyEngine.setEmbeddedData(\"key_log_confusing\", JSON.stringify(keylog));\n    });\n});\n\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID60","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const metaData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconst loopNum = parseInt(\"${lm:\/\/CurrentLoopNumber}\");\n\tconsole.log(loopNum);\n\tconst nameNum = loopNum + 3;\n\tconsole.log(nameNum);\n    const causal = metaData.causal;\n    const noise = metaData.noise;\n\tconsole.log(noise);\n\tconst pA = metaData.pA;\n\tconst id = metaData.id;\n\tconst playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + nameNum);\n\tconst playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + nameNum);\n\tconst playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1_' + nameNum);\n\tconst playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2_' + nameNum);\n\tconst playerIcon1 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon1_' + nameNum);\n\tconst playerIcon2 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon2_' + nameNum);\n\n\t\n\tlet gameOrder = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('gameOrder'));\n\tgameOrder.push(id);\n\t\n\tconsole.log(\"pA\");\n\tconsole.log(pA);\n\t\n\n\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName1', playerName1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName2', playerName2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', playerPronoun1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', playerPronoun2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon1', playerIcon1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon2', playerIcon2);\n\tQualtrics.SurveyEngine.setEmbeddedData('causal', causal);\n\tQualtrics.SurveyEngine.setEmbeddedData('noise', noise);\n\tQualtrics.SurveyEngine.setEmbeddedData('pA', pA);\n\tQualtrics.SurveyEngine.setEmbeddedData('id', id);\n\t\n\tvar gameCounter     = parseInt(\"${e:\/\/Field\/gameCounter}\");\n \tQualtrics.SurveyEngine.setEmbeddedData('gameCounter', gameCounter+1);\n\tQualtrics.SurveyEngine.setEmbeddedData('gameOrder', JSON.stringify(gameOrder));\n\tconsole.log(gameOrder);\n\t\n\tjQuery(\"#NextButton\").click();\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"DataExportTag":"Q53","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID60"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID600","SecondaryAttribute":"DAG2 1: ${e:\/\/Field\/subjDAG2_1} DAG Confidence 1:\u00a0${e:\/\/Field\/dagConfidence2_1} DAG Alert Count 1..","TertiaryAttribute":null,"Payload":{"QuestionText":"DAG2 1: ${e:\/\/Field\/subjDAG2_1}<br>\nDAG Confidence 1:&nbsp;${e:\/\/Field\/dagConfidence2_1}<br>\nDAG Alert Count 1:&nbsp;${e:\/\/Field\/DAGAlertCount2_1}<br>\nDAG2 Time 1: ${e:\/\/Field\/subjDAGTime2_1}<br>\nDAG Confidence Time 1:&nbsp;${e:\/\/Field\/dagConfidenceTime2_1}<br>\n<br>\nDAG2 3: ${e:\/\/Field\/subjDAG2_3}<br>\nDAG Confidence 3:&nbsp;${e:\/\/Field\/dagConfidence2_3}<br>\nDAG Alert Count 3:&nbsp;${e:\/\/Field\/DAGAlertCount2_3}<br>\nDAG2 Time 3: ${e:\/\/Field\/subjDAGTime2_3}<br>\nDAG Confidence Time 3:&nbsp;${e:\/\/Field\/dagConfidenceTime2_3}<br>\n<br>\nDAG2 5: ${e:\/\/Field\/subjDAG2_5}<br>\nDAG Confidence 5:&nbsp;${e:\/\/Field\/dagConfidence2_5}<br>\nDAG Alert Count 5:&nbsp;${e:\/\/Field\/DAGAlertCount2_5}<br>\nDAG2 Time 5: ${e:\/\/Field\/subjDAGTime2_5}<br>\nDAG Confidence Time 5:&nbsp;${e:\/\/Field\/dagConfidenceTime2_5}<br>\n<br>\nDAG2 7: ${e:\/\/Field\/subjDAG2_7}<br>\nDAG Confidence 7:&nbsp;${e:\/\/Field\/dagConfidence2_7}<br>\nDAG Alert Count 7:&nbsp;${e:\/\/Field\/DAGAlertCount2_7}<br>\nDAG2 Time 7: ${e:\/\/Field\/subjDAGTime2_7}<br>\nDAG Confidence Time 7:&nbsp;${e:\/\/Field\/dagConfidenceTime2_7}<br>\n<br>\nDAG2 9: ${e:\/\/Field\/subjDAG2_9}<br>\nDAG Confidence 9:&nbsp;${e:\/\/Field\/dagConfidence2_9}<br>\nDAG Alert Count 9:&nbsp;${e:\/\/Field\/DAGAlertCount2_9}<br>\nDAG2 Time 9: ${e:\/\/Field\/subjDAGTime2_9}<br>\nDAG Confidence Time 9:&nbsp;${e:\/\/Field\/dagConfidenceTime2_9}<br>\n<br>\nDAG2 11: ${e:\/\/Field\/subjDAG2_11}<br>\nDAG Confidence 11:&nbsp;${e:\/\/Field\/dagConfidence2_11}<br>\nDAG Alert Count 11:&nbsp;${e:\/\/Field\/DAGAlertCount2_11}<br>\nDAG2 Time 11: ${e:\/\/Field\/subjDAGTime2_11}<br>\nDAG Confidence Time 11:&nbsp;${e:\/\/Field\/dagConfidenceTime2_11}<br>\n<br>\nDAG2 13: ${e:\/\/Field\/subjDAG2_13}<br>\nDAG Confidence 13:&nbsp;${e:\/\/Field\/dagConfidence2_13}<br>\nDAG Alert Count 13:&nbsp;${e:\/\/Field\/DAGAlertCount2_13}<br>\nDAG2 Time 13: ${e:\/\/Field\/subjDAGTime2_13}<br>\nDAG Confidence Time 13:&nbsp;${e:\/\/Field\/dagConfidenceTime2_13}<br>\n<br>\nDAG2 15: ${e:\/\/Field\/subjDAG2_15}<br>\nDAG Confidence 15:&nbsp;${e:\/\/Field\/dagConfidence2_15}<br>\nDAG Alert Count 15:&nbsp;${e:\/\/Field\/DAGAlertCount2_15}<br>\nDAG2 Time 15: ${e:\/\/Field\/subjDAGTime2_15}<br>\nDAG Confidence Time 15:&nbsp;${e:\/\/Field\/dagConfidenceTime2_15}<br>\n<br>\nDAG2 41: ${e:\/\/Field\/subjDAG2_41}<br>\nDAG Confidence 41:&nbsp;${e:\/\/Field\/dagConfidence2_41}<br>\nDAG Alert Count 41:&nbsp;${e:\/\/Field\/DAGAlertCount2_41}<br>\nDAG2 Time 41: ${e:\/\/Field\/subjDAGTime2_41}<br>\nDAG Confidence Time 41:&nbsp;${e:\/\/Field\/dagConfidenceTime2_41}<br>\n<br>\nDAG2 43: ${e:\/\/Field\/subjDAG2_43}<br>\nDAG Confidence 43:&nbsp;${e:\/\/Field\/dagConfidence2_43}<br>\nDAG Alert Count 43:&nbsp;${e:\/\/Field\/DAGAlertCount2_43}<br>\nDAG2 Time 43: ${e:\/\/Field\/subjDAGTime2_43}<br>\nDAG Confidence Time 43:&nbsp;${e:\/\/Field\/dagConfidenceTime2_43}<br>\n<br>\nDAG2 45: ${e:\/\/Field\/subjDAG2_45}<br>\nDAG Confidence 45:&nbsp;${e:\/\/Field\/dagConfidence2_45}<br>\nDAG Alert Count 45:&nbsp;${e:\/\/Field\/DAGAlertCount2_45}<br>\nDAG2 Time 45: ${e:\/\/Field\/subjDAGTime2_45}<br>\nDAG Confidence Time 45:&nbsp;${e:\/\/Field\/dagConfidenceTime2_45}","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"DAG2 1: ${e:\/\/Field\/subjDAG2_1} DAG Confidence 1:\u00a0${e:\/\/Field\/dagConfidence2_1} DAG Alert Count 1...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<p>DAG2 1: ${e:\/\/Field\/subjDAG2_1}<br \/>\nDAG Confidence 1:&nbsp;${e:\/\/Field\/dagConfidence2_1}<br \/>\nDAG Alert Count 1:&nbsp;${e:\/\/Field\/DAGAlertCount2_1}<br \/>\nDAG2 Time 1: ${e:\/\/Field\/subjDAGTime2_1}<br \/>\nDAG Confidence Time 1:&nbsp;${e:\/\/Field\/dagConfidenceTime2_1}<br \/>\n<br \/>\nDAG2 3: ${e:\/\/Field\/subjDAG2_3}<br \/>\nDAG Confidence 3:&nbsp;${e:\/\/Field\/dagConfidence2_3}<br \/>\nDAG Alert Count 3:&nbsp;${e:\/\/Field\/DAGAlertCount2_3}<br \/>\nDAG2 Time 3: ${e:\/\/Field\/subjDAGTime2_3}<br \/>\nDAG Confidence Time 3:&nbsp;${e:\/\/Field\/dagConfidenceTime2_3}<\/p>","DataExportTag":"Q600","QuestionID":"QID600"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID601","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tjQuery(\"#\"+this.questionId+\" .InputText:eq(0)\").on(\"cut copy paste\",function(e) {\n   e.preventDefault();\n  });\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\tconst rationalInference = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('rationalInference_' + id));\n\t\n\tconst beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n\tconst beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n\t\n\tfunction percentageToCategory(value) {\n\t\tif (value >= 0 && value <= 10) return 1;\n\t\tif (value > 10 && value <= 20) return 2;\n\t\tif (value > 20 && value <= 30) return 3;\n\t\tif (value > 30 && value <= 40) return 4;\n\t\tif (value > 40 && value <= 50) return 5;\n\t\tif (value > 50 && value <= 60) return 6;\n\t\tif (value > 60 && value <= 70) return 7;\n\t\tif (value > 70 && value <= 80) return 8;\n\t\tif (value > 80 && value <= 90) return 9;\n\t\tif (value > 90 && value <= 100) return 10;\n\t\treturn null;\n\t}\n\t\n\tconst verbalVariables = ['dieterPA', 'dieterPX', 'dieterPY', 'dieterSameYes', 'dieterSameNo'];\n\tconst verbalPayments = [];\n\t\n\tfor (let i = 0; i < verbalVariables.length; i++) {\n\t\tconst varName = verbalVariables[i];\n\t\tconst userAnswer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData(varName + '_' + id));\n\t\tconst correctValue = rationalInference[varName];\n\t\tconst correctCategory = percentageToCategory(correctValue);\n\t\tconst difference = Math.abs(correctCategory - userAnswer);\n\t\tconst payment = beliefPaymentMax - (difference * beliefPaymentIncentive);\n\t\tverbalPayments.push(payment);\n\t\tconsole.log(varName + ' - Correct:', correctValue, 'Category:', correctCategory, 'Answer:', userAnswer, 'Payment:', payment);\n\t}\n\t\n\t\/\/ --- Correct DAG (same for all 3 elicitations) ---\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tlet correctDAG;\n\tif (causal == 0) {\n\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"},{\"from\":\"Y\",\"to\":\"X\"}]';\n\t} else if (causal == 1) {\n\t\tif (id == 31) {\n\t\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"}]';\n\t\t}\n\t\telse if (id == 33) {\n\t\t\tcorrectDAG = '[{\"from\":\"X\",\"to\":\"Y\"}]';\n\t\t}\n\t\telse {\n\t\t\tcorrectDAG = '[{\"from\":\"A\",\"to\":\"X\"},{\"from\":\"X\",\"to\":\"Y\"}]';\n\t\t}\n\t}\n\t\n\t\/\/ --- DAG payments for subjDAG0, subjDAG1, subjDAG2 ---\n\tfor (let idx = 0; idx <= 2; idx++) {\n\t\tconst subjDAG_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG' + idx + '_' + id);\n\t\tconst dagPayment = (subjDAG_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tverbalPayments.push(dagPayment);\n\t\tconsole.log('subjDAG' + idx + ' - Answer:', subjDAG_answer, 'Correct:', correctDAG, 'Payment:', dagPayment);\n\t}\n\t\n\t\/\/ --- Confidence DAG payments for dagConfidence1, dagConfidence2 ---\n\tfor (let idx = 1; idx <= 2; idx++) {\n\t\tconst confidenceDAG = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('dagConfidence' + idx + '_' + id));\n\t\tconst subjDAG_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG' + idx + '_' + id);\n\t\t\n\t\tconst X = Math.random() * 100;\n\t\tlet confidenceDAGPayment;\n\t\t\n\t\tif (X > confidenceDAG) {\n\t\t\tconst randomChance = Math.random() * 100;\n\t\t\tconfidenceDAGPayment = (randomChance < X) ? beliefPaymentMax : 0;\n\t\t\tconsole.log('dagConfidence' + idx + ' - X:', X, '> confidence:', confidenceDAG, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment);\n\t\t} else {\n\t\t\tconfidenceDAGPayment = (subjDAG_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\t\tconsole.log('dagConfidence' + idx + ' - X:', X, '<= confidence:', confidenceDAG, ', DAG correct:', (subjDAG_answer === correctDAG), ', Payment:', confidenceDAGPayment);\n\t\t}\n\t\t\n\t\tverbalPayments.push(confidenceDAGPayment);\n\t}\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('verbalPayment_' + id, JSON.stringify(verbalPayments));\n\tconsole.log('Verbal Payments:', verbalPayments);\n\tjQuery(\"#NextButton\").click();\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"[This page continues automatically]","DataExportTag":"Q601","QuestionID":"QID601","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_ctJtOtiAA0XvcnI,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/main3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_ctJtOtiAA0XvcnI,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/main3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID602","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/instructionsV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var completed = false;\n    var currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n    var currentGameId = 'dieterInstructions';\n\n    function sendInit() {\n        var iframe = document.querySelector('iframe');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                participantId: currentParticipantId,\n                gameId: currentGameId,\n                gameConfig: {\n                    currency: '${e:\/\/Field\/currency}',\n                    basePay: parseFloat('${e:\/\/Field\/basePay}'),\n                    aCost: parseFloat('${e:\/\/Field\/aCost}'),\n                    yBonus: parseFloat('${e:\/\/Field\/yBonus}'),\n                    nRounds: parseInt('${e:\/\/Field\/nRounds}'),\n                    playerName0_1: '${e:\/\/Field\/playerName0_1}',\n                    playerName1_1: '${e:\/\/Field\/playerName1_1}',\n                    playerIcon0_1: '${e:\/\/Field\/playerIcon0_1}',\n                    playerName0_2: '${e:\/\/Field\/playerName0_2}',\n                    playerName1_2: '${e:\/\/Field\/playerName1_2}',\n                    playerIcon0_2: '${e:\/\/Field\/playerIcon0_2}',\n                    playerName0_3: '${e:\/\/Field\/playerName0_3}',\n                    playerName1_3: '${e:\/\/Field\/playerName1_3}',\n                    playerIcon0_3: '${e:\/\/Field\/playerIcon0_3}',\n\t\t\t\t\tplayerName2Neg_1: '${e:\/\/Field\/playerName2Neg_1}',\n\t\t\t\t\tplayerName2Neg_2: '${e:\/\/Field\/playerName2Neg_2}',\n\t\t\t\t\tplayerName2Neg_3: '${e:\/\/Field\/playerName2Neg_3}',\n                    color_1: '${e:\/\/Field\/color_1}',\n                    color_2: '${e:\/\/Field\/color_2}',\n                    color_3: '${e:\/\/Field\/color_3}',\n\t\t\t\t\taCostMigraines0: parseFloat('${e:\/\/Field\/aCostMigraines0}'),\n\t\t\t\t\taCostMigraines1: parseFloat('${e:\/\/Field\/aCostMigraines1}'),\n\t\t\t\t\tsupergame: '${e:\/\/Field\/supergame}',\n\t\t\t\t\texperiment: '${e:\/\/Field\/experiment}',\n\t\t\t\t\tnSupergames: '${e:\/\/Field\/nSupergames}'\n\t\t\t\t\t\n                }\n            }, '*');\n            console.log('Sent INIT to instructions iframe');\n        }\n    }\n\n    var messageHandler = function(event) {\n        if (event.data.type !== 'GAME_DATA') return;\n        if (completed) return;\n\n        var dataType = event.data.dataType;\n        var data = event.data.data;\n\n        console.log('Received:', dataType, data);\n\n        switch (dataType) {\n            case 'INSTRUCTIONS_COMPLETE':\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('instructionsAllData', JSON.stringify(data));\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionsCompleted', data.completed);\n                Qualtrics.SurveyEngine.setEmbeddedData('attentionCheck', data.attentionCheck);\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehension', JSON.stringify(data.comprehension));\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountDieterQ1', data.wrongCountDieterQ1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountDieterQ2', data.wrongCountDieterQ2 || 0);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('wrongCountMigrainesQ1', data.wrongCountMigrainesQ1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountMigrainesQ2', data.wrongCountMigrainesQ2 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersDieterQ1', JSON.stringify(data.allAnswersDieterQ1 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersDieterQ2', JSON.stringify(data.allAnswersDieterQ2 || []));\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('allAnswersMigrainesQ1', JSON.stringify(data.allAnswersMigrainesQ1 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersMigrainesQ2', JSON.stringify(data.allAnswersMigrainesQ2 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionTimes', JSON.stringify(data.pageTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehTimes', JSON.stringify(data.comprehTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderDieter1', data.gameVersionsDescriptionOrderDieter1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderDieter2', data.gameVersionsDescriptionOrderDieter2 || 0);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderMigraines1', data.gameVersionsDescriptionOrderMigraines1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderMigraines2', data.gameVersionsDescriptionOrderMigraines2 || 0);\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedInstructions', JSON.stringify(event.data.configReceived ? '1' : '0'));\n\n                completed = true;\n                window.removeEventListener('message', messageHandler);\n                setTimeout(function() {\n                    jQuery(\"#NextButton\").click();\n                }, 500);\n                break;\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ Iframe height listener\n    window.addEventListener('message', function(event) {\n        if (event.data && typeof event.data === 'object' && 'iframeHeight' in event.data) {\n            var h = Number(event.data.iframeHeight);\n            var iframe = document.getElementById('dietersGame');\n            if (iframe && Number.isFinite(h) && h > 300) {\n                iframe.style.height = Math.ceil(h) + 'px';\n            }\n        }\n    });\n\n    \/\/ Lifetime handlers: IFRAME_READY handshake + SCROLL_TO_TOP\n    window.addEventListener('message', function(event) {\n        if (!event.data) return;\n\n        if (event.data.type === 'IFRAME_READY') {\n            sendInit();\n        } else if (event.data.type === 'SCROLL_TO_TOP') {\n            window.scrollTo({ top: 0, behavior: 'smooth' });\n        }\n    });\n\n    \/\/ Safety net: fire once shortly after load in case IFRAME_READY\n    \/\/ was posted before this listener attached.\n    setTimeout(sendInit, 500);\n});","QuestionText_Unsafe":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dieterInstructionsV3.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DataExportTag":"instructions","QuestionID":"QID602"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID603","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","