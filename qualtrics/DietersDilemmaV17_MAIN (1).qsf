oun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2_' + gameCounter);\n\tconst playerIcon1 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon1_' + gameCounter);\n\tconst playerIcon2 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon2_' + gameCounter);\n\n\tlet gameOrder = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('gameOrder'));\n\tgameOrder.push(id);\n\t\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('gameOrder', JSON.stringify(gameOrder));\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName1', playerName1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName2', playerName2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', playerPronoun1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', playerPronoun2);\n\t\n\t\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerName1', 'Player 1');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerName2', 'Player 2');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', 'their');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', 'their');\n\t\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon1', playerIcon1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon2', playerIcon2);\n\tQualtrics.SurveyEngine.setEmbeddedData('causal', causal);\n\tQualtrics.SurveyEngine.setEmbeddedData('noise', noise);\n\tQualtrics.SurveyEngine.setEmbeddedData('id', id);\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_Y', pX_Y);\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_y', pX_y);\n\tQualtrics.SurveyEngine.setEmbeddedData('pA', pA);\n\tQualtrics.SurveyEngine.setEmbeddedData('current', current);\n\tQualtrics.SurveyEngine.setEmbeddedData('treatment', treatment);\n\tQualtrics.SurveyEngine.setEmbeddedData('pY', pY);\n\t\n\t\n\n\tconsole.log(gameOrder);\n\t\n\tjQuery(\"#NextButton\").click();\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"[This page continues automatically]","DataExportTag":"Q1","QuestionID":"QID1218862973"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862974","SecondaryAttribute":"In the next two games, you will sometimes not have a choice about your own button. In these cases...","TertiaryAttribute":null,"Payload":{"QuestionText":"In the next two games, <b>you will sometimes not have a choice about your own button<\/b>. In these cases, you will either have to press &quot;Yes&quot; or have to press &quot;No&quot;. In these cases, you will have to press the buttons&nbsp;<em>with your mouse<\/em>.<br \/>\n<br \/>\nAt other times, you will be able to choose freely. In these cases, you will not see Player 2&rsquo;s choice, but it may nonetheless determine your payment. You will have to make these choices with your keyboard, pressing <em>y<\/em> for &quot;yes&quot; and <em>n<\/em> for &quot;no.&quot;","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In the next two games, you will sometimes not have a choice about your own button. In these cases...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> exo <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"exo","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/exoLoop1}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3Cdcbq49hKlJ6v4,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"In the next two games, <b>you will sometimes not have a choice about your own button<\/b>. In these cases, you will either have to press &quot;Yes&quot; or have to press &quot;No&quot;. In these cases, you will have to press the buttons&nbsp;<em>with your mouse<\/em>.<br \/>\n<br \/>\nAt other times, you will be able to choose freely. In these cases, you will not see Player 2&rsquo;s choice, but it may nonetheless determine your payment. You will have to make these choices with your keyboard, pressing <em>y<\/em> for &quot;yes&quot; and <em>n<\/em> for &quot;no.&quot;","DataExportTag":"Q2","QuestionID":"QID1218862974"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862975","SecondaryAttribute":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"testing","Operator":"EqualTo","RightOperand":"0","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DataExportTag":"Q3","QuestionID":"QID1218862975"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862976","SecondaryAttribute":"[Will be replaced with animation]","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[Will be replaced with animation]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  this.hidePreviousButton();\n  this.hideNextButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n  \/* -------------------- CONFIG -------------------- *\/\n  const cols = 4, rows = 3;\n  const symbols = [\n    \"\u25c6\", \"\u25b2\", \"\u25cf\", \"\u25a0\", \"\u2605\", \"\u271a\", \"\u2b20\", \"\u2b22\", \"\u25d2\", \"\u2618\ufe0e\",\n    \"\u2726\", \"\u272a\", \"\u2729\", \"\u2730\", \"\u2736\", \"\u2737\", \"\u273a\", \"\u273b\", \"\u273c\", \"\u2742\"\n  ];\n  const total = cols * rows, gap = 20, swaps = 8;\n  const fadeDelay = 150, zoomDelay = 550;\n  \n  \/\/ Use discrete hue steps (30\u00b0 intervals) for better color distinction\n  const hueSteps = 12; \/\/ 360\u00b0 \/ 12 = 30\u00b0 per step\n  const minHueDistance = 30; \/\/ Minimum difference between hues\n\n  \/* ---------------- INITIAL SETUP ------------------ *\/\n  const container = document.getElementById('container');\n  if (!container) return;\n  container.textContent = \"\";\n\n  const size = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--size'), 10) || 70;\n  \n  \/\/ Get shown symbols and hues from embedded data\n  let shownSymbols = [];\n  try {\n    shownSymbols = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownSymbols') || \"[]\");\n  } catch (e) { shownSymbols = []; }\n  \n  let shownHues = [];\n  try {\n    shownHues = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownHues') || \"[]\");\n  } catch (e) { shownHues = []; }\n\n  \/\/ Pick unique symbol\n  if (shownSymbols.length >= symbols.length) shownSymbols = [];\n  let chosenSym = symbols.find(sym => !shownSymbols.includes(sym)) || symbols[0];\n  shownSymbols.push(chosenSym);\n\n  \/\/ Pick unique hue with discrete steps\n  if (shownHues.length >= hueSteps) shownHues = [];\n  let chosenHue;\n  \n  \/\/ Find a hue that's sufficiently different from previous ones\n  for (let attempt = 0; attempt < 100; attempt++) {\n    const step = Math.floor(Math.random() * hueSteps);\n    const candidateHue = step * (360 \/ hueSteps);\n    \n    \/\/ Check against all previously used hues\n    const isDistinct = shownHues.every(usedHue => {\n      const diff = Math.abs(candidateHue - usedHue);\n      return Math.min(diff, 360 - diff) >= minHueDistance;\n    });\n    \n    if (isDistinct) {\n      chosenHue = candidateHue;\n      shownHues.push(chosenHue);\n      break;\n    }\n  }\n  \n  \/\/ Fallback if no distinct hue found\n  if (chosenHue === undefined) {\n    chosenHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n    shownHues = [chosenHue];\n  }\n\n  \/\/ Store selections\n  Qualtrics.SurveyEngine.setEmbeddedData('shownSymbols', JSON.stringify(shownSymbols));\n  Qualtrics.SurveyEngine.setEmbeddedData('shownHues', JSON.stringify(shownHues));\n  Qualtrics.SurveyEngine.setEmbeddedData('currentSymbol', chosenSym);\n  Qualtrics.SurveyEngine.setEmbeddedData('currentHue', chosenHue);\n\n  \/\/ Create positions\n  const positions = [];\n  for (let r = 0; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      positions.push({ left: c * (size + gap), top: r * (size + gap) });\n    }\n  }\n\n  const chosenIndex = Math.floor(Math.random() * total);\n  let chosenTile = null;\n  const games = [];\n\n  for (let i = 0; i < total; i++) {\n    const tile = document.createElement('div');\n    tile.className = 'game';\n    \n    \/\/ Generate distinct hues for other tiles\n    let tileHue;\n    if (i === chosenIndex) {\n      tileHue = chosenHue;\n    } else {\n      \/\/ Ensure other tiles don't match the chosen hue\n      do {\n        tileHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n      } while (tileHue === chosenHue);\n    }\n    \n    tile.style.setProperty('--hue', tileHue);\n    \n    \/\/ Create tile structure using DOM methods\n    const inner = document.createElement('div');\n    inner.className = 'inner';\n    \n    const back = document.createElement('div');\n    back.className = 'face back';\n    \n    const front = document.createElement('div');\n    front.className = 'face front';\n    \n    \/\/ Only add content to the chosen tile\n    if (i === chosenIndex) {\n      const label = document.createElement('div');\n      label.className = 'label';\n      label.textContent = 'Game';\n      \n      const sym = document.createElement('div');\n      sym.className = 'sym';\n      sym.textContent = chosenSym;  \/\/ Use textContent for symbols\n      \n      front.appendChild(label);\n      front.appendChild(sym);\n    }\n    \n    inner.appendChild(back);\n    inner.appendChild(front);\n    tile.appendChild(inner);\n    \n    tile.style.left = positions[i].left + 'px';\n    tile.style.top = positions[i].top + 'px';\n    container.appendChild(tile);\n    \n    games.push(tile);\n    if (i === chosenIndex) chosenTile = tile;\n  }\n\n  let currentPositions = [...positions];\n  let step = 0;\n\n  const interval = setInterval(() => {\n    \/\/ Shuffle positions\n    for (let i = currentPositions.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [currentPositions[i], currentPositions[j]] = [currentPositions[j], currentPositions[i]];\n    }\n    \n    \/\/ Apply new positions\n    games.forEach((game, i) => {\n      game.style.left = currentPositions[i].left + 'px';\n      game.style.top = currentPositions[i].top + 'px';\n    });\n    \n    if (++step >= swaps) {\n      clearInterval(interval);\n      reveal();\n    }\n  }, 250);\n\n  function reveal() {\n    games.forEach(game => {\n      if (game !== chosenTile) game.classList.add('faded');\n    });\n    \n    setTimeout(() => {\n      chosenTile.classList.add('flipped');\n      setTimeout(() => {\n        chosenTile.classList.add('chosen');\n        jQuery('#NextButton').fadeIn(500);\n      }, zoomDelay - fadeDelay);\n    }, fadeDelay);\n  }\n});","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"testing","Operator":"EqualTo","RightOperand":"0","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DataExportTag":"Q4","QuestionID":"QID1218862976"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862977","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DataExportTag":"Q5","QuestionID":"QID1218862977"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862978","SecondaryAttribute":"You will play this game with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}. \u00a0 ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">\n\nYou will play this game with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}. <span id=\"D2\">&nbsp;<\/span>\n\n<table align=\"center\" border=\"0\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:300px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon1}\"><\/td>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon2}\"><\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br>\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will play this game with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}. \u00a0 ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tif (loopNum != 1){\n\t\tvar loopPrev = loopNum - 1;\n\t\tvar name1prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopPrev);\n\t\tvar name2prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopPrev);\n\t\tjQuery(this.questionContainer).find(\"#D2\").html(\"They may play differently than \" +  name1prev + \" and \" + name2prev +\", with whom you played the previous game.\");\n\t}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<div style=\"text-align: center;\">\n\nYou will play this game with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}. <span id=\"D2\">&nbsp;<\/span>\n\n<table align=\"center\" border=\"0\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:300px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon1}\"><\/td>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon2}\"><\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br>\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DataExportTag":"Q6","QuestionID":"QID1218862978"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862979","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DataExportTag":"Q7","QuestionID":"QID1218862979"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862980","SecondaryAttribute":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        \n <div class=\"panel-wrapper\">\n     \n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n\t\t\t<div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n\t\t\t<div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n\t\t\t<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hidePreviousButton();\n    this.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n    const buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\n    \n    let roundCounter    = 0;\n    let X, A, Y;\n    let history         = [];\n    let roundTimes      = [];\n    let payment         = [];\n    let roundStartTime  = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n    let xReady          = false;\n    let colorDisplayed  = false;\n\n    const btnNo        = document.getElementById(\"btnNo\");\n    const btnYes       = document.getElementById(\"btnYes\");\n    const panelXinfo   = document.getElementById(\"panelXinfo\");\n    const panelYinfo   = document.getElementById(\"panelYinfo\");\n    const panelAchoice = document.getElementById(\"panelAchoice\");\n    const resultText   = document.getElementById(\"resultText\");\n    const riskText     = document.getElementById(\"riskText\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n    const actionPrompt = document.getElementById(\"actionPrompt\"); \n    \n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\n    [panelAchoice, panelXinfo, panelYinfo].forEach(p => p.style.border = \"1px solid black\");\n\n    btnYes.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('y');\n        }\n    });\n    btnNo.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('n');\n        }\n    });\n    \n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    const causal = parseInt(\"${e:\/\/Field\/causal}\");\n    const noise = Qualtrics.SurveyEngine.getEmbeddedData('noise');\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n    function handleDecision(decision) {\n        if (!panelAchoice || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\n        A = decision === 'y' ? 1 : 0;\n        if (causal === 0) {\n            const pX = [noise, 1-noise, 1-noise, 1-noise];\n            Y = Math.random() < pY ? 1 : 0;\n            X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n        } else {\n            const pX = [noise, 1-noise];\n            const pY = [noise, 1-noise];\n            X = Math.random() < pX[A] ? 1 : 0;\n            Y = Math.random() < pY[X] ? 1 : 0;\n        }\n\n        history.push([A, X, Y]);\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        payment.push(-aCost*A + yBonus*Y);\n\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            \/\/ Check if this is a player choice round or automatic round\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n            \n            if (isPlayerChoiceRound && treatment !== \"endog\") {\n                panelXinfo.style.backgroundColor = \"lightgray\";\n                riskText.innerHTML =  \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round. <br>(press 'c' to continue)\"; \n                panelYinfo.style.backgroundColor = \"white\";\n                xReady = true;\n            } else {\n                panelXinfo.style.backgroundColor = X ? \"green\" : \"red\";\n                riskText.innerHTML = X\n                ? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button. <br>(press 'c' to continue)\"\n                : \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button. <br>(press 'c' to continue)\";\n                panelYinfo.style.backgroundColor = \"white\";\n                xReady = true;\n            }\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        \/\/ Check which buttons are currently visible and enabled\n        const yesVisible = btnYes.style.display !== \"none\" && !btnYes.disabled;\n        const noVisible = btnNo.style.display !== \"none\" && !btnNo.disabled;\n        \n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound) {\n            if (e.key === 'y' && yesVisible) {\n                handleDecision('y');\n            }\n            else if (e.key === 'n' && noVisible) {\n                handleDecision('n');\n            }\n        }\n        \n        \/\/ Continue key always works regardless of round type\n        if (e.key === 'c' && xReady) {\n            \/\/ Check if this is a player choice round or automatic round\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n            \n            if (isPlayerChoiceRound && treatment !== \"endog\") {\n                \/\/ Player choice round: show generic message for playerName2\n                panelYinfo.style.backgroundColor = \"lightgray\";\n                resultText.innerHTML = \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round. <br>(press 'space' to continue)\";\n            } else {\n                \/\/ Automatic round OR endog treatment: show actual outcome for playerName2\n                panelYinfo.style.backgroundColor = Y ? \"green\" : \"red\";\n                resultText.innerHTML = Y\n                ? \"${e:\/\/Field\/playerName2} pressed ${e:\/\/Field\/playerPronoun2} button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!).<br> (press 'space' to continue)\"\n                : \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).<br>(press 'space' to continue)\";\n            }\n            xReady = false;\n            colorDisplayed = true;\n\t\t\tresultPanelStartTime = Date.now();\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tresultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function initiateRound() {\n        panelAchoice.style.display =\n        panelXinfo.style.display =\n        panelYinfo.style.display = \"none\";\n        setTimeout(() => {\n            showActionPanels();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes_' + id, JSON.stringify(roundTimes));\n        Qualtrics.SurveyEngine.setEmbeddedData('payment_' + id, JSON.stringify(payment));\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === nRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n            \n            jQuery(\"#NextButton\").show().click();\n        }\n    }\n\n    function showActionPanels() {\n        panelAchoice.style.display = \"flex\";\n        panelXinfo.style.display   = \"flex\";\n        panelYinfo.style.display   = \"flex\";\n        panelXinfo.style.backgroundColor =\n        panelYinfo.style.backgroundColor = \"white\";\n        riskText.textContent = resultText.textContent = \"\";\n\n        const showBothButtons = treatment === \"endog\" ? 1 : buttonConfig[roundCounter - 1];\n        \n        if (showBothButtons === 1) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            \n            if (Math.random() < pA) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = \"You must press \\\"Yes\\\" in this round. <br> Press your button? (Use your mouse)\";\n            } else {\n                \/\/ Force No\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = \"You must press \\\"No\\\" in this round. <br> Press your button? (Use your mouse)\";\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> dieter <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"dieter","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        \n <div class=\"panel-wrapper\">\n     \n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n\t\t\t<div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n\t\t\t<div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n\t\t\t<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","DataExportTag":"Q8","QuestionID":"QID1218862980"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218862981","SecondaryAttribute":"You Press your button? No Yes ${e:\/\/Field\/playerName2} (determines your bonus)","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n#actionPrompt {\n    padding-bottom: 2px; \n}\n\n#panelX {\n    padding-top: 2px; \n}\n\n#panelAchoice {\n\theight: 190px;\n}\n\n#panelYinfo {\n\theight: 190px;\n}\n\n\n<\/style>\n\n<body>\n    <div style=\"height:450px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n           <div class=\"panel-wrapper\">\n        <div id=\"panelAchoice\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <div class=\"panel-name\"> You <\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div id=\"panelX\" class=\"text\"><\/div>\n            <div class=\"button-container\">\n                <button id=\"btnNo\" class=\"actionButton red\">No<\/button>\n                <button id=\"btnYes\" class=\"actionButton green\">Yes<\/button>\n            <\/div>\n        <\/div>\n        <div id=\"panelYinfo\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n                <\/div>\n            <div id=\"resultText\" class=\"text\"><\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n\tconst aCost0 = parseFloat(\"${e:\/\/Field\/aCostMigraines0}\");\n\tconst aCost1 = parseFloat(\"${e:\/\/Field\/aCostMigraines1}\");\n\tconst aCost = [aCost0, aCost1];\n\tconst yBonus = Qualtrics.SurveyEngine.getEmbeddedData('yBonus');\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    const buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tconst pY            = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst pX_Y\t\t    = parseFloat(\"${e:\/\/Field\/pX_Y}\");\n\tconst pX_y \t\t\t= parseFloat(\"${e:\/\/Field\/pX_y}\");\n    let roundCounter    = 0;\n    let X, A, Y;\n    let history         = [];\n    let roundTimes      = [];\n\tlet payment         = [];\n    let roundStartTime  = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n    let userChoiceReady = false;\n    let colorDisplayed  = false;\n\n    const btnNo        = document.getElementById(\"btnNo\");\n    const btnYes       = document.getElementById(\"btnYes\");\n    const panelYinfo   = document.getElementById(\"panelYinfo\");\n    const panelAchoice = document.getElementById(\"panelAchoice\");\n    const panelX       = document.getElementById(\"panelX\");\n    const resultText   = document.getElementById(\"resultText\");\n    const riskText     = document.getElementById(\"riskText\");\n    const actionPrompt = document.getElementById(\"actionPrompt\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n\n    btnYes.addEventListener(\"click\", () => handleDecision('y'));\n    btnNo .addEventListener(\"click\", () => handleDecision('n'));\n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    \n\n    function generateChoices() {\n\t\tY = Math.random() < pY ? 1 : 0;\n\t\tconst pX = [pX_y, pX_Y];\n\t\tX = Math.random() < pX[Y] ? 1 : 0;\n    }\n\n    function handleDecision(decision) {\n        if (!userChoiceReady || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tA = decision === 'y' ? 1 : 0;\n        \n        history.push([A, X, Y]);\n\t\tpayment.push(yBonus*Y - A*aCost[X]);\n        userChoiceReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n            \n            if (isPlayerChoiceRound && treatment !== \"endog\") {\n                panelYinfo.style.backgroundColor = \"lightgray\";\n                resultText.innerHTML = \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.<br>(press 'space' to continue)\";\n            } else {\n                panelYinfo.style.backgroundColor = Y ? \"green\" : \"red\";\n                resultText.innerHTML = Y\n                    ? \"${e:\/\/Field\/playerName2} pressed his button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!)<br>(press 'space' to continue)\"\n                    : \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).<br>(press 'space' to continue)\";\n            }\n            colorDisplayed = true;\n\t\t\tresultPanelStartTime = Date.now();\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound && userChoiceReady && !btnYes.disabled) {\n            if (e.key === 'y') {\n                handleDecision('y');\n            }\n            else if (e.key === 'n') {\n                handleDecision('n');\n            }\n        }\n        \n        if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tconst resultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function initiateRound() {\n        panelAchoice.style.display = \"none\";\n        panelYinfo.style.display = \"none\";\n        panelYinfo.style.backgroundColor = \"white\";\n        \n        setTimeout(() => {\n            showUserChoice();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes_' + id, JSON.stringify(roundTimes));\n\t\tQualtrics.SurveyEngine.setEmbeddedData('payment_' + id, JSON.stringify(payment));\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === nRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n\t\t\tconsole.log(\"Payment:\", payment);\n            \n            jQuery(\"#NextButton\").show().click();\n        }\n    }\n\n    function showUserChoice() {\n        generateChoices();\n        \n        if (X === 1) {\n            panelX.innerHTML = \"(${e:\/\/Field\/playerName1} pressed \" + \"${e:\/\/Field\/playerPronoun1}\" + \" button)\";\n\t\t\tbtnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines1}\";\n\t\t\tbtnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines1}\";\n        } else {\n            panelX.innerHTML = \"(${e:\/\/Field\/playerName1} did <u>not<\/u> press \" + \"${e:\/\/Field\/playerPronoun1}\" + \" button)\";\n\t\t\tbtnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines0}\";\n\t\t\tbtnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines0}\";\n        }\n        \n        \/\/ Check if this is a player choice round or forced round\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        if (isPlayerChoiceRound) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            \n            if (Math.random() < pA || X == 1) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = 'You must press \"Yes\" in this round.<br>Press your button? (Use your mouse)';\n            } else {\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = 'You must press \"No\" in this round.<br>Press your button? (Use your mouse)';\n            }\n        }\n        \n        panelAchoice.style.display = \"flex\";\n        panelYinfo.style.display = \"flex\";\n        panelYinfo.style.backgroundColor = \"white\";\n        resultText.textContent = \"\";\n        \n        userChoiceReady = true;\n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? No Yes ${e:\/\/Field\/playerName2} (determines your bonus)","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> migraines <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"migraines","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<style>\n#actionPrompt {\n    padding-bottom: 2px; \n}\n\n#panelX {\n    