hStake_3}<br \/>\nBelief Round 10 1:&nbsp;${e:\/\/Field\/beliefRound10_3}<br \/>\nConfig Received 1:&nbsp;${e:\/\/Field\/configReceivedMain_3}<br \/>\n<br \/>\nHistory 41: ${e:\/\/Field\/history_41}<br \/>\nRound Times 41: ${e:\/\/Field\/roundTimes_41}<br \/>\nPayment 41: ${e:\/\/Field\/payment_41}<br \/>\nHigh Stake 41: ${e:\/\/Field\/highStake_41}<br \/>\nPayment High Stake 41: ${e:\/\/Field\/paymentHighStake_41}<br \/>\nBelief Round 10 41: ${e:\/\/Field\/beliefRound10_41}<br \/>\nConfig Received 41: ${e:\/\/Field\/configReceivedMain_41}<br \/>\n<br \/>\nHistory 43: ${e:\/\/Field\/history_43}<br \/>\nRound Times 43: ${e:\/\/Field\/roundTimes_43}<br \/>\nPayment 43: ${e:\/\/Field\/payment_43}<br \/>\nHigh Stake 43: ${e:\/\/Field\/highStake_43}<br \/>\nPayment High Stake 43: ${e:\/\/Field\/paymentHighStake_43}<br \/>\nBelief Round 10 43: ${e:\/\/Field\/beliefRound10_43}<br \/>\nConfig Received 43: ${e:\/\/Field\/configReceivedMain_43}<br \/>\n<br \/>\nHistory 45: ${e:\/\/Field\/history_45}<br \/>\nRound Times 45: ${e:\/\/Field\/roundTimes_45}<br \/>\nPayment 45: ${e:\/\/Field\/payment_45}<br \/>\nHigh Stake 45: ${e:\/\/Field\/highStake_45}<br \/>\nPayment High Stake 45: ${e:\/\/Field\/paymentHighStake_45}<br \/>\nBelief Round 10 45: ${e:\/\/Field\/beliefRound10_45}<br \/>\nConfig Received 45: ${e:\/\/Field\/configReceivedMain_45}","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"History 1: ${e:\/\/Field\/history_1} Round Times 1: ${e:\/\/Field\/roundTimes_1} Payment 1: ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"History 1: ${e:\/\/Field\/history_1}<br \/>\nRound Times 1: ${e:\/\/Field\/roundTimes_1}<br \/>\nPayment 1: ${e:\/\/Field\/payment_1}<br \/>\n<br \/>\nHistory 2: ${e:\/\/Field\/history_2}<br \/>\nRound Times 2: ${e:\/\/Field\/roundTimes_2}<br \/>\nPayment 2: ${e:\/\/Field\/payment_2}<br \/>\n<br \/>\nHistory 3: ${e:\/\/Field\/history_3}<br \/>\nRound Times 3: ${e:\/\/Field\/roundTimes_3}<br \/>\nPayment 3: ${e:\/\/Field\/payment_3}<br \/>\n<br \/>\nHistory 4: ${e:\/\/Field\/history_4}<br \/>\nRound Times 4: ${e:\/\/Field\/roundTimes_4}<br \/>\nPayment 4: ${e:\/\/Field\/payment_4}<br \/>\n<br \/>\nHistory 5: ${e:\/\/Field\/history_5}<br \/>\nRound Times 5: ${e:\/\/Field\/roundTimes_5}<br \/>\nPayment 5: ${e:\/\/Field\/payment_5}<br \/>\n<br \/>\nHistory 6: ${e:\/\/Field\/history_6}<br \/>\nRound Times 6: ${e:\/\/Field\/roundTimes_6}<br \/>\nPayment 6: ${e:\/\/Field\/payment_6}<br \/>\n<br \/>\nHistory 7: ${e:\/\/Field\/history_7}<br \/>\nRound Times 7: ${e:\/\/Field\/roundTimes_7}<br \/>\nPayment 7: ${e:\/\/Field\/payment_7}<br \/>\n<br \/>\nHistory 8: ${e:\/\/Field\/history_8}<br \/>\nRound Times 8: ${e:\/\/Field\/roundTimes_8}<br \/>\nPayment 8: ${e:\/\/Field\/payment_8}<br \/>\n<br \/>\nHistory 9: ${e:\/\/Field\/history_9}<br \/>\nRound Times 9: ${e:\/\/Field\/roundTimes_9}<br \/>\nPayment 9: ${e:\/\/Field\/payment_9}<br \/>\n<br \/>\nHistory 10: ${e:\/\/Field\/history_10}<br \/>\nRound Times 10: ${e:\/\/Field\/roundTimes_10}<br \/>\nPayment 10: ${e:\/\/Field\/payment_10}<br \/>\n<br \/>\nHistory 11: ${e:\/\/Field\/history_11}<br \/>\nRound Times 11: ${e:\/\/Field\/roundTimes_11}<br \/>\nPayment 11: ${e:\/\/Field\/payment_11}<br \/>\n<br \/>\nHistory 12: ${e:\/\/Field\/history_12}<br \/>\nRound Times 12: ${e:\/\/Field\/roundTimes_12}<br \/>\nPayment 12: ${e:\/\/Field\/payment_12}<br \/>\n<br \/>\nHistory 13: ${e:\/\/Field\/history_13}<br \/>\nRound Times 13: ${e:\/\/Field\/roundTimes_13}<br \/>\nPayment 13: ${e:\/\/Field\/payment_13}<br \/>\n<br \/>\nHistory 14: ${e:\/\/Field\/history_14}<br \/>\nRound Times 14: ${e:\/\/Field\/roundTimes_14}<br \/>\nPayment 14: ${e:\/\/Field\/payment_14}<br \/>\n<br \/>\nHistory 15: ${e:\/\/Field\/history_15}<br \/>\nRound Times 15: ${e:\/\/Field\/roundTimes_15}<br \/>\nPayment 15: ${e:\/\/Field\/payment_15}","DataExportTag":"Q515","QuestionID":"QID515"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID516","SecondaryAttribute":"Your Beliefs About the Game Game ${e:\/\/Field\/currentSymbol} Each of the next ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align:center\">\n    <span style=\"font-size:24px;\"><strong>Your Beliefs About the Game<\/strong><\/span>\n    <div style=\"text-align: center;\">\n        <span style=\"font-size:24px;\">\n            <strong>\n                <span class=\"miniGame\">\n                    <span class=\"label\">Game<\/span>\n                    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n                <\/span>\n            <\/strong>\n        <\/span>\n    <\/div>\n<\/div>\n\n<br>\nEach of the next ${e:\/\/Field\/nBeliefElicitationsDieter} decision screens show you a different scenario. Each will ask you how you believe the player's choices affected each other in the game you played during the last ${e:\/\/Field\/nRounds} rounds with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}.\n<br><br>\n\nThere will be ${e:\/\/Field\/nBeliefElicitationsDieter} different scenarios. Some scenarios will ask what would happen if one or more players were forced to press or not press their button. In these scenarios, <b>it does not matter what the forced players would have chosen independently<\/b>. \n<br><br>\nThis part may determine your bonus payment. Depending on the accuracy of your reports, your bonus will be between $0 and ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax}. The payment system is designed such that it is in your own interest to report your beliefs truthfully. \n\t<button onclick=\"document.getElementById('detailsContent').style.display='block'; this.style.display='none';\" style=\"display: ${e:\/\/Field\/gameCounter == 1 ? 'none' : 'block'};\"\n> Show details<\/button>\n<br><br>\n\n\t\t\n\n\n\n\n<div id=\"detailsContent\" class=\"details-content\">\n\t<p>\n\t\t\t<b>How is my payment determined if this part counts?<\/b>\n\t<\/p>\n\t<br>\n\t<p>\n\tYou will report your beliefs in two ways. \n\t<\/p>\n\t<br>\n    <p>\n        In the first, you will select a probability from a wheel like this (for instance, to answer how often a given player pressed their button):\n\t\t<\/p>\n\t\t\n\t<div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_2tJZVYJcF4KW7aK\">\n    <\/div>\n\t<br>\n\t<p>\n\t\tIn the second, you will select a line from a list like this:\n\t\t\n\t<\/p>\t<br>\n\t\t    <div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=${e:\/\/Field\/exampleBeliefURL}>\n    <\/div>\n\t<p>\n\t\tYou will earn ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} if you choose the segment or line that matches what actually happened. For each segment or line by which your estimate deviates from the correct answer, your bonus shrinks by ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentIncentive}.\n\t<\/p>\n\n<\/div>\n\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tthis.hideNextButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    \n\tvar gameCounter = \"${e:\/\/Field\/gameCounter}\";\n    \n    if (gameCounter == \"1\") {\n        document.getElementById('detailsContent').style.display = 'block';\n        document.querySelector('button').style.display = 'none';\n    }\n\t\n\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your Beliefs About the Game Game ${e:\/\/Field\/currentSymbol} Each of the next ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align:center\">\n    <span style=\"font-size:24px;\"><strong>Your Beliefs About the Game<\/strong><\/span>\n    <div style=\"text-align: center;\">\n        <span style=\"font-size:24px;\">\n            <strong>\n                <span class=\"miniGame\">\n                    <span class=\"label\">Game<\/span>\n                    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n                <\/span>\n            <\/strong>\n        <\/span>\n    <\/div>\n<\/div>\n\n<br>\nEach of the next ${e:\/\/Field\/nBeliefElicitationsDieter} decision screens show you a different scenario. Each will ask you how you believe the player's choices affected each other in the game you played during the last ${e:\/\/Field\/nRounds} rounds with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}.\n<br><br>\n\nThere will be ${e:\/\/Field\/nBeliefElicitationsDieter} different scenarios. Some scenarios will ask what would happen if one or more players were forced to press or not press their button. In these scenarios, <b>it does not matter what the forced players would have chosen independently<\/b>. \n<br><br>\nThis part may determine your bonus payment. Depending on the accuracy of your reports, your bonus will be between $0 and ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax}. The payment system is designed such that it is in your own interest to report your beliefs truthfully. \n\t<button onclick=\"document.getElementById('detailsContent').style.display='block'; this.style.display='none';\" style=\"display: ${e:\/\/Field\/gameCounter == 1 ? 'none' : 'block'};\"\n> Show details<\/button>\n<br><br>\n\n\t\t\n\n\n\n\n<div id=\"detailsContent\" class=\"details-content\">\n\t<p>\n\t\t\t<b>How is my payment determined if this part counts?<\/b>\n\t<\/p>\n\t<br>\n\t<p>\n\tYou will report your beliefs in two ways. \n\t<\/p>\n\t<br>\n    <p>\n        In the first, you will select a probability from a wheel like this (for instance, to answer how often a given player pressed their button):\n\t\t<\/p>\n\t\t\n\t<div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_2tJZVYJcF4KW7aK\">\n    <\/div>\n\t<br>\n\t<p>\n\t\tIn the second, you will select a line from a list like this:\n\t\t\n\t<\/p>\t<br>\n\t\t    <div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=${e:\/\/Field\/exampleBeliefURL}>\n    <\/div>\n\t<p>\n\t\tYou will earn ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} if you choose the segment or line that matches what actually happened. For each segment or line by which your estimate deviates from the correct answer, your bonus shrinks by ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentIncentive}.\n\t<\/p>\n\n<\/div>\n\n","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q516","QuestionID":"QID516"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID517","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":60,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q517","QuestionID":"QID517"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID518","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dietersDilemmaBeliefV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1300px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var elicitCompleted = false;\n\n    var id = parseInt(\"${e:\/\/Field\/id}\");\n\n    var gameConfig = {\n        id: id,\n        playerName0: \"${e:\/\/Field\/playerName0}\",\n        playerName1: \"${e:\/\/Field\/playerName1}\",\n        playerIcon0: \"${e:\/\/Field\/playerIcon0}\",\n        playerName2Pos: \"${e:\/\/Field\/playerName2Pos}\",\n        playerName2Neg: \"${e:\/\/Field\/playerName2Neg}\",\n        playerName2PosExo: \"${e:\/\/Field\/playerName2PosExo}\",\n        playerName2NegExo: \"${e:\/\/Field\/playerName2NegExo}\",\n        order: \"${e:\/\/Field\/order}\",\n        aCost: parseFloat(\"${e:\/\/Field\/aCost}\"),\n        beliefPaymentMax: parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\"),\n        beliefPaymentIncentive: parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\"),\n        increasingOrder: parseInt(\"${e:\/\/Field\/increasingOrder}\"),\n        rationalInference: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"rationalInference_\" + id)),\n        mainCausal1: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal1\")),\n        mainCausal2: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal2\")),\n        mainCausal3: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal3\")),\n        mainCausal4: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal4\")),\n        mainCausal5: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal5\")),\n        mainCausal6: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal6\")),\n        mainCausal7: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal7\")),\n        mainCausal8: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal8\")),\n        mainCausal9: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal9\")),\n        mainCausal10: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal10\")),\n        mainCausal11: JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData(\"mainCausal11\")),\n        themeColor: \"${e:\/\/Field\/color}\"\n    };\n\n    console.log(\"Belief elicitation configuration for ID \" + id + \":\", gameConfig);\n\n    var currentGameId = \"beliefElicit_\" + id;\n    var currentParticipantId = \"${e:\/\/Field\/PROLIFIC_PID}\";\n\n    function sendInit() {\n        var iframe = document.querySelector(\"iframe\");\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: \"INIT\",\n                participantId: currentParticipantId,\n                surveyId: \"${e:\/\/Field\/STUDY_ID}\",\n                gameConfig: gameConfig,\n                gameId: currentGameId\n            }, \"*\");\n            console.log(\"Sent INIT to belief elicitation iframe\");\n        }\n    }\n\n    var messageHandler = (function(gameId, participantId) {\n        return function(event) {\n            if (event.data.type !== \"GAME_DATA\") return;\n            if (elicitCompleted) return;\n\n            if (event.data.participantId && event.data.participantId !== participantId) {\n                console.log(\"Ignoring message for different participant:\", event.data.participantId);\n                return;\n            }\n\n            if (event.data.gameId && event.data.gameId !== gameId) {\n                console.log(\"Ignoring message for different game:\", event.data.gameId);\n                return;\n            }\n\n            var dataType = event.data.dataType;\n            var data = event.data.data;\n\n            console.log(\"Received from participant \" + participantId + \", game ID \" + gameId + \":\", dataType, data);\n\n            switch (dataType) {\n                case \"ELICIT_START\":\n                    console.log(\"Belief elicitation started for participant \" + participantId);\n                    break;\n\n                case \"CAUSAL_BELIEFS\":\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefHistory_\" + id, JSON.stringify(data.beliefHistory));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefRoundTimes_\" + id, JSON.stringify(data.beliefRoundTimes));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefPayment_\" + id, JSON.stringify(data.beliefPayment));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefPaymentSlider1_\" + id, JSON.stringify(data.beliefPaymentSlider1));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefPaymentSlider2_\" + id, JSON.stringify(data.beliefPaymentSlider2));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefCorrectAnswer_\" + id, JSON.stringify(data.beliefCorrectAnswer));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"slider1Values_\" + id, JSON.stringify(data.pie1Values));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"slider2Values_\" + id, JSON.stringify(data.pie2Values));\n                    Qualtrics.SurveyEngine.setEmbeddedData(\"beliefs_\" + id, JSON.stringify(data.verbalValues));\n\t\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedBeliefs_' + gameId, JSON.stringify(event.data.configReceived ? '1' : '0'));\n\n                    console.log(\"Saved belief data for participant \" + participantId + \", ID:\", id);\n                    break;\n\n                case \"ELICIT_COMPLETE\":\n                    elicitCompleted = true;\n                    console.log(\"Belief elicitation completed for participant \" + participantId + \", ID:\", id);\n\n                    window.removeEventListener(\"message\", messageHandler);\n\n                    setTimeout(function() {\n                        jQuery(\"#NextButton\").click();\n                    }, 1000);\n                    break;\n            }\n        };\n    })(currentGameId, currentParticipantId);\n\n    window.addEventListener(\"message\", messageHandler);\n\n    \/\/ Lifetime handlers: IFRAME_READY handshake + SCROLL_TO_TOP\n    window.addEventListener(\"message\", function(event) {\n        if (!event.data) return;\n\n        if (event.data.type === \"IFRAME_READY\") {\n            sendInit();\n        } else if (event.data.type === \"SCROLL_TO_TOP\") {\n            window.scrollTo({ top: 0, behavior: \"smooth\" });\n        }\n    });\n\n    \/\/ Safety net: fire once shortly after load in case IFRAME_READY\n    \/\/ was posted before this listener attached.\n    setTimeout(sendInit, 500);\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n.Skin .SkinInner,\n.Skin #SkinContent,\n.Skin #Questions,\n.Skin .QuestionOuter,\n.Skin .QuestionBody,\n.Skin .QuestionText {\n    max-width: 1400px !important;\n    width: 100% !important;\n}\n.Skin .SkinInner {\n    margin: 0 auto !important;\n}\n\t\n.choice-pointer {\n    position: absolute;\n    left: 110%;\n    margin-left: 20px;\n    top: 50%;\n    transform: translateY(-50%);\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 5px;\n    font-size: 20px;\n    font-weight: bold;\n    min-width: 390px;\n    padding: 10px;  \/* Add this - increases space between border and text *\/\n}\n.choice-pointer button {\n    white-space: nowrap;\n}\n\/* Add this to increase panel height specifically for this page \n.panel {\n    height: 200px !important;\n}\n*\/\n<\/style>\n<div class=\"panel-block\">\n    <h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:0.3em;\">\n  Scenario <span id=\"roundNr\"> <\/span> of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div>\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        <div id=\"instructionTitle\"> <\/div>\n\n<button id=\"startButton\" class=\"progressButton actionButton\">\n    Start This Scenario\n<\/button>\n        <div class=\"panel-wrapper\" style=\"display:none\">\n\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n\n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n\n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n\n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\n        <\/div>\n\n    <\/div>\n              \n<\/div>\n<div class=\"belief-block\">\n\n    <div id=\"beliefQuestionContainer\" class=\"verbal-section\" style=\"display: none;\">\n\n    <div id=\"question1Container\">\n        <div id=\"beliefQuestion1\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart1\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion1\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question2Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion2\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart2\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion2\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question3Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion3\" style=\"font-size:22px;margin-bottom:20px;\"><\/div>\n        <div id=\"beliefOptions\" style=\"margin:20px 0;\"><\/div>\n        <button id=\"beliefSubmit\" class=\"verbal-submit\" disabled>Submit Answer<\/button>\n    <\/div>\n<\/div>\n<\/div>\n","DataExportTag":"Q518","QuestionID":"QID518"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID519","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    \n    window.allBeliefs = [];\n    window.allBeliefsText = [];\n    window.allSlider1Values = [];\n    window.allSlider2Values = [];\n    \n    const storedBeliefs = Qualtrics.SurveyEngine.getEmbeddedData('beliefs_' + id);\n    if (storedBeliefs) {\n        window.allBeliefs = JSON.parse(storedBeliefs);\n    }\n    \n    const storedBeliefsText = Qualtrics.SurveyEngine.getEmbeddedData('beliefsText_' + id);\n    if (storedBeliefsText) {\n        window.allBeliefsText = JSON.parse(storedBeliefsText);\n    }\n    \n    const storedSlider1 = Qualtrics.SurveyEngine.getEmbeddedData('slider1Values_' + id);\n    if (storedSlider1) {\n        window.allSlider1Values = JSON.parse(storedSlider1);\n    }\n    \n    const storedSlider2 = Qualtrics.SurveyEngine.getEmbeddedData('slider2Values_' + id);\n    if (storedSlider2) {\n        window.allSlider2Values = JSON.parse(storedSlider2);\n    }\n\n    const question1Div = document.getElementById('beliefQuestion1');\n    const question2Div = document.getElementById('beliefQuestion2');\n    const question3Div = document.getElementById('beliefQuestion3');\n    const optionsDiv = document.getElementById('beliefOptions');\n    \n    const question1Container = document.getElementById('question1Container');\n    const question2Container = document.getElementById('question2Container');\n    const question3Container = document.getElementById('question3Container');\n    \n    const pieChart1 = document.getElementById('pieChart1');\n    const pieChart2 = document.getElementById('pieChart2');\n    \n    const submitQuestion1 = document.getElementById('submitQuestion1');\n    const submitQuestion2 = document.getElementById('submitQuestion2');\n    const submitButton = document.getElementById('beliefSubmit');\n    \n    let currentSlider1Value = null;\n    let currentSlider2Value = null;\n\n    const UNFILLED_COLOR = '#e0e0e0';\n    const FILLED_COLOR = '#2196F3';\n\n    function createPieChart(svgElement, onSelect) {\n        svgElement.innerHTML = '';\n        \n        const segments = [];\n        let filledCount = 0;\n        \n        const centerLabel = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n        centerLabel.setAttribute('class', 'pie-center-label');\n        centerLabel.setAttribute('x', '0');\n        centerLabel.setAttribute('y', '0');\n        centerLabel.textContent = '?%';\n        \n        for (let i = 0; i < 10; i++) {\n            const startAngle = (i * 36) - 90;\n            const endAngle = ((i + 1) * 36) - 90;\n            \n            const path = createPieSegment(startAngle, endAngle, 0, 200);\n            path.setAttribute('fill', UNFILLED_COLOR);\n            path.setAttribute('stroke', 'white');\n            path.setAttribute('stroke-width', '2');\n            path.setAttribute('class', 'pie-segment');\n            path.setAttribute('data-index', i);\n            \n            path.addEventListener('click', function() {\n                const clickedIndex = parseInt(this.getAttribute('data-index'));\n                \n                if (filledCount === 1 && clickedIndex === 0) {\n                    filledCount = 0;\n                    segments.forEach(seg => {\n                        seg.setAttribute('fill', UNFILLED_COLOR);\n                    });\n                    centerLabel.textContent = '0%';\n                    onSelect(0);\n                } else {\n                    filledCount = clickedIndex + 1;\n                    \n                    segments.forEach((seg, idx) => {\n                        if (idx < filledCount) {\n                            seg.setAttribute('fill', FILLED_COLOR);\n                        } else {\n                            seg.setAttribute('fill', UNFILLED_COLOR);\n                        }\n                    });\n                    \n                    const percentage = filledCount * 10;\n                    centerLabel.textContent = percentage + '%';\n                    onSelect(percentage);\n                }\n            });\n            \n            segments.push(path);\n            svgElement.appendChild(path);\n            \n            const labelAngle = (startAngle + endAngle) \/ 2;\n            const labelRadius = 130;\n            const labelX = Math.cos(labelAngle * Math.PI \/ 180) * labelRadius;\n            const labelY = Math.sin(labelAngle * Math.PI \/ 180) * labelRadius;\n            \n            const label = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'text');\n            label.setAttribute('x', labelX);\n            label.setAttribute('y', labelY);\n            label.setAttribute('text-anchor', 'middle');\n            label.setAttribute('dominant-baseline', 'middle');\n            label.setAttribute('fill', '#666');\n            label.setAttribute('font-size', '16');\n            label.setAttribute('font-weight', 'bold');\n            label.setAttribute('pointer-events', 'none');\n            label.textContent = ((i + 1) * 10) + '%';\n            svgElement.appendChild(label);\n        }\n        \n        svgElement.appendChild(centerLabel);\n        \n        return {\n            reset: function() {\n                filledCount = 0;\n                segments.forEach(seg => {\n                    seg.setAttribute('fill', UNFILLED_COLOR);\n                });\n                centerLabel.textContent = '?%';\n            }\n        };\n    }\n\n    function createPieSegment(startAngle, endAngle, innerRadius, outerRadius) {\n        const start = polarToCartesian(0, 0, outerRadius, endAngle);\n        const end = polarToCartesian(0, 0, outerRadius, startAngle);\n        \n        const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';\n        \n        let d;\n        if (innerRadius === 0) {\n            d = [\n                'M', 0, 0,\n                'L', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'Z'\n            ].join(' ');\n        } else {\n            const startInner = polarToCartesian(0, 0, innerRadius, endAngle);\n            const endInner = polarToCartesian(0, 0, innerRadius, startAngle);\n            \n            d = [\n                'M', start.x, start.y,\n                'A', outerRadius, outerRadius, 0, largeArcFlag, 0, end.x, end.y,\n                'L', endInner.x, endInner.y,\n                'A', innerRadius, innerRadius, 0, largeArcFlag, 1, startInner.x, startInner.y,\n                'Z'\n            ].join(' ');\n        }\n        \n        const path = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', 'path');\n        path.setAttribute('d', d);\n        return path;\n    }\n\n    function polarToCartesian(centerX, centerY, radius, angleInDegrees) {\n        const angleInRadians = (angleInDegrees) * Math.PI \/ 180.0;\n        return {\n            x: centerX + (radius * Math.cos(angleInRadians)),\n            y: centerY + (radius * Math.sin(angleInRadians))\n        };\n    }\n\n    let pie1Controller, pie2Controller;\n\n    window.updateBeliefQuestion = function() {\n        const data = window.currentBeliefData;\n        \n        question1Container.style.display = 'block';\n        question2Container.style.display = 'none';\n        question3Container.style.display = 'none';\n        submitQuestion1.style.display = 'block';\n        submitQuestion2.style.display = 'block';\n        currentSlider1Value = null;\n        currentSlider2Value = null;\n        submitQuestion1.disabled = true;\n        submitQuestion2.disabled = true;\n        \n        pie1Controller = createPieChart(pieChart1, function(value) {\n            currentSlider1Value = value;\n            submitQuestion1.disabled = false;\n        });\n        \n        pie2Controller = createPieChart(pieChart2, function(value) {\n            currentSlider2Value = value;\n            submitQuestion2.disabled = false;\n        });\n        \n        const questionConfigs = {\n            AX: {\n                prefix: data.exoButton == null \n                    ? \" the <b>Bonus Player chooses freely<\/b>?\" \n                    : \" the <b>Bonus Player must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing <b>your own button<\/b> change the <b>Co-Player\\'s choice<\/b>',\n                affectedPlayer: 'the Co-Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            },\n            AY: {\n                prefix: data.exoButton == null \n                    ? \" the <b>Co-Player chooses freely<\/b>?\" \n                    : \" the <b>Co-Player must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if <b>you must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing <b>your own button<\/b> change the <b>Bonus Player\\'s choice<\/b>',\n                affectedPlayer: 'the Bonus Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            XY: {\n                prefix: data.exoButton == null \n                    ? \"\" \n                    : \" <b>you must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if the <b>Co-Player must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Bonus Player presses \"Yes\"<\/b> if the <b>Co-Player must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does pressing the <b>Co-Player\\'s button<\/b> change the <b>Bonus Player\\'s choice<\/b>',\n                affectedPlayer: 'the Bonus Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun2}'\n            },\n            YX: {\n                prefix: data.exoButton == null \n                    ? \"\" \n                    : \" <b>you must press \" + (data.exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \"<\/b>?\",\n                question1: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if the <b>Bonus Player must press <span style=\"color: #f44336;\">\"No\"<\/span><\/b>',\n                question2: 'What is the chance that the <b>Co-Player presses \"Yes\"<\/b> if the <b>Bonus Player must press <span style=\"color: #4CAF50;\">\"Yes\"<\/span><\/b>',\n                question3: 'How does <b>pressing the Bonus Player\\'s button<\/b> change the <b>Co-Player\\'s choice<\/b>',\n                affectedPlayer: 'the Co-Player',\n                affectedPronoun: '${e:\/\/Field\/playerPronoun1}'\n            }\n        };\n        \n        const config = questionConfigs[data.causalElicitType];\n        question1Div.innerHTML = 'Question 1: <br><br>' + config.question1 + ' and ' + config.prefix;\n        question2Div.innerHTML = 'Question 2: <br><br>' + config.question2 + ' and ' + config.prefix;\n        question3Div.innerHTML = 'Question 3: <br><br>' + config.question3 + ' if ' + config.prefix;\n\n        const options = [\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Decreases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'No change in the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 1-19%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 20-39%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 40-59%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 60-79%.',\n            'Increases the chance that ' + config.affectedPlayer + ' presses ' + config.affectedPronoun + ' button by 80-100%.'\n        ];\n\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        optionsDiv.innerHTML = '';\n        submitButton.disabled = true;\n\n        displayOptions.forEach((option, index) => {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n\n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'beliefResponse';\n            radio.value = index;\n            radio.id = 'beliefOption' + index;\n\n            const label = document.createElement('label');\n            label.setAttribute('for', 'beliefOption' + index);\n            label.textContent = option;\n\n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n\n            optionDiv.addEventListener('click', function() {\n                \/\/ Remove selected class from all options\n                document.querySelectorAll('#beliefOptions .verbal-option').forEach(opt => {\n                    opt.classList.remove('selected');\n                });\n\n                \/\/ Add selected class to clicked option\n                this.classList.add('selected');\n                radio.checked = true;\n                submitButton.disabled = false;\n            });\n        });\n\n        \/\/ setTimeout(() => {\n        \/\/     const beliefBlock = document.querySelector('.belief-block');\n        \/\/     if (beliefBlock) {\n        \/\/         beliefBlock.scrollTop = 0;\n        \/\/         beliefBlock.scrollTo({ top: 0, behavior: 'auto' });\n        \/\/     }\n        \/\/ }, 150);\n        \n        \/\/ NEW: Add glow to No button when first question appears\n        const btnNo = document.getElementById('btnNo');\n        const btnYes = document.getElementById('btnYes');\n        if (btnNo) {\n            btnNo.classList.add('active-choice');\n        }\n        if (btnYes) {\n            btnYes.classList.remove('active-choice');\n            btnYes.style.backgroundColor = 'gray';\n        }\n    };\n\n    submitQuestion1.addEventListener('click', function() {\n        submitQuestion1.style.display = 'none';\n        question2Container.style.display = 'block';\n\t\tsetTimeout(() => {\n            question2Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n        }, 100);\n        \n        \/\/ NEW: Move glow from No button to Yes button\n        const btnNo = document.getElementById('btnNo');\n        const btnYes = document.getElementById('btnYes');\n        if (btnNo) {\n            btnNo.classList.remove('active-choice');\n            btnNo.style.backgroundColor = 'gray'; \n        }\n        if (btnYes) {\n            btnYes.classList.add('active-choice');\n            btnYes.style.backgroundColor = '';\n        }\n    });\n\n    submitQuestion2.addEventListener('click', function() {\n\t\tsubmitQuestion2.style.display = 'none';\n\t\tquestion3Container.style.display = 'block';\n\t\tsetTimeout(() => {\n\t\t\tquestion3Container.scrollIntoView({ behavior: 'smooth', block: 'start' });\n\t\t}, 100);\n\n\t\t\/\/ Remove button glow\n\t\tconst btnYes = document.getElementById('btnYes');\n\t\tconst btnNo = document.getElementById('btnNo');\n\t\tif (btnYes) {\n\t\t\tbtnYes.classList.remove('active-choice');\n\t\t}\n\t\tif (btnNo) {\n\t\t\tbtnNo.classList.remove('active-choice');\n\t\t\tbtnNo.style.backgroundColor = '';\n\t\t}\n\n\t\t\/\/ NEW: Highlight the panel with buttons\n\t\tconst buttonContainer = document.querySelector('.button-container');\n\t\tif (buttonContainer) {\n\t\t\tconst panelWithButtons = buttonContainer.closest('.panel');\n\t\t\tif (panelWithButtons) {\n\t\t\t\tpanelWithButtons.classList.add('active-choice');\n\t\t\t}\n\t\t}\n\t});\n\n    submitButton.addEventListener('click', function() {\n        const selected = document.querySelector('input[name=\"beliefResponse\"]:checked');\n        if (selected) {\n            const selectedIndex = parseInt(selected.value);\n            const selectedText = selected.parentElement.querySelector('label').textContent;\n            const originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\n            window.allBeliefs.push(originalIndex);\n            window.allBeliefsText.push(selectedText);\n            window.allSlider1Values.push(currentSlider1Value);\n            window.allSlider2Values.push(currentSlider2Value);\n\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(window.allBeliefs));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(window.allBeliefsText));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider1Values_' + id, JSON.stringify(window.allSlider1Values));\n            Qualtrics.SurveyEngine.setEmbeddedData('slider2Values_' + id, JSON.stringify(window.allSlider2Values));\n\n            if (window.onBeliefSubmitted) {\n                window.onBeliefSubmitted(selectedIndex, selectedText);\n            }\n        }\n    });\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Exp