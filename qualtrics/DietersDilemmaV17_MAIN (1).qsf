","Type":"Expression"},"2":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span><span> False<\/span>","LogicType":"BooleanValue","Type":"Expression","Value":"False"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"In the next two games, <b>you will sometimes not have a choice about your own button<\/b>. In these cases, you will either have to press &quot;Yes&quot; or have to press &quot;No&quot;. In these cases, you will have to press the buttons&nbsp;<em>with your mouse<\/em>.<br \/>\n<br \/>\nAt other times, you will be able to choose freely. In these cases, you will not see Player 2&rsquo;s choice, but it may nonetheless determine your payment. You will have to make these choices with your keyboard, pressing <em>y<\/em> for &quot;yes&quot; and <em>n<\/em> for &quot;no.&quot;","DataExportTag":"Q300","QuestionID":"QID300"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID301","SecondaryAttribute":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DataExportTag":"Q301","QuestionID":"QID301"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID302","SecondaryAttribute":"[Will be replaced with animation]","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[Will be replaced with animation]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  this.hidePreviousButton();\n  this.hideNextButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n  \/* -------------------- CONFIG -------------------- *\/\n  const cols = 4, rows = 3;\n  const symbols = [\n    \"\u25c6\", \"\u25b2\", \"\u25cf\", \"\u25a0\", \"\u2605\", \"\u271a\", \"\u2b20\", \"\u2b22\", \"\u25d2\", \"\u2618\ufe0e\",\n    \"\u2726\", \"\u272a\", \"\u2729\", \"\u2730\", \"\u2736\", \"\u2737\", \"\u273a\", \"\u273b\", \"\u273c\", \"\u2742\"\n  ];\n  const total = cols * rows, gap = 20, swaps = 8;\n  const fadeDelay = 150, zoomDelay = 550;\n  \n  \/\/ Use discrete hue steps (30\u00b0 intervals) for better color distinction\n  const hueSteps = 12; \/\/ 360\u00b0 \/ 12 = 30\u00b0 per step\n  const minHueDistance = 30; \/\/ Minimum difference between hues\n\n  \/* ---------------- INITIAL SETUP ------------------ *\/\n  const container = document.getElementById('container');\n  if (!container) return;\n  container.textContent = \"\";\n\n  const size = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--size'), 10) || 70;\n  \n  \/\/ Get shown symbols and hues from embedded data\n  let shownSymbols = [];\n  try {\n    shownSymbols = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownSymbols') || \"[]\");\n  } catch (e) { shownSymbols = []; }\n  \n  let shownHues = [];\n  try {\n    shownHues = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownHues') || \"[]\");\n  } catch (e) { shownHues = []; }\n\n  \/\/ Pick unique symbol\n  if (shownSymbols.length >= symbols.length) shownSymbols = [];\n  let chosenSym = symbols.find(sym => !shownSymbols.includes(sym)) || symbols[0];\n  shownSymbols.push(chosenSym);\n\n  \/\/ Pick unique hue with discrete steps\n  if (shownHues.length >= hueSteps) shownHues = [];\n  let chosenHue;\n  \n  \/\/ Find a hue that's sufficiently different from previous ones\n  for (let attempt = 0; attempt < 100; attempt++) {\n    const step = Math.floor(Math.random() * hueSteps);\n    const candidateHue = step * (360 \/ hueSteps);\n    \n    \/\/ Check against all previously used hues\n    const isDistinct = shownHues.every(usedHue => {\n      const diff = Math.abs(candidateHue - usedHue);\n      return Math.min(diff, 360 - diff) >= minHueDistance;\n    });\n    \n    if (isDistinct) {\n      chosenHue = candidateHue;\n      shownHues.push(chosenHue);\n      break;\n    }\n  }\n  \n  \/\/ Fallback if no distinct hue found\n  if (chosenHue === undefined) {\n    chosenHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n    shownHues = [chosenHue];\n  }\n\n  \/\/ Store selections\n  Qualtrics.SurveyEngine.setEmbeddedData('shownSymbols', JSON.stringify(shownSymbols));\n  Qualtrics.SurveyEngine.setEmbeddedData('shownHues', JSON.stringify(shownHues));\n  Qualtrics.SurveyEngine.setEmbeddedData('currentSymbol', chosenSym);\n  Qualtrics.SurveyEngine.setEmbeddedData('currentHue', chosenHue);\n\n  \/\/ Create positions\n  const positions = [];\n  for (let r = 0; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      positions.push({ left: c * (size + gap), top: r * (size + gap) });\n    }\n  }\n\n  const chosenIndex = Math.floor(Math.random() * total);\n  let chosenTile = null;\n  const games = [];\n\n  for (let i = 0; i < total; i++) {\n    const tile = document.createElement('div');\n    tile.className = 'game';\n    \n    \/\/ Generate distinct hues for other tiles\n    let tileHue;\n    if (i === chosenIndex) {\n      tileHue = chosenHue;\n    } else {\n      \/\/ Ensure other tiles don't match the chosen hue\n      do {\n        tileHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n      } while (tileHue === chosenHue);\n    }\n    \n    tile.style.setProperty('--hue', tileHue);\n    \n    \/\/ Create tile structure using DOM methods\n    const inner = document.createElement('div');\n    inner.className = 'inner';\n    \n    const back = document.createElement('div');\n    back.className = 'face back';\n    \n    const front = document.createElement('div');\n    front.className = 'face front';\n    \n    \/\/ Only add content to the chosen tile\n    if (i === chosenIndex) {\n      const label = document.createElement('div');\n      label.className = 'label';\n      label.textContent = 'Game';\n      \n      const sym = document.createElement('div');\n      sym.className = 'sym';\n      sym.textContent = chosenSym;  \/\/ Use textContent for symbols\n      \n      front.appendChild(label);\n      front.appendChild(sym);\n    }\n    \n    inner.appendChild(back);\n    inner.appendChild(front);\n    tile.appendChild(inner);\n    \n    tile.style.left = positions[i].left + 'px';\n    tile.style.top = positions[i].top + 'px';\n    container.appendChild(tile);\n    \n    games.push(tile);\n    if (i === chosenIndex) chosenTile = tile;\n  }\n\n  let currentPositions = [...positions];\n  let step = 0;\n\n  const interval = setInterval(() => {\n    \/\/ Shuffle positions\n    for (let i = currentPositions.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [currentPositions[i], currentPositions[j]] = [currentPositions[j], currentPositions[i]];\n    }\n    \n    \/\/ Apply new positions\n    games.forEach((game, i) => {\n      game.style.left = currentPositions[i].left + 'px';\n      game.style.top = currentPositions[i].top + 'px';\n    });\n    \n    if (++step >= swaps) {\n      clearInterval(interval);\n      reveal();\n    }\n  }, 250);\n\n  function reveal() {\n    games.forEach(game => {\n      if (game !== chosenTile) game.classList.add('faded');\n    });\n    \n    setTimeout(() => {\n      chosenTile.classList.add('flipped');\n      setTimeout(() => {\n        chosenTile.classList.add('chosen');\n        jQuery('#NextButton').fadeIn(500);\n      }, zoomDelay - fadeDelay);\n    }, fadeDelay);\n  }\n});","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DataExportTag":"Q302","QuestionID":"QID302"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID303","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\