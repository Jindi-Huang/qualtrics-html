pression","Description":"<span class=\"ConjDesc\">If<\/span><span> False<\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"History: ${e:\/\/Field\/history_1_AX0}<br \/>\nRound Times:&nbsp;${e:\/\/Field\/time_1_AX0}<br \/>\nPayment:&nbsp;${e:\/\/Field\/payment_1_AX0}<br \/>\nVerbal:&nbsp;${e:\/\/Field\/verbal_1_AX0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_1_AY0}<br \/>\nRound Times: ${e:\/\/Field\/time_1_AY0}<br \/>\nPayment: ${e:\/\/Field\/payment_1_AY0}<br \/>\nVerbal: ${e:\/\/Field\/verbal_1_AY0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_1_XY0}<br \/>\nRound Times: ${e:\/\/Field\/time_1_XY0}<br \/>\nPayment: ${e:\/\/Field\/payment_1_XY0}<br \/>\nVerbal: ${e:\/\/Field\/verbal_1_XY0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_1_XY1}<br \/>\nRound Times: ${e:\/\/Field\/time_1_XY1}<br \/>\nPayment: ${e:\/\/Field\/payment_1_XY1}<br \/>\nVerbal: ${e:\/\/Field\/verbal_1_XY1}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_2_AX0}<br \/>\nRound Times:&nbsp;${e:\/\/Field\/time_2_AX0}<br \/>\nPayment:&nbsp;${e:\/\/Field\/payment_2_AX0}<br \/>\nVerbal: ${e:\/\/Field\/verbal_2_AX0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_2_AY0}<br \/>\nRound Times: ${e:\/\/Field\/time_2_AY0}<br \/>\nPayment: ${e:\/\/Field\/payment_2_AY0}<br \/>\nVerbal: ${e:\/\/Field\/verbal_2_AY0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_2_XY0}<br \/>\nRound Times: ${e:\/\/Field\/time_2_XY0}<br \/>\nPayment: ${e:\/\/Field\/payment_2_XY0}<br \/>\nVerbal: ${e:\/\/Field\/verbal_2_XY0}<br \/>\n<br \/>\nHistory: ${e:\/\/Field\/history_2_XY1}<br \/>\nRound Times: ${e:\/\/Field\/time_2_XY1}<br \/>\nPayment: ${e:\/\/Field\/payment_2_XY1}<br \/>\nVerbal: ${e:\/\/Field\/verbal_2_XY1}<br \/>\n<br \/>\n&nbsp;","DataExportTag":"Q8","QuestionID":"QID1218791965"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792312","SecondaryAttribute":"What is your prolific ID? (This field should be auto-filled with your prolific ID)","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your prolific ID? (This field should be auto-filled with your prolific ID)","DefaultChoices":{"TEXT":{"Text":"${e:\/\/Field\/PROLIFIC_PID}"}},"QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your prolific ID? (This field should be auto-filled with your prolific ID)","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"What is your prolific ID? (This field should be auto-filled with your prolific ID)","DataExportTag":"Q1","QuestionID":"QID1218792312"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792313","SecondaryAttribute":"Instructions \u00a0Do NOT click Next on any instructions page without having read all of it carefully...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Instructions<\/strong><\/h2>\n<br>\n<strong><span style=\"color:#c0392b;\"><em>&nbsp;Do NOT click Next on any instructions page without having read all of it carefully. Otherwise, you will fail the attention check!<\/em><\/span><\/strong><br>\n<br>\nIn this study, you will play <strong>${e:\/\/Field\/nSupergames} different games<\/strong> with computer players.&nbsp;<br>\n<br>\nIn each game, each player has a button they can press. Your payment will depend on whether you press your button or not, and on whether other players press their buttons or not. Specifics follow.&nbsp;<br>\n<br>\nEach game has ${e:\/\/Field\/nRounds} rounds. This may sound like a lot, but each round takes only a few seconds, so completing all rounds will take just a few minutes. A round ends once all players have decided whether to press their button.&nbsp;<br>\n<br>\nYou will be paid for exactly one round from exactly one of the games, selected at random at the end of the study.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Instructions \u00a0Do NOT click Next on any instructions page without having read all of it carefully....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tjQuery(\"#NextButton\").hide();\n\tvar delay = parseInt(\"${e:\/\/Field\/instructionDelay}\");\n\tdelay = 1000*delay;\n\n\tsetTimeout(function() {\n\tjQuery(\"#NextButton\").fadeIn(1000);\n\t}, delay);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Instructions<\/strong><\/h2>\n<br>\n<strong><span style=\"color:#c0392b;\"><em>&nbsp;Do NOT click Next on any instructions page without having read all of it carefully. Otherwise, you will fail the attention check!<\/em><\/span><\/strong><br>\n<br>\nIn this study, you will play <strong>${e:\/\/Field\/nSupergames} different games<\/strong> with computer players.&nbsp;<br>\n<br>\nIn each game, each player has a button they can press. Your payment will depend on whether you press your button or not, and on whether other players press their buttons or not. Specifics follow.&nbsp;<br>\n<br>\nEach game has ${e:\/\/Field\/nRounds} rounds. This may sound like a lot, but each round takes only a few seconds, so completing all rounds will take just a few minutes. A round ends once all players have decided whether to press their button.&nbsp;<br>\n<br>\nYou will be paid for exactly one round from exactly one of the games, selected at random at the end of the study.","DataExportTag":"Q2","QuestionID":"QID1218792313"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792314","SecondaryAttribute":"Games 1 and 2 In the first two games, you will play with two computer players, player 1 and playe...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Games 1 and 2<\/strong><\/h2>\n<br>In the first two games, you will <span id=\"clickableWord\">play<\/span> with two computer players, player 1 and player 2. You begin each round with a base payment of $${e:\/\/Field\/basePay}. The game proceeds as follows:<br><ol>\n\t<li>You move first by choosing whether or not to press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You observe <strong>player 1<\/strong>\u2019s choice.<\/li>\n\t<li>You observe <strong>player 2<\/strong>'s choice, regardless of whether player 1 actually moved before or after player 2.<\/li><\/ol><u>If<\/u><b style=\"text-decoration-line: underline;\"> player 2<\/b><u> presses their button, you receive a bonus of $${e:\/\/Field\/win}.<\/u> To confirm you are following this, click the word \"play\" in the first sentence. If you do not, the survey will terminate.\n\n<br><br>\nBelow is an example of a decision screen:\n\n<br>\n<div style=\"text-align: center;\">\n<img src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_e8Pf2VKABui3iE6\" style=\"width: 50%;\">\n<\/div>\n\n<br>\nAt the end of the study, if one of the two games is selected to determine your payment, you will be paid based on the outcome of one randomly selected round. Your payment for that round will include the base payment, the bonus if Player 2 pressed their button, and a deduction for the cost incurred if you pressed your button.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Games 1 and 2 In the first two games, you will play with two computer players, player 1 and playe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\t\n\tjQuery(\"#NextButton\").hide();\n\tvar delay = parseInt(\"${e:\/\/Field\/instructionDelay}\");\n\tdelay = 1000*delay;\n\n\tsetTimeout(function() {\n\tjQuery(\"#NextButton\").fadeIn(1000);\n\t}, delay);\n\t\n\n\tlet attentionCheck = parseInt(\"attentionCheck\");\n\t\n    \/\/ Get the clickable element\n    var clickableWord = document.getElementById('clickableWord');\n\n    \/\/ Set up the click function\n    clickableWord.onclick = function() {\n        this.style.color = 'purple'; \/\/ Change the color to purple on click\n\t\tthis.style.textDecoration = 'underline';\n        Qualtrics.SurveyEngine.setEmbeddedData('attentionCheck', 1); \/\/ Set the embedded data value\n    };\n\t\n\t\n\n\n  var counter     =  0;\n\n  var versions = [\n    {\n      html: \"<ul><li>Version&nbsp;1: <u>Player 2's choice affects Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><li>Version 2: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><\/ul>\",\n      key : \"dag1first\"\n    },\n    {\n      html: \"<ul><li>Version 1: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><li>Version 2: <u>Player 2's choice affect Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><\/ul>\",\n      key : \"dag7first\"\n    }\n  ];\n\n  var idx  = Math.random() < 0.5 ? 0 : 1;\n  var html = versions[idx].html;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n\n  var fieldName = \"gameVersionsDescriptionOrder\" + counter;\n  Qualtrics.SurveyEngine.setEmbeddedData(fieldName, versions[idx].key);\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> endog <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"endog","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Games 1 and 2<\/strong><\/h2>\n<br>In the first two games, you will <span id=\"clickableWord\">play<\/span> with two computer players, player 1 and player 2. You begin each round with a base payment of $${e:\/\/Field\/basePay}. The game proceeds as follows:<br><ol>\n\t<li>You move first by choosing whether or not to press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You observe <strong>player 1<\/strong>\u2019s choice.<\/li>\n\t<li>You observe <strong>player 2<\/strong>'s choice, regardless of whether player 1 actually moved before or after player 2.<\/li><\/ol><u>If<\/u><b style=\"text-decoration-line: underline;\"> player 2<\/b><u> presses their button, you receive a bonus of $${e:\/\/Field\/win}.<\/u> To confirm you are following this, click the word \"play\" in the first sentence. If you do not, the survey will terminate.\n\n<br><br>\nBelow is an example of a decision screen:\n\n<br>\n<div style=\"text-align: center;\">\n<img src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_e8Pf2VKABui3iE6\" style=\"width: 50%;\">\n<\/div>\n\n<br>\nAt the end of the study, if one of the two games is selected to determine your payment, you will be paid based on the outcome of one randomly selected round. Your payment for that round will include the base payment, the bonus if Player 2 pressed their button, and a deduction for the cost incurred if you pressed your button.<br>","DataExportTag":"Q3","QuestionID":"QID1218792314"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792315","SecondaryAttribute":"Game 1 and 2 You will play with two computer players, player 1 and player 2. In each round, you b...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Game 1 and 2<\/strong><\/h2>\n<br>\nYou will <span id=\"clickableWord\">play<\/span> with two computer players, player 1 and player 2. In each round, you begin with a base payment of $${e:\/\/Field\/basePay}. <b>In most rounds, <\/b>the game proceeds as follows:\n\n<ol>\n\t<li>You move first, and you are forced to press or not press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You observe <strong>player 1<\/strong>\u2019s choice.<\/li>\n\t<li>You observe <strong>player 2<\/strong>'s choice, regardless of whether player 1 actually moved before or after player 2.<\/li>\n<\/ol>\n\n<u>If<\/u><b style=\"text-decoration-line: underline;\"> player 2<\/b><u> presses their button, you receive a bonus of $${e:\/\/Field\/win}.<\/u> It is in your own best interest to pay attention to the computer player's choices even you cannot make a decision yourself. These observations will help you make better decisions in other rounds. To confirm you are following this, click the word \"play\" in the first sentence. If you do not, the survey will terminate.<br>\n\n<br>\nBelow is an example of a decision screen when you are forced to press your button:\n\n<br>\n<div style=\"text-align: center;\">\n<img style=\"width: 50%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_3UH8r7dGtapzu6y\"><br><br>\n<\/div>\n<div>In other rounds,&nbsp;<\/div>\n\n<div>\n<ol>\n\t<li>You move first, and you choose whether or not to press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You do NOT observe player 1's or player 2's choice.&nbsp;<\/li>\n<\/ol>\n<\/div>\n\n\n\nBelow is an example of a decision screen when you choose whether or not to press your button:\n\n<br>\n<div style=\"text-align: center;\">\n<img style=\"width: 50%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_e8Pf2VKABui3iE6\">\n<\/div>\n<br>\nAt the end of the study, if one of the two games is selected to determine your payment, you will be paid based on the outcome of one randomly selected round. Your payment for that round will include the base payment, the bonus if Player 2 pressed their button, and a deduction for the cost incurred if you pressed your button.","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\t\n\tjQuery(\"#NextButton\").hide();\n\tvar delay = parseInt(\"${e:\/\/Field\/instructionDelay}\");\n\tdelay = 1000*delay;\n\n\tsetTimeout(function() {\n\tjQuery(\"#NextButton\").fadeIn(1000);\n\t}, delay);\n\t\n\n\tlet attentionCheck = parseInt(\"attentionCheck\");\n\t\n    \/\/ Get the clickable element\n    var clickableWord = document.getElementById('clickableWord');\n\n    \/\/ Set up the click function\n    clickableWord.onclick = function() {\n        this.style.color = 'purple'; \/\/ Change the color to purple on click\n\t\tthis.style.textDecoration = 'underline';\n        Qualtrics.SurveyEngine.setEmbeddedData('attentionCheck', 1); \/\/ Set the embedded data value\n    };\n\t\n\t\n\n\n  var counter     =  0;\n\n  var versions = [\n    {\n      html: \"<ul><li>Version&nbsp;1: <u>Player 2's choice affects Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><li>Version 2: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><\/ul>\",\n      key : \"dag1first\"\n    },\n    {\n      html: \"<ul><li>Version 1: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><li>Version 2: <u>Player 2's choice affect Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><\/ul>\",\n      key : \"dag7first\"\n    }\n  ];\n\n  var idx  = Math.random() < 0.5 ? 0 : 1;\n  var html = versions[idx].html;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n\n  var fieldName = \"gameVersionsDescriptionOrder\" + counter;\n  Qualtrics.SurveyEngine.setEmbeddedData(fieldName, versions[idx].key);\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game 1 and 2 You will play with two computer players, player 1 and player 2. In each round, you b...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> exo <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"exo","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Game 1 and 2<\/strong><\/h2>\n<br>\nYou will <span id=\"clickableWord\">play<\/span> with two computer players, player 1 and player 2. In each round, you begin with a base payment of $${e:\/\/Field\/basePay}. <b>In most rounds, <\/b>the game proceeds as follows:\n\n<ol>\n\t<li>You move first, and you are forced to press or not press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You observe <strong>player 1<\/strong>\u2019s choice.<\/li>\n\t<li>You observe <strong>player 2<\/strong>'s choice, regardless of whether player 1 actually moved before or after player 2.<\/li>\n<\/ol>\n\n<u>If<\/u><b style=\"text-decoration-line: underline;\"> player 2<\/b><u> presses their button, you receive a bonus of $${e:\/\/Field\/win}.<\/u> It is in your own best interest to pay attention to the computer player's choices even you cannot make a decision yourself. These observations will help you make better decisions in other rounds. To confirm you are following this, click the word \"play\" in the first sentence. If you do not, the survey will terminate.<br>\n\n<br>\nBelow is an example of a decision screen when you are forced to press your button:\n\n<br>\n<div style=\"text-align: center;\">\n<img style=\"width: 50%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_3UH8r7dGtapzu6y\"><br><br>\n<\/div>\n<div>In other rounds,&nbsp;<\/div>\n\n<div>\n<ol>\n\t<li>You move first, and you choose whether or not to press your button. <u>Pressing your button costs you $${e:\/\/Field\/actionCost}<\/u>.<\/li>\n\t<li>You do NOT observe player 1's or player 2's choice.&nbsp;<\/li>\n<\/ol>\n<\/div>\n\n\n\nBelow is an example of a decision screen when you choose whether or not to press your button:\n\n<br>\n<div style=\"text-align: center;\">\n<img style=\"width: 50%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_e8Pf2VKABui3iE6\">\n<\/div>\n<br>\nAt the end of the study, if one of the two games is selected to determine your payment, you will be paid based on the outcome of one randomly selected round. Your payment for that round will include the base payment, the bonus if Player 2 pressed their button, and a deduction for the cost incurred if you pressed your button.","DataExportTag":"Q4","QuestionID":"QID1218792315"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792316","SecondaryAttribute":"Game 1 and 2 The following two pieces of infomation are crucial to know if you want to earn the m...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Game 1 and 2<\/strong><\/h2>\n<br \/>\nThe following two pieces of infomation are crucial to know if you want to earn the most from this study:\n\n<br><br>\n<u>Your choice will definitely affect <b>player 1<\/b>&#39;s choice<\/u>: player 1 is more likely to press their button if you press yours.<br \/>\n<br \/>\n<u>Player 1 and Player 2&#39;s choices may be related, but we DO NOT tell you who influences whom.<\/u>&nbsp;Each game will be one of two versions; we won&#39;t tell you which one.\n\n<div id=\"gameDesc\">[Game description]<\/div>\nComputer players do not remember previous rounds. Only your choices in the current round can affect their choices &mdash; not your choices in earlier rounds.<br \/>\n<br \/>\n<span id=\"buttonInstruction\">[Button instruction]<\/span> Press the space bar to proceed to the next round after completing the current one.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game 1 and 2 The following two pieces of infomation are crucial to know if you want to earn the m...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\n\tjQuery(\"#NextButton\").hide();\n\tvar delay = parseInt(\"${e:\/\/Field\/instructionDelay}\");\n\tdelay = 1000*delay;\n\n\tsetTimeout(function() {\n\tjQuery(\"#NextButton\").fadeIn(1000);\n\t}, delay);\n\t\n  const treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n  var counter     =  0;\n  var versions = [\n    {\n      html: \"<ul><li>Version&nbsp;1: <u>Player 2's choice affects Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><li>Version 2: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><\/ul>\",\n      key : \"dag1first\"\n    },\n    {\n      html: \"<ul><li>Version 1: <u>Player 1's choice affects Player 2's.<\/u> Player 2 moves after Player 1, and is more likely to press their button if Player 1 pressed theirs.<\/li><li>Version 2: <u>Player 2's choice affect Player 1's.<\/u> Player 1 moves after Player 2, and is more likely to press their button if Player 2 pressed theirs.<\/li><\/ul>\",\n      key : \"dag7first\"\n    }\n  ];\n\n  var idx  = Math.random() < 0.5 ? 0 : 1;\n  var html = versions[idx].html;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n\n  var fieldName = \"gameVersionsDescriptionOrder\" + counter;\n  Qualtrics.SurveyEngine.setEmbeddedData(fieldName, versions[idx].key);\n\t\n\tvar buttonInstruction = '';\n   if (treatment == \"exo\") {\n\t  buttonInstruction = `When you are forced to press or not press your button, you can only select the option with your mouse. When you decide whether to press your button, you can only use your keyboard: Press \"y\" for Yes and \"n\" for No.`\n  }\n\telse {\n\t\tbuttonInstruction = `You can make your choices using your mouse or your keyboard: Press \"y\" for Yes and \"n\" for No.`\n\t\t\n\t}\n\tjQuery(this.questionContainer).find(\"#buttonInstruction\").html(buttonInstruction);\n  \n  \n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">attentionCheck<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"attentionCheck","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Game 1 and 2<\/strong><\/h2>\n<br \/>\nThe following two pieces of infomation are crucial to know if you want to earn the most from this study:\n\n<br><br>\n<u>Your choice will definitely affect <b>player 1<\/b>&#39;s choice<\/u>: player 1 is more likely to press their button if you press yours.<br \/>\n<br \/>\n<u>Player 1 and Player 2&#39;s choices may be related, but we DO NOT tell you who influences whom.<\/u>&nbsp;Each game will be one of two versions; we won&#39;t tell you which one.\n\n<div id=\"gameDesc\">[Game description]<\/div>\nComputer players do not remember previous rounds. Only your choices in the current round can affect their choices &mdash; not your choices in earlier rounds.<br \/>\n<br \/>\n<span id=\"buttonInstruction\">[Button instruction]<\/span> Press the space bar to proceed to the next round after completing the current one.","DataExportTag":"Q5","QuestionID":"QID1218792316"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792317","SecondaryAttribute":"Information about previous rounds To help you see the association between players' choices, we wi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center; margin-left: 40px;\"><strong>Information about previous rounds<\/strong><\/h2>\n<br \/>\nTo help you see the association between players&#39; choices, we will show you a panel such as this that summarizes previous rounds:&nbsp;\n<div style=\"text-align: center;\"><br \/>\n<img height=\"636\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_4NlPvPVDjmvrlrg\" style=\"width: 550px; height: 636px;\" width=\"550\" \/><\/div>\nThe panel has two parts:\n\n<ul>\n\t<li>The first part shows<strong> <\/strong><u>how often <strong>Player 1 <\/strong>pressed their button when <strong>you <\/strong>pressed yours, compared to when you did not press yours. <\/u>For example: If the panel says &quot;42 percentage points more often&quot;, it means that in past rounds, Player 1pressed their button 42% more frequently when you pressed than when you didn&#39;t.&nbsp;<\/li>\n\t<li>The second part shows <u>how often<strong> Player 2<\/strong> pressed their button when <strong>Player 1<\/strong> pressed their button,&nbsp;compared to when Player 1 did not press theirs.<\/u><\/li>\n<\/ul>\nNote that this is only an observed pattern from past rounds. It does <strong data-end=\"889\" data-start=\"882\">not<\/strong> mean that either player&rsquo;s choices caused the other&rsquo;s.<br \/>\n<br \/>\nThe information in the panel will only appear after a few rounds, once there is enough data to calculate it.<br \/>\n&nbsp;\n<div style=\"text-align: center;\">&nbsp;<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tjQuery(\"#NextButton\").hide();\n\tvar delay = parseInt(\"${e:\/\/Field\/instructionDelay}\");\n\tdelay = 1000*delay;\n\n\tsetTimeout(function() {\n\tjQuery(\"#NextButton\").fadeIn(1000);\n\t}, delay);\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Information about previous rounds To help you see the association between players' choices, we wi...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">attentionCheck<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"attentionCheck","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<h2 style=\"text-align: center; margin-left: 40px;\"><strong>Information about previous rounds<\/strong><\/h2>\n<br \/>\nTo help you see the association between players&#39; choices, we will show you a panel such as this that summarizes previous rounds:&nbsp;\n<div style=\"text-align: center;\"><br \/>\n<img height=\"636\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_4NlPvPVDjmvrlrg\" style=\"width: 550px; height: 636px;\" width=\"550\" \/><\/div>\nThe panel has two parts:\n\n<ul>\n\t<li>The first part shows<strong> <\/strong><u>how often <strong>Player 1 <\/strong>pressed their button when <strong>you <\/strong>pressed yours, compared to when you did not press yours. <\/u>For example: If the panel says &quot;42 percentage points more often&quot;, it means that in past rounds, Player 1pressed their button 42% more frequently when you pressed than when you didn&#39;t.&nbsp;<\/li>\n\t<li>The second part shows <u>how often<strong> Player 2<\/strong> pressed their button when <strong>Player 1<\/strong> pressed their button,&nbsp;compared to when Player 1 did not press theirs.<\/u><\/li>\n<\/ul>\nNote that this is only an observed pattern from past rounds. It does <strong data-end=\"889\" data-start=\"882\">not<\/strong> mean that either player&rsquo;s choices caused the other&rsquo;s.<br \/>\n<br \/>\nThe information in the panel will only appear after a few rounds, once there is enough data to calculate it.<br \/>\n&nbsp;\n<div style=\"text-align: center;\">&nbsp;<\/div>","DataExportTag":"Q6","QuestionID":"QID1218792317"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792318","SecondaryAttribute":"Comprehension check To make sure you have understood these instructions, please select all correc...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Comprehension check<\/strong><\/h2>\n\n<div style=\"text-align: left;\"><br \/>\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/div>","DefaultChoices":false,"QuestionType":"MC","Selector":"MACOL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2},"QuestionDescription":"Comprehension check To make sure you have understood these instructions, please select all correc...","Choices":{"1":{"Display":"If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this means that Ann decided before Bob"},"2":{"Display":"If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this does <u>not<\/u> mean that Ann decided before Bob"},"3":{"Display":"Whether I press my button or not does <u>not<\/u> affect my payment"},"4":{"Display":"My overall payment will be the sum of all the payments I collect over the various games and rounds of each game I play."},"5":{"Display":"My overall payment will be determined by one randomly selected round from one randomly selected game."},"6":{"Display":"Pressing my button will cost $${e:\/\/Field\/aCost}"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","MinChoices":"1","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/6","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">Pressing my button will cost $${e:\/\/Field\/aCost}<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/6","LogicType":"Question","Operator":"Selected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/5","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">My overall payment will be determined by one randomly selected round from one randomly selected game.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/5","LogicType":"Question","Operator":"Selected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"2":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/2","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this does &lt;u&gt;not&lt;\/u&gt; mean that Ann decided before Bob<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/2","LogicType":"Question","Operator":"Selected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"3":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/1","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">If I'm playing with Ann and Bob and I see Ann's choice before Bob's, this means that Ann decided before Bob<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/1","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"4":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/3","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">Whether I press my button or not does &lt;u&gt;not&lt;\/u&gt; affect my payment<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/3","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"5":{"ChoiceLocator":"q:\/\/QID1218792318\/SelectableChoice\/4","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check\n\n\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/span> <span class=\"LeftOpDesc\">My overall payment will be the sum of all the payments I collect over the various games and rounds of each game I play.<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> ","LeftOperand":"q:\/\/QID1218792318\/SelectableChoice\/4","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID1218792318","QuestionIDFromLocator":"QID1218792318","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"comprehension","libraryID":"UR_3aR5mUbLuJDsnRk","messageID":"MS_elN0gPvjo0NU2Ds","subMessageID":"VE_CUSTOM_VALIDATION_1"}}}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">attentionCheck<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"attentionCheck","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    var correctAnswer = \"2,5,6\";  \/\/ Change this to your correct answer\n    var wrongCount = Number(Qualtrics.SurveyEngine.getEmbeddedData(\"wrongCount\")) || 0;\n    var allAnswers = Qualtrics.SurveyEngine.getEmbeddedData(\"allAnswers\") || \"\";\n    \n    var nextBtn = document.getElementById(\"NextButton\");\n    nextBtn.addEventListener(\"click\", function(e)\n    {\n        var userAnswer = that.getSelectedChoices() || \"none\";\n        \n        \/\/ Add this answer to history\n        if (allAnswers === \"\") {\n            allAnswers = userAnswer;\n        } else {\n            allAnswers = allAnswers + \"||\" + userAnswer;\n        }\n        \n        \/\/ Check if correct\n        if (userAnswer === correctAnswer) {\n            \/\/ Correct!\n        } else {\n            \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCount\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswers\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Comprehension check<\/strong><\/h2>\n\n<div style=\"text-align: left;\"><br \/>\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/div>","DataExportTag":"Q7","QuestionID":"QID1218792318"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218792319","SecondaryAttribute":"Your decisions begin now. \u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><br \/>\n<br \/>\n<strong><span style=\"font-size:48px;\">Your decisions begin now.<\/span><\/strong><br \/>\n<br \/>\n&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your decisions begin now. \u00a0","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"attentionCheck","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"