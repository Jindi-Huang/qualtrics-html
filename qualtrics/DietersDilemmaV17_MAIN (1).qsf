\n    {\n        var userAnswer = that.getSelectedChoices() || \"none\";\n        \n        \/\/ Add this answer to history\n        if (allAnswers === \"\") {\n            allAnswers = userAnswer;\n        } else {\n            allAnswers = allAnswers + \"||\" + userAnswer;\n        }\n        \n        \/\/ Check if correct\n        if (userAnswer === correctAnswer) {\n            \/\/ Correct!\n        } else {\n            \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCount\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswers\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Comprehension check<\/strong><\/h2>\n\n<div style=\"text-align: left;\"><br \/>\nTo make sure you have understood these instructions, please select all correct statements (and only those).<\/div>","DataExportTag":"Q7","QuestionID":"QID1218873336"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218873337","SecondaryAttribute":"Your decisions begin now. \u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><br \/>\n<br \/>\n<strong><span style=\"font-size:48px;\">Your decisions begin now.<\/span><\/strong><br \/>\n<br \/>\n&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your decisions begin now. \u00a0","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"attentionCheck","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">attentionCheck<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\"><br \/>\n<br \/>\n<strong><span style=\"font-size:48px;\">Your decisions begin now.<\/span><\/strong><br \/>\n<br \/>\n&nbsp;<\/div>","DataExportTag":"Q8","QuestionID":"QID1218873337"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218918756","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const metaData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconst loopNum = parseInt(\"${lm:\/\/CurrentLoopNumber}\");\n\tconst pX_A0 = metaData.pX_A0;\n\tconst pX_A1 = metaData.pX_A1;\n\tconst risk_id = metaData.risk_id;\n\n\n\n\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_A0', pX_A0);\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_A1', pX_A1);\n\tQualtrics.SurveyEngine.setEmbeddedData('riskLoopNum', loopNum);\n\tQualtrics.SurveyEngine.setEmbeddedData('riskID', risk_id);\n\t\n\t\n\tjQuery(\"#NextButton\").click();\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"[This page continues automatically]","DataExportTag":"Q1","QuestionID":"QID1218918756"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218918757","SecondaryAttribute":"On this page, you choose between pairs of lotteries for a ${e:\/\/Field\/currency}...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:19px;\">On this page, you choose between pairs of lotteries for a <b>${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}<\/b> prize.<br>\n<br>\nIn each pair, the lottery on the left offers a lower chance of winning (<b>${e:\/\/Field\/pX_A0} in 10<\/b>) than the lottery on the right (<b>${e:\/\/Field\/pX_A1} in 10<\/b>).<br>\n<br>Pressing your button always incurs a cost of ${e:\/\/Field\/currency}${e:\/\/Field\/cost}, regardless of whether you win the prize.&nbsp;<\/span>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"On this page, you choose between pairs of lotteries for a ${e:\/\/Field\/currency}...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    this.hidePreviousButton();\n    window.pageAnswers = {\n        q1: null,\n        q2: null,\n        q3: null,\n        q4: null,\n        q5: null,\n        q6: null,\n        q7: null\n    };\n    \n    window.isValidating = false; \/\/ Flag to prevent concurrent validation\n    \n    window.validateAnswers = function() {\n        \/\/ If already validating, skip\n        if (window.isValidating) {\n            return;\n        }\n        \n        window.isValidating = true;\n        \n        var answers = [\n            window.pageAnswers.q1,\n            window.pageAnswers.q2,\n            window.pageAnswers.q3,\n            window.pageAnswers.q4,\n            window.pageAnswers.q5,\n            window.pageAnswers.q6,\n            window.pageAnswers.q7\n        ];\n        \n        \/\/ Check the rule: if previous = '1', current cannot be '2'\n        for (var i = 0; i < answers.length - 1; i++) {\n            if (answers[i] && answers[i][0] === '1' && answers[i + 1] && answers[i + 1][0] === '2') {\n                alert(\"You chose to press your button when the cost is higher, but not when it's lower. Please reconsider your choice.\");\n                \n                \/\/ Reset flag after a short delay\n                setTimeout(function() {\n                    window.isValidating = false;\n                }, 500);\n                \n                return false;\n            }\n        }\n        \n        \/\/ Reset flag\n        window.isValidating = false;\n        return true;\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n   \n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","QuestionText_Unsafe":"<span style=\"font-size:22px;\"><b>If you don&#39;t press your button, you&rsquo;ll get the prize of $${e:\/\/Field\/yBonus} with a&nbsp;${e:\/\/Field\/pX_A0} in 10 chance. If you press it, you get the prize of $${e:\/\/Field\/yBonus} with a&nbsp;${e:\/\/Field\/pX_A1} in 10 chance.&nbsp;<\/b>For each question below, choose the option you prefer.<\/span>","DataExportTag":"Q2","QuestionID":"QID1218918757"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID1218918758","SecondaryAttribute":"Which option do you prefer if\u00a0pressing your button costs $0.0?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which option do you prefer if&nbsp;<b>pressing your button costs $0.0<\/b>?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Which option do you prefer if\u00a0pressing your button costs $0.0?","Choices":{"1":{"Display":"Don\u20