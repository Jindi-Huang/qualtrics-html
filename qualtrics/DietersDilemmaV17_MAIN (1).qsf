"QuestionText_Unsafe":"Which option do you prefer &nbsp;if <b>pressing your button costs $3.0<\/b>?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    this.questionclick = function(event, element) {\n        var answer = that.getSelectedChoices();\n        window.pageAnswers.q7 = answer; \n\t\tconsole.log(answer);\n\t\twindow.validateAnswers();\n\t\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('riskID');\n\t\tQualtrics.SurveyEngine.setEmbeddedData(\"riskQ7_\" + id, answer);\n    };\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DataExportTag":"risk7","QuestionID":"QID389"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","TertiaryAttribute":null,"Payload":{"QuestionText":"\t<div style=\"text-align: center; position: absolute; bottom: 10px; margin: 0; padding: 0;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work. One round will randomly be selected for payment.<\/span><\/div>\n\t","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"\t<div style=\"text-align: center; position: absolute; bottom: 10px; margin: 0; padding: 0;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work. One round will randomly be selected for payment.<\/span><\/div>\n\t","DataExportTag":"Q39","QuestionID":"QID39"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID390","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('riskID');\n\tconst yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n\tconst pX_A0 = parseFloat(\"${e:\/\/Field\/pX_A0}\");\n\tconst cost = parseFloat(\"${e:\/\/Field\/cost}\");\n\tconst basePay = parseFloat(\"${e:\/\/Field\/basePay}\");\n\t\n\t\/\/ Probabilities (out of 100) for Q1 to Q11 when choosing option 2\n\tconst pX_A1 = [0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50];\n\t\n\t\/\/ Array to store payments\n\tconst riskPayments = [];\n\t\n\t\/\/ Loop through riskQ1 to riskQ11\n\tfor (let i = 1; i <= 11; i++) {\n\t\t\/\/ Get the answer from embedded data\n\t\tconst answerRaw = Qualtrics.SurveyEngine.getEmbeddedData('riskQ' + i + '_' + id);\n\t\t\n\t\t\/\/ Parse the answer - it's stored as \"['1']\" or \"['2']\"\n\t\tlet choice;\n\t\tif (answerRaw.includes('1')) {\n\t\t\tchoice = 1;\n\t\t} else if (answerRaw.includes('2')) {\n\t\t\tchoice = 2;\n\t\t}\n\t\t\n\t\t\/\/ Draw a random integer between 1 and 100\n\t\tconst randomNumber = Math.floor(Math.random() * 100) + 1;\n\t\t\n\t\tlet payment = 0;\n\t\t\n\t\tif (choice === 1) {\n\t\t\t\/\/ Choice ['1']: get yBonus if random <= pX_A0 (no cost)\n\t\t\tif (randomNumber <= pX_A0) {\n\t\t\t\tpayment = yBonus;\n\t\t\t} else {\n\t\t\t\tpayment = 0;\n\t\t\t}\n\t\t} else if (choice === 2) {\n\t\t\t\/\/ Choice ['2']: always incur cost, get yBonus if random <= pX_A1[i-1]\n\t\t\tif (randomNumber <= pX_A1[i - 1]) {\n\t\t\t\tpayment = yBonus - cost;\n\t\t\t} else {\n\t\t\t\tpayment = -cost;\n\t\t\t}\n\t\t}\n\t\t\n\t\t\n\t\triskPayments.push(payment+basePay);\n\t\tconsole.log('riskQ' + i + ' - Choice:', choice, 'Random:', randomNumber, 'Payment:', payment);\n\t}\n\t\n\t\/\/ Save the payment array to embedded data\n\tQualtrics.SurveyEngine.setEmbeddedData('riskPayment_' + id, JSON.stringify(riskPayments));\n\tconsole.log('Risk Payments:', riskPayments);\n\t\n\tjQuery(\"#NextButton\").click();\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"[This page continues automatically]","DataExportTag":"Q390","QuestionID":"QID390"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID391","SecondaryAttribute":"Which option do you prefer if the winning chance of the lottery on the right is 35%?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which option do you prefer if the winning chance of the lottery on the right is <b>35%<\/b>?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    this.questionclick = function(event, element) {\n        var answer = that.getSelectedChoices();\n        window.pageAnswers.q8 = answer; \n\t\tconsole.log(answer);\n\t\twindow.validateAnswers();\n\t\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('riskID');\n\t\tQualtrics.SurveyEngine.setEmbeddedData(\"riskQ8_\" + id, answer);\n    };\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"DataExportTag":"risk8","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Which option do you prefer if the winning chance of the lottery on the right is 35%?","Choices":{"1":{"Display":"Get the prize with a ${e:\/\/Field\/pX_A0}% chance"},"2":{"Display":"Pay  ${e:\/\/Field\/currency}${e:\/\/Field\/cost} <br> Get the prize with a <b>35%<\/b> chance"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":3,"QuestionID":"QID391"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID392","SecondaryAttribute":"Which option do you prefer if the winning chance of the lottery on the right is 40%?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which option do you prefer if the winning chance of the lottery on the right is <b>40%<\/b>?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    this.questionclick = function(event, element) {\n        var answer = that.getSelectedChoices();\n        window.pageAnswers.q9 = answer; \n\t\tconsole.log(answer);\n\t\twindow.validateAnswers();\n\t\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('riskID');\n\t\tQualtrics.SurveyEngine.setEmbeddedData(\"riskQ9_\" + id, answer);\n    };\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":fal