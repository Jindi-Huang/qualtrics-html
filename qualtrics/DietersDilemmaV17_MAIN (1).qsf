             \n                return false;\n            }\n        }\n        \n        window.isValidating = false;\n        return true;\n    };\n});","QuestionText_Unsafe":"<span style=\"font-size:19px;\">On this page, you choose between pairs of lotteries for a <b>${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}<\/b> prize.<br>\n<br>\nIn each pair, the lottery on the left offers a lower chance of winning (<b>${e:\/\/Field\/pX_A0} in 10<\/b>) than the lottery on the right (<b>${e:\/\/Field\/pX_A1} in 10<\/b>).<br>\n<br>Pressing your button always incurs a cost of ${e:\/\/Field\/currency}${e:\/\/Field\/cost}, regardless of whether you win the prize.&nbsp;<\/span>","DataExportTag":"Q382","QuestionID":"QID382"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID383","SecondaryAttribute":"Which option do you prefer if the winning chance of the lottery on the right is 0%?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which option do you prefer if the winning chance of the lottery on the right is <strong>0%<\/strong>?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    \/*Place your JavaScript here to run when the page loads*\/\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    var that = this;\n    this.questionclick = function(event, element) {\n        var answer = that.getSelectedChoices();\n        window.pageAnswers.q1 = answer; \n\t\twindow.validateAnswers();\n\t\tconsole.log(answer);\n\t\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('riskID');\n\t\tQualtrics.SurveyEngine.setEmbeddedData(\"riskQ1_\" + id, answer);\n    };\n\t\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Which option do