    var allAnswers = Qualtrics.SurveyEngine.getEmbeddedData(\"allAnswersDieterQ1\") || \"\";\n    \n    var nextBtn = document.getElementById(\"NextButton\");\n    nextBtn.addEventListener(\"click\", function(e)\n    {\n        var userAnswer = that.getSelectedChoices() || \"none\";\n        \n        \/\/ Add this answer to history\n        if (allAnswers === \"\") {\n            allAnswers = userAnswer;\n        } else {\n            allAnswers = allAnswers + \"||\" + userAnswer;\n        }\n        \n        \/\/ Check if correct\n        if (userAnswer === correctAnswer) {\n            \/\/ Correct!\n        } else {\n            \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCountDieterQ1\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswersDieterQ1\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID366","SecondaryAttribute":"Which of the following statements about the game versions and the display order are correct? Sele...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Which of the following statements about the game versions and the display order are correct?<\/b> Select all that apply.","DefaultChoices":false,"DataExportTag":"compreh2","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which of the following statements about the game versions and the display order are correct? Sele...","Choices":{"1":{"Display":"If I'm playing with Ann and Bob and I see Bob's choice after Ann\u2019s, this means that Bob decided after Ann."},"2":{"Display":"If I