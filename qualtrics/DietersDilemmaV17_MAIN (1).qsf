:false,"DataExportTag":"Q425","QuestionID":"QID432","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID433","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const metaData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tvar gameCounter = parseInt(\"${e:\/\/Field\/gameCounter}\") + 1;\n \tQualtrics.SurveyEngine.setEmbeddedData('gameCounter', gameCounter);\n    const causal = metaData.causal;\n\tconst beta00 = metaData.beta00 || null;\n\tconst beta01 = metaData.beta01 || null;\n\tconst beta10 = metaData.beta10 || null;\n\tconst beta11 = metaData.beta11 || null;\n\tconst sigma0 = metaData.sigma0 || null;\n\tconst sigma1 = metaData.sigma1 || null;\n\tconst rho0 = metaData.rho0 || null;\n\tconst rho1 = metaData.rho1 || null;\n\tconst pX_Y = metaData.pX_Y || null;\n\tconst pX_y = metaData.pX_y || null;\n\tconst id = metaData.id;\n\tconst pA = metaData.pA || null;\n\tconst order = metaData.order || null;\n\tconst treatment = metaData.treatment;\n\tconst current = metaData.game;\n\tconst pY = metaData.pY;\n\tconst linkfn = metaData.linkfn; \n\tlet playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + gameCounter);\n\tlet playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + gameCounter);\n\tconst playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1_' + gameCounter);\n\tconst playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2_' + gameCounter);\n\tconst playerIcon1 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon1_' + gameCounter);\n\tconst playerIcon2 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon2_' + gameCounter);\n\n\tlet gameOrder = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('gameOrder'));\n\tgameOrder.push(id);\n\tconsole.log(\"Current Game ID: \");\n\tconsole.log(id);\n\t\n\tplayerName1 = playerName1 + \" (Co-Player)\";\n\tplayerName2 = playerName2 + \" (Bonus Player)\";\n\t\n\tlet playerNameDisplay1 = \"\";\n\tlet playerNameDisplay2 = \"\";\n\tlet playerDescription1 = \"\";\n\tlet playerDescription2 = \"\";\n\n\tif (order == \"AYX\") {\n\t\tplayerNameDisplay1 = playerName2;\n\t\tplayerNameDisplay2 = playerName1;\n\t\tplayerDescription1 = \"(the player at the bottom of the screen)\";\n\t\tplayerDescription2 = \"(the player in the middle of the screen)\";\n\t}\n\telse {\n\t\tplayerNameDisplay1 = playerName1;\n\t\tplayerNameDisplay2 = playerName2;\n\t\tplayerDescription1 = \"(the player in the middle of the screen)\";\n\t\tplayerDescription2 = \"(the player at the bottom of the screen)\";\n\t}\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('gameOrder', JSON.stringify(gameOrder));\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName1', playerName1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName2', playerName2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', playerPronoun1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', playerPronoun2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerNameDisplay1', playerNameDisplay1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerNameDisplay2', playerNameDisplay2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerDescription1', playerDescription1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerDescription2', playerDescription2);\n\t\n\t\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerName1', 'Player 1');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerName2', 'Player 2');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', 'their');\n\t\/\/Qualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', 'their');\n\t\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon1', playerIcon1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon2', playerIcon2);\n\tQualtrics.SurveyEngine.setEmbeddedData('causal', causal);\n\tQualtrics.SurveyEngine.setEmbeddedData('sigma0', sigma0);\n\tQualtrics.SurveyEngine.setEmbeddedData('sigma1', sigma1);\n\tQualtrics.SurveyEngine.setEmbeddedData('rho0', rho0);\n\tQualtrics.SurveyEngine.setEmbeddedData('rho1', rho1);\n\tQualtrics.SurveyEngine.setEmbeddedData('beta00', beta00);\n\tQualtrics.SurveyEngine.setEmbeddedData('beta01', beta01);\n\tQualtrics.SurveyEngine.setEmbeddedData('beta10', beta10);\n\tQualtrics.SurveyEngine.setEmbeddedData('beta11', beta11);\n\tQualtrics.SurveyEngine.setEmbeddedData('id', id);\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_Y', pX_Y);\n\tQualtrics.SurveyEngine.setEmbeddedData('pX_y', pX_y);\n\tQualtrics.SurveyEngine.setEmbeddedData('pA', pA);\n\tQualtrics.SurveyEngine.setEmbeddedData('current', current);\n\tQualtrics.SurveyEngine.setEmbeddedData('treatment', treatment);\n\tQualtrics.SurveyEngine.setEmbeddedData('pY', pY);\n\tQualtrics.SurveyEngine.setEmbeddedData('order', order);\n\tQualtrics.SurveyEngine.setEmbeddedData('linkfn', linkfn);\n\t\n\tQualtrics.SurveyEngine.setEmbeddedData('roundCounter', 0);\n\t\n\t\n\n\tconsole.log(gameOrder);\n\t\n\tjQuery(\"#NextButton\").click();\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"[This page continues automatically]","DataExportTag":"Q433","QuestionID":"QID433"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID434","SecondaryAttribute":"In the next two games, you will sometimes not have a choice about your own button. In these cases...","TertiaryAttribute":null,"Payload":{"QuestionText":"In the next two games, <b>you will sometimes not have a choice about your own button<\/b>. In these cases, you will either have to press &quot;Yes&quot; or have to press &quot;No&quot;. In these cases, you will have to press the buttons&nbsp;<em>with your mouse<\/em>.<br \/>\n<br \/>\nAt other times, you will be able to choose freely. In these cases, you will not see Player 2&rsquo;s choice, but it may nonetheless determine your payment. You will have to make these choices with your keyboard, pressing <em>y<\/em> for &quot;yes&quot; and <em>n<\/em> for &quot;no.&quot;","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In the next two games, you will sometimes not have a choice about your own button. In these cases...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> exo <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"exo","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_5njDz3P0yi3K2zk,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"2":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span><span> False<\/span>","LogicType":"BooleanValue","Type":"Expression","Value":"False"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"In the next two games, <b>you will sometimes not have a choice about your own button<\/b>. In these cases, you will either have to press &quot;Yes&quot; or have to press &quot;No&quot;. In these cases, you will have to press the buttons&nbsp;<em>with your mouse<\/em>.<br \/>\n<br \/>\nAt other times, you will be able to choose freely. In these cases, you will not see Player 2&rsquo;s choice, but it may nonetheless determine your payment. You will have to make these choices with your keyboard, pressing <em>y<\/em> for &quot;yes&quot; and <em>n<\/em> for &quot;no.&quot;","DataExportTag":"Q434","QuestionID":"QID434"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID435","SecondaryAttribute":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DataExportTag":"Q435","QuestionID":"QID435","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"testing","Operator":"EqualTo","RightOperand":"0","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID436","SecondaryAttribute":"[Will be replaced with animation]","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[Will be replaced with animation]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  this.hidePreviousButton();\n  this.hideNextButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n  \/* -------------------- CONFIG -------------------- *\/\n  const cols = 4, rows = 3;\n  const symbols = [\n    \"\u25c6\", \"\u25b2\", \"\u25cf\", \"\u25a0\", \"\u2605\", \"\u271a\", \"\u2b20\", \"\u2b22\", \"\u25d2\", \"\u2618\ufe0e\",\n    \"\u2726\", \"\u272a\", \"\u2729\", \"\u2730\", \"\u2736\", \"\u2737\", \"\u273a\", \"\u273b\", \"\u273c\", \"\u2742\"\n  ];\n  const total = cols * rows, gap = 20, swaps = 8;\n  const fadeDelay = 150, zoomDelay = 550;\n  \n  \/\/ Use discrete hue steps (30\u00b0 intervals) for better color distinction\n  const hueSteps = 12; \/\/ 360\u00b0 \/ 12 = 30\u00b0 per step\n  const minHueDistance = 30; \/\/ Minimum difference between hues\n\n  \/* ---------------- INITIAL SETUP ------------------ *\/\n  const container = document.getElementById('container');\n  if (!container) return;\n  container.textContent = \"\";\n\n  const size = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--size'), 10) || 70;\n  \n  \/\/ Get shown symbols and hues from embedded data\n  let shownSymbols = [];\n  try {\n    shownSymbols = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownSymbols') || \"[]\");\n  } catch (e) { shownSymbols = []; }\n  \n  let shownHues = [];\n  try {\n    shownHues = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownHues') || \"[]\");\n  } catch (e) { shownHues = []; }\n\n  \/\/ Pick unique symbol\n  if (shownSymbols.length >= symbols.length) shownSymbols = [];\n  let chosenSym = symbols.find(sym => !shownSymbols.includes(sym)) || symbols[0];\n  shownSymbols.push(chosenSym);\n\n  \/\/ Pick unique hue with discrete steps\n  if (shownHues.length >= hueSteps) shownHues = [];\n  let chosenHue;\n  \n  \/\/ Find a hue that's sufficiently different from previous ones\n  for (let attempt = 0; attempt < 100; attempt++) {\n    const step = Math.floor(Math.random() * hueSteps);\n    const candidateHue = step * (360 \/ hueSteps);\n    \n    \/\/ Check against all previously used hues\n    const isDistinct = shownHues.every(usedHue => {\n      const diff = Math.abs(candidateHue - usedHue);\n      return Math.min(diff, 360 - diff) >= minHueDistance;\n    });\n    \n    if (isDistinct) {\n      chosenHue = candidateHue;\n      shownHues.push(chosenHue);\n      break;\n    }\n  }\n  \n  \/\/ Fallback if no distinct hue found\n  if (chosenHue === undefined) {\n    chosenHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n    shownHues = [chosenHue];\n  }\n\n  \/\/ Store selections\n  Qualtrics.SurveyEngine.setEmbeddedData('shownSymbols', JSON.stringify(shownSymbols));\n  Qualtrics.SurveyEngine.setEmbeddedData('shownHues', JSON.stringify(shownHues));\n  Qualtrics.SurveyEngine.setEmbeddedData('currentSymbol', chosenSym);\n  Qualtrics.SurveyEngine.setEmbeddedData('currentHue', chosenHue);\n\n  \/\/ Create positions\n  const positions = [];\n  for (let r = 0; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      positions.push({ left: c * (size + gap), top: r * (size + gap) });\n    }\n  }\n\n  const chosenIndex = Math.floor(Math.random() * total);\n  let chosenTile = null;\n  const games = [];\n\n  for (let i = 0; i < total; i++) {\n    const tile = document.createElement('div');\n    tile.className = 'game';\n    \n    \/\/ Generate distinct hues for other tiles\n    let tileHue;\n    if (i === chosenIndex) {\n      tileHue = chosenHue;\n    } else {\n      \/\/ Ensure other tiles don't match the chosen hue\n      do {\n        tileHue = Math.floor(Math.random() * hueSteps) * (360 \/ hueSteps);\n      } while (tileHue === chosenHue);\n    }\n    \n    tile.style.setProperty('--hue', tileHue);\n    \n    \/\/ Create tile structure using DOM methods\n    const inner = document.createElement('div');\n    inner.className = 'inner';\n    \n    const back = document.createElement('div');\n    back.className = 'face back';\n    \n    const front = document.createElement('div');\n    front.className = 'face front';\n    \n    \/\/ Only add content to the chosen tile\n    if (i === chosenIndex) {\n      const label = document.createElement('div');\n      label.className = 'label';\n      label.textContent = 'Game';\n      \n      const sym = document.createElement('div');\n      sym.className = 'sym';\n      sym.textContent = chosenSym;  \/\/ Use textContent for symbols\n      \n      front.appendChild(label);\n      front.appendChild(sym);\n    }\n    \n    inner.appendChild(back);\n    inner.appendChild(front);\n    tile.appendChild(inner);\n    \n    tile.style.left = positions[i].left + 'px';\n    tile.style.top = positions[i].top + 'px';\n    container.appendChild(tile);\n    \n    games.push(tile);\n    if (i === chosenIndex) chosenTile = tile;\n  }\n\n  let currentPositions = [...positions];\n  let step = 0;\n\n  const interval = setInterval(() => {\n    \/\/ Shuffle positions\n    for (let i = currentPositions.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i + 1));\n      [currentPositions[i], currentPositions[j]] = [currentPositions[j], currentPositions[i]];\n    }\n    \n    \/\/ Apply new positions\n    games.forEach((game, i) => {\n      game.style.left = currentPositions[i].left + 'px';\n      game.style.top = currentPositions[i].top + 'px';\n    });\n    \n    if (++step >= swaps) {\n      clearInterval(interval);\n      reveal();\n    }\n  }, 250);\n\n  function reveal() {\n    games.forEach(game => {\n      if (game !== chosenTile) game.classList.add('faded');\n    });\n    \n    setTimeout(() => {\n      chosenTile.classList.add('flipped');\n      setTimeout(() => {\n        chosenTile.classList.add('chosen');\n        jQuery('#NextButton').fadeIn(500);\n      }, zoomDelay - fadeDelay);\n    }, fadeDelay);\n  }\n});","QuestionText_Unsafe":"<style>\n    :root{--size:70px;}\n  *{box-sizing:border-box;margin:0;padding:0;}\n  body{display:flex;justify-content:center;align-items:center;height:100vh;background:#fff;}\n  .container{\n    position:relative;\n    width:calc(var(--size)*4 + 60px);\n    height:calc(var(--size)*3 + 40px);\n    margin:20px auto;              \/* center within Qualtrics question *\/\n} \n\n  \/* TILE STRUCTURE *\/\n  .game{\n    position:absolute;\n    width:var(--size);\n    height:var(--size);\n    perspective:600px;\n    transition:left .4s ease, top .4s ease, transform .4s ease, opacity .6s ease;\n    border-radius:12px;\n    overflow:hidden;\n    background:hsl(var(--hue) 70% 85%);\n  }\n  .inner{\n    width:100%;\n    height:100%;\n    position:relative;\n    transform-style:preserve-3d;\n    transition:transform 1s ease;\n  }\n  .face{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    backface-visibility:hidden;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n  }\n  .back{background:inherit;}\n  .front{\n    background:inherit;\n    transform:rotateY(180deg);\n  }\n  .front .label{font-size:14px;line-height:1;color:#333;margin-bottom:2px;}\n  .front .sym{font-size:38px;line-height:1;color:#333;}\n\n  \/* STATES *\/\n  .flipped .inner{transform:rotateY(180deg);}           \/* reveal symbol *\/\n  .faded{opacity:0.15;}\n  .chosen{\n    box-shadow:0 0 40px rgba(0,0,0,0.25);\n    transform:scale(1.8) translate(-50%, -50%) !important;\n    left:50% !important;\n    top:50% !important;\n    z-index:10;\n  }\n<\/style>\n\n<div class=\"container\" id=\"container\">[Will be replaced with animation]<\/div>","DataExportTag":"Q436","QuestionID":"QID436","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"testing","Operator":"EqualTo","RightOperand":"0","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID437","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <s