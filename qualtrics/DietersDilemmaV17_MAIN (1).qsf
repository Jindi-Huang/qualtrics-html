Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\t<br> \n\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will play this game with ${e:\/\/Field\/playerNameDisplay1} and ${e:\/\/Field\/playerNameDisplay2}....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tif (loopNum != 1){\n\t\tvar loopPrev = loopNum - 1;\n\t\tvar name1prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopPrev);\n\t\tvar name2prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopPrev);\n\t\tjQuery(this.questionContainer).find(\"#D2\").html(\"They may play differently than \" +  name1prev + \" and \" + name2prev +\", with whom you played the previous game.\");\n\t}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<div style=\"text-align: center;\">\n\nYou will play this game with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}. <span id=\"D2\">&nbsp;<\/span>\n\n<table align=\"center\" border=\"0\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:300px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon1}\"><\/td>\n\t\t\t<td style=\"text-align: center;\"><img alt=\"Player\" class=\"panel-icon\" src=\"${e:\/\/Field\/playerIcon2}\"><\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName1}<\/td>\n\t\t\t<td style=\"text-align: center;\">${e:\/\/Field\/playerName2}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br>\n\t<b>The computer has now determined which version of the game you will play.<\/b>\n\t\n\t<\/div>","DataExportTag":"Q304","QuestionID":"QID304","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>"},"1":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID305","SecondaryAttribute":"Game Game ${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Game ${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n","DataExportTag":"Q305","QuestionID":"QID305","DisplayLogic":{"0":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"NotEqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>"},"Type":"If"},"1":{"0":{"LogicType":"LoopAndMerge","LeftOperand":"BL_3E3lWivUg5B4L0W,3","RightOperand":"lm:\/\/CurrentLoop","Operator":"EqualTo","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"nSupergames","Operator":"EqualTo","RightOperand":"3","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","Conjuction":"And"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID306","SecondaryAttribute":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n\n <div class=\"panel-wrapper\">\n\n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n\n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hidePreviousButton();\n    this.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\tjQuery(\"#NextButton\").hide();\n\n\n   \n\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n\tconst buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\tconst linkfn = Qualtrics.SurveyEngine.getEmbeddedData('linkfn');\n\tconst basePay = parseFloat(\"${e:\/\/Field\/basePay}\");\n\tconst halfRounds = Math.floor(nRounds \/ 2);\n\n\t\/\/ Determine panel order and configure content\n\tconst isYFirst = order === \"AYX\";\n\n\tlet roundCounter    = parseInt(\"${e:\/\/Field\/roundCounter}\");\n\tlet X, A, Y;\n\tlet history         = [];\n\tlet roundTimes      = [];\n\tlet payment         = [];\n\tlet roundStartTime  = 0;\n    let firstPanelStartTime = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n\tlet xReady          = false;\n\tlet colorDisplayed  = false;\n\n\tconst btnNo        = document.getElementById(\"btnNo\");\n\tconst btnYes       = document.getElementById(\"btnYes\");\n\tconst panelXinfo   = document.getElementById(\"panelXinfo\");\n\tconst panelYinfo   = document.getElementById(\"panelYinfo\");\n\tconst panelAchoice = document.getElementById(\"panelAchoice\");\n\tconst resultText   = document.getElementById(\"resultText\");\n\tconst riskText     = document.getElementById(\"riskText\");\n\tconst roundDisplay = document.getElementById(\"roundDisplay\");\n\tconst actionPrompt = document.getElementById(\"actionPrompt\"); \n\n\t\/\/ Set up first and second panels based on order\n\tconst firstPanel = isYFirst ? panelYinfo : panelXinfo;\n\tconst secondPanel = isYFirst ? panelXinfo : panelYinfo;\n\tconst firstPanelText = isYFirst ? resultText : riskText;\n\tconst secondPanelText = isYFirst ? riskText : resultText;\n\t\n\t\n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n\t\/\/ Function to get panel content\n\tfunction getPanelContent(panelType, value, isPlayerChoice) {\n\t\tif (panelType === 'X') {\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value \n\t\t\t\t\t? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t};\n\t\t} else { \/\/ Y panel\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value\n\t\t\t\t\t? \"${e:\/\/Field\/playerName2} pressed ${e:\/\/Field\/playerPronoun2} button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!).\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).\"\n\t\t\t};\n\t\t}\n\t}\n\n\t\/\/ Swap visual order if needed\n\tif (isYFirst) {\n\t\tconst parent = panelXinfo.parentNode;\n\t\tparent.insertBefore(panelYinfo, panelXinfo);\n\t}\n    \n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\n    [panelAchoice, panelXinfo, panelYinfo].forEach(p => p.style.border = \"1px solid black\");\n\n    btnYes.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('y');\n        }\n    });\n    btnNo.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('n');\n        }\n    });\n    \n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    const causal = parseInt(\"${e:\/\/Field\/causal}\");\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst sigma0 = parseFloat(\"${e:\/\/Field\/sigma0}\");\n\tconst sigma1 = parseFloat(\"${e:\/\/Field\/sigma1}\");\n\tconst rho0 = parseFloat(\"${e:\/\/Field\/rho0}\");\n\tconst rho1 = parseFloat(\"${e:\/\/Field\/rho1}\");\n\tconst beta00 = parseFloat(\"${e:\/\/Field\/beta00}\");\n\tconst beta01 = parseFloat(\"${e:\/\/Field\/beta01}\");\n\tconst beta10 = parseFloat(\"${e:\/\/Field\/beta10}\");\n\tconst beta11 = parseFloat(\"${e:\/\/Field\/beta11}\");\n    function handleDecision(decision) {\n        if (!panelAchoice || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tlet pX = [0, 0, 0, 0];\n        A = decision === 'y' ? 1 : 0;\n        if (causal === 0) {\n\t\t\tpX = [beta00, beta01, beta10, beta11];\n\t\t\tY = Math.random() < pY ? 1 : 0;\n\t\t\tX = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            \n        } else {\n            const pX = [sigma0, sigma1];\n            const pY = [rho0, rho1];\n            X = Math.random() < pX[A] ? 1 : 0;\n            Y = Math.random() < pY[X] ? 1 : 0;\n        }\n\n        history.push([A, X, Y]);\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        payment.push(-aCost*A + yBonus*Y + basePay);\n\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n            \/\/ Show first panel\n            const firstPanelType = isYFirst ? 'Y' : 'X';\n            const firstValue = isYFirst ? Y : X;\n            const content = getPanelContent(firstPanelType, firstValue, isPlayerChoiceRound);\n\n            firstPanel.style.backgroundColor = content.color;\n            firstPanelText.innerHTML = content.text + \" <br>(press 'c' to continue)\";\n            secondPanel.style.backgroundColor = \"white\";\n            xReady = true;\n            firstPanelStartTime = Date.now(); \/\/ ADD THIS LINE\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        const yesVisible = btnYes.style.display !== \"none\" && !btnYes.disabled;\n        const noVisible = btnNo.style.display !== \"none\" && !btnNo.disabled;\n        \n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound) {\n            if (e.key === 'y' && yesVisible) {\n                handleDecision('y');\n            }\n            else if (e.key === 'n' && noVisible) {\n                handleDecision('n');\n            }\n        }\n        \n        \/\/ Continue key always works regardless of round type\n        if (e.key === 'c' && xReady) {\n            const firstTimeRemaining = (firstPanelStartTime + 500) - Date.now();\n            \n            if (firstTimeRemaining > 0) {\n                setTimeout(() => {\n                    showSecondPanel();\n                }, firstTimeRemaining);\n            } else {\n                showSecondPanel();\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tresultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function showSecondPanel() {\n    const currentRoundIndex = roundCounter - 1;\n    const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n    \/\/ Show second panel\n    const secondPanelType = isYFirst ? 'X' : 'Y';\n    const secondValue = isYFirst ? X : Y;\n    const content = getPanelContent(secondPanelType, secondValue, isPlayerChoiceRound);\n\n    secondPanel.style.backgroundColor = content.color;\n    secondPanelText.innerHTML = content.text + \" <br>(press 'space' to continue)\";\n    xReady = false;\n    colorDisplayed = true;\n    resultPanelStartTime = Date.now();\n}\n\n    function initiateRound() {\n        panelAchoice.style.display =\n        panelXinfo.style.display =\n        panelYinfo.style.display = \"none\";\n        setTimeout(() => {\n            showActionPanels();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history1_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes1_' + id, JSON.stringify(roundTimes));\n        Qualtrics.SurveyEngine.setEmbeddedData('payment1_' + id, JSON.stringify(payment));\n\t\tQualtrics.SurveyEngine.setEmbeddedData('roundCounter', roundCounter);\n        if (roundCounter < halfRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === halfRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n            \n            jQuery(\"#NextButton\").click();\n        }\n    }\n\n    function showActionPanels() {\n        panelAchoice.style.display = \"flex\";\n        panelXinfo.style.display   = \"flex\";\n        panelYinfo.style.display   = \"flex\";\n        panelXinfo.style.backgroundColor =\n        panelYinfo.style.backgroundColor = \"white\";\n        riskText.textContent = resultText.textContent = \"\";\n\n        const showBothButtons = treatment === \"endog\" ? 1 : buttonConfig[roundCounter - 1];\n        \n        if (showBothButtons === 1) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            \n            if (Math.random() < pA) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = \"You must press \\\"Yes\\\" in this round. <br> Press your button? (Use your mouse)\";\n            } else {\n                \/\/ Force No\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = \"You must press \\\"No\\\" in this round. <br> Press your button? (Use your mouse)\";\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        \n <div class=\"panel-wrapper\">\n     \n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n\t\t\t<div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n\t\t\t<div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n\t\t\t<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n        \n        \n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","DataExportTag":"decision1","QuestionID":"QID306","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID307","SecondaryAttribute":"You Press your button? No Yes ${e:\/\/Field\/playerName2} (determines your bonus)","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n#actionPrompt {\n    padding-bottom: 2px; \n}\n\n#panelX {\n    padding-top: 2px; \n}\n\n#panelAchoice {\n\theight: 190px;\n}\n\n#panelYinfo {\n\theight: 190px;\n}\n\n\n<\/style>\n\n<body>\n    <div style=\"height:450px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n           <div class=\"panel-wrapper\">\n        <div id=\"panelAchoice\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <div class=\"panel-name\"> You <\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div id=\"panelX\" class=\"text\"><\/div>\n            <div class=\"button-container\">\n                <button id=\"btnNo\" class=\"actionButton red\">No<\/button>\n                <button id=\"btnYes\" class=\"actionButton green\">Yes<\/button>\n            <\/div>\n        <\/div>\n        <div id=\"panelYinfo\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n                <\/div>\n            <div id=\"resultText\" class=\"text\"><\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n\tconst aCost0 = parseFloat(\"${e:\/\/Field\/aCostMigraines0}\");\n\tconst aCost1 = parseFloat(\"${e:\/\/Field\/aCostMigraines1}\");\n\tconst aCost = [aCost0, aCost1];\n\tconst yBonus = Qualtrics.SurveyEngine.getEmbeddedData('yBonus');\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    const buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tconst pY            = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst pX_Y\t\t    = parseFloat(\"${e:\/\/Field\/pX_Y}\");\n\tconst pX_y \t\t\t= parseFloat(\"${e:\/\/Field\/pX_y}\");\n    let roundCounter    = 0;\n    let X, A, Y;\n    let history         = [];\n    let roundTimes      = [];\n\tlet payment         = [];\n    let roundStartTime  = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n    let userChoiceReady = false;\n    let colorDisplayed  = false;\n\n    const btnNo        = document.getElementById(\"btnNo\");\n    const btnYes       = document.getElementById(\"btnYes\");\n    const panelYinfo   = document.getElementById(\"panelYinfo\");\n    const panelAchoice = document.getElementById(\"panelAchoice\");\n    const panelX       = document.getElementById(\"panelX\");\n    const resultText   = document.getElementById(\"resultText\");\n    const riskText     = document.getElementById(\"riskText\");\n    const actionPrompt = document.getElementById(\"actionPrompt\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n\n    btnYes.addEventListener(\"click\", () => handleDecision('y'));\n    btnNo .addEventListener(\"click\", () => handleDecision('n'));\n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    \n\n    function generateChoices() {\n\t\tY = Math.random() < pY ? 1 : 0;\n\t\tconst pX = [pX_y, pX_Y];\n\t\tX = Math.random() < pX[Y] ? 1 : 0;\n    }\n\n    function handleDecision(decision) {\n        if (!userChoiceReady || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tA = decision === 'y' ? 1 : 0;\n        \n        history.push([A, X, Y]);\n\t\tpayment.push(yBonus*Y - A*aCost[X]);\n        userChoiceReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n            \n            if (isPlayerChoiceRound && treatment !== \"endog\") {\n                panelYinfo.style.backgroundColor = \"lightgray\";\n                resultText.innerHTML = \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.<br>(press 'space' to continue)\";\n            } else {\n                panelYinfo.style.backgroundColor = Y ? \"green\" : \"red\";\n                resultText.innerHTML = Y\n                    ? \"${e:\/\/Field\/playerName2} pressed his button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!)<br>(press 'space' to continue)\"\n                    : \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).<br>(press 'space' to continue)\";\n            }\n            colorDisplayed = true;\n\t\t\tresultPanelStartTime = Date.now();\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound && userChoiceReady && !btnYes.disabled) {\n            if (e.key === 'y') {\n                handleDecision('y');\n            }\n            else if (e.key === 'n') {\n                handleDecision('n');\n            }\n        }\n        \n        if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tconst resultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function initiateRound() {\n        panelAchoice.style.display = \"none\";\n        panelYinfo.style.display = \"none\";\n        panelYinfo.style.backgroundColor = \"white\";\n        \n        setTimeout(() => {\n            showUserChoice();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes_' + id, JSON.stringify(roundTimes));\n\t\tQualtrics.SurveyEngine.setEmbeddedData('payment_' + id, JSON.stringify(payment));\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === nRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n\t\t\tconsole.log(\"Payment:\", payment);\n            \n            jQuery(\"#NextButton\").show().click();\n        }\n    }\n\n    function showUserChoice() {\n        generateChoices();\n        \n        if (X === 1) {\n            panelX.innerHTML = \"(${e:\/\/Field\/playerName1} pressed \" + \"${e:\/\/Field\/playerPronoun1}\" + \" button)\";\n\t\t\tbtnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines1}\";\n\t\t\tbtnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines1}\";\n        } else {\n            panelX.innerHTML = \"(${e:\/\/Field\/playerName1} did <u>not<\/u> press \" + \"${e:\/\/Field\/playerPronoun1}\" + \" button)\";\n\t\t\tbtnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines0}\";\n\t\t\tbtnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines0}\";\n        }\n        \n        \/\/ Check if this is a player choice round or forced round\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        if (isPlayerChoiceRound) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            \n            if (Math.random() < pA || X == 1) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = 'You must press \"Yes\" in this round.<br>Press your button? (Use your mouse)';\n            } else {\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = 'You must press \"No\" in this round.<br>Press your button? (Use your mouse)';\n            }\n        }\n        \n        panelAchoice.style.display = \"flex\";\n        panelYinfo.style.display = \"flex\";\n        panelYinfo.style.backgroundColor = \"white\";\n        resultText.textContent = \"\";\n        \n        userChoiceReady = true;\n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? No Yes ${e:\/\/Field\/playerName2} (determines your bonus)","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> migraines <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"migraines","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<style>\n#actionPrompt {\n    padding-bottom: 2px; \n}\n\n#panelX {\n    padding-top: 2px; \n}\n\n#panelAchoice {\n\theight: 190px;\n}\n\n#panelYinfo {\n\theight: 190px;\n}\n\n\n<\/style>\n\n<body>\n    <div style=\"height:450px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n           <div class=\"panel-wrapper\">\n        <div id=\"panelAchoice\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <div class=\"panel-name\"> You <\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div id=\"panelX\" class=\"text\"><\/div>\n            <div class=\"button-container\">\n                <button id=\"btnNo\" class=\"actionButton red\">No<\/button>\n                <button id=\"btnYes\" class=\"actionButton green\">Yes<\/button>\n            <\/div>\n        <\/div>\n        <div id=\"panelYinfo\" class=\"panel\">\n\t\t\t<div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2} (determines your bonus)<\/div>\n                <\/div>\n            <div id=\"resultText\" class=\"text\"><\/div>\n        <\/div>\n    <\/div>\n\t<\/div>\n<\/body>","DataExportTag":"Q307","QuestionID":"QID307"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID308","SecondaryAttribute":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: -20px; text-align: center;\"><span style=\"font-size:13px;\">You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You can press \"n\" on your keyboard to select the No button and \"y\" to select the Yes button. You...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"position: absolute; bottom: 10px; margin: 0px; padding: 0px; text-align: center;\"><span style=\"font-size:13px;\">You can press &quot;n&quot; on your keyboard to select the No button and &quot;y&quot; to select the Yes button. You need to click with the mouse at least once for the keyboard commands to work.<\/span><\/div>","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperan