":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":52,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q530","QuestionID":"QID530"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID531","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dagElicitation.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1300px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var that = this;\n    var completed = false;\n\tconst id = parseInt(\"${e:\/\/Field\/id}\");\n\n    var messageHandler = function(event) {\n        var data = event.data;\n        if (!data || typeof data !== 'object') return;\n\n        if (data.type === 'DAG_DATA' && data.dataType === 'DAG_COMPLETE') {\n            if (completed) return;\n            completed = true;\n\n            var dagData = data.data;\n\n            Qualtrics.SurveyEngine.setEmbeddedData('subjDAG2_' + id, JSON.stringify(dagData.initialDAG));\n            Qualtrics.SurveyEngine.setEmbeddedData('dagConfidence2_' + id, dagData.confidence);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount2_' + id, dagData.DAGAlertCount);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('subjDAGTime2_' + id, JSON.stringify(dagData.initialDAGTime));\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('dagConfidenceTime2_' + id, JSON.stringify(dagData.confidenceTime));\n\n            console.log('DAG saved:', dagData);\n\n            window.removeEventListener('message', messageHandler);\n            setTimeout(function() {\n                jQuery(\"#NextButton\").click();\n            }, 500);\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    setTimeout(function() {\n        var iframe = document.getElementById('dietersGame');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                gameConfig: {\n                    playerName0: \"${e:\/\/Field\/playerName0}\",\n                    playerName1: \"${e:\/\/Field\/playerName1}\",\n                    playerIcon0: \"${e:\/\/Field\/playerIcon0}\",\n\t\t\t\t\tnoConfirmation: 1,\n                }\n            }, '*');\n        }\n    }, 1000);\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"&nbsp;\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span><\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three players below. An arrow from one player to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a player, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.<\/li>\n<\/ul>","DataExportTag":"Q531","QuestionID":"QID531"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID532","SecondaryAttribute":"How confident are you in your diagram? That is, what is the chance it correctly shows who can inf...","TertiaryAttribute":null,"Payload":{"QuestionText":"<script>\nfunction toggleDetails(btn) {\n    var content = document.getElementById('detailsContent');\n    if (content.style.display === 'none' || content.style.display === '') {\n        content.style.display = 'block';\n        btn.textContent = 'Hide details';\n    } else {\n        content.style.display = 'none';\n        btn.textContent = 'Show details';\n    }\n}\n<\/script>\n\n<p><b>\nHow confident are you in your diagram? That is, what is the chance it correctly shows who can influence whom?<\/b>  \n<\/p>\n<p style=\"font-size: 12pt\">The payment mechanism is set up such that you will earn the most by answering truthfully. <button onclick=\"toggleDetails(this)\" class=\"show-details-btn\">\n    Show details\n<\/button>\n<\/p>\n<div class=\"details-content\" id=\"detailsContent\" style=\"display: none;\">\n  <p>\n  Here's how the payment system works:\n  <\/p>\n  <ol>\n    <li>After you enter your confidence, we will randomly draw a number <b>X<\/b> between 0 and 100.<\/li>\n    <li>If your stated confidence is <b>greater than X%<\/b>:\n      <ul>\n        <li>You will receive a <b>${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus<\/b> if the \"who influences whom\" relationship you provided in the previous question is correct.<\/li>\n      <\/ul>\n    <\/li>\n    <li>If your stated confidence is <b>less than X<\/b>:\n      <ul>\n        <li>You will have a <b>X% chance<\/b> of receiving the ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus, regardless of whether your answer was correct.<\/li>\n      <\/ul>\n    <\/li>\n  <\/ol>\n  <p>\n  This setup ensures that <b>you maximize your expected payment by reporting your true confidence<\/b>.  \n  Overstating or understating your confidence will only reduce your chance of earning the bonus. Hence, it is in your own best interest to state what you truly think. \n  <\/p>\n\t<br>\n<\/div>\n\n","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you in your diagram? That is, what is the chance it correctly shows who can inf...","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tjQuery(\"#\"+this.questionId+\" .numbers li\").each(function(){\n\t\tjQuery(this).text((jQuery(this).text()+\"%\").trim().replace(\" \",\"\"));\n\t});\n\t\n\tvar q = jQuery(\"#\"+this.questionId);\n\tq.find(\".handle\").css('visibility', 'hidden');\n\tq.find(\".track\").css('cursor', 'pointer');\n\tq.find(\".track\").on(\"click , touchstart\", function() {\n\t\tjQuery(this).find(\".handle\").css('visibility', 'visible');\n\t});\n\t\n\tfor (var i = 0; i <= 100; i += 10) {\n\t\tvar percentage = i + \"%\";\n\t\tjQuery(\"#\" + this.questionId + \" .numbers li:eq(\" + (i \/ 10) + \")\").html(percentage);\n\t}\n\t\n\t\/\/ Save slider value on Next button click\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\tvar that = this;\n\tvar nextBtn = document.getElementById(\"NextButton\");\n\tnextBtn.addEventListener(\"click\", function(e)\n\t{\n\t\tvar answer = that.getChoiceValue(1);\n\t\tQualtrics.SurveyEngine.setEmbeddedData(\"confidenceDAG2_\" + id, answer);\n\t\tconsole.log('confidenceDAG2_' + id + ':', answer);\n\t}, true);\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<script>\nfunction toggleDetails(btn) {\n    var content = document.getElementById('detailsContent');\n    if (content.style.display === 'none' || content.style.display === '') {\n        content.style.display = 'block';\n        btn.textContent = 'Hide details';\n    } else {\n        content.style.display = 'none';\n        btn.textContent = 'Show details';\n    }\n}\n<\/script>\n\n<p><b>\nHow confident are you in your diagram? That is, what is the chance it correctly shows who can influence whom?<\/b>  \n<\/p>\n<p style=\"font-size: 12pt\">The payment mechanism is set up such that you will earn the most by answering truthfully. <button onclick=\"toggleDetails(this)\" class=\"show-details-btn\">\n    Show details\n<\/button>\n<\/p>\n<div class=\"details-content\" id=\"detailsContent\" style=\"display: none;\">\n  <p>\n  Here's how the payment system works:\n  <\/p>\n  <ol>\n    <li>After you enter your confidence, we will randomly draw a number <b>X<\/b> between 0 and 100.<\/li>\n    <li>If your stated confidence is <b>greater than X%<\/b>:\n      <ul>\n        <li>You will receive a <b>${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus<\/b> if the \"who influences whom\" relationship you provided in the previous question is correct.<\/li>\n      <\/ul>\n    <\/li>\n    <li>If your stated confidence is <b>less than X<\/b>:\n      <ul>\n        <li>You will have a <b>X% chance<\/b> of receiving the ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} bonus, regardless of whether your answer was correct.<\/li>\n      <\/ul>\n    <\/li>\n  <\/ol>\n  <p>\n  This setup ensures that <b>you maximize your expected payment by reporting your true confidence<\/b>.  \n  Overstating or understating your confidence will only reduce your chance of earning the bonus. Hence, it is in your own best interest to state what you truly think. \n  <\/p>\n\t<br>\n<\/div>\n\n","DataExportTag":"Q532","QuestionID":"QID532"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID533","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":40,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q533","QuestionID":"QID533"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID534","SecondaryAttribute":"In your own words, please describe how you usually chose between \"drink xxx\" and \"No\" in game Gam...","TertiaryAttribute":null,"Payload":{"QuestionText":"In your own words, please describe how you usually chose between \"drink xxx\" and \"No\" in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span>. How did your decision making evolve over time?","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tjQuery(\"#\"+this.questionId+\" .InputText:eq(0)\").on(\"cut copy paste\",function(e) {\n   e.preventDefault();\n  });\n});\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/\/ Get rational inference data\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\tconst rationalInference = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('rationalInference_' + id));\n\t\n\t\/\/ Payment settings\n\tconst beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n\tconst beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n\t\n\t\/\/ Function to convert percentage (0-100) to category (1-10)\n\tfunction percentageToCategory(value) {\n\t\tif (value >= 0 && value <= 10) return 1;\n\t\tif (value > 10 && value <= 20) return 2;\n\t\tif (value > 20 && value <= 30) return 3;\n\t\tif (value > 30 && value <= 40) return 4;\n\t\tif (value > 40 && value <= 50) return 5;\n\t\tif (value > 50 && value <= 60) return 6;\n\t\tif (value > 60 && value <= 70) return 7;\n\t\tif (value > 70 && value <= 80) return 8;\n\t\tif (value > 80 && value <= 90) return 9;\n\t\tif (value > 90 && value <= 100) return 10;\n\t\treturn null;\n\t}\n\t\n\t\/\/ Variables to process\n\tconst verbalVariables = ['dieterPA', 'dieterPX', 'dieterPY', 'dieterSameYes', 'dieterSameNo'];\n\tconst verbalPayments = [];\n\t\n\t\/\/ Loop through each variable\n\tfor (let i = 0; i < verbalVariables.length; i++) {\n\t\tconst varName = verbalVariables[i];\n\t\t\n\t\t\/\/ Get user's answer (should be category 1-10)\n\t\tconst userAnswer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData(varName + '_' + id));\n\t\t\n\t\t\/\/ Get correct value (percentage) and convert to category\n\t\tconst correctValue = rationalInference[varName];\n\t\tconst correctCategory = percentageToCategory(correctValue);\n\t\t\n\t\t\/\/ Calculate payment\n\t\tconst difference = Math.abs(correctCategory - userAnswer);\n\t\tconst payment = beliefPaymentMax - (difference * beliefPaymentIncentive);\n\t\t\n\t\t\/\/ Store payment in array\n\t\tverbalPayments.push(payment);\n\t\t\n\t\tconsole.log(varName + ' - Correct:', correctValue, 'Category:', correctCategory, 'Answer:', userAnswer, 'Payment:', payment);\n\t}\n\t\n\tconst subjDAG1_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG1_' + id);\n\tconst subjDAG2_answer = Qualtrics.SurveyEngine.getEmbeddedData('subjDAG2_' + id);\n\tconsole.log(id);\n\tconst causal = parseInt(\"${e:\/\/Field\/causal}\");\n\tlet correctDAG;\n\tif (causal == 0){\n\t\tcorrectDAG = '[{\"source\":\"you\",\"target\":\"p1\"},{\"source\":\"p2\",\"target\":\"p1\"}]';\n\t}\n\telse if (causal == 1){\n\t\tcorrectDAG = '[{\"source\":\"you\",\"target\":\"p1\"},{\"source\":\"p1\",\"target\":\"p2\"}]';\n\t}\n\t\n\t\/\/ Calculate DAG payment\n\tconst dagPayment1 = (subjDAG1_answer === correctDAG) ? beliefPaymentMax : 0;\n\tconst dagPayment2 = (subjDAG2_answer === correctDAG) ? beliefPaymentMax : 0;\n\tverbalPayments.push(dagPayment1);\n\tverbalPayments.push(dagPayment2);\n\tconsole.log('subjDAG - Answer:', subjDAG1_answer, 'Correct:', correctDAG, 'Payment:', dagPayment1);\n\tconsole.log('subjDAG - Answer:', subjDAG2_answer, 'Correct:', correctDAG, 'Payment:', dagPayment2);\n\t\n\t\/\/ Calculate confidence DAG payment\n\tconst confidenceDAG1 = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('confidenceDAG1_' + id));\n\tconst confidenceDAG2 = parseFloat(Qualtrics.SurveyEngine.getEmbeddedData('confidenceDAG2_' + id));\n\t\n\t\/\/ Step 1: Randomly draw X from 0 to 100\n\tconst X = Math.random() * 100;\n\t\n\tlet confidenceDAGPayment1;\n\tlet confidenceDAGPayment2;\n\t\n\tif (X > confidenceDAG1) {\n\t\t\/\/ Step 2: Give max payment with X% chance\n\t\tconst randomChance = Math.random() * 100;\n\t\tconfidenceDAGPayment1 = (randomChance < X) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '> confidence1:', confidenceDAG1, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment1);\n\t} else {\n\t\t\/\/ Step 3: Give max payment if DAG answer is correct\n\t\tconfidenceDAGPayment1 = (subjDAG1_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '<= confidence1:', confidenceDAG1, ', DAG correct:', (subjDAG1_answer === correctDAG), ', Payment:', confidenceDAGPayment1);\n\t}\n\t\n\t\n\tif (X > confidenceDAG2) {\n\t\t\/\/ Step 2: Give max payment with X% chance\n\t\tconst randomChance = Math.random() * 100;\n\t\tconfidenceDAGPayment2 = (randomChance < X) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '> confidence2:', confidenceDAG2, ', Random chance:', randomChance, ', Payment:', confidenceDAGPayment2);\n\t} else {\n\t\t\/\/ Step 3: Give max payment if DAG answer is correct\n\t\tconfidenceDAGPayment2 = (subjDAG2_answer === correctDAG) ? beliefPaymentMax : 0;\n\t\tconsole.log('confidenceDAG - X:', X, '<= confidence1:', confidenceDAG2, ', DAG correct:', (subjDAG2_answer === correctDAG), ', Payment:', confidenceDAGPayment2);\n\t}\n\t\n\tverbalPayments.push(confidenceDAGPayment1);\n\tverbalPayments.push(confidenceDAGPayment2);\n\t\n\t\/\/ Calculate dieterVersion payment\n\tconst dieterVersion_answer = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('dieterVersion_' + id));\n\t\n\t\/\/ Determine correct answer based on causal\n\tconst dieterVersion_correct = (causal == 0) ? 10 : 1;\n\t\n\t\/\/ Calculate payment\n\tconst dieterVersion_difference = Math.abs(dieterVersion_correct - dieterVersion_answer);\n\tconst dieterVersion_payment = beliefPaymentMax - (dieterVersion_difference * beliefPaymentIncentive);\n\t\n\tverbalPayments.push(dieterVersion_payment);\n\tconsole.log('dieterVersion - Causal:', causal, 'Correct:', dieterVersion_correct, 'Answer:', dieterVersion_answer, 'Payment:', dieterVersion_payment);\n\t\n\t\/\/ Save the payment array to embedded data\n\tQualtrics.SurveyEngine.setEmbeddedData('verbalPayment_' + id, JSON.stringify(verbalPayments));\n\tconsole.log('Verbal Payments:', verbalPayments);\n});\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":600,"InputHeight":113},"QuestionDescription":"In your own words, please describe how you usually chose between \"drink xxx\" and \"No\" in game Gam...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"In your own words, please describe how you usually chose between &quot;Yes&quot; and &quot;No&quot; in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span>. How did your decision making evolve over time?","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q534","QuestionID":"QID534"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID535","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":28,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q535","QuestionID":"QID535"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID536","SecondaryAttribute":"DAG2 1: ${e:\/\/Field\/subjDAG2_1} DAG Confidence 1:\u00a0${e:\/\/Field\/dagConfidence2_1} DAG Alert Count 1..","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>DAG2 1: ${e:\/\/Field\/subjDAG2_1}<br \/>\nDAG Confidence 1:&nbsp;${e:\/\/Field\/dagConfidence2_1}<br \/>\nDAG Alert Count 1:&nbsp;${e:\/\/Field\/DAGAlertCount2_1}<br \/>\nDAG2 Time 1: ${e:\/\/Field\/subjDAGTime2_1}<br \/>\nDAG Confidence Time 1:&nbsp;${e:\/\/Field\/dagConfidenceTime2_1}<br \/>\n<br \/>\nDAG2 3: ${e:\/\/Field\/subjDAG2_3}<br \/>\nDAG Confidence 3:&nbsp;${e:\/\/Field\/dagConfidence2_3}<br \/>\nDAG Alert Count 3:&nbsp;${e:\/\/Field\/DAGAlertCount2_3}<br \/>\nDAG2 Time 3: ${e:\/\/Field\/subjDAGTime2_3}<br \/>\nDAG Confidence Time 3:&nbsp;${e:\/\/Field\/dagConfidenceTime2_3}<\/p>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"DAG2 1: ${e:\/\/Field\/subjDAG2_1} DAG Confidence 1:\u00a0${e:\/\/Field\/dagConfidence2_1} DAG Alert Count 1...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<p><span style=\"font-size:11px;\">${e:\/\/Field\/subjDAG_1}${e:\/\/Field\/subjDAG_2}${e:\/\/Field\/subjDAG_3}${e:\/\/Field\/subjDAG_4}${e:\/\/Field\/subjDAG_5}${e:\/\/Field\/subjDAG_6}${e:\/\/Field\/subjDAG_7}${e:\/\/Field\/subjDAG_8}${e:\/\/Field\/subjDAG_9}${e:\/\/Field\/subjDAG_10}${e:\/\/Field\/subjDAG_11}${e:\/\/Field\/subjDAG_12}${e:\/\/Field\/subjDAG_13}${e:\/\/Field\/subjDAG_14}${e:\/\/Field\/subjDAG_15}<\/span><br \/>\n&nbsp;<\/p>\n\n<p><span style=\"font-size:11px;\"><code>${e:\/\/Field\/DAGAlertCount_1}<br \/>\n${e:\/\/Field\/DAGAlertCount_2}<br \/>\n${e:\/\/Field\/DAGAlertCount_3}<br \/>\n${e:\/\/Field\/DAGAlertCount_4}<br \/>\n${e:\/\/Field\/DAGAlertCount_5}<br \/>\n${e:\/\/Field\/DAGAlertCount_6}<br \/>\n${e:\/\/Field\/DAGAlertCount_7}<br \/>\n${e:\/\/Field\/DAGAlertCount_8}<br \/>\n${e:\/\/Field\/DAGAlertCount_9}<br \/>\n${e:\/\/Field\/DAGAlertCount_10}<br \/>\n${e:\/\/Field\/DAGAlertCount_11}<br \/>\n${e:\/\/Field\/DAGAlertCount_12}<br \/>\n${e:\/\/Field\/DAGAlertCount_13}<br \/>\n${e:\/\/Field\/DAGAlertCount_14}<br \/>\n${e:\/\/Field\/DAGAlertCount_15}<\/code>&nbsp;<\/span><\/p>","DataExportTag":"Q536","QuestionID":"QID536"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID537","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    \/* Reset Qualtrics containers *\/\n    .Skin,\n    .SkinInner,\n    .QuestionOuter,\n    .QuestionBody,\n    .ChoiceStructure,\n    #Questions {\n      max-width: none !important;\n      width: 100% !important;\n      padding: 0 !important;\n      margin: 0 !important;\n      box-sizing: border-box !important;\n    }\n    \n    .SkinInner > .QuestionOuter {\n      padding: 0 !important;\n    }\n    \n    body.SurveyEngine {\n      padding: 0 !important;\n      margin: 0 !important;\n    }\n    \n    \/* Iframe styling *\/\n    #dietersGame {\n      width: 100% !important;\n      border: 0 !important;\n      display: block !important;\n      overflow: hidden !important;\n    }\n  <\/style>\n  \n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dietersDilemmaV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n  \n  <script>\n    (function () {\n      var iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n      iframe.style.height = \"1100px\";\n      window.addEventListener(\"message\", function (event) {\n        var data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n        var h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var gameCompleted = false;\n\n    \/\/ Collect configuration from embedded data\n    const gameConfig = {\n        nRounds: parseInt(\"${e:\/\/Field\/nRounds}\"),\n        id: parseInt(\"${e:\/\/Field\/id}\"),\n        yBonus: parseFloat(\"${e:\/\/Field\/yBonus}\"),\n        aCost: parseFloat(\"${e:\/\/Field\/aCost}\"),\n        currency: \"${e:\/\/Field\/currency}\",\n        pY: parseFloat(\"${e:\/\/Field\/pY}\"),\n        playerName0: \"${e:\/\/Field\/playerName0}\",\n        playerName1: \"${e:\/\/Field\/playerName1}\",\n        playerName2: \"${e:\/\/Field\/playerName2}\",\n        beta00: parseFloat(\"${e:\/\/Field\/beta00}\"),\n        beta01: parseFloat(\"${e:\/\/Field\/beta01}\"),\n        beta10: parseFloat(\"${e:\/\/Field\/beta10}\"),\n        beta11: parseFloat(\"${e:\/\/Field\/beta11}\"),\n        sigma0: parseFloat(\"${e:\/\/Field\/sigma0}\"),\n        sigma1: parseFloat(\"${e:\/\/Field\/sigma1}\"),\n        rho0: parseFloat(\"${e:\/\/Field\/rho0}\"),\n        rho1: parseFloat(\"${e:\/\/Field\/rho1}\"),\n        causal: parseInt(\"${e:\/\/Field\/causal}\"),\n        playerIcon0: \"${e:\/\/Field\/playerIcon0}\",\n        playerIcon2: \"${e:\/\/Field\/playerIcon2}\",\n        playerName2Pos: \"${e:\/\/Field\/playerName2Pos}\",\n        playerName2Neg: \"${e:\/\/Field\/playerName2Neg}\",\n        playerName2PosExo: \"${e:\/\/Field\/playerName2PosExo}\",\n        playerName2NegExo: \"${e:\/\/Field\/playerName2NegExo}\",\n        treatment: \"${e:\/\/Field\/treatment}\",\n        pA: parseFloat(\"${e:\/\/Field\/pA}\"),\n        order: \"${e:\/\/Field\/order}\",\n        buttonConfig: Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig'),\n        currentSymbol: Qualtrics.SurveyEngine.getEmbeddedData('currentSymbol'),\n        increasingPrice: \"${e:\/\/Field\/increasingPrice}\",\n        themeColor: \"${e:\/\/Field\/color}\"\n    };\n\n    console.log('Game configuration for ID ' + gameConfig.id + ':', gameConfig);\n\n    const currentGameId = gameConfig.id;\n    const currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n\n    \/\/ ---- Send INIT to the game iframe ----\n    function sendInit() {\n        const iframe = document.querySelector('iframe');\n        if (iframe && iframe.contentWindow) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                participantId: currentParticipantId,\n                surveyId: '${e:\/\/Field\/STUDY_ID}',\n                gameConfig: gameConfig,\n                gameId: currentGameId\n            }, '*');\n            console.log('Sent INIT to iframe for game ' + currentGameId);\n        }\n    }\n\n    \/\/ ---- GAME_DATA handler (per-game, removed on GAME_COMPLETE) ----\n    var messageHandler = (function(gameId, participantId) {\n        return function(event) {\n            if (event.data.type === 'GAME_DATA') {\n                if (gameCompleted) return;\n\n                if (event.data.participantId && event.data.participantId !== participantId) {\n                    console.log('Ignoring message for different participant:', event.data.participantId);\n                    return;\n                }\n                if (event.data.gameId && event.data.gameId !== gameId) {\n                    console.log('Ignoring message for different game:', event.data.gameId);\n                    return;\n                }\n\n                const dataType = event.data.dataType;\n                const data = event.data.data;\n\n                console.log('Received from participant ' + participantId + ', game ID ' + gameId + ':', dataType, data);\n\n                switch (dataType) {\n                    case 'GAME_START':\n                        console.log('Game ' + gameId + ' started for participant ' + participantId);\n                        break;\n\n                    case 'FINAL_DATA':\n                        Qualtrics.SurveyEngine.setEmbeddedData('history_' + gameId, JSON.stringify(data.history));\n                        console.log(data.history);\n                        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes_' + gameId, JSON.stringify(data.roundTimes));\n                        console.log(data.roundTimes);\n                        Qualtrics.SurveyEngine.setEmbeddedData('payment_' + gameId, JSON.stringify(data.payment));\n                        Qualtrics.SurveyEngine.setEmbeddedData('subjDAG0_' + gameId, JSON.stringify(data.dagInitial));\n                        Qualtrics.SurveyEngine.setEmbeddedData('subjDAG1_' + gameId, JSON.stringify(data.dagFinal));\n                        Qualtrics.SurveyEngine.setEmbeddedData('dagConfidence1_' + gameId, JSON.stringify(data.dagConfidence));\n                        Qualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount0_' + gameId, JSON.stringify(data.DAGAlertCount));\n                        Qualtrics.SurveyEngine.setEmbeddedData('subjDAGTime0_' + gameId, JSON.stringify(data.initialDAGTime));\n                        Qualtrics.SurveyEngine.setEmbeddedData('subjDAGTime1_' + gameId, JSON.stringify(data.finalDAGTime));\n                        Qualtrics.SurveyEngine.setEmbeddedData('dagConfidenceTime1_' + gameId, JSON.stringify(data.confidenceTime));\n                        Qualtrics.SurveyEngine.setEmbeddedData('tracking_' + gameId, JSON.stringify(data.tracking));\n                        Qualtrics.SurveyEngine.setEmbeddedData('highStake_' + gameId, JSON.stringify(data.priceElicitation));\n                        Qualtrics.SurveyEngine.setEmbeddedData('paymentHighStake_' + gameId, JSON.stringify(data.paymentHighStake));\n                        Qualtrics.SurveyEngine.setEmbeddedData('beliefRound10_' + gameId, JSON.stringify(data.beliefData));\n\t\t\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('configReceivedMain_' + gameId, JSON.stringify(event.data.configReceived ? '1' : '0'));\n\t\t\t\t\t\t\n\n                        console.log('Saved data for participant ' + participantId + ', game ID:', gameId);\n                        break;\n\n                    case 'GAME_COMPLETE':\n                        gameCompleted = true;\n                        console.log('Game ' + gameId + ' completed for participant ' + participantId);\n\n                        window.removeEventListener('message', messageHandler);\n\n                        setTimeout(function() {\n                            jQuery(\"#NextButton\").click();\n                        }, 1000);\n                        break;\n                }\n            }\n        };\n    })(currentGameId, currentParticipantId);\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ ---- Lifetime handlers: IFRAME_READY (handshake) + SCROLL_TO_TOP ----\n    window.addEventListener('message', function(event) {\n        if (!event.data) return;\n\n        if (event.data.type === 'IFRAME_READY') {\n            \/\/ Iframe has loaded and attached its listener \u2014 safe to send INIT.\n            \/\/ Also fires on iframe refresh, which the bare setTimeout misses.\n            sendInit();\n        } else if (event.data.type === 'SCROLL_TO_TOP') {\n            window.scrollTo({ top: 0, behavior: 'smooth' });\n        }\n    });\n\n    \/\/ Belt-and-suspenders: fire once shortly after load in case IFRAME_READY\n    \/\/ was posted before this listener attached (very fast iframe loads).\n    setTimeout(sendInit, 500);\n});","DefaultChoices":false,"DataExportTag":"main","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID537"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID538","SecondaryAttribute":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n    <div style=\"height:500px;margin:0;\">\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n\n <div class=\"panel-wrapper\">\n\n        <div id=\"panelAchoice\" class=\"panel\">\n            <div class=\"panel-header\">\n                <div class=\"panel-name\">You<\/div>\n            <\/div>\n            <div id=\"actionPrompt\" class=\"text\">Press your button?<\/div>\n            <div class=\"button-container\">\n            <button id=\"btnNo\" class=\"actionButton red\">${e:\/\/Field\/btnNo}<\/button>\n            <button id=\"btnYes\" class=\"actionButton green\">${e:\/\/Field\/btnYes}<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"panelXinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n            <\/div>\n            <div id=\"riskText\" class=\"text\">(press \"c\" to continue)<\/div>\n        <\/div>\n\n        <div id=\"panelYinfo\" class=\"panel hidden\">\n            <div class=\"panel-header\">\n                <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n            <\/div>\n            <div id=\"resultText\" class=\"text\">(press \"space\" to continue)<\/div>\n        <\/div>\n    <\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hidePreviousButton();\n    this.hideNextButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\tjQuery(\"#NextButton\").hide();\n\n\n   \n\n    const nRounds = parseInt(\"${e:\/\/Field\/nRounds}\");\n\tconst treatment = Qualtrics.SurveyEngine.getEmbeddedData('treatment');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n\tconst buttonConfig = Qualtrics.SurveyEngine.getEmbeddedData('buttonConfig');\n\tconst linkfn = Qualtrics.SurveyEngine.getEmbeddedData('linkfn');\n\tconst basePay = parseFloat(\"${e:\/\/Field\/basePay}\");\n\tconst halfRounds = Math.floor(nRounds \/ 2);\n\n\t\/\/ Determine panel order and configure content\n\tconst isYFirst = order === \"AYX\";\n\n\tlet roundCounter    = parseInt(\"${e:\/\/Field\/roundCounter}\");\n\tlet X, A, Y;\n\tlet history         = [];\n\tlet roundTimes      = [];\n\tlet payment         = [];\n\tlet roundStartTime  = 0;\n    let firstPanelStartTime = 0;\n\tlet resultPanelStartTime = 0;\n\tlet resultTimeRemaining = 0;\n\tlet xReady          = false;\n\tlet colorDisplayed  = false;\n\n\tconst btnNo        = document.getElementById(\"btnNo\");\n\tconst btnYes       = document.getElementById(\"btnYes\");\n\tconst panelXinfo   = document.getElementById(\"panelXinfo\");\n\tconst panelYinfo   = document.getElementById(\"panelYinfo\");\n\tconst panelAchoice = document.getElementById(\"panelAchoice\");\n\tconst resultText   = document.getElementById(\"resultText\");\n\tconst riskText     = document.getElementById(\"riskText\");\n\tconst roundDisplay = document.getElementById(\"roundDisplay\");\n\tconst actionPrompt = document.getElementById(\"actionPrompt\"); \n\n\t\/\/ Set up first and second panels based on order\n\tconst firstPanel = isYFirst ? panelYinfo : panelXinfo;\n\tconst secondPanel = isYFirst ? panelXinfo : panelYinfo;\n\tconst firstPanelText = isYFirst ? resultText : riskText;\n\tconst secondPanelText = isYFirst ? riskText : resultText;\n\t\n\t\n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < halfRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n\t\/\/ Function to get panel content\n\tfunction getPanelContent(panelType, value, isPlayerChoice) {\n\t\tif (panelType === 'X') {\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value \n\t\t\t\t\t? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button.\"\n\t\t\t};\n\t\t} else { \/\/ Y panel\n\t\t\tif (isPlayerChoice && treatment !== \"endog\") {\n\t\t\t\treturn {\n\t\t\t\t\tcolor: \"lightgray\",\n\t\t\t\t\ttext: \"${e:\/\/Field\/playerName2}'s choice will not be shown in this round.\"\n\t\t\t\t};\n\t\t\t}\n\t\t\treturn {\n\t\t\t\tcolor: value ? \"green\" : \"red\",\n\t\t\t\ttext: value\n\t\t\t\t\t? \"${e:\/\/Field\/playerName2} pressed ${e:\/\/Field\/playerPronoun2} button (bonus ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus}!).\"\n\t\t\t\t\t: \"${e:\/\/Field\/playerName2} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun2} button (no bonus).\"\n\t\t\t};\n\t\t}\n\t}\n\n\t\/\/ Swap visual order if needed\n\tif (isYFirst) {\n\t\tconst parent = panelXinfo.parentNode;\n\t\tparent.insertBefore(panelYinfo, panelXinfo);\n\t}\n    \n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n\n    [panelAchoice, panelXinfo, panelYinfo].forEach(p => p.style.border = \"1px solid black\");\n\n    btnYes.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('y');\n        }\n    });\n    btnNo.addEventListener(\"click\", () => {\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        if (!isPlayerChoiceRound || treatment === \"endog\") {\n            handleDecision('n');\n        }\n    });\n    \n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    const causal = parseInt(\"${e:\/\/Field\/causal}\");\n    const pA = parseFloat(\"${e:\/\/Field\/pA}\");\n\tconst sigma0 = parseFloat(\"${e:\/\/Field\/sigma0}\");\n\tconst sigma1 = parseFloat(\"${e:\/\/Field\/sigma1}\");\n\tconst rho0 = parseFloat(\"${e:\/\/Field\/rho0}\");\n\tconst rho1 = parseFloat(\"${e:\/\/Field\/rho1}\");\n\tconst beta00 = parseFloat(\"${e:\/\/Field\/beta00}\");\n\tconst beta01 = parseFloat(\"${e:\/\/Field\/beta01}\");\n\tconst beta10 = parseFloat(\"${e:\/\/Field\/beta10}\");\n\tconst beta11 = parseFloat(\"${e:\/\/Field\/beta11}\");\n    function handleDecision(decision) {\n        if (!panelAchoice || panelAchoice.style.display !== 'flex') return;\n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tlet pX = [0, 0, 0, 0];\n        A = decision === 'y' ? 1 : 0;\n        if (causal === 0) {\n\t\t\tpX = [beta00, beta01, beta10, beta11];\n\t\t\tY = Math.random() < pY ? 1 : 0;\n\t\t\tX = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            \n        } else {\n            const pX = [sigma0, sigma1];\n            const pY = [rho0, rho1];\n            X = Math.random() < pX[A] ? 1 : 0;\n            Y = Math.random() < pY[X] ? 1 : 0;\n        }\n\n        history.push([A, X, Y]);\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        payment.push(-aCost*A + yBonus*Y + basePay);\n\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            const currentRoundIndex = roundCounter - 1;\n            const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n            \/\/ Show first panel\n            const firstPanelType = isYFirst ? 'Y' : 'X';\n            const firstValue = isYFirst ? Y : X;\n            const content = getPanelContent(firstPanelType, firstValue, isPlayerChoiceRound);\n\n            firstPanel.style.backgroundColor = content.color;\n            firstPanelText.innerHTML = content.text + \" <br>(press 'c' to continue)\";\n            secondPanel.style.backgroundColor = \"white\";\n            xReady = true;\n            firstPanelStartTime = Date.now(); \/\/ ADD THIS LINE\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        const yesVisible = btnYes.style.display !== \"none\" && !btnYes.disabled;\n        const noVisible = btnNo.style.display !== \"none\" && !btnNo.disabled;\n        \n        \/\/ Check if this is a player choice round (keyboard allowed) or forced round (no keyboard)\n        const currentRoundIndex = roundCounter - 1;\n        const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n        \n        \/\/ Only allow keyboard input for player choice rounds (or always if treatment is \"endog\")\n        if (isPlayerChoiceRound) {\n            if (e.key === 'y' && yesVisible) {\n                handleDecision('y');\n            }\n            else if (e.key === 'n' && noVisible) {\n                handleDecision('n');\n            }\n        }\n        \n        \/\/ Continue key always works regardless of round type\n        if (e.key === 'c' && xReady) {\n            const firstTimeRemaining = (firstPanelStartTime + 500) - Date.now();\n            \n            if (firstTimeRemaining > 0) {\n                setTimeout(() => {\n                    showSecondPanel();\n                }, firstTimeRemaining);\n            } else {\n                showSecondPanel();\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n\t\t\tlet roundEnd = Date.now();\n\t\t\troundTimes.push((roundEnd - roundStartTime) \/ 1000);\n\t\t\tif (roundCounter <= nRounds) {\n\t\t\t\tresultTimeRemaining = (resultPanelStartTime + 500) - Date.now();\n\t\t\t\tif (resultTimeRemaining > 0) {\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tnextRound();\n\t\t\t\t\t}, resultTimeRemaining);\n\t\t\t\t} else {\n\t\t\t\t\tnextRound();\n\t\t\t\t}\n\t\t\t\tcolorDisplayed = false;\n\t\t\t}\n\t\t}\n    }\n\n    function showSecondPanel() {\n    const currentRoundIndex = roundCounter - 1;\n    const isPlayerChoiceRound = treatment === \"endog\" ? true : buttonConfig[currentRoundIndex] === 1;\n\n    \/\/ Show second panel\n    const secondPanelType = isYFirst ? 'X' : 'Y';\n    const secondValue = isYFirst ? X : Y;\n    const content = getPanelContent(secondPanelType, secondValue, isPlayerChoiceRound);\n\n    secondPanel.style.backgroundColor = content.color;\n    secondPanelText.innerHTML = content.text + \" <br>(press 'space' to continue)\";\n    xReady = false;\n    colorDisplayed = true;\n    resultPanelStartTime = Date.now();\n}\n\n    function initiateRound() {\n        panelAchoice.style.display =\n        panelXinfo.style.display =\n        panelYinfo.style.display = \"none\";\n        setTimeout(() => {\n            showActionPanels();\n        }, 500);\n    }\n\n    function nextRound() {\n        Qualtrics.SurveyEngine.setEmbeddedData('history1_' + id, JSON.stringify(history));\n        Qualtrics.SurveyEngine.setEmbeddedData('roundTimes1_' + id, JSON.stringify(roundTimes));\n        Qualtrics.SurveyEngine.setEmbeddedData('payment1_' + id, JSON.stringify(payment));\n\t\tQualtrics.SurveyEngine.setEmbeddedData('roundCounter', roundCounter);\n        if (roundCounter < halfRounds) {\n            roundCounter++;\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n        else if (roundCounter === halfRounds) {\n            console.log(\"History:\", history);\n            console.log(\"Times:\", roundTimes);\n            \n            jQuery(\"#NextButton\").click();\n        }\n    }\n\n    function showActionPanels() {\n        panelAchoice.style.display = \"flex\";\n        panelXinfo.style.display   = \"flex\";\n        panelYinfo.style.display   = \"flex\";\n        panelXinfo.style.backgroundColor =\n        panelYinfo.style.backgroundColor = \"white\";\n        riskText.textContent = resultText.textContent = \"\";\n\n        const showBothButtons = treatment === \"endog\" ? 1 : buttonConfig[roundCounter - 1];\n        \n        if (showBothButtons === 1) {\n            \/\/ Player choice round - both buttons enabled\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            btnNo.disabled = false;\n            btnYes.disabled = false;\n            btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n            btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n            \n            if (treatment === \"endog\") {\n                \/\/ For \"endog\" treatment: allow both keyboard and mouse\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.textContent = \"Press your button?\";\n            } else {\n                \/\/ For other treatments: keyboard only\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.textContent = \"Press your button? (Use your keyboard)\";\n            }\n        } else {\n            \/\/ Forced round - show both but disable one, allow mouse\n            btnNo.style.display = \"inline-block\";\n            btnYes.style.display = \"inline-block\";\n            \n            if (Math.random() < pA) {\n                \/\/ Force Yes\n                btnNo.disabled = true;\n                btnYes.disabled = false;\n                btnNo.style.backgroundColor = \"gray\";\n                btnYes.style.backgroundColor = \"#4CAF50\"; \/\/ green\n                btnNo.style.pointerEvents = \"none\";\n                btnYes.style.pointerEvents = \"auto\";\n                actionPrompt.innerHTML = \"You must press \\\"Yes\\\" in this round. <br> Press your button? (Use your mouse)\";\n            } else {\n                \/\/ Force No\n                btnNo.disabled = false;\n                btnYes.disabled = true;\n                btnNo.style.backgroundColor = \"#f44336\"; \/\/ red\n                btnYes.style.backgroundColor = \"gray\";\n                btnNo.style.pointerEvents = \"auto\";\n                btnYes.style.pointerEvents = \"none\";\n                actionPrompt.innerHTML = \"You must press \\\"No\\\" in this round. <br> Press your button? (Use your mouse)\";\n            }\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    nextRound();\n});","DefaultChoices":false,"DataExportTag":"Q531","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You Press your button? ${e:\/\/Field\/btnNo} ${e:\/\/Field\/btnYes} ${e:\/\/Field\/playerName1} (press \"c\"...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID538"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID539","SecondaryAttribute":"Each day, when you get up, you decide whether to consume the drink. Shortly after, your BioClip t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Each day, when you get up, you decide whether to consume the drink. Shortly after, your BioClip tells you whether your blood chemical level is normal. What you care about is whether you will feel good or bad later in the day. You know that consuming a drink makes it more likely that the blood chemical level will be normal. What you don&rsquo;t know is what changing the chemical level means for how you feel later that day. There are two possibilities: Possibility 1: The chemical level is a cause of how you will feel later that day. Hence, normalizing your chemical level (by consuming the drink) raises the chance that you will feel good later that day. Possibility 2: The chemical level predicts how you will feel later that day, but does not cause it. The chemical might, for example, be a side-product of your body processing something else that is the actual cause for how you feel later that day. In this case, drinking the beverage will still increase the chance that your chemical level will be normal, but this will not affect how you feel later that day.","DefaultChoices":false,"DataExportTag":"Q532","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Each day, when you get up, you decide whether to consume the drink. Shortly after, your BioClip t...","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID539"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"[This page continues automatically]","TertiaryAttribute":null,"Payload":{"QuestionText":"[This page continues automatically]","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    const metaData = JSON.parse(`\\${lm:\/\/Field\/1}`);\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tconsole.log(loopNum);\n    const causal = metaData.causal;\n    const noise = metaData.noise;\n\tconst id = metaData.id;\n\tconst playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopNum);\n\tconst playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopNum);\n\tconst playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1_' + loopNum);\n\tconst playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2_' + loopNum);\n\tconst playerIcon1 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon1_' + loopNum);\n\tconst playerIcon2 = Qualtrics.SurveyEngine.getEmbeddedData('playerIcon2_' + loopNum);\n\tconsole.log(playerIcon1);\n\tlet gameOrder = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('gameOrder'));\n\tgameOrder.push(id);\n\t\n\n\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName1', playerName1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerName2', playerName2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun1', playerPronoun1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerPronoun2', playerPronoun2);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon1', playerIcon1);\n\tQualtrics.SurveyEngine.setEmbeddedData('playerIcon2', playerIcon2);\n\tQualtrics.SurveyEngine.setEmbeddedData('causal', causal);\n\tQualtrics.SurveyEngine.setEmbeddedData('noise', noise);\n\tQualtrics.SurveyEngine.setEmbeddedData('id', id);\n\t\n\t\n\tvar gameCounter     = parseInt(\"${e:\/\/Field\/gameCounter}\");\n \tQualtrics.SurveyEngine.setEmbeddedData('gameCounter', gameCounter+1);\n\tQualtrics.SurveyEngine.setEmbeddedData('gameOrder', JSON.stringify(gameOrder));\n\tconsole.log(gameOrder);\n\t\n\tjQuery(\"#NextButton\").click();\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n});","DefaultChoices":false,"DataExportTag":"Q47","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[This page continues automatically]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID54"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID540","SecondaryAttribute":"How you make decisions and get paid in this study. Each day corresponds to one round of the game....","TertiaryAttribute":null,"Payload":{"QuestionText":"\n<b>How you make decisions and get paid in this study. <\/b>\n<br>\n<br>\nEach day corresponds to one round of the game. In each round, you first decide whether to consume the drink. Shortly after, you read off the blood chemical level. You care about how you feel during the rest of the day. \n<br>\n\n<br>\n<b>Payment<\/b>\n<br><br>\nYou begin each round with a baseline bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/basePay}.  \n<ul>\n\t<li>If you consume the drink, you pay ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} for it (deducted from your baseline bonus). <\/li>\n\t<li>If you feel good at the end of the day, you receive an additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus, if you feel bad, you don't.<\/li>\n\t<li>The BioClip\u2019s reading of your blood chemicals does not directly affect your payment.<\/li>\n<\/ul>\n<br>\n\nThere will be ${e:\/\/Field\/nSupergames} rounds. This may sound like a lot, but because each round only takes a few seconds, this is quite manageable. \n<br><br>\nYou will be paid for one round, selected at random at the end of the study. ","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\t\n\t  var versions = [\n    {\n      html: \"You will play with two computer players that we call the <b>Bonus Player<\/b> and the <b>Co-Player<\/b>.\",\n\t  title: \"Game Instructions\"\n    },\n    {\n      html: \"The next ${e:\/\/Field\/nDieter} games follow different rules than the four games you have just played. As before, you will play with two computer players that we call the Bonus Player and the Co-Player.\",\n\t  title: \"Games 3 to 4 <br> A different type of game\"\n    }\n  ];\n\n  var dieterFirst = parseInt(\"${e:\/\/Field\/dieterFirst}\");\n  var html = versions[1-dieterFirst].html;\n  var title = versions[1-dieterFirst].title;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n  jQuery(this.questionContainer).find(\"#gameTitle\").html(title);\n  if (dieterFirst == 0){\n\t  jQuery(this.questionContainer).find(\"#D2_1\").html(\"As in the first ${e:\/\/Field\/nMigraines} games, \");\n\t  jQuery(this.questionContainer).find(\"#D2_2\").html(\"Unlike in the previous ${e:\/\/Field\/nMigraines} games, pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} in each round.\");\n  }\n   else if (dieterFirst == 1){\n\t  jQuery(this.questionContainer).find(\"#D2_2\").html(\"You always move first, and pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} in each round.\");\n  }\n\t\n\n});\n\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q533","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How you make decisions and get paid in this study. Each day corresponds to one round of the game....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID540"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID541","SecondaryAttribute":"[Game Title] [Game description] \u00a0 Payments You begin each round with a baseline bonus of ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align: center;\" id=\"gameTitle\"><b>[Game Title]<\/b><\/h1>\n<br>\n<span id=\"gameDesc\">[Game description]<\/span><br>\n&nbsp;\n<h2>Payments<\/h2>\n<br>\nYou begin each round with a baseline bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/basePay}.<br>\n<br>\nIn each round, every player chooses whether to press their button. Your payment depends on who presses their button:\n<ul>\n\t<li>The <b>Bonus Player<\/b> decides whether you receive an <b>additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus<\/b>. If they press their button, you get the bonus; if not, you don't.<\/li>\n\t<li>The Co-Player's button does not directly affect your payoff, though their choice may affect other players.<\/li>\n\t<li>Pressing your <b>own button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}<\/b>, deducted from your baseline bonus.<\/li>\n<\/ul>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\t\n\t  var versions = [\n    {\n      html: \"You will play with two computer players that we call the <b>Bonus Player<\/b> and the <b>Co-Player<\/b>.\",\n\t  title: \"Game Instructions\"\n    },\n    {\n      html: \"The next ${e:\/\/Field\/nDieter} games follow different rules than the four games you have just played. As before, you will play with two computer players that we call the Bonus Player and the Co-Player.\",\n\t  title: \"Games 3 to 4 <br> A different type of game\"\n    }\n  ];\n\n  var dieterFirst = parseInt(\"${e:\/\/Field\/dieterFirst}\");\n  var html = versions[1-dieterFirst].html;\n  var title = versions[1-dieterFirst].title;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n  jQuery(this.questionContainer).find(\"#gameTitle\").html(title);\n  if (dieterFirst == 0){\n\t  jQuery(this.questionContainer).find(\"#D2_1\").html(\"As in the first ${e:\/\/Field\/nMigraines} games, \");\n\t  jQuery(this.questionContainer).find(\"#D2_2\").html(\"Unlike in the previous ${e:\/\/Field\/nMigraines} games, pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} in each round.\");\n  }\n   else if (dieterFirst == 1){\n\t  jQuery(this.questionContainer).find(\"#D2_2\").html(\"You always move first, and pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} in each round.\");\n  }\n\t\n\n});\n\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q534","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[Game Title] [Game description] \u00a0 Payments You begin each round with a baseline bonus of ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID541"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID542","SecondaryAttribute":"Scenario of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game Game ${e:\/\/Field\/currentSymbol} Start...","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n.Skin .SkinInner,\n.Skin #SkinContent,\n.Skin #Questions,\n.Skin .QuestionOuter,\n.Skin .QuestionBody,\n.Skin .QuestionText {\n    max-width: 1400px !important;\n    width: 100% !important;\n}\n.Skin .SkinInner {\n    margin: 0 auto !important;\n}\n\t\n.choice-pointer {\n    position: absolute;\n    left: 110%;\n    margin-left: 20px;\n    top: 50%;\n    transform: translateY(-50%);\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 5px;\n    font-size: 20px;\n    font-weight: bold;\n    min-width: 390px;\n    padding: 10px;  \/* Add this - increases space between border and text *\/\n}\n.choice-pointer button {\n    white-space: nowrap;\n}\n\/* Add this to increase panel height specifically for this page \n.panel {\n    height: 200px !important;\n}\n*\/\n<\/style>\n<div class=\"panel-block\">\n    <h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:0.3em;\">\n  Scenario <span id=\"roundNr\"> <\/span> of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div>\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        <div id=\"instructionTitle\"> <\/div>\n\n<button id=\"startButton\" class=\"progressButton actionButton\">\n    Start This Scenario\n<\/button>\n        <div class=\"panel-wrapper\" style=\"display:none\">\n\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n\n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n\n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n\n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\n        <\/div>\n\n    <\/div>\n              \n<\/div>\n<div class=\"belief-block\">\n\n    <div id=\"beliefQuestionContainer\" class=\"verbal-section\" style=\"display: none;\">\n\n    <div id=\"question1Container\">\n        <div id=\"beliefQuestion1\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart1\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion1\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question2Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion2\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart2\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion2\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question3Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion3\" style=\"font-size:22px;margin-bottom:20px;\"><\/div>\n        <div id=\"beliefOptions\" style=\"margin:20px 0;\"><\/div>\n        <button id=\"beliefSubmit\" class=\"verbal-submit\" disabled>Submit Answer<\/button>\n    <\/div>\n<\/div>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    jQuery(\"#NextButton\").hide();\n    \n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n    const allMetaData = [\n        JSON.parse('${e:\/\/Field\/mainCausal1}'),\n        JSON.parse('${e:\/\/Field\/mainCausal2}'),\n        JSON.parse('${e:\/\/Field\/mainCausal3}'),\n        JSON.parse('${e:\/\/Field\/mainCausal4}'),\n        JSON.parse('${e:\/\/Field\/mainCausal5}'),\n        JSON.parse('${e:\/\/Field\/mainCausal6}'),\n        JSON.parse('${e:\/\/Field\/mainCausal7}'),\n        JSON.parse('${e:\/\/Field\/mainCausal8}'),\n        JSON.parse('${e:\/\/Field\/mainCausal9}'),\n        JSON.parse('${e:\/\/Field\/mainCausal10}')\n    ];\n    \n    let currentMetaIndex = 0;\n    let metaData = allMetaData[currentMetaIndex];\n    let causalElicitType = metaData.causalElicit;\n\tlet causalElicitID = metaData.id;\n    let exoButton = metaData.exoButton;\n    const nRounds = allMetaData.length;\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    var rationalInference = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('rationalInference_' + id));\n\tconsole.log(\"Look!\");\n    console.log(rationalInference);\n    let correctAnswerList = rationalInference[\"causal_\" + causalElicitID];\n\tconsole.log(correctAnswerList);\n    let correctAnswerListSlider1 = rationalInference[\"pNo_\" + causalElicitID];\n\tlet correctAnswerListSlider2 = rationalInference[\"pYes_\" + causalElicitID];\n    \n\n    const playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1');\n    const playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2');\n    const playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1');\n    const playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2');\n\t\n    const lockSvgHTML = Qualtrics.SurveyEngine.getEmbeddedData('lockSvg');\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n    \n    let roundCounter = 0;\n    let history = [];\n    let roundTimes = [];\n    let correctAnswers = [];\n    let correctAnswersSlider1 = [];\n    let correctAnswersSlider2 = [];\n    let roundStartTime = 0;\n    let displayStage = -1; \/\/  0 = locked panel, 1 = decision panel, 2 = ? panel\n\n    let aMessage = '';\n    let xMessage = '';\n    let yMessage = '';\n    let aBackgroundColor = 'white';\n    let xBackgroundColor = 'white';\n    let yBackgroundColor = 'white';\n\n    let progressButton; \/\/ Add this at the top with other variables\n    let hasStarted = false; \/\/ Make sure this is declared\n\n    window.currentBeliefData = {\n        causalElicitType: '',\n        exoButton: null,\n        playerName1: playerName1,\n        playerName2: playerName2,\n        playerPronoun1: playerPronoun1,\n        playerPronoun2: playerPronoun2\n    };\n\n\n    function createLockIcon() {\n        const lockSvg = document.createElement('div');\n        lockSvg.className = 'lock-icon';\n        lockSvg.innerHTML = lockSvgHTML;\n        return lockSvg;\n    }\n\t\n\tfunction highlightActivePanel(panel) {\n    \/\/ Remove highlight and pointers from all panels first\n    panelAinfo.classList.remove('active-choice');\n    panelXinfo.classList.remove('active-choice');\n    panelYinfo.classList.remove('active-choice');\n    \n    \/\/ Remove any existing pointers\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Add highlight and pointer to the active panel\n    if (panel) {\n        panel.classList.add('active-choice');\n        \n        \/\/ Create and add pointer with text\n        const pointer = document.createElement('div');\n        pointer.className = 'choice-pointer';\n        pointer.innerHTML = '...report how your choice...';\n        panel.appendChild(pointer);\n    }\n    }\n\n    const btnNo = document.createElement('button');\n    btnNo.id = 'btnNo';\n    btnNo.className = 'actionButton red';\n    btnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n    \n    const btnYes = document.createElement('button');\n    btnYes.id = 'btnYes';\n    btnYes.className = 'actionButton green';\n    btnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n\t\n\t\n\n    const buttonContainer = document.createElement('div');\n    buttonContainer.className = 'button-container';\n    buttonContainer.appendChild(btnNo);\n    buttonContainer.appendChild(btnYes);\n\t\n\t\n\tbtnYes.disabled = true;\n\tbtnNo.disabled = true;\n\tbtnYes.classList.add('disabled');\n\tbtnNo.classList.add('disabled');\n\n    const panelXinfo = document.getElementById(\"panelXinfo\");\n    const panelYinfo = document.getElementById(\"panelYinfo\");\n    const panelAinfo = document.getElementById(\"panelAinfo\");\n\n\n\tif (order === \"AYX\") {\n\t\tconst panelWrapper = document.querySelector('.panel-wrapper');\n\t\tpanelWrapper.insertBefore(panelYinfo, panelXinfo);\n\t}\n\n\n    const YText = document.getElementById(\"YText\");\n    const XText = document.getElementById(\"XText\");\n    const AText = document.getElementById(\"AText\");\n    const instructionElement = document.getElementById('instructionTitle');\n\n\n\t\n\tdocument.getElementById('startButton').addEventListener('click', function() {\n    if (!hasStarted) {\n        \/\/ First click: show panels, hide start button, create progress button\n        document.querySelector('.panel-wrapper').style.display = 'block';\n        startButton.style.display = 'none'; \/\/ Hide the start button\n        \n        \/\/ Create the new progress button\n        progressButton = document.createElement('button');\n        progressButton.className = 'progressButton actionButton';\n        progressButton.innerHTML = 'Next';\n        \n        hasStarted = true;\n        startRoundDisplay();\n\n        \/\/document.querySelectorAll('.stage1').forEach(el => el.classList.add('blink-text'));\n        \/\/ Attach the button to the appropriate panel\n        attachProgressButton();\n    }\n});\n\n\/\/ Add this new function to handle progress button clicks\nfunction handleProgressClick() {\n    if (displayStage === 0) {\n        displayStage = 1;\n        showStage1();\n        \/\/document.querySelectorAll('.stage1').forEach(el => el.classList.remove('blink-text'));\n        \/\/document.querySelectorAll('.stage2').forEach(el => el.classList.add('blink-text'));\n        attachProgressButton();\n    } else if (displayStage === 1) {\n        displayStage = 2;\n        showStage2();\n        \/\/document.querySelectorAll('.stage2').forEach(el => el.classList.remove('blink-text'));\n        \/\/document.querySelectorAll('.stage3').forEach(el => el.classList.add('blink-text'));\n        progressButton.innerHTML = \"I understand this scenario\";\n        attachProgressButton();\n    } else if (displayStage === 2) {\n        progressButton.remove(); \/\/ Remove the button\n        \n        \/\/ Remove all pointers\n        document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n        \n        \/\/document.querySelectorAll('.stage3').forEach(el => el.classList.remove('blink-text'));\n        panelAinfo.classList.remove('active-choice');\n        panelXinfo.classList.remove('active-choice');\n        panelYinfo.classList.remove('active-choice');\n        showBeliefQuestion();\n    }\n}\nfunction attachProgressButton() {\n    if (!progressButton) return;\n    \n    if (progressButton.parentNode) {\n        progressButton.remove();\n    }\n    \n    let targetPanel = null;\n    \n    if (displayStage === 0) {\n        \/\/ Stage 0: handles all cases with a \"first panel\"\n        if (causalElicitType === 'AX') {\n            targetPanel = panelYinfo;\n        } else if (causalElicitType === 'AY') {\n            targetPanel = panelXinfo;\n        } else if (causalElicitType === 'XY' || causalElicitType === 'YX') {\n            targetPanel = panelAinfo;\n        }\n    } else if (displayStage === 1) {\n        \/\/ Stage 1: decision panel\n        if (exoButton == null) {\n            if (causalElicitType === 'YX') {\n                targetPanel = panelYinfo;\n            } else {\n                targetPanel = panelAinfo;\n            }\n        } else {\n            if (causalElicitType === 'AX' || causalElicitType === 'AY') {\n                targetPanel = panelAinfo;\n            } else if (causalElicitType === 'XY') {\n                targetPanel = panelXinfo;\n            } else if (causalElicitType === 'YX') {\n                targetPanel = panelYinfo;\n            }\n        }\n    } else if (displayStage === 2) {\n        \/\/ Stage 2: \"?\" panel\n        if (causalElicitType === 'XY' || causalElicitType === 'AY') {\n            targetPanel = panelYinfo;\n        } else if (causalElicitType === 'YX' || causalElicitType === 'AX') {\n            targetPanel = panelXinfo;\n        }\n    }\n    \n    if (targetPanel) {\n        const pointer = targetPanel.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.appendChild(progressButton);\n        } else {\n            targetPanel.appendChild(progressButton);\n        }\n    }\n    \n    progressButton.onclick = handleProgressClick;\n}\n\n\n \n\n    function showPanelQuestion() {\n        document.querySelector('.panel-wrapper').style.display = '';\n        instructionElement.style.display = 'block';\n    }\n\n    function showBeliefQuestion() {\n        window.currentBeliefData.causalElicitType = causalElicitType;\n        window.currentBeliefData.exoButton = exoButton;\n        \n        const beliefContainer = document.getElementById('beliefQuestionContainer');\n        if (beliefContainer) {\n            beliefContainer.style.display = 'block';\n            \n            setTimeout(() => {\n                beliefContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });\n            }, 100);\n            \n            if (window.updateBeliefQuestion) {\n                window.updateBeliefQuestion();\n            }\n        }\n    }\n\n    window.onBeliefSubmitted = function(selectedIndex, selectedText) {\n        let roundEnd = Date.now();\n        roundTimes.push((roundEnd - roundStartTime) \/ 1000);\n        const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n        const originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n        \n        const beliefContainer = document.getElementById('beliefQuestionContainer');\n        if (beliefContainer) {\n            beliefContainer.style.display = 'none';\n        }\n        \n        if (roundCounter < nRounds) {\n\t\t\tdocument.getElementById('NextButton').style.display = 'none';\n            showPanelQuestion();\n            nextRound();\n        } else {\n            function getOptionIndex(percentage) {\n                if (percentage === null || percentage === undefined) return null;\n                \n                if (percentage <= -80) return 0;\n                if (percentage <= -60) return 1;\n                if (percentage <= -40) return 2;\n                if (percentage <= -20) return 3;\n                if (percentage < 0) return 4;\n                if (percentage === 0) return 5;\n                if (percentage < 20) return 6;\n                if (percentage < 40) return 7;\n                if (percentage < 60) return 8;\n                if (percentage < 80) return 9;\n                return 10;\n            }\n\n            const beliefPayment = correctAnswers.map((correct, index) => {\n                const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n                const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n\n                \/\/ If correct is null, give max payment\n                if (correct === null || correct === undefined) {\n                    return beliefPaymentMax;\n                }\n\n                \/\/ Convert correct percentage to option index\n                const correctOptionIndex = getOptionIndex(correct);\n                \n                \/\/ User's choice is already stored as option index (0-10)\n                const userChoice = window.allBeliefs[index];\n                \n                \/\/ Calculate difference between option indices\n                const absoluteDifference = Math.abs(correctOptionIndex - userChoice);\n                \n                return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n            });\n\n            const beliefPaymentSlider1 = correctAnswersSlider1.map((correct, index) => {\n            const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n            const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n            \n            \/\/ If correct is null, return max payment\n            if (correct === null || correct === undefined) {\n                return beliefPaymentMax;\n            }\n            \n            \/\/ Transform to nearest category (0, 10, 20, ..., 100)\n            const nearestCategory = Math.round(correct \/ 10) * 10;\n            \n            \/\/ Calculate payment using nearest category\n            const absoluteDifference = Math.abs(nearestCategory - window.allSlider1Values[index]) \/ 10;\n            return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n        });\n\n        const beliefPaymentSlider2 = correctAnswersSlider2.map((correct, index) => {\n            const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n            const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n            \n            \/\/ If correct is null, return max payment\n            if (correct === null || correct === undefined) {\n                return beliefPaymentMax;\n            }\n            \n            \/\/ Transform to nearest category (0, 10, 20, ..., 100)\n            const nearestCategory = Math.round(correct \/ 10) * 10;\n            \n            \/\/ Calculate payment using nearest category\n            const absoluteDifference = Math.abs(nearestCategory - window.allSlider2Values[index]) \/ 10;\n            return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n        });\n            \n            Qualtrics.SurveyEngine.setEmbeddedData('beliefHistory_' + id, JSON.stringify(history));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefRoundTimes_' + id, JSON.stringify(roundTimes));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPayment_' + id, JSON.stringify(beliefPayment));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPaymentSlider1_' + id, JSON.stringify(beliefPaymentSlider1));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPaymentSlider2_' + id, JSON.stringify(beliefPaymentSlider2));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefCorrectAnswer_' + id, JSON.stringify(correctAnswers));\n\t\t\t\n\t\t\tconsole.log(beliefPayment);\n\t\t\tconsole.log(correctAnswers);\n            \n            setTimeout(() => {\n                jQuery(\"#NextButton\").click();\n            }, 100);\n        }\n    };\n\n    function clearLockIcons() {\n        const existingLocks = document.querySelectorAll('.lock-icon');\n        existingLocks.forEach(lock => lock.remove());\n    }\n\n    function initiateRound() {\n        document.querySelector('.panel-wrapper').style.display = 'none';\n\t\thighlightActivePanel(null);\n\t\tclearLockIcons();\n\n\t\tpanelAinfo.style.backgroundColor = \"white\";\n\t\tpanelXinfo.style.backgroundColor = \"white\";\n\t\tpanelYinfo.style.backgroundColor = \"white\";\n\n\t\t\/\/ REMOVED: document.querySelector('.panel-wrapper').style.display = 'none';\n\t\t\/\/understandButton.style.display = 'none';\n\n\t\tAText.innerHTML = \"\";\n\t\tXText.innerHTML = \"\";\n\t\tYText.innerHTML = \"\";\n\n\t\tif (panelXinfo.contains(buttonContainer)) panelXinfo.removeChild(buttonContainer);\n\t\tif (panelAinfo.contains(buttonContainer)) panelAinfo.removeChild(buttonContainer);\n\t\tif (panelYinfo.contains(buttonContainer)) panelYinfo.removeChild(buttonContainer);\n\n\t\tbtnYes.disabled = btnNo.disabled = false;\n\t\tbtnYes.classList.remove(\"flash\");\n\t\tbtnNo.classList.remove(\"flash\");\n\n\t\txReady = false;\n\t\tcolorDisplayed = false;\n\t\tdecisionPanelShown = false;\n\n        panelAinfo.classList.remove('active-choice');\n        panelXinfo.classList.remove('active-choice');\n        panelYinfo.classList.remove('active-choice');\n\n        \/\/ NEW: Show the start button for each round\n        document.getElementById('startButton').style.display = 'block';\n\n\t\t\/\/ Prepare the action panels but don't show them yet\n\t\tprepareActionPanels();\n\t}\n\n    function updateInstructionTitle() {\n        if (!instructionElement) return;\n        \n        const instructionConfigs = {\n            AX: {\n                title: \"How does <b><span class=\\\"stage2\\\">your choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName1}'s choice<\/b><\/span> if ...\",\n                bullet1: exoButton == null\n                    ? \"${e:\/\/Field\/playerName2} chooses freely.\"\n                    : \"<span class=\\\"stage1\\\">${e:\/\/Field\/playerName2} must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName1} chooses freely.<\/span>\"\n            },\n            XY: {\n                title: \"How does <b><span class=\\\"stage2\\\">${e:\/\/Field\/playerName1}'s choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName2}'s choice<\/b><\/span> if ...\",\n                bullet1: \"<span class=\\\"stage1\\\">You must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName2} chooses freely.<\/span>\"\n            },\n            AY: {\n                title: \"How does <b><span class=\\\"stage2\\\">your choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName2}'s choice<\/b><\/span> if ...\",\n                bullet1: exoButton == null\n                    ? \"${e:\/\/Field\/playerName1} chooses freely.\"\n                    : \"<span class=\\\"stage1\\\">${e:\/\/Field\/playerName1} must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName2} chooses freely.<\/span>\"\n            },\n            YX: {\n                title: \"How does <b><span class=\\\"stage2\\\">${e:\/\/Field\/playerName2}'s choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName1}'s choice<\/b><\/span> if ...\",\n                bullet1: \"<span class=\\\"stage1\\\">You must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName1} chooses freely.<\/span>\"\n            }\n        };\n        \n        const config = instructionConfigs[causalElicitType];\n        if (config) {\n            instructionElement.innerHTML = \n                '<div style=\"text-align:left\"><span style=\"font-size:22px;\">' + config.title + '<\/span><\/div>' +\n                '<ul style=\"font-size:22px;\"><li>...' + config.bullet1 + '<\/li><li>...' + config.bullet2 + '<\/li><\/ul>';\n        }\n    }\n\n    function nextRound() {\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            currentMetaIndex = roundCounter - 1;\n            metaData = allMetaData[currentMetaIndex];\n            console.log('All metadata:', allMetaData);\n            causalElicitType = metaData.causalElicit;\n            causalElicitID = metaData.id;\n            exoButton = metaData.exoButton;\n            correctAnswerList = rationalInference[\"causal_\" + causalElicitID];\n            correctAnswerListSlider1 = rationalInference[\"pNo_\" + causalElicitID];\n            correctAnswerListSlider2 = rationalInference[\"pYes_\" + causalElicitID];\n\n            updateInstructionTitle();\n            document.getElementById('roundNr').textContent = roundCounter;\n\n            const configs = {\n                AX: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: exoButton == 1 \n                        ? '<br>${e:\/\/Field\/playerName2} must press \"Yes\".'\n                        : exoButton == 0\n                        ? '<br>${e:\/\/Field\/playerName2} must press \"No\".'\n                        : '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\"\n                },\n                AY: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == 1\n                        ? '<br>${e:\/\/Field\/playerName1} must press \"Yes\".'\n                        : exoButton == 0\n                        ? '<br>${e:\/\/Field\/playerName1} must press \"No\".'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: 'lightgray'\n                },\n                XY: {\n                    aMessage: exoButton == 1\n                        ? '<br>You must press \"Yes\".'\n                        : '<br>You must press \"No\".',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: \"<br>\",\n                    xBackgroundColor: \"white\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: 'lightgray'\n                },\n                YX: {\n                    aMessage: exoButton == 1\n                        ? '<br>You must press \"Yes\".'\n                        : '<br>You must press \"No\".',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: \"<br>\",\n                    yBackgroundColor: \"white\"\n                }\n            };\n            \n\n            const config = configs[causalElicitType];\n\t\t\taMessage = config.aMessage;\n\t\t\taBackgroundColor = config.aBackgroundColor;\n\t\t\txMessage = config.xMessage;\n\t\t\txBackgroundColor = config.xBackgroundColor;\n\t\t\tyMessage = config.yMessage;\n\t\t\tyBackgroundColor = config.yBackgroundColor;\n\n\t\t\t\/\/ Swap messages when order is AYX and no forced choice\n\t\t\tif (order === \"AYX\" && exoButton == null && (causalElicitType === \"AX\" || causalElicitType === \"AY\")) {\n\t\n\t\t\t\tconst temp = xMessage;\n\t\t\t\txMessage = yMessage;\n\t\t\t\tyMessage = temp;\n\t\t\t}\n\n            document.querySelectorAll('.panel-name').forEach(el => {\n                el.textContent = el.textContent.replace(' (determines your bonus)', '');\n            });\n\n            \n\n            initiateRound();\n        }\n    }\n\n\n    \/\/ NEW: Function to set up all panel content at the beginning\nfunction setupAllPanels() {\n    \/\/ Clear any existing content and pointers\n    AText.innerHTML = \"\";\n    XText.innerHTML = \"\";\n    YText.innerHTML = \"\";\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Reset backgrounds\n    panelAinfo.style.backgroundColor = \"white\";\n    panelXinfo.style.backgroundColor = \"white\";\n    panelYinfo.style.backgroundColor = \"white\";\n    \n    \/\/ Set up panel content based on causalElicitType and exoButton\n    if (exoButton != null) {\n        \/\/ Cases with locked\/forced choices\n        if (causalElicitType === 'AX') {\n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(createLockIcon());\n            \n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'AY') {\n            XText.innerHTML = '<div style=\"margin-top: 10px;\">' + xMessage + '<\/div>';\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            panelXinfo.appendChild(createLockIcon());\n            \n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'XY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(createLockIcon());\n            \n            XText.innerHTML = '<div style=\"margin-top: 10px;\">' + xMessage + '<\/div>';\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            panelXinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'YX') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(createLockIcon());\n            \n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n        }\n    } else {\n        \/\/ Cases with free choices (exoButton == null)\n        if (causalElicitType === 'AX') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'AY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'XY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'YX') {\n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n        }\n    }\n}\n\n\n    \/\/ NEW: Stage 0 - Add content to locked\/forced panel only\n    function showStage0() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    if (exoButton != null) {\n        \/\/ Determine the forced choice text based on exoButton value\n        const forcedChoice = exoButton == 1 ? '\"Yes\"' : '\"No\"';\n        \n        \/\/ Add pointer to locked panel\n        if (causalElicitType === 'AX') {\n            highlightActivePanel(panelYinfo);\n            const pointer = panelYinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Bonus Player must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'AY') {\n            highlightActivePanel(panelXinfo);\n            const pointer = panelXinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Co-Player must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'XY' || causalElicitType === 'YX') {\n            highlightActivePanel(panelAinfo);\n            const pointer = panelAinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which you must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        }\n    } else {\n        \/\/ Add pointer to free choice panel\n        if (causalElicitType === 'AX') {\n            highlightActivePanel(panelYinfo);\n            const pointer = panelYinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Bonus Player chooses freely...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'AY') {\n            highlightActivePanel(panelXinfo);\n            const pointer = panelXinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Co-Player chooses freely...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        }\n    }\n}\n\n    \/\/ NEW: Stage 1 - Add content to decision panel (with buttons)\n    function showStage1() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    let pointerText = '';\n    \n    \/\/ Add pointer to decision panel\n    if (exoButton == null) {\n        if (causalElicitType === 'YX') {\n            highlightActivePanel(panelYinfo);\n            pointerText = \"...report how the Bonus Player's choice...\";\n        } else {\n            highlightActivePanel(panelAinfo);\n            pointerText = \"...report how your choice...\";\n        }\n    } else {\n        if (causalElicitType === 'AX' || causalElicitType === 'AY') {\n            highlightActivePanel(panelAinfo);\n            pointerText = \"...report how your choice...\";\n        } else if (causalElicitType === 'XY') {\n            highlightActivePanel(panelXinfo);\n            pointerText = \"...report how the Co-Player's choice...\";\n        } else if (causalElicitType === 'YX') {\n            highlightActivePanel(panelYinfo);\n            pointerText = \"...report how the Bonus Player's choice...\";\n        }\n    }\n    \n    const pointer = document.querySelector('.active-choice .choice-pointer');\n    if (pointer) {\n        pointer.innerHTML = '<span>' + pointerText + '<\/span>';\n        pointer.classList.add('active-choice');\n    }\n    \n    decisionPanelShown = true;\n    attachProgressButton();\n}\n    \/\/ NEW: Stage 2 - Add content to \"?\" panel\n    function showStage2() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Add pointer to \"?\" panel\n    if (causalElicitType === 'XY' || causalElicitType === 'AY') {\n        highlightActivePanel(panelYinfo);\n        const pointer = panelYinfo.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.innerHTML = '<span>... affects the Bonus Player.<\/span>';\n            pointer.classList.add('active-choice');\n        }\n    } else if (causalElicitType === 'YX' || causalElicitType === 'AX') {\n        highlightActivePanel(panelXinfo);\n        const pointer = panelXinfo.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.innerHTML = '<span>... affects the Co-Player.<\/span>';\n            pointer.classList.add('active-choice');\n        }\n    }\n    \n    \/\/ Set xReady for the next stage\n    if (exoButton == null) {\n        xReady = true;\n    }\n    \n    attachProgressButton();\n}\n\n    function prepareActionPanels() {\n\t\tcorrectAnswers.push(correctAnswerList);\n        correctAnswersSlider1.push(correctAnswerListSlider1);\n        correctAnswersSlider2.push(correctAnswerListSlider2);\n\n\t\tconsole.log(\"here\");\n\t\tconsole.log(correctAnswers);\n        window.scrollTo({ top: 0, behavior: 'smooth' });\n        \n        \/\/ NEW: Reset display stage\n        displayStage = 0;\n        hasStarted = false;\n        startButton.innerHTML = \"Start this scenario\"; \/\/ Reset button text\n        startButton.style.display = 'block'; \/\/ Show button again\n        \n        if (causalElicitType === 'XY') {\n            btnYes.innerHTML = \"Co-Player: Yes\";\n            btnNo.innerHTML = \"Co-Player: No\";\n\t\t}\n        else if (causalElicitType === 'YX') {\n            btnYes.innerHTML = \"Bonus Player: Yes\";\n            btnNo.innerHTML = \"Bonus Player: No\";\n\n        } else {\n            btnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n            btnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n        }\n\n        \/\/ NEW: Show all three panels as blank\n        panelXinfo.style.display = 'block';\n        panelYinfo.style.display = 'block';\n        panelAinfo.style.display = 'block';\n        \n        \/\/ Clear all content\n        AText.innerHTML = \"\";\n        XText.innerHTML = \"\";\n        YText.innerHTML = \"\";\n        \n        \/\/ Reset backgrounds\n        panelAinfo.style.backgroundColor = \"white\";\n        panelXinfo.style.backgroundColor = \"white\";\n        panelYinfo.style.backgroundColor = \"white\";\n    }\n\n    function startRoundDisplay() {\n    instructionElement.style.display = 'block';\n    \n    \/\/ Set up all panel content first\n    setupAllPanels();\n    \n    \/\/ Then show the appropriate first stage\n    if (exoButton != null || causalElicitType === 'AX' || causalElicitType === 'AY') {\n        showStage0();\n        displayStage = 0;\n    } else {\n        showStage1();\n        displayStage = 1;\n    }\n    \n    roundStartTime = Date.now();\n}\n    nextRound();\n});","DefaultChoices":false,"DataExportTag":"Q535","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Scenario of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game Game ${e:\/\/Field\/currentSymbol} Start...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID542"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID543","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dietersGameShuffleV3.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var self = this;\n    var completed = false;\n    var active = true;  \/\/ guard flag \u2014 flips to false on unload\n    \n    var currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n    var nSupergames = '${e:\/\/Field\/nSupergames}';\n    var nRounds = '${e:\/\/Field\/nRounds}';\n    var id = parseInt(\"${e:\/\/Field\/id}\");\n    var currentGameId = 'scenarioReveal_' + id;\n    \n    function sendInit() {\n        if (!active) return;  \/\/ don't send if page is gone\n        var iframe = document.querySelector('iframe');\n        if (!iframe || !iframe.contentWindow) return;\n        var shownScenarios = [];\n        try {\n            shownScenarios = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('shownScenarios') || '[]');\n        } catch (e) {}\n        iframe.contentWindow.postMessage({\n            type: 'INIT',\n            participantId: currentParticipantId,\n            gameId: currentGameId,\n            gameConfig: {\n                shownScenarios: shownScenarios,\n                gameCounter: '${e:\/\/Field\/gameCounter}',\n                playerName0: '${e:\/\/Field\/playerName0}',\n                playerName1: '${e:\/\/Field\/playerName1}',\n                playerIcon0: '${e:\/\/Field\/playerIcon0}',\n                yBonus: parseFloat(\"${e:\/\/Field\/yBonus}\"),\n                aCost: parseFloat(\"${e:\/\/Field\/aCost}\"),\n                currency: \"${e:\/\/Field\/currency}\",\n                order: \"${e:\/\/Field\/order}\",\n                themeColor: \"${e:\/\/Field\/color}\",\n                nRounds: \"${e:\/\/Field\/nRounds}\"\n            }\n        }, '*');\n        console.log('Sent INIT to scenarioReveal iframe (gameId=' + currentGameId + ')');\n    }\n    \n    var messageHandler = function(event) {\n        if (!active) return;\n        if (!event.data || event.data.type !== 'GAME_DATA') return;\n        if (completed) return;\n        var dataType = event.data.dataType;\n        var data = event.data.data;\n        console.log('Received:', dataType, data);\n        switch (dataType) {\n            case 'SCENARIO_REVEALED':\n                Qualtrics.SurveyEngine.setEmbeddedData('scenarioIndex', data.scenarioIndex);\n                Qualtrics.SurveyEngine.setEmbeddedData('shownScenarios', JSON.stringify(data.shownScenarios));\n                Qualtrics.SurveyEngine.setEmbeddedData('currentSymbol', data.tileHTML);\n                console.log('Saved scenario:', data.drinkName, data.drinkIcon, data.chemicalName);\n                break;\n            case 'SCENARIO_COMPLETE':\n                completed = true;\n                cleanup();\n                setTimeout(function() {\n                    jQuery(\"#NextButton\").click();\n                }, 500);\n                break;\n        }\n    };\n    \n    var readyHandler = function(event) {\n        if (!active) return;\n        if (event.data && event.data.type === 'IFRAME_READY') {\n            sendInit();\n        }\n    };\n    \n    var initTimer = setTimeout(sendInit, 500);\n    \n    function cleanup() {\n        active = false;\n        window.removeEventListener('message', messageHandler);\n        window.removeEventListener('message', readyHandler);\n        if (initTimer) {\n            clearTimeout(initTimer);\n            initTimer = null;\n        }\n        console.log('Cleaned up scenarioReveal handlers (gameId=' + currentGameId + ')');\n    }\n    \n    window.addEventListener('message', messageHandler);\n    window.addEventListener('message', readyHandler);\n    \n    \/\/ Stash cleanup so addOnUnload can find it\n    self._cleanup = cleanup;\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (this._cleanup) {\n        this._cleanup();\n        this._cleanup = null;\n    }\n});","DefaultChoices":false,"DataExportTag":"divider","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID543"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID544","SecondaryAttribute":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})<\/h1>","DefaultChoices":false,"DataExportTag":"Q537","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game ${e:\/\/Field\/gameCounter} (of ${e:\/\/Field\/nSupergames})","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID544"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID545","SecondaryAttribute":"${e:\/\/Field\/currentSymbol}","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"display: flex; justify-content: center; align-items: center;\">                                                                                                                                    \n  ${e:\/\/Field\/currentSymbol}                                                                                                                                                                                         \n  <\/div>","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"Q538","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${e:\/\/Field\/currentSymbol}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID545"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID546","SecondaryAttribute":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;\n<div style=\"text-align: center;\"><strong>Please indicate below who you think had an influence on whom in game <span style=\"text-align: center;\"><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/span><\/strong><\/div>\n\n<ul>\n\t<li>Please draw arrows between the three players below. An arrow from one player to another means the former could influence the latter in a given round. Make an arrow if you think there was an influence, regardless of whether the influence was strong or weak.<\/li>\n\t<li>To draw an arrow, click on a player, hold your mouse pressed, and move it.<\/li>\n\t<li>To delete an arrow, double-click it.<\/li>\n<\/ul>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n  var q = this;\n\n  \/\/ ---------- DOM scaffold ----------\n  var qc = this.getQuestionContainer();\n  var qt = qc.querySelector('.QuestionText');\n  var wrap = document.createElement('div');\n  wrap.id = 'dag-wrap';\n  wrap.innerHTML = [\n    '<style>',\n    '  #dag-wrap{font-family:system-ui,Arial,sans-serif;}',\n    '  #dag-stage{width:100%;height:60vh;background:#f7f7f7;border:1px solid #ddd;border-radius:8px;}',\n    '  .label{font-size:20px;text-anchor:middle;dominant-baseline:middle;pointer-events:none;}',\n    '  .edge{stroke:#c00;stroke-width:2.5;fill:none;cursor:pointer;pointer-events:stroke;}',\n    '  .node-box{fill:#fff;stroke:#222;stroke-width:2;}',\n    '  #dag-controls{margin-top:6px;display:flex;gap:8px;align-items:center;font-size:12px;color:#555;}',\n    '  #dag-reset{padding:6px 10px;cursor:pointer;border:1px solid #aaa;border-radius:6px;background:#fff;}',\n    '<\/style>',\n    '<svg id=\"dag-stage\" viewBox=\"0 0 800 600\"><\/svg>',\n    '<div id=\"dag-controls\">',\n    '  <button id=\"dag-reset\" type=\"button\">Reset<\/button>',\n    '  <span>Drag from a node to another to add an arrow. Double-click an arrow to delete.<\/span>',\n    '<\/div>'\n  ].join('');\n  qt.appendChild(wrap);\n\n  \/\/ ---------- Core state ----------\n  var svg = document.getElementById('dag-stage');\n  var resetBtn = document.getElementById('dag-reset');\n  var PADX = 50, PADY = 35, CORNER = 30;\n  var GAP_LEAVE = 6, GAP_RING = 2, HEAD_LEN = 14;\n\n  var nodes = [\n    { id:'p1',  lines:['${e:\/\/Field\/playerName1}'],  x:200, y:120 },\n    { id:'p2',  lines:['${e:\/\/Field\/playerName2}'], x:600, y:120 },\n    { id:'you', lines:['You', '(chooses first)'],    x:400, y:460 }\n  ];\n  var edges = [];\n  var alertCount = 0;\n  var hasAddedEdge = false;\n\n  \/\/ ---------- Layers ----------\n  var defs  = el('defs');\n  var gNodes= el('g');\n  var gTemp = el('g');\n  var gEdges= el('g');\n  svg.append(defs,gNodes,gTemp,gEdges);\n\n  \/\/ Arrowhead marker (bigger + red)\n  var marker = el('marker',{\n    id:'arrowhead', viewBox:'0 0 12 12', refX:12, refY:6,\n    markerWidth:18, markerHeight:18, orient:'auto-start-reverse',\n    markerUnits:'userSpaceOnUse'\n  });\n  marker.appendChild(el('path',{ d:'M 0 0 L 12 6 L 0 12 z', fill:'#c00' }));\n  defs.appendChild(marker);\n\n  \/\/ Nodes\n  nodes.forEach(function(n){\n    var g = el('g',{ class:'node','data-id':n.id });\n\n    var tg = el('g');\n    n.lines.forEach(function(t,i){\n      tg.appendChild(el('text',{\n        class:'label', x:n.x, y:n.y - (n.lines.length-1)*9 + i*18\n      }, t));\n    });\n    g.appendChild(tg); gNodes.appendChild(g);\n\n    var bb = tg.getBBox(), w=bb.width+2*PADX, h=bb.height+2*PADY;\n    var x = n.x-w\/2, y = n.y-h\/2;\n    g.insertBefore(el('rect',{class:'node-box', x:x, y:y, width:w, height:h, rx:CORNER, ry:CORNER}), tg);\n\n    n.box = {x:x,y:y,w:w,h:h};\n    n.anchorR = Math.min(w,h)\/2 - 2;\n  });\n\n  var centroid = { x: avg(nodes.map(function(n){return n.x;})), y: avg(nodes.map(function(n){return n.y;})) };\n\n  \/\/ ---------- Interaction ----------\n  var dragStart=null, dragging=false, tempPath=null;\n\n  gNodes.addEventListener('mousedown', function(e){\n    var id = nodeAt(e); if(!id) return;\n    dragStart = getNode(id); dragging=true;\n    tempPath = el('path',{class:'edge','marker-end':'url(#arrowhead)',strokeDasharray:'4 4'});\n    gTemp.appendChild(tempPath);\n  });\n\n  svg.addEventListener('mousemove', function(e){\n    if(!dragging||!dragStart||!tempPath) return;\n    var p = svgPoint(e);\n    tempPath.setAttribute('d', curve(dragStart, {x:p.x,y:p.y}, null, 46));\n  });\n\n  svg.addEventListener('mouseup', function(e){\n    if(!dragging) return cleanup();\n    var id = nodeAt(e);\n    if(id && id!==dragStart.id) addEdge(dragStart.id,id);\n    cleanup();\n    persist();\n  });\n\n  gEdges.addEventListener('dblclick', function(e){\n    var p = e.target.closest('path.edge'); if(!p) return;\n    var key = p.getAttribute('data-key');\n    var i = edges.findIndex(function(ed){return keyOf(ed)===key;});\n    if(i>=0){ edges.splice(i,1); p.remove(); persist(); }\n  });\n\n  resetBtn.addEventListener('click', function(){\n    edges = [];\n    drawEdges();\n    persist();\n  });\n\n  function cleanup(){ dragging=false; dragStart=null; if(tempPath) tempPath.remove(); tempPath=null; }\n\n  function addEdge(s,t){\n\t  \/\/ Show warning for invalid connections but still allow them\n\t  if(s === 'p1' && t === 'you'){\n\t\talertCount++;\n\t\talert(\"Alert #\" + alertCount + \": You did not know the Co-Player's choice when making yours. Hence, the Co-Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n\t  }\n\t  if(s === 'p2' && t === 'you'){\n\t\talertCount++;\n\t\talert(\"Alert #\" + alertCount + \": You did not know the Bonus Player's choice when making yours. Hence, the Bonus Player's choice cannot have affected your choice within any given round. You can double-click an arrow to delete it.\");\n\t  }\n\n\t  if(edges.some(function(e){return e.source===s && e.target===t;})) return;\n\t  edges.push({source:s,target:t}); drawEdges();\n\t  hasAddedEdge = true;\n\t}\n\t\n  function drawEdges(){\n    gEdges.innerHTML='';\n    for(var i=0;i<edges.length;i++){\n      var e = edges[i];\n      var s=getNode(e.source), t=getNode(e.target);\n      var d = curve(s,t, dir(s.id,t.id), 54);\n      gEdges.appendChild(el('path',{class:'edge', d:d, 'marker-end':'url(#arrowhead)', 'data-key':keyOf(e)}));\n    }\n  }\n\n  \/\/ ---------- Geometry ----------\n  function curve(src, tgt, dirType, offset){\n    var sx=src.x, sy=src.y;\n    var tx=('x' in tgt)?tgt.x:getNode(tgt).x;\n    var ty=('y' in tgt)?tgt.y:getNode(tgt).y;\n\n    var theta = Math.atan2(ty-sy, tx-sx);\n    var start = {\n      x: sx + Math.cos(theta) * (src.anchorR + GAP_LEAVE),\n      y: sy + Math.sin(theta) * (src.anchorR + GAP_LEAVE)\n    };\n\n    var end;\n    if('x' in tgt){\n      end = {x:tx,y:ty};\n    } else {\n      var tn = getNode(tgt);\n      var tip = {\n        x: tn.x + Math.cos(theta+Math.PI) * (tn.anchorR - GAP_RING),\n        y: tn.y + Math.sin(theta+Math.PI) * (tn.anchorR - GAP_RING)\n      };\n      var ux = Math.cos(theta+Math.PI), uy = Math.sin(theta+Math.PI);\n      var sep = 6, tanx = -uy, tany = ux, sgn = (src.id < tn.id)?1:-1;\n      end = { x: tip.x - ux*HEAD_LEN + tanx*sep*sgn,\n              y: tip.y - uy*HEAD_LEN + tany*sep*sgn };\n    }\n\n    var dx=end.x-start.x, dy=end.y-start.y, L=Math.hypot(dx,dy)||1;\n    var mx=(start.x+end.x)\/2, my=(start.y+end.y)\/2;\n    var nx=-dy\/L, ny=dx\/L;\n    var outward = ((mx-centroid.x)*nx + (my-centroid.y)*ny) > 0 ? 1 : -1;\n    var sign = dirType==='ccw' ? -outward : outward;\n\n    var cx = mx + nx*offset*sign;\n    var cy = my + ny*offset*sign;\n    return 'M '+start.x+' '+start.y+' Q '+cx+' '+cy+' '+end.x+' '+end.y;\n  }\n\n  function dir(s,t){\n    var o=['p1','p2','you']; var i=o.indexOf(s), j=o.indexOf(t);\n    return ((i+1)%3===j)?'cw':'ccw';\n  }\n\n  function nodeAt(e){\n    var p = svgPoint(e);\n    var n = nodes.find(function(n){\n      return p.x>=n.box.x && p.x<=n.box.x+n.box.w && p.y>=n.box.y && p.y<=n.box.y+n.box.h;\n    });\n    return n ? n.id : null;\n  }\n\n  \/\/ ---------- Utils ----------\n  function el(tag, attrs, text){\n    if(!attrs) attrs={};\n    var E = document.createElementNS('http:\/\/www.w3.org\/2000\/svg', tag);\n    Object.keys(attrs).forEach(function(k){ E.setAttribute(k, attrs[k]); });\n    if(text!=null) E.textContent = text;\n    return E;\n  }\n  function getNode(id){ return nodes.find(function(n){return n.id===id;}); }\n  function keyOf(e){ return e.source+'->'+e.target; }\n  function avg(a){ return a.reduce(function(s,v){return s+v;},0)\/a.length; }\n  function svgPoint(e){ var p=svg.createSVGPoint(); p.x=e.clientX; p.y=e.clientY; return p.matrixTransform(svg.getScreenCTM().inverse()); }\n\n  \/\/ ---------- Persist + Next gating ----------\n  function persist(){\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id'); \n    Qualtrics.SurveyEngine.setEmbeddedData('subjDAG2_' + id, JSON.stringify(edges));\n\tQualtrics.SurveyEngine.setEmbeddedData('DAGAlertCount2_' + id, alertCount);\n    updateNextVisibility();\n  }\n\n  function updateNextVisibility(){\n  if(hasAddedEdge){ q.showNextButton(); }  \n}\n\n  \/\/ Hide Next until at least one edge exists\n  q.hideNextButton();\n  updateNextVisibility();\n\n  \/\/ Save on page leave and on Next\n  Qualtrics.SurveyEngine.addOnUnload(persist);\n  var nb = document.getElementById('NextButton');\n  if (nb) nb.addEventListener('click', persist, {capture:true});\n\n  \/\/ Initial draw\n  drawEdges();\n  persist();\n});","DefaultChoices":false,"DataExportTag":"Q539","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 Please indicate below who you think had an influence on whom in game Game...","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_cUtq2NpCz2O2hbo,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID546"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID547","SecondaryAttribute":"Game Instructions You will play with two computer players that we call the Bonus Player and the C...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align: center;\" id=\"gameTitle\"><b>Game Instructions<\/b><\/h1>\n<br>\n<span>You will play with two computer players that we call the <b>Bonus Player<\/b> and the <b>Co-Player<\/b>.<\/span><br>\n&nbsp;\n<h2>Payments<\/h2>\n<br>\nYou begin each round with a baseline bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/basePay}.<br>\n<br>\nIn each round, every player chooses whether to press their button. Your payment depends on who presses their button:\n<ul>\n\t<li>The <b>Bonus Player<\/b> decides whether you receive an <b>additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus<\/b>. If they press their button, you get the bonus; if not, you don't.<\/li>\n\t<li>The <b>Co-Player<\/b> decides whether pressing your own button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, deducted from your baseline bonus. That is, <b>if the Co-Player presses their button, you can press your button for free. If the Co-Player does not, then pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}.<\/b><\/li>\n<\/ul>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\t\n\n});\n\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Instructions You will play with two computer players that we call the Bonus Player and the C...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<h1 style=\"text-align: center;\" id=\"gameTitle\"><b>Game Instructions<\/b><\/h1>\n<br>\n<span>You will play with two computer players that we call the <b>Bonus Player<\/b> and the <b>Co-Player<\/b>.<\/span><br>\n&nbsp;\n<h2>Payments<\/h2>\n<br>\nYou begin each round with a baseline bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/basePay}.<br>\n<br>\nIn each round, every player chooses whether to press their button. Your payment depends on who presses their button:\n<ul>\n\t<li>The <b>Bonus Player<\/b> decides whether you receive an <b>additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus<\/b>. If they press their button, you get the bonus; if not, you don't.<\/li>\n\t<li>The <b>Co-Player<\/b> decides whether pressing your own button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, deducted from your baseline bonus. That is, <b>if the Co-Player presses their button, you can press your button for free. If the Co-Player does not, then pressing your button costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}.<\/b><\/li>\n<\/ul>","DataExportTag":"Q547","QuestionID":"QID547"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID548","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":24,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q548","QuestionID":"QID548"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID549","SecondaryAttribute":"Order of play You always move after the Co-Player. There are two versions of the game. They diffe...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2><b>Order of play<\/b><\/h2>\n<br>\n<b>You always move after the Co-Player.<\/b> \n\nThere are two versions of the game. They differ in whether the Bonus Player observes your choice or the Co-Player's choice. \n<span id=\"gameDesc\">[Game description]<\/span><br>\n\n<b>We will not tell you which version you are playing; you might be playing either.<\/b> At the start of each of the ${e:\/\/Field\/nSupergames} games, the computer selects the version you will play. That version remains fixed for all ${e:\/\/Field\/nRounds} rounds of that game. Each new game may use the same or a different version.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Order of play You always move after the Co-Player. There are two versions of the game. They diffe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n  var versions = [\n    {\n      html: \"<ul><li>Version 1: the Bonus Player observes only your choice but not the Co-Player\u2019s choice. If you are playing this version, it is possible that you affect the Bonus Player\u2019s choice.\u00a0<\/li><li>Version 2: the Bonus Player observes only the Co-Player\u2019s choice but not yours. If you are playing this version, your own choice has no impact on the Bonus Player\u2019s choice.\u00a0<\/li><\/ul>\",\n      key : 1\n    },\n    {\n      html: \"<ul><li>Version 1: the Bonus Player observes only the Co-Player\u2019s choice but not yours. If you are playing this version, your own choice has no impact on the Bonus Player\u2019s choice.\u00a0<\/li><li>Version 2: the Bonus Player observes only your choice but not the Co-Player\u2019s choice. If you are playing this version, it is possible that you affect the Bonus Player\u2019s choice.<\/li><\/ul>\",\n      key : 2\n    }\n  ];\n\n  var idx  = Math.random() < 0.5 ? 0 : 1;\n  var html = versions[idx].html;\n\n  jQuery(this.questionContainer).find(\"#gameDesc\").html(html);\n\n\n  var gameCounter = parseInt(\"${e:\/\/Field\/gameCounter}\");\n\n  Qualtrics.SurveyEngine.setEmbeddedData(\"gameVersionsDescriptionOrderMigraines1\", versions[idx].key);\n  Qualtrics.SurveyEngine.setEmbeddedData(\"gameVersionsDescriptionOrderMigraines2\", 3-versions[idx].key);\n  Qualtrics.SurveyEngine.setEmbeddedData(\"gameDescriptionMigraines\", html);\n  var dieterFirst = parseInt(\"${e:\/\/Field\/dieterFirst}\");\n     if (dieterFirst == 0){\n\t  jQuery(this.questionContainer).find(\"#D2\").html(\"Unlike in the first ${e:\/\/Field\/nMigraines} games, \");\n\t  \n  }\n\t\n\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<h2><b>Order of play<\/b><\/h2>\n<br>\n<b>You always move after the Co-Player.<\/b> \n\nThere are two versions of the game. They differ in whether the Bonus Player observes your choice or the Co-Player's choice. \n<span id=\"gameDesc\">[Game description]<\/span><br>\n\n<b>We will not tell you which version you are playing; you might be playing either.<\/b> At the start of each of the ${e:\/\/Field\/nSupergames} games, the computer selects the version you will play. That version remains fixed for all ${e:\/\/Field\/nRounds} rounds of that game. Each new game may use the same or a different version.","DataExportTag":"Q549","QuestionID":"QID549"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID55","SecondaryAttribute":"${e:\/\/Field\/instructionText}","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n  .miniGame{\n    display:inline-flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    width:70px;height:70px;border-radius:12px;\n    background:hsl(${e:\/\/Field\/currentHue} 70% 85%);\n    font-family:sans-serif;\n    vertical-align:middle;          \/* keeps it level with the text *\/\n  }\n  .miniGame .sym  {font-size:38px;line-height:1;color:#333;}\n  .miniGame .label{font-size:14px;color:#333;margin-bottom:2px;}\n<\/style>\n\n<div style=\"text-align: center;\">${e:\/\/Field\/instructionText}<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q48","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${e:\/\/Field\/instructionText}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID55"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID550","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":24,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q550","QuestionID":"QID550"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID551","SecondaryAttribute":"What you will see In each round, you will first observe whether pressing your button is free or c...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2><b>What you will see<\/b><\/h2>\n<br>\nIn each round, you will first observe whether pressing your button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, as determined by <b>Co-Player<\/b>'s choice. Then, you will make a choice about whether or not to press your button. After that, you will then see the Bonus Player' choice.\n<br><br>\n\nYou can make your choices using either your mouse or your keyboard. If you're using your keyboard, press <em>Y<\/em> for \"Yes\" and <em>N<\/em> for \"No\".\n\n<br><br>\n<b>You will always see the Bonus Player's choice after your choice, regardless of whether the Bonus Player actually observes your or the Co-Player's choice.<\/b>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What you will see In each round, you will first observe whether pressing your button is free or c...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionText_Unsafe":"<h2><b>What you will see<\/b><\/h2>\n<br>\nIn each round, you will first observe whether pressing your button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, as determined by <b>Co-Player<\/b>'s choice. Then, you will make a choice about whether or not to press your button. After that, you will then see the Bonus Player' choice.\n<br><br>\n\nYou can make your choices using either your mouse or your keyboard. If you're using your keyboard, press <em>Y<\/em> for \"Yes\" and <em>N<\/em> for \"No\".\n\n<br><br>\n<b>You will always see the Bonus Player's choice after your choice, regardless of whether the Bonus Player actually observes your or the Co-Player's choice.<\/b>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> endog <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"endog","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"DataExportTag":"Q551","QuestionID":"QID551"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID552","SecondaryAttribute":"Two Kinds of Rounds \u00a0 In each round, you will first observe whether pressing your button is free...","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2><b>Two Kinds of Rounds<\/b><\/h2>\n&nbsp;\n\n<p>In each round, you will first observe whether pressing your button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, as determined by <b>Co-Player<\/b>'s choice. <\/p>\n<br>\n\n<p>Each game includes <b>some rounds<\/b> in which you <b>cannot choose<\/b> whether to press your button, because only one button will be clickable. Once you click, you will see the Bonus Player's choices. In these rounds, you do not make a choice yourself, but they help you <b>observe how the players respond<\/b> to one another and to you. <b>you will always see the Bonus Player's choice after your choice, regardless of whether the Bonus Player actually observes your or the Co-Player's choice.<\/b><\/p> \n&nbsp;\n\n<p>You will have to make these choices using your <b>mouse<\/b>.<\/p>\n&nbsp;\n\n<p>In <b>other rounds<\/b>, you will <b>make your own choice<\/b>. In these rounds, you will not see the Bonus Player's choices. However, the <b> Bonus Player's choice will still determine your bonus<\/b> if that round is randomly selected for payment.<\/p>\n&nbsp;\n\n<p>You must use your <b>keyboard<\/b>, not your mouse, to make these choices: press <em>Y<\/em> for &quot;Yes&quot; and <em>N<\/em> for &quot;No&quot;.<\/p>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tthis.hideNextButton();\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Two Kinds of Rounds \u00a0 In each round, you will first observe whether pressing your button is free...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">treatment<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> exo <\/span>","LeftOperand":"treatment","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"exo","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<h2><b>Two Kinds of Rounds<\/b><\/h2>\n&nbsp;\n\n<p>In each round, you will first observe whether pressing your button is free or costs ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}, as determined by <b>Co-Player<\/b>'s choice. <\/p>\n<br>\n\n<p>Each game includes <b>some rounds<\/b> in which you <b>cannot choose<\/b> whether to press your button, because only one button will be clickable. Once you click, you will see the Bonus Player's choices. In these rounds, you do not make a choice yourself, but they help you <b>observe how the players respond<\/b> to one another and to you. <b>you will always see the Bonus Player's choice after your choice, regardless of whether the Bonus Player actually observes your or the Co-Player's choice.<\/b><\/p> \n&nbsp;\n\n<p>You will have to make these choices using your <b>mouse<\/b>.<\/p>\n&nbsp;\n\n<p>In <b>other rounds<\/b>, you will <b>make your own choice<\/b>. In these rounds, you will not see the Bonus Player's choices. However, the <b> Bonus Player's choice will still determine your bonus<\/b> if that round is randomly selected for payment.<\/p>\n&nbsp;\n\n<p>You must use your <b>keyboard<\/b>, not your mouse, to make these choices: press <em>Y<\/em> for &quot;Yes&quot; and <em>N<\/em> for &quot;No&quot;.<\/p>","DataExportTag":"Q552","QuestionID":"QID552"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID553","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":24,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q553","QuestionID":"QID553"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID554","SecondaryAttribute":"Comprehension check \u00a0 To make sure you have understood these instructions, please answer the next..","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>Comprehension check<\/strong><\/h2>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><em>To make sure you have understood these instructions, please answer the next two questions.<\/em><\/div>\n<br \/>\n<strong>Which of the following statements about your payment are correct?<\/strong> Select all that apply.","DefaultChoices":false,"QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Comprehension check \u00a0 To make sure you have understood these instructions, please answer the next...","Choices":{"1":{"Display":"Whether I press my button or not does <u>not<\/u> affect my payment."},"2":{"Display":"Pressing my button will always cost ${e:\/\/Field\/currency}${e:\/\/Field\/aCost}."},"3":{"Display":"If the Bonus Player presses their button, I'll receive an additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus."},"4":{"Display":"My overall payment will be determined by one decision randomly selected from throughout the study."},"5":{"Display":"My overall payment will be the sum of all the payments I collect over the various games and rounds of each game I play."},"6":{"Display":"If the Co-Player presses their button, I'll receive an additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus."},"7":{"Display":"Pressing my button will cost ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} if the Co-Player did not press their button, but will be free if the Co-Player pressed their button."}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"CustomValidation","MinChoices":"1","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID554\/SelectableChoice\/7","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Comprehension check &nbsp; To make sure you have understood these instructions, please answer the next...<\/span> <span class=\"LeftOpDesc\">Pressing my button will cost ${e:\/\/Field\/currency}${e:\/\/Field\/aCost} if the Co-Player did not press their button, but will be free if the Co-Player pressed their button.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID554\/SelectableChoice\/7","LogicType":"Question","Operator":"Selected","QuestionID":"QID554","QuestionIDFromLocator":"QID554","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID554\/SelectableChoice\/3","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">Comprehension check &nbsp; To make sure you have understood these instructions, please answer the next...<\/span> <span class=\"LeftOpDesc\">If the Bonus Player presses their button, I'll receive an additional ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} bonus.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID554\/SelectableChoice\/3","LogicType":"Question","Operator