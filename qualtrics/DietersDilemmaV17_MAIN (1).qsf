var allAnswers = Qualtrics.SurveyEngine.getEmbeddedData(\"allAnswersMigrainesQ1\") || \"\";\n    \n    var nextBtn = document.getElementById(\"NextButton\");\n    nextBtn.addEventListener(\"click\", function(e)\n    {\n        var userAnswer = that.getSelectedChoices() || \"none\";\n        \n        \/\/ Add this answer to history\n        if (allAnswers === \"\") {\n            allAnswers = userAnswer;\n        } else {\n            allAnswers = allAnswers + \"||\" + userAnswer;\n        }\n        \n        \/\/ Check if correct\n        if (userAnswer === correctAnswer) {\n            \/\/ Correct!\n        } else {\n            \/\/ Wrong\n            wrongCount++;\n        }\n        \n        \/\/ Save data\n        Qualtrics.SurveyEngine.setEmbeddedData(\"wrongCountMigrainesQ1\", wrongCount);\n        Qualtrics.SurveyEngine.setEmbeddedData(\"allAnswersMigrainesQ1\", allAnswers);\n        \n    }, true);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/*Place your JavaScript here to run when the page is unloaded*\/\n});","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"<h2 style=\"text-align: center;\"><strong>Comprehension check<\/strong><\/h2>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><em>To make sure you have understood these instructions, please answer the next two questions.<\/em><\/div>\n<br \/>\n<strong>Which of the following statements about your payment are correct?<\/strong> Select all that apply.","DataExportTag":"Q554","QuestionID":"QID554"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID555","SecondaryAttribute":"Which of the following statements about the game versions and the display order are correct? Sele...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Which of the following statements about the game versions and the display order are correct?<\/b> Select all that apply.","DefaultChoices":false,"QuestionTy