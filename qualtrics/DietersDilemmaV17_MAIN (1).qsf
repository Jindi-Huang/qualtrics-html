ou will always see the Bonus Player\u2019s choice after your choice<\/b><strong>, regardless of whether the Bonus Player actually observes your or the Co-Player's choice.<\/strong><\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\tconst loopNum = \"${lm:\/\/CurrentLoopNumber}\";\n\tif (loopNum != 1){\n\t\tvar loopPrev = loopNum - 1;\n\t\tvar name1prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName1_' + loopPrev);\n\t\tvar name2prev = Qualtrics.SurveyEngine.getEmbeddedData('playerName2_' + loopPrev);\n\t\tjQuery(this.questionContainer).find(\"#D2\").html(\"They may play differently than \" +  name1prev + \" and \" + name2prev +\", with whom you played the previous game.\");\n\t}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this game, you will always see the Bonus Player\u2019s choice after your choice, regardless of whet...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\">In this game, <b>you will always see the Co-Player\u2019s choice before the Bonus Player\u2019s choice,<\/b> regardless of who actually moved when.&nbsp;<\/div>","DataExportTag":"Q438","QuestionID":"QID438","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"0","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"Su