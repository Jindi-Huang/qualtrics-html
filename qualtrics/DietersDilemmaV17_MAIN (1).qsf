:{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">testing<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID562"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID563","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/counfoundedChoiceInstructionsV2.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var completed = false;\n    const currentParticipantId = '${e:\/\/Field\/PROLIFIC_PID}';\n    const currentGameId = 'migrainesInstructions';\n    const currency = '${e:\/\/Field\/currency}';\n    const basePay = '${e:\/\/Field\/basePay}';\n    const aCost0 = '${e:\/\/Field\/aCostMigraines0}';\n    const aCost1 = '${e:\/\/Field\/aCostMigraines1}';\n    const yBonus = '${e:\/\/Field\/yBonus}';\n    const nRounds = '${e:\/\/Field\/nRounds}';\n    const playerName0 = '${e:\/\/Field\/playerName0}';\n    const playerName1 = '${e:\/\/Field\/playerName1}';\n    const playerIcon0 = '${e:\/\/Field\/playerIcon0}';\n\n    var messageHandler = function(event) {\n        if (event.data.type !== 'GAME_DATA') return;\n        if (completed) return;\n\n        const dataType = event.data.dataType;\n        const data = event.data.data;\n\n        console.log('Received:', dataType, data);\n\n        switch(dataType) {\n            case 'INSTRUCTIONS_COMPLETE':\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionsCompleted', data.completed);\n                Qualtrics.SurveyEngine.setEmbeddedData('attentionCheck', data.attentionCheck);\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehension', JSON.stringify(data.comprehension));\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountMigrainesQ1', data.wrongCountMigrainesQ1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('wrongCountMigrainesQ2', data.wrongCountMigrainesQ2 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersMigrainesQ1', JSON.stringify(data.allAnswersMigrainesQ1 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('allAnswersMigrainesQ2', JSON.stringify(data.allAnswersMigrainesQ2 || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('instructionTimes', JSON.stringify(data.pageTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('comprehTimes', JSON.stringify(data.comprehTimes || []));\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderMigraines1', data.gameVersionsDescriptionOrderMigraines1 || 0);\n                Qualtrics.SurveyEngine.setEmbeddedData('gameVersionsDescriptionOrderMigraines2', data.gameVersionsDescriptionOrderMigraines2 || 0);\n\n                completed = true;\n                window.removeEventListener('message', messageHandler);\n                setTimeout(function() {\n                    jQuery(\"#NextButton\").click();\n                }, 500);\n                break;\n        }\n    };\n\n    window.addEventListener('message', messageHandler);\n\n    \/\/ Iframe height listener\n    window.addEventListener('message', function(event) {\n        if (event.data && typeof event.data === 'object' && 'iframeHeight' in event.data) {\n            var h = Number(event.data.iframeHeight);\n            var iframe = document.getElementById('dietersGame');\n            if (iframe && Number.isFinite(h) && h > 300) {\n                iframe.style.height = Math.ceil(h) + 'px';\n            }\n        }\n    });\n\n    setTimeout(function() {\n        const iframe = document.querySelector('iframe');\n        if (iframe) {\n            iframe.contentWindow.postMessage({\n                type: 'INIT',\n                participantId: currentParticipantId,\n                gameId: currentGameId,\n                gameConfig: {\n                    currency: currency,\n                    basePay: parseFloat(basePay),\n                    aCost0: parseFloat(aCost0),\n                    aCost1: parseFloat(aCost1),\n                    yBonus: parseFloat(yBonus),\n                    nRounds: parseInt(nRounds),\n                    playerName0: playerName0,\n                    playerName1: playerName1,\n                    playerIcon0: playerIcon0\n                }\n            }, '*');\n        }\n    }, 1500);\n});","QuestionText_Unsafe":"<div id=\"dd-wrapper\" style=\"width:100%; margin:0; padding:0;\">\n  <style>\n    .SkinInner { max-width: none !important; width: 100% !important; }\n    .QuestionBody { width: 100% !important; max-width: none !important; }\n\n    #dietersGame {\n      width: 100%;\n      border: 0;\n      display: block;\n      overflow: hidden;\n    }\n  <\/style>\n\n  <iframe\n    id=\"dietersGame\"\n    src=\"https:\/\/jindi-huang.github.io\/qualtrics-html\/dieterInstructions.html\"\n    scrolling=\"no\"\n    allowfullscreen\n  ><\/iframe>\n\n  <script>\n    (function () {\n      const iframe = document.getElementById(\"dietersGame\");\n      if (!iframe) return;\n\n      \/\/ Start tall so there's no initial clipping while we wait for messages\n      iframe.style.height = \"1100px\";\n\n      window.addEventListener(\"message\", function (event) {\n        const data = event.data;\n        if (!data || typeof data !== \"object\") return;\n        if (!(\"iframeHeight\" in data)) return;\n\n        const h = Number(data.iframeHeight);\n        if (Number.isFinite(h) && h > 300) {\n          iframe.style.height = Math.ceil(h) + \"px\";\n        }\n      });\n    })();\n  <\/script>\n<\/div>\n","DataExportTag":"Q563","QuestionID":"QID563"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID564","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3"