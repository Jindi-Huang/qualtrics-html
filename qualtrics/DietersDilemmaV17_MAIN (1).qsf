span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"testing","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"History 1: ${e:\/\/Field\/history_1}<br>\nRound Times 1: ${e:\/\/Field\/roundTimes_1}<br>\nPayment 1: ${e:\/\/Field\/payment_1}<br>\n<br>\nHistory 2: ${e:\/\/Field\/history_2}<br>\nRound Times 2: ${e:\/\/Field\/roundTimes_2}<br>\nPayment 2: ${e:\/\/Field\/payment_2}<br>\n<br>\nHistory 3: ${e:\/\/Field\/history_3}<br>\nRound Times 3: ${e:\/\/Field\/roundTimes_3}<br>\nPayment 3: ${e:\/\/Field\/payment_3}<br>\n<br>\nHistory 4: ${e:\/\/Field\/history_4}<br>\nRound Times 4: ${e:\/\/Field\/roundTimes_4}<br>\nPayment 4: ${e:\/\/Field\/payment_4}<br>\n<br>\nHistory 5: ${e:\/\/Field\/history_5}<br>\nRound Times 5: ${e:\/\/Field\/roundTimes_5}<br>\nPayment 5: ${e:\/\/Field\/payment_5}<br>\n<br>\nHistory 6: ${e:\/\/Field\/history_6}<br>\nRound Times 6: ${e:\/\/Field\/roundTimes_6}<br>\nPayment 6: ${e:\/\/Field\/payment_6}<br>\n<br>\nHistory 7: ${e:\/\/Field\/history_7}<br>\nRound Times 7: ${e:\/\/Field\/roundTimes_7}<br>\nPayment 7: ${e:\/\/Field\/payment_7}<br>\n<br>\nHistory 8: ${e:\/\/Field\/history_8}<br>\nRound Times 8: ${e:\/\/Field\/roundTimes_8}<br>\nPayment 8: ${e:\/\/Field\/payment_8}<br><br>\nHistory 9: ${e:\/\/Field\/history_9}<br>\nRound Times 9: ${e:\/\/Field\/roundTimes_9}<br>\nPayment 9: ${e:\/\/Field\/payment_9}<br>\n<br>\nHistory 10: ${e:\/\/Field\/history_10}<br>\nRound Times 10: ${e:\/\/Field\/roundTimes_10}<br>\nPayment 10: ${e:\/\/Field\/payment_10}<br>\n<br>\nHistory 11: ${e:\/\/Field\/history_11}<br>\nRound Times 11: ${e:\/\/Field\/roundTimes_11}<br>\nPayment 11: ${e:\/\/Field\/payment_11}<br>\n<br>\nHistory 12: ${e:\/\/Field\/history_12}<br>\nRound Times 12: ${e:\/\/Field\/roundTimes_12}<br>\nPayment 12: ${e:\/\/Field\/payment_12}","DataExportTag":"Q309","QuestionID":"QID309"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"History: ${e:\/\/Field\/history} Round Times:\u00a0${e:\/\/Field\/roundTimes}","TertiaryAttribute":null,"Payload":{"QuestionText":"History: ${e:\/\/Field\/history}<br>Round Times:&nbsp;${e:\/\/Field\/roundTimes}<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"History: ${e:\/\/Field\/history} Round Times:\u00a0${e:\/\/Field\/roundTimes}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"LogicType":"BooleanValue","Value":"False","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span><span> False<\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"History: ${e:\/\/Field\/history}<br>Round Times:&nbsp;${e:\/\/Field\/roundTimes}<br>","DataExportTag":"Q31","QuestionID":"QID31"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID310","SecondaryAttribute":"Your Beliefs About the Game Game ${e:\/\/Field\/currentSymbol} Each of the next ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align:center\">\n    <span style=\"font-size:24px;\"><strong>Your Beliefs About the Game<\/strong><\/span>\n    <div style=\"text-align: center;\">\n        <span style=\"font-size:24px;\">\n            <strong>\n                <span class=\"miniGame\">\n                    <span class=\"label\">Game<\/span>\n                    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n                <\/span>\n            <\/strong>\n        <\/span>\n    <\/div>\n<\/div>\n\n<br>\nEach of the next ${e:\/\/Field\/nBeliefElicitationsDieter} decision screens show you a different scenario. Each will ask you how you believe the player's choices affected each other in the game you played during the last ${e:\/\/Field\/nRounds} rounds with ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}.\n<br><br>\n\nThere will be ${e:\/\/Field\/nBeliefElicitationsDieter} different scenarios. Some scenarios will ask what would happen if one or more players were forced to press or not press their button. In these scenarios, <b>it does not matter what the forced players would have chosen independently<\/b>. \n<br><br>\nThis part may determine your bonus payment. Depending on the accuracy of your reports, your bonus will be between $0 and ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax}. The payment system is designed such that it is in your own interest to report your beliefs truthfully. \n\t<button onclick=\"document.getElementById('detailsContent').style.display='block'; this.style.display='none';\" style=\"display: ${e:\/\/Field\/gameCounter == 1 ? 'none' : 'block'};\"\n> Show details<\/button>\n<br><br>\n\n\t\t\n\n\n\n\n<div id=\"detailsContent\" class=\"details-content\">\n\t<p>\n\t\t\t<b>How is my payment determined if this part counts?<\/b>\n\t<\/p>\n\t<br>\n\t<p>\n\tYou will report your beliefs in two ways. \n\t<\/p>\n\t<br>\n    <p>\n        In the first, you will select a probability from a wheel like this (for instance, to answer how often a given player pressed their button):\n\t\t<\/p>\n\t\t\n\t<div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_2tJZVYJcF4KW7aK\">\n    <\/div>\n\t<br>\n\t<p>\n\t\tIn the second, you will select a line from a list like this:\n\t\t\n\t<\/p>\t<br>\n\t\t    <div style=\"text-align: center;\">\n        <img style=\"width: 60%;\" src=${e:\/\/Field\/exampleBeliefURL}>\n    <\/div>\n\t<p>\n\t\tYou will earn ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} if you choose the segment or line that matches what actually happened. For each segment or line by which your estimate deviates from the correct answer, your bonus shrinks by ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentIncentive}.\n\t<\/p>\n\n<\/div>\n\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tthis.hidePreviousButton();\n\tthis.hideNextButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    \n\tvar gameCounter = \"${e:\/\/Field\/gameCounter}\";\n    \n    if (gameCounter == \"1\") {\n        document.getElementById('detailsContent').style.display = 'block';\n        document.querySelector('button').style.display = 'none';\n    }\n\t\n\n\n    var delay = parseInt(\"${e:\/\/Field\/instructionDelay}\") * 1000;\n\n    function showNextButton() {\n        jQuery(\"#NextButton\").fadeIn(1000);\n    }\n\n    \/\/ Initial delayed reveal\n    setTimeout(showNextButton, delay);\n\n    \/\/ Ensure it stays visible if the tab is switched or re-rendered\n    document.addEventListener(\"visibilitychange\", function() {\n        if (!document.hidden) {\n            showNextButton();\n        }\n    });\n\n    \/\/ Also re-show it when the window regains focus\n    window.addEventListener(\"focus\", function() {\n        showNextButton();\n    });\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your Beliefs About the Game Game ${e:\/\/Field\/currentSymbol} Each of the next ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<style>\n        .show-details-btn {\n            border: none;\n            padding: 10px 20px;\n            font-size: 14px;\n            border-radius: 5px;\n            cursor: pointer;\n            margin: 10px 0;\n        }\n        \n        .show-details-btn:hover {\n            background-color: #0056b3;\n        }\n        \n        .details-content {\n            display: none;\n        }\n        \n        .details-content.show {\n            display: block;\n        }\n    <\/style>\n<div style=\"text-align:center\"><span style=\"font-size:24px;\"><strong>Variations of Game <\/strong><\/span>\n<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong><span class=\"miniGame\"><span class=\"label\">Game<\/span><span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span><\/span><\/strong><\/span><\/div>\n<\/div>\n<br>\n<br>\nIn the next ${e:\/\/Field\/nBeliefElicitations}&nbsp;decision screens, you will continue to play the game that you have played in the previous ${e:\/\/Field\/nRounds} rounds. <b>You will continue to play with the same two other players, ${e:\/\/Field\/playerName1} and ${e:\/\/Field\/playerName2}, who choose in the same way as before.<\/b><br>\n<br>\nAs at the end of the previous games, on the next ${e:\/\/Field\/nBeliefElicitations} decision screens, you will make different types of decisions. Instead of pressing your button, you will sometimes decide whether to press another player's button. Instead of having your bonus determined by <b>${e:\/\/Field\/playerName2}'s<\/b> choice, you may be paid according to <b>${e:\/\/Field\/playerName1}<\/b>'s choice.<br>\n<br>\nEach time, you will report your beliefs about whether and how pressing a button affects another player's choice.<br>\n<br>\nRecall: it is in your best interest to answer truthfully.    <button onclick=\"document.getElementById('detailsContent').style.display='block'; this.style.display='none';\" style=\"display: ${e:\/\/Field\/gameCounter == 1 ? 'none' : 'block'};\">Show details<\/button>\n\n<div id=\"detailsContent\" class=\"details-content\">\n<div style=\"text-align: center;\"><img style=\"width: 80%;\" src=\"https:\/\/uzhwwf.qualtrics.com\/CP\/Graphic.php?IM=IM_6M64bgao94XKmd8\"><\/div>\n<br>\nYou will select one of multiple lines to report your beliefs. You will receive ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentMax} if you selected the line that corresponds to the truth. For each line by which your estimate differs from the truth, we will deduct ${e:\/\/Field\/currency}${e:\/\/Field\/beliefPaymentIncentive}.<br>\n<br>\n&nbsp;<\/div>\n<div>\nThe specific rules will be shown on each screen. Please read them carefully before making your choice.<br>\n&nbsp;<\/div>\n\n<div style=\"text-align:center; font-weight:bold;\">\n\tThese are <u>not<\/u> new games. <br> The questions are all about the game you have played in the previous ${e:\/\/Field\/nRounds} rounds, and about the way in which  ${e:\/\/Field\/playerName2} and ${e:\/\/Field\/playerName1} would usually choose. <br>\n&nbsp;\n<\/div>","DataExportTag":"Q310","QuestionID":"QID310","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID311","SecondaryAttribute":"Scenario of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game Game ${e:\/\/Field\/currentSymbol} Start...","TertiaryAttribute":null,"Payload":{"QuestionText":"<style>\n.Skin .SkinInner,\n.Skin #SkinContent,\n.Skin #Questions,\n.Skin .QuestionOuter,\n.Skin .QuestionBody,\n.Skin .QuestionText {\n    max-width: 1400px !important;\n    width: 100% !important;\n}\n.Skin .SkinInner {\n    margin: 0 auto !important;\n}\n\t\n.choice-pointer {\n    position: absolute;\n    left: 110%;\n    margin-left: 20px;\n    top: 50%;\n    transform: translateY(-50%);\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 5px;\n    font-size: 20px;\n    font-weight: bold;\n    min-width: 390px;\n    padding: 10px;  \/* Add this - increases space between border and text *\/\n}\n.choice-pointer button {\n    white-space: nowrap;\n}\n\/* Add this to increase panel height specifically for this page \n.panel {\n    height: 200px !important;\n}\n*\/\n<\/style>\n<div class=\"panel-block\">\n    <h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:0.3em;\">\n  Scenario <span id=\"roundNr\"> <\/span> of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div>\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n        <div id=\"instructionTitle\"> <\/div>\n\n<button id=\"startButton\" class=\"progressButton actionButton\">\n    Start This Scenario\n<\/button>\n        <div class=\"panel-wrapper\" style=\"display:none\">\n\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n\n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n\n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n\n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\n        <\/div>\n\n    <\/div>\n              \n<\/div>\n<div class=\"belief-block\">\n\n    <div id=\"beliefQuestionContainer\" class=\"verbal-section\" style=\"display: none;\">\n\n    <div id=\"question1Container\">\n        <div id=\"beliefQuestion1\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart1\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion1\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question2Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion2\" style=\"font-size:22px; margin-bottom:20px;\"><\/div>\n        <div class=\"pie-container\">\n            <svg class=\"pie-chart\" id=\"pieChart2\" viewBox=\"-210 -210 420 420\"><\/svg>\n            <div style=\"margin-top:10px; color:#666; font-size:14px;\">Click on the pie to make your prediction<\/div>\n        <\/div>\n        <button id=\"submitQuestion2\" class=\"verbal-submit\" disabled>Next<\/button>\n    <\/div>\n\n    <div id=\"question3Container\" style=\"display:none;\">\n        <div id=\"beliefQuestion3\" style=\"font-size:22px;margin-bottom:20px;\"><\/div>\n        <div id=\"beliefOptions\" style=\"margin:20px 0;\"><\/div>\n        <button id=\"beliefSubmit\" class=\"verbal-submit\" disabled>Submit Answer<\/button>\n    <\/div>\n<\/div>\n<\/div>\n","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    jQuery(\"#NextButton\").hide();\n    \n    \/\/ Add visibility change listener\n    document.addEventListener('visibilitychange', function() {\n        if (!document.hidden && roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    \n    \/\/ Enhance the MutationObserver to catch attribute changes too\n    const observer = new MutationObserver(function(mutations) {\n        if (roundCounter < nRounds) {\n            jQuery(\"#NextButton\").hide();\n        }\n    });\n    observer.observe(document.body, { \n        childList: true, \n        subtree: true,\n        attributes: true,  \/\/ Add this\n        attributeFilter: ['style', 'class'] \/\/ Add this\n    });\n\n    const allMetaData = [\n        JSON.parse('${e:\/\/Field\/mainCausal1}'),\n        JSON.parse('${e:\/\/Field\/mainCausal2}'),\n        JSON.parse('${e:\/\/Field\/mainCausal3}'),\n        JSON.parse('${e:\/\/Field\/mainCausal4}'),\n        JSON.parse('${e:\/\/Field\/mainCausal5}'),\n        JSON.parse('${e:\/\/Field\/mainCausal6}'),\n        JSON.parse('${e:\/\/Field\/mainCausal7}'),\n        JSON.parse('${e:\/\/Field\/mainCausal8}'),\n        JSON.parse('${e:\/\/Field\/mainCausal9}'),\n        JSON.parse('${e:\/\/Field\/mainCausal10}')\n    ];\n    \n    let currentMetaIndex = 0;\n    let metaData = allMetaData[currentMetaIndex];\n    let causalElicitType = metaData.causalElicit;\n\tlet causalElicitID = metaData.id;\n    let exoButton = metaData.exoButton;\n    const nRounds = allMetaData.length;\n\tconst id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    var rationalInference = JSON.parse(Qualtrics.SurveyEngine.getEmbeddedData('rationalInference_' + id));\n\tconsole.log(\"Look!\");\n    console.log(rationalInference);\n    let correctAnswerList = rationalInference[\"causal_\" + causalElicitID];\n\tconsole.log(correctAnswerList);\n    let correctAnswerListSlider1 = rationalInference[\"pNo_\" + causalElicitID];\n\tlet correctAnswerListSlider2 = rationalInference[\"pYes_\" + causalElicitID];\n    \n\n    const playerName1 = Qualtrics.SurveyEngine.getEmbeddedData('playerName1');\n    const playerName2 = Qualtrics.SurveyEngine.getEmbeddedData('playerName2');\n    const playerPronoun1 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun1');\n    const playerPronoun2 = Qualtrics.SurveyEngine.getEmbeddedData('playerPronoun2');\n\t\n    const lockSvgHTML = Qualtrics.SurveyEngine.getEmbeddedData('lockSvg');\n\tconst order = Qualtrics.SurveyEngine.getEmbeddedData('order');\n    \n    let roundCounter = 0;\n    let history = [];\n    let roundTimes = [];\n    let correctAnswers = [];\n    let correctAnswersSlider1 = [];\n    let correctAnswersSlider2 = [];\n    let roundStartTime = 0;\n    let displayStage = -1; \/\/  0 = locked panel, 1 = decision panel, 2 = ? panel\n\n    let aMessage = '';\n    let xMessage = '';\n    let yMessage = '';\n    let aBackgroundColor = 'white';\n    let xBackgroundColor = 'white';\n    let yBackgroundColor = 'white';\n\n    let progressButton; \/\/ Add this at the top with other variables\n    let hasStarted = false; \/\/ Make sure this is declared\n\n    window.currentBeliefData = {\n        causalElicitType: '',\n        exoButton: null,\n        playerName1: playerName1,\n        playerName2: playerName2,\n        playerPronoun1: playerPronoun1,\n        playerPronoun2: playerPronoun2\n    };\n\n\n    function createLockIcon() {\n        const lockSvg = document.createElement('div');\n        lockSvg.className = 'lock-icon';\n        lockSvg.innerHTML = lockSvgHTML;\n        return lockSvg;\n    }\n\t\n\tfunction highlightActivePanel(panel) {\n    \/\/ Remove highlight and pointers from all panels first\n    panelAinfo.classList.remove('active-choice');\n    panelXinfo.classList.remove('active-choice');\n    panelYinfo.classList.remove('active-choice');\n    \n    \/\/ Remove any existing pointers\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Add highlight and pointer to the active panel\n    if (panel) {\n        panel.classList.add('active-choice');\n        \n        \/\/ Create and add pointer with text\n        const pointer = document.createElement('div');\n        pointer.className = 'choice-pointer';\n        pointer.innerHTML = '...report how your choice...';\n        panel.appendChild(pointer);\n    }\n    }\n\n    const btnNo = document.createElement('button');\n    btnNo.id = 'btnNo';\n    btnNo.className = 'actionButton red';\n    btnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n    \n    const btnYes = document.createElement('button');\n    btnYes.id = 'btnYes';\n    btnYes.className = 'actionButton green';\n    btnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n\t\n\t\n\n    const buttonContainer = document.createElement('div');\n    buttonContainer.className = 'button-container';\n    buttonContainer.appendChild(btnNo);\n    buttonContainer.appendChild(btnYes);\n\t\n\t\n\tbtnYes.disabled = true;\n\tbtnNo.disabled = true;\n\tbtnYes.classList.add('disabled');\n\tbtnNo.classList.add('disabled');\n\n    const panelXinfo = document.getElementById(\"panelXinfo\");\n    const panelYinfo = document.getElementById(\"panelYinfo\");\n    const panelAinfo = document.getElementById(\"panelAinfo\");\n\n\n\tif (order === \"AYX\") {\n\t\tconst panelWrapper = document.querySelector('.panel-wrapper');\n\t\tpanelWrapper.insertBefore(panelYinfo, panelXinfo);\n\t}\n\n\n    const YText = document.getElementById(\"YText\");\n    const XText = document.getElementById(\"XText\");\n    const AText = document.getElementById(\"AText\");\n    const instructionElement = document.getElementById('instructionTitle');\n\n\n\t\n\tdocument.getElementById('startButton').addEventListener('click', function() {\n    if (!hasStarted) {\n        \/\/ First click: show panels, hide start button, create progress button\n        document.querySelector('.panel-wrapper').style.display = 'block';\n        startButton.style.display = 'none'; \/\/ Hide the start button\n        \n        \/\/ Create the new progress button\n        progressButton = document.createElement('button');\n        progressButton.className = 'progressButton actionButton';\n        progressButton.innerHTML = 'Next';\n        \n        hasStarted = true;\n        startRoundDisplay();\n\n        \/\/document.querySelectorAll('.stage1').forEach(el => el.classList.add('blink-text'));\n        \/\/ Attach the button to the appropriate panel\n        attachProgressButton();\n    }\n});\n\n\/\/ Add this new function to handle progress button clicks\nfunction handleProgressClick() {\n    if (displayStage === 0) {\n        displayStage = 1;\n        showStage1();\n        \/\/document.querySelectorAll('.stage1').forEach(el => el.classList.remove('blink-text'));\n        \/\/document.querySelectorAll('.stage2').forEach(el => el.classList.add('blink-text'));\n        attachProgressButton();\n    } else if (displayStage === 1) {\n        displayStage = 2;\n        showStage2();\n        \/\/document.querySelectorAll('.stage2').forEach(el => el.classList.remove('blink-text'));\n        \/\/document.querySelectorAll('.stage3').forEach(el => el.classList.add('blink-text'));\n        progressButton.innerHTML = \"I understand this scenario\";\n        attachProgressButton();\n    } else if (displayStage === 2) {\n        progressButton.remove(); \/\/ Remove the button\n        \n        \/\/ Remove all pointers\n        document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n        \n        \/\/document.querySelectorAll('.stage3').forEach(el => el.classList.remove('blink-text'));\n        panelAinfo.classList.remove('active-choice');\n        panelXinfo.classList.remove('active-choice');\n        panelYinfo.classList.remove('active-choice');\n        showBeliefQuestion();\n    }\n}\nfunction attachProgressButton() {\n    if (!progressButton) return;\n    \n    if (progressButton.parentNode) {\n        progressButton.remove();\n    }\n    \n    let targetPanel = null;\n    \n    if (displayStage === 0) {\n        \/\/ Stage 0: handles all cases with a \"first panel\"\n        if (causalElicitType === 'AX') {\n            targetPanel = panelYinfo;\n        } else if (causalElicitType === 'AY') {\n            targetPanel = panelXinfo;\n        } else if (causalElicitType === 'XY' || causalElicitType === 'YX') {\n            targetPanel = panelAinfo;\n        }\n    } else if (displayStage === 1) {\n        \/\/ Stage 1: decision panel\n        if (exoButton == null) {\n            if (causalElicitType === 'YX') {\n                targetPanel = panelYinfo;\n            } else {\n                targetPanel = panelAinfo;\n            }\n        } else {\n            if (causalElicitType === 'AX' || causalElicitType === 'AY') {\n                targetPanel = panelAinfo;\n            } else if (causalElicitType === 'XY') {\n                targetPanel = panelXinfo;\n            } else if (causalElicitType === 'YX') {\n                targetPanel = panelYinfo;\n            }\n        }\n    } else if (displayStage === 2) {\n        \/\/ Stage 2: \"?\" panel\n        if (causalElicitType === 'XY' || causalElicitType === 'AY') {\n            targetPanel = panelYinfo;\n        } else if (causalElicitType === 'YX' || causalElicitType === 'AX') {\n            targetPanel = panelXinfo;\n        }\n    }\n    \n    if (targetPanel) {\n        const pointer = targetPanel.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.appendChild(progressButton);\n        } else {\n            targetPanel.appendChild(progressButton);\n        }\n    }\n    \n    progressButton.onclick = handleProgressClick;\n}\n\n\n \n\n    function showPanelQuestion() {\n        document.querySelector('.panel-wrapper').style.display = '';\n        instructionElement.style.display = 'block';\n    }\n\n    function showBeliefQuestion() {\n        window.currentBeliefData.causalElicitType = causalElicitType;\n        window.currentBeliefData.exoButton = exoButton;\n        \n        const beliefContainer = document.getElementById('beliefQuestionContainer');\n        if (beliefContainer) {\n            beliefContainer.style.display = 'block';\n            \n            setTimeout(() => {\n                beliefContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });\n            }, 100);\n            \n            if (window.updateBeliefQuestion) {\n                window.updateBeliefQuestion();\n            }\n        }\n    }\n\n    window.onBeliefSubmitted = function(selectedIndex, selectedText) {\n        let roundEnd = Date.now();\n        roundTimes.push((roundEnd - roundStartTime) \/ 1000);\n        const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n        const originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n        \n        const beliefContainer = document.getElementById('beliefQuestionContainer');\n        if (beliefContainer) {\n            beliefContainer.style.display = 'none';\n        }\n        \n        if (roundCounter < nRounds) {\n\t\t\tdocument.getElementById('NextButton').style.display = 'none';\n            showPanelQuestion();\n            nextRound();\n        } else {\n            function getOptionIndex(percentage) {\n                if (percentage === null || percentage === undefined) return null;\n                \n                if (percentage <= -80) return 0;\n                if (percentage <= -60) return 1;\n                if (percentage <= -40) return 2;\n                if (percentage <= -20) return 3;\n                if (percentage < 0) return 4;\n                if (percentage === 0) return 5;\n                if (percentage < 20) return 6;\n                if (percentage < 40) return 7;\n                if (percentage < 60) return 8;\n                if (percentage < 80) return 9;\n                return 10;\n            }\n\n            const beliefPayment = correctAnswers.map((correct, index) => {\n                const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n                const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n\n                \/\/ If correct is null, give max payment\n                if (correct === null || correct === undefined) {\n                    return beliefPaymentMax;\n                }\n\n                \/\/ Convert correct percentage to option index\n                const correctOptionIndex = getOptionIndex(correct);\n                \n                \/\/ User's choice is already stored as option index (0-10)\n                const userChoice = window.allBeliefs[index];\n                \n                \/\/ Calculate difference between option indices\n                const absoluteDifference = Math.abs(correctOptionIndex - userChoice);\n                \n                return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n            });\n\n            const beliefPaymentSlider1 = correctAnswersSlider1.map((correct, index) => {\n            const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n            const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n            \n            \/\/ If correct is null, return max payment\n            if (correct === null || correct === undefined) {\n                return beliefPaymentMax;\n            }\n            \n            \/\/ Transform to nearest category (0, 10, 20, ..., 100)\n            const nearestCategory = Math.round(correct \/ 10) * 10;\n            \n            \/\/ Calculate payment using nearest category\n            const absoluteDifference = Math.abs(nearestCategory - window.allSlider1Values[index]) \/ 10;\n            return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n        });\n\n        const beliefPaymentSlider2 = correctAnswersSlider2.map((correct, index) => {\n            const beliefPaymentMax = parseFloat(\"${e:\/\/Field\/beliefPaymentMax}\");\n            const beliefPaymentIncentive = parseFloat(\"${e:\/\/Field\/beliefPaymentIncentive}\");\n            \n            \/\/ If correct is null, return max payment\n            if (correct === null || correct === undefined) {\n                return beliefPaymentMax;\n            }\n            \n            \/\/ Transform to nearest category (0, 10, 20, ..., 100)\n            const nearestCategory = Math.round(correct \/ 10) * 10;\n            \n            \/\/ Calculate payment using nearest category\n            const absoluteDifference = Math.abs(nearestCategory - window.allSlider2Values[index]) \/ 10;\n            return beliefPaymentMax - (absoluteDifference * beliefPaymentIncentive);\n        });\n            \n            Qualtrics.SurveyEngine.setEmbeddedData('beliefHistory_' + id, JSON.stringify(history));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefRoundTimes_' + id, JSON.stringify(roundTimes));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPayment_' + id, JSON.stringify(beliefPayment));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPaymentSlider1_' + id, JSON.stringify(beliefPaymentSlider1));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefPaymentSlider2_' + id, JSON.stringify(beliefPaymentSlider2));\n            Qualtrics.SurveyEngine.setEmbeddedData('beliefCorrectAnswer_' + id, JSON.stringify(correctAnswers));\n\t\t\t\n\t\t\tconsole.log(beliefPayment);\n\t\t\tconsole.log(correctAnswers);\n            \n            setTimeout(() => {\n                jQuery(\"#NextButton\").click();\n            }, 100);\n        }\n    };\n\n    function clearLockIcons() {\n        const existingLocks = document.querySelectorAll('.lock-icon');\n        existingLocks.forEach(lock => lock.remove());\n    }\n\n    function initiateRound() {\n        document.querySelector('.panel-wrapper').style.display = 'none';\n\t\thighlightActivePanel(null);\n\t\tclearLockIcons();\n\n\t\tpanelAinfo.style.backgroundColor = \"white\";\n\t\tpanelXinfo.style.backgroundColor = \"white\";\n\t\tpanelYinfo.style.backgroundColor = \"white\";\n\n\t\t\/\/ REMOVED: document.querySelector('.panel-wrapper').style.display = 'none';\n\t\t\/\/understandButton.style.display = 'none';\n\n\t\tAText.innerHTML = \"\";\n\t\tXText.innerHTML = \"\";\n\t\tYText.innerHTML = \"\";\n\n\t\tif (panelXinfo.contains(buttonContainer)) panelXinfo.removeChild(buttonContainer);\n\t\tif (panelAinfo.contains(buttonContainer)) panelAinfo.removeChild(buttonContainer);\n\t\tif (panelYinfo.contains(buttonContainer)) panelYinfo.removeChild(buttonContainer);\n\n\t\tbtnYes.disabled = btnNo.disabled = false;\n\t\tbtnYes.classList.remove(\"flash\");\n\t\tbtnNo.classList.remove(\"flash\");\n\n\t\txReady = false;\n\t\tcolorDisplayed = false;\n\t\tdecisionPanelShown = false;\n\n        panelAinfo.classList.remove('active-choice');\n        panelXinfo.classList.remove('active-choice');\n        panelYinfo.classList.remove('active-choice');\n\n        \/\/ NEW: Show the start button for each round\n        document.getElementById('startButton').style.display = 'block';\n\n\t\t\/\/ Prepare the action panels but don't show them yet\n\t\tprepareActionPanels();\n\t}\n\n    function updateInstructionTitle() {\n        if (!instructionElement) return;\n        \n        const instructionConfigs = {\n            AX: {\n                title: \"How does <b><span class=\\\"stage2\\\">your choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName1}'s choice<\/b><\/span> if ...\",\n                bullet1: exoButton == null\n                    ? \"${e:\/\/Field\/playerName2} chooses freely.\"\n                    : \"<span class=\\\"stage1\\\">${e:\/\/Field\/playerName2} must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName1} chooses freely.<\/span>\"\n            },\n            XY: {\n                title: \"How does <b><span class=\\\"stage2\\\">${e:\/\/Field\/playerName1}'s choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName2}'s choice<\/b><\/span> if ...\",\n                bullet1: \"<span class=\\\"stage1\\\">You must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName2} chooses freely.<\/span>\"\n            },\n            AY: {\n                title: \"How does <b><span class=\\\"stage2\\\">your choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName2}'s choice<\/b><\/span> if ...\",\n                bullet1: exoButton == null\n                    ? \"${e:\/\/Field\/playerName1} chooses freely.\"\n                    : \"<span class=\\\"stage1\\\">${e:\/\/Field\/playerName1} must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName2} chooses freely.<\/span>\"\n            },\n            YX: {\n                title: \"How does <b><span class=\\\"stage2\\\">${e:\/\/Field\/playerName2}'s choice<\/span><\/b> typically <span class=\\\"stage3\\\">affect <b>${e:\/\/Field\/playerName1}'s choice<\/b><\/span> if ...\",\n                bullet1: \"<span class=\\\"stage1\\\">You must press \" + (exoButton == 1 ? \"\\\"Yes\\\"\" : \"\\\"No\\\"\") + \".<\/span>\",\n                bullet2: \"<span class=\\\"stage3\\\">${e:\/\/Field\/playerName1} chooses freely.<\/span>\"\n            }\n        };\n        \n        const config = instructionConfigs[causalElicitType];\n        if (config) {\n            instructionElement.innerHTML = \n                '<div style=\"text-align:left\"><span style=\"font-size:22px;\">' + config.title + '<\/span><\/div>' +\n                '<ul style=\"font-size:22px;\"><li>...' + config.bullet1 + '<\/li><li>...' + config.bullet2 + '<\/li><\/ul>';\n        }\n    }\n\n    function nextRound() {\n        if (roundCounter < nRounds) {\n            roundCounter++;\n            currentMetaIndex = roundCounter - 1;\n            metaData = allMetaData[currentMetaIndex];\n            console.log('All metadata:', allMetaData);\n            causalElicitType = metaData.causalElicit;\n            causalElicitID = metaData.id;\n            exoButton = metaData.exoButton;\n            correctAnswerList = rationalInference[\"causal_\" + causalElicitID];\n            correctAnswerListSlider1 = rationalInference[\"pNo_\" + causalElicitID];\n            correctAnswerListSlider2 = rationalInference[\"pYes_\" + causalElicitID];\n\n            updateInstructionTitle();\n            document.getElementById('roundNr').textContent = roundCounter;\n\n            const configs = {\n                AX: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: exoButton == 1 \n                        ? '<br>${e:\/\/Field\/playerName2} must press \"Yes\".'\n                        : exoButton == 0\n                        ? '<br>${e:\/\/Field\/playerName2} must press \"No\".'\n                        : '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\"\n                },\n                AY: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == 1\n                        ? '<br>${e:\/\/Field\/playerName1} must press \"Yes\".'\n                        : exoButton == 0\n                        ? '<br>${e:\/\/Field\/playerName1} must press \"No\".'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: exoButton == 1 ? \"green\" : exoButton == 0 ? \"red\" : \"lightgray\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: 'lightgray'\n                },\n                XY: {\n                    aMessage: exoButton == 1\n                        ? '<br>You must press \"Yes\".'\n                        : '<br>You must press \"No\".',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: \"<br>\",\n                    xBackgroundColor: \"white\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round.',\n                    yBackgroundColor: 'lightgray'\n                },\n                YX: {\n                    aMessage: exoButton == 1\n                        ? '<br>You must press \"Yes\".'\n                        : '<br>You must press \"No\".',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round.',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: \"<br>\",\n                    yBackgroundColor: \"white\"\n                }\n            };\n            \n\n            const config = configs[causalElicitType];\n\t\t\taMessage = config.aMessage;\n\t\t\taBackgroundColor = config.aBackgroundColor;\n\t\t\txMessage = config.xMessage;\n\t\t\txBackgroundColor = config.xBackgroundColor;\n\t\t\tyMessage = config.yMessage;\n\t\t\tyBackgroundColor = config.yBackgroundColor;\n\n\t\t\t\/\/ Swap messages when order is AYX and no forced choice\n\t\t\tif (order === \"AYX\" && exoButton == null && (causalElicitType === \"AX\" || causalElicitType === \"AY\")) {\n\t\n\t\t\t\tconst temp = xMessage;\n\t\t\t\txMessage = yMessage;\n\t\t\t\tyMessage = temp;\n\t\t\t}\n\n            document.querySelectorAll('.panel-name').forEach(el => {\n                el.textContent = el.textContent.replace(' (determines your bonus)', '');\n            });\n\n            \n\n            initiateRound();\n        }\n    }\n\n\n    \/\/ NEW: Function to set up all panel content at the beginning\nfunction setupAllPanels() {\n    \/\/ Clear any existing content and pointers\n    AText.innerHTML = \"\";\n    XText.innerHTML = \"\";\n    YText.innerHTML = \"\";\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Reset backgrounds\n    panelAinfo.style.backgroundColor = \"white\";\n    panelXinfo.style.backgroundColor = \"white\";\n    panelYinfo.style.backgroundColor = \"white\";\n    \n    \/\/ Set up panel content based on causalElicitType and exoButton\n    if (exoButton != null) {\n        \/\/ Cases with locked\/forced choices\n        if (causalElicitType === 'AX') {\n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(createLockIcon());\n            \n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'AY') {\n            XText.innerHTML = '<div style=\"margin-top: 10px;\">' + xMessage + '<\/div>';\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            panelXinfo.appendChild(createLockIcon());\n            \n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'XY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(createLockIcon());\n            \n            XText.innerHTML = '<div style=\"margin-top: 10px;\">' + xMessage + '<\/div>';\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            panelXinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'YX') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(createLockIcon());\n            \n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n        }\n    } else {\n        \/\/ Cases with free choices (exoButton == null)\n        if (causalElicitType === 'AX') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'AY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'XY') {\n            AText.innerHTML = '<div style=\"margin-top: 10px;\">' + aMessage + '<\/div>';\n            panelAinfo.style.backgroundColor = aBackgroundColor;\n            panelAinfo.appendChild(buttonContainer);\n            \n            YText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n            \n        } else if (causalElicitType === 'YX') {\n            YText.innerHTML = '<div style=\"margin-top: 10px;\">' + yMessage + '<\/div>';\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n            \n            XText.innerHTML = '<div style=\"font-size: 70px; text-align: center; padding-top: 50px;\">?<\/div>';\n        }\n    }\n}\n\n\n    \/\/ NEW: Stage 0 - Add content to locked\/forced panel only\n    function showStage0() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    if (exoButton != null) {\n        \/\/ Determine the forced choice text based on exoButton value\n        const forcedChoice = exoButton == 1 ? '\"Yes\"' : '\"No\"';\n        \n        \/\/ Add pointer to locked panel\n        if (causalElicitType === 'AX') {\n            highlightActivePanel(panelYinfo);\n            const pointer = panelYinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Bonus Player must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'AY') {\n            highlightActivePanel(panelXinfo);\n            const pointer = panelXinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Co-Player must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'XY' || causalElicitType === 'YX') {\n            highlightActivePanel(panelAinfo);\n            const pointer = panelAinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which you must press ' + forcedChoice + '...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        }\n    } else {\n        \/\/ Add pointer to free choice panel\n        if (causalElicitType === 'AX') {\n            highlightActivePanel(panelYinfo);\n            const pointer = panelYinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Bonus Player chooses freely...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        } else if (causalElicitType === 'AY') {\n            highlightActivePanel(panelXinfo);\n            const pointer = panelXinfo.querySelector('.choice-pointer');\n            if (pointer) {\n                pointer.innerHTML = '<span>In the scenario in which the Co-Player chooses freely...<\/span>';\n                pointer.classList.add('active-choice');\n            }\n        }\n    }\n}\n\n    \/\/ NEW: Stage 1 - Add content to decision panel (with buttons)\n    function showStage1() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    let pointerText = '';\n    \n    \/\/ Add pointer to decision panel\n    if (exoButton == null) {\n        if (causalElicitType === 'YX') {\n            highlightActivePanel(panelYinfo);\n            pointerText = \"...report how the Bonus Player's choice...\";\n        } else {\n            highlightActivePanel(panelAinfo);\n            pointerText = \"...report how your choice...\";\n        }\n    } else {\n        if (causalElicitType === 'AX' || causalElicitType === 'AY') {\n            highlightActivePanel(panelAinfo);\n            pointerText = \"...report how your choice...\";\n        } else if (causalElicitType === 'XY') {\n            highlightActivePanel(panelXinfo);\n            pointerText = \"...report how the Co-Player's choice...\";\n        } else if (causalElicitType === 'YX') {\n            highlightActivePanel(panelYinfo);\n            pointerText = \"...report how the Bonus Player's choice...\";\n        }\n    }\n    \n    const pointer = document.querySelector('.active-choice .choice-pointer');\n    if (pointer) {\n        pointer.innerHTML = '<span>' + pointerText + '<\/span>';\n        pointer.classList.add('active-choice');\n    }\n    \n    decisionPanelShown = true;\n    attachProgressButton();\n}\n    \/\/ NEW: Stage 2 - Add content to \"?\" panel\n    function showStage2() {\n    \/\/ Remove any existing pointers first\n    document.querySelectorAll('.choice-pointer').forEach(pointer => pointer.remove());\n    \n    \/\/ Add pointer to \"?\" panel\n    if (causalElicitType === 'XY' || causalElicitType === 'AY') {\n        highlightActivePanel(panelYinfo);\n        const pointer = panelYinfo.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.innerHTML = '<span>... affects the Bonus Player.<\/span>';\n            pointer.classList.add('active-choice');\n        }\n    } else if (causalElicitType === 'YX' || causalElicitType === 'AX') {\n        highlightActivePanel(panelXinfo);\n        const pointer = panelXinfo.querySelector('.choice-pointer');\n        if (pointer) {\n            pointer.innerHTML = '<span>... affects the Co-Player.<\/span>';\n            pointer.classList.add('active-choice');\n        }\n    }\n    \n    \/\/ Set xReady for the next stage\n    if (exoButton == null) {\n        xReady = true;\n    }\n    \n    attachProgressButton();\n}\n\n    function prepareActionPanels() {\n\t\tcorrectAnswers.push(correctAnswerList);\n        correctAnswersSlider1.push(correctAnswerListSlider1);\n        correctAnswersSlider2.push(correctAnswerListSlider2);\n\n\t\tconsole.log(\"here\");\n\t\tconsole.log(correctAnswers);\n        window.scrollTo({ top: 0, behavior: 'smooth' });\n        \n        \/\/ NEW: Reset display stage\n        displayStage = 0;\n        hasStarted = false;\n        startButton.innerHTML = \"Start this scenario\"; \/\/ Reset button text\n        startButton.style.display = 'block'; \/\/ Show button again\n        \n        if (causalElicitType === 'XY') {\n            btnYes.innerHTML = \"Co-Player: Yes\";\n            btnNo.innerHTML = \"Co-Player: No\";\n\t\t}\n        else if (causalElicitType === 'YX') {\n            btnYes.innerHTML = \"Bonus Player: Yes\";\n            btnNo.innerHTML = \"Bonus Player: No\";\n\n        } else {\n            btnYes.innerHTML = \"${e:\/\/Field\/btnYes}\";\n            btnNo.innerHTML = \"${e:\/\/Field\/btnNo}\";\n        }\n\n        \/\/ NEW: Show all three panels as blank\n        panelXinfo.style.display = 'block';\n        panelYinfo.style.display = 'block';\n        panelAinfo.style.display = 'block';\n        \n        \/\/ Clear all content\n        AText.innerHTML = \"\";\n        XText.innerHTML = \"\";\n        YText.innerHTML = \"\";\n        \n        \/\/ Reset backgrounds\n        panelAinfo.style.backgroundColor = \"white\";\n        panelXinfo.style.backgroundColor = \"white\";\n        panelYinfo.style.backgroundColor = \"white\";\n    }\n\n    function startRoundDisplay() {\n    instructionElement.style.display = 'block';\n    \n    \/\/ Set up all panel content first\n    setupAllPanels();\n    \n    \/\/ Then show the appropriate first stage\n    if (exoButton != null || causalElicitType === 'AX' || causalElicitType === 'AY') {\n        showStage0();\n        displayStage = 0;\n    } else {\n        showStage1();\n        displayStage = 1;\n    }\n    \n    roundStartTime = Date.now();\n}\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Scenario of ${e:\/\/Field\/nBeliefElicitationsDieter} in Game Game ${e:\/\/Field\/currentSymbol} Start...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"\n<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","DataExportTag":"causality","QuestionID":"QID311","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Not Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"NotEqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"Type":"If"},"1":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">Loop 3: ${e:\/\/Field\/mainDieter3}<\/span> <span class=\"RightOpDesc\">Current Loop<\/span>","LeftOperand":"BL_3E3lWivUg5B4L0W,3","LogicType":"LoopAndMerge","Operator":"EqualTo","RightOperand":"lm:\/\/CurrentLoop","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">nSupergames<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 3 <\/span>","LeftOperand":"nSupergames","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"3","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID312","SecondaryAttribute":"Variant of Game Game ${e:\/\/Field\/currentSymbol} ${e:\/\/Field\/playerName1} panel X You panel A ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n\t\t\t<div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n\t\t\t\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this.hideNextButton();\n    this.hidePreviousButton();\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\n    const allMetaData = [\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines1}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines2}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines3}'),\n        JSON.parse('${e:\/\/Field\/mainCausalMigraines4}'),\n\t\tJSON.parse('${e:\/\/Field\/mainCausalMigraines5}')\n\t\t\n    ];\n\t\n    \n    let currentMetaIndex = 0;\n    let metaData = allMetaData[currentMetaIndex];\n    const costArray = [0.5];\n    let causalElicitType = metaData.causalElicit;\n    let exoButton = metaData.exoButton;\n    const nRounds = allMetaData.length;\n\tlet correctAnswerList = metaData.correct;\n    const noise = Qualtrics.SurveyEngine.getEmbeddedData('noise');\n    const causal = Qualtrics.SurveyEngine.getEmbeddedData('causal');\n    const id = Qualtrics.SurveyEngine.getEmbeddedData('id');\n    const yBonus = parseFloat(\"${e:\/\/Field\/yBonus}\");\n    const aCost = parseFloat(\"${e:\/\/Field\/aCost}\");\n    const pY = parseFloat(\"${e:\/\/Field\/pY}\");\n    const increasingOrder = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('increasingOrder'));\n    \n    let roundCounter = 0;\n    let X, A, Y;\n    let history = [];\n    let roundTimes = [];\n    let payment = [];\n    let beliefs = []; \n    let beliefsText = []; \n\tlet correctAnswers = [];\n\tlet beliefPayment = [];\n\n    let roundStartTime = 0;\n    let xReady = false;\n    let colorDisplayed = false;\n\n    \/\/ Store messages to be assigned later\n    let aMessage = '';\n    let xMessage = '';\n    let yMessage = '';\n    let aBackgroundColor = 'white';\n    let xBackgroundColor = 'white';\n    let yBackgroundColor = 'white';\n\n    \/\/ Store the submit handler function so we can remove it\n    let currentSubmitHandler = null;\n\n    \/\/ Create lock icon SVG\n    function createLockIcon() {\n        const lockSvg = document.createElement('div');\n        lockSvg.className = 'lock-icon';\n        lockSvg.innerHTML = `\n            <svg class=\"svg-icon\" style=\"width: 2.5em; height: 2.5em; vertical-align: middle; overflow: hidden;\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n                <path d=\"M824.888889 426.666667v-85.333334c0-173.511111-139.377778-312.888889-312.888889-312.888889S199.111111 167.822222 199.111111 341.333333v85.333334H85.333333v455.111111h853.333334V426.666667h-113.777778z m-284.444445 219.022222V739.555556h-56.888888v-93.866667c-17.066667-8.533333-28.444444-28.444444-28.444445-48.355556 0-31.288889 25.6-56.888889 56.888889-56.888889s56.888889 25.6 56.888889 56.888889c0 19.911111-11.377778 39.822222-28.444445 48.355556zM512 426.666667h-199.111111v-85.333334c0-110.933333 88.177778-199.111111 199.111111-199.111111s199.111111 88.177778 199.111111 199.111111v85.333334h-199.111111z\" fill=\"\" \/>\n            <\/svg>\n        `;\n        return lockSvg;\n    }\n\n    \/\/ Create buttons dynamically\n    const btnNo = document.createElement('button');\n    btnNo.id = 'btnNo';\n    btnNo.className = 'actionButton red';\n    \n    const btnYes = document.createElement('button');\n    btnYes.id = 'btnYes';\n    btnYes.className = 'actionButton green';\n\n    function updateButtonText() {\n        \/\/ Update button text based on current X value\n        if (causalElicitType === \"AY\") {\n            \/\/ For AY treatment, X is determined by exoButton, not user decision\n            if (exoButton === 0) {\n                btnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines0}\";\n                btnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines0}\";\n            } else {\n                btnNo.innerHTML = \"${e:\/\/Field\/btnNoMigraines1}\";\n                btnYes.innerHTML = \"${e:\/\/Field\/btnYesMigraines1}\";\n            }\n        } else {\n            \/\/ Default text when X is not yet determined or for other treatments\n            btnNo.innerHTML = \"No (no cost for you)\";\n            btnYes.innerHTML = \"Yes (no cost for you)\";\n        }\n    }\n        \n    const buttonContainer = document.createElement('div');\n    buttonContainer.className = 'button-container';\n    buttonContainer.appendChild(btnNo);\n    buttonContainer.appendChild(btnYes);\n\t\n\tconst understandButton = document.createElement('button');\n\tunderstandButton.id = 'understandButton';\n\tunderstandButton.className = 'actionButton';\n\tunderstandButton.innerHTML = \"I understand my choice options\";\n\tunderstandButton.style.display = 'none';\n\tunderstandButton.style.margin = '20px auto';\n\tunderstandButton.style.fontSize = '16px';\n\tunderstandButton.style.padding = '10px 20px';\n\tunderstandButton.style.backgroundColor = '#28a745';\n\tunderstandButton.style.color = 'white';\n\tunderstandButton.style.minWidth = '300px';\n\tunderstandButton.style.whiteSpace = 'nowrap';\n\tunderstandButton.style.position = 'relative'; \/\/ Add this\n\tunderstandButton.style.zIndex = '1000'; \/\/ Add this\n\n\t\/\/ Insert it after the instructionTitle instead of body\n\tdocument.getElementById('instructionTitle').insertAdjacentElement('afterend', understandButton);\n\n\t\/\/ Add click handler\n\tunderstandButton.addEventListener('click', function() {\n\t\tunderstandButton.style.display = 'none';\n\t\tdocument.querySelector('.panel-wrapper').style.display = '';\n\t\tshowActionPanels();\n\t});\n\n    const panelXinfo = document.getElementById(\"panelXinfo\");\n    const panelYinfo = document.getElementById(\"panelYinfo\");\n    const panelAinfo = document.getElementById(\"panelAinfo\");\n    const YText = document.getElementById(\"YText\");\n    const XText = document.getElementById(\"XText\");\n    const AText = document.getElementById(\"AText\");\n    const roundDisplay = document.getElementById(\"roundDisplay\");\n\n    btnYes.addEventListener(\"click\", () => handleDecision('y'));\n    btnNo.addEventListener(\"click\", () => handleDecision('n'));\n    document.addEventListener(\"keydown\", handleKeyPress);\n\n    function handleDecision(decision) {\n        const decisionPanel = (causalElicitType === \"XY\") ? panelXinfo : \n                             (causalElicitType === \"YX\") ? panelYinfo : panelAinfo;\n        \n        btnYes.disabled = btnNo.disabled = true;\n        (decision === 'y' ? btnYes : btnNo).classList.add(\"flash\");\n        setTimeout(() => (decision === 'y' ? btnYes : btnNo).classList.remove(\"flash\"), 200);\n\t\t\n\t\tcorrectAnswers.push(correctAnswerList[id-1]);\n\t\tconsole.log(\"Ahhh\")\n\t\tconsole.log(\"why?\");\n\t\tconsole.log(correctAnswers);\n\t\tconsole.log(correctAnswerList);\n\t\t\n\n        const currentCost = aCost;\n\t\t\n        \n        if (causalElicitType === \"XY\") {\n            A = exoButton;\n            X = decision === 'y' ? 1 : 0;\n            if (causal === 0) {\n                Y = Math.random() < pY ? 1 : 0;\n            } else {\n                const pY = [noise, 1-noise];\n                Y = Math.random() < pY[X] ? 1 : 0;\n            }\n            \n            payment.push(-X * currentCost + yBonus * Y);\n        }\n        \n        if (causalElicitType === \"AX\") {\n            A = decision === 'y' ? 1 : 0;\n            Y = exoButton;\n            if (causal === 0) {\n                const pX = [noise, 1-noise, 1-noise, 1-noise];\n                X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n            } else {\n                const pX = [noise, 1-noise];\n                X = Math.random() < pX[A] ? 1 : 0;\n            }\n            \n            payment.push(-A * currentCost + yBonus * X);\n        }\n        \n        if (causalElicitType === \"AY\") {\n            A = decision === 'y' ? 1 : 0;\n            X = exoButton;\n            if (causal === 0) {\n                Y = Math.random() < pY ? 1 : 0;\n            } else {\n                const pY = [noise, 1-noise];\n                Y = Math.random() < pY[X] ? 1 : 0;\n            }\n            \n            payment.push(-A * currentCost + yBonus * Y);\n        }\n        \n        if (causalElicitType === \"YX\") {\n            Y = decision === 'y' ? 1 : 0;\n            if (exoButton == null) {\n                \/\/ For YX with null exoButton, generate A and X randomly\n                A = Math.random() < 0.5 ? 1 : 0;\n                if (causal === 0) {\n                    X = Math.random() < 0.5 ? 1 : 0;\n                } else {\n                    const pX = [noise, 1-noise];\n                    X = Math.random() < pX[Y] ? 1 : 0;\n                }\n            } else {\n                A = exoButton;\n                if (causal === 0) {\n                    const pX = [noise, 1-noise, 1-noise, 1-noise];\n                    X = Math.random() < pX[A*2 + Y] ? 1 : 0;\n                } else {\n                    const pX = [noise, 1-noise];\n                    X = Math.random() < pX[Y] ? 1 : 0;\n                }\n            }\n            \n            payment.push(-Y * currentCost + yBonus * X);\n        }\n\n        history.push([A, X, Y]);\n        xReady = false;\n        colorDisplayed = false;\n\n        setTimeout(() => {\n            if (causalElicitType === \"XY\") {\n                AText.innerHTML = aMessage;\n                panelAinfo.style.backgroundColor = aBackgroundColor;\n                colorDisplayed = true; \n            } else if (causalElicitType === \"AY\") {\n                \/\/ For AY, after decision show Y panel (X status already shown)\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                colorDisplayed = true;\n            } else if (causalElicitType === \"YX\" && exoButton == null) {\n                \/\/ For YX with null exoButton, show X panel after Y decision\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                colorDisplayed = true;\n            } else {\n                \/\/ For AX, show X panel\n                XText.innerHTML = xMessage;\n                panelXinfo.style.backgroundColor = xBackgroundColor;\n                xReady = true; \n            }\n        }, 200);\n    }\n\n    function handleKeyPress(e) {\n        if (['y','n'].includes(e.key) && !btnYes.disabled && \n           ((causalElicitType === \"XY\") || \n            (causalElicitType === \"AY\" && xReady) || \n            (causalElicitType === \"YX\" && !xReady) || \n            (causalElicitType === \"AX\"))) handleDecision(e.key);\n        else if (e.key === 'c') {\n            if (causalElicitType === \"XY\" && colorDisplayed) {\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                yReady = true;\n            } else if (causalElicitType === \"AY\" && !xReady && !colorDisplayed) {\n                \/\/ This case should not occur anymore since AY shows everything immediately\n                \/\/ Keeping for safety but should not be triggered\n                const playerActionText = exoButton === 1 \n                    ? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button\"\n                    : \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button\";\n                AText.innerHTML = aMessage + \"<br>(\" + playerActionText + \")\";\n                panelAinfo.style.backgroundColor = aBackgroundColor;\n                updateButtonText();\n                panelAinfo.appendChild(buttonContainer);\n                xReady = true;\n            } else if (xReady && causalElicitType === \"AX\") {\n                YText.innerHTML = yMessage;\n                panelYinfo.style.backgroundColor = yBackgroundColor;\n                xReady = false;\n                colorDisplayed = true;\n            }\n        }\n        else if (e.key === ' ' && colorDisplayed) {\n            let roundEnd = Date.now();\n            roundTimes.push((roundEnd - roundStartTime) \/ 1000);\n            \n            \/\/ Show verbal elicitation after each choice\n            showVerbalElicitation();\n            colorDisplayed = false;\n        }\n    }\n\n    function clearLockIcons() {\n        const existingLocks = document.querySelectorAll('.lock-icon');\n        existingLocks.forEach(lock => lock.remove());\n    }\n\n    function initiateRound() {\n        roundDisplay.style.display = \"none\";\n\t\tdocument.querySelector('.panel-wrapper').style.display = 'none';\n\t\tsetTimeout(() => {\n\t\t\tunderstandButton.style.display = 'block';\n\t\t}, 5000);\n\n        \/\/ Clear all remnants from previous round\n        clearLockIcons();\n        \n        \/\/ Force reset all panel backgrounds and remove any leftover styling\n        panelAinfo.style.backgroundColor = \"white\";\n        panelXinfo.style.backgroundColor = \"white\";\n        panelYinfo.style.backgroundColor = \"white\";\n        \n        \/\/ Also clear any other potential background styles\n        panelAinfo.style.background = \"\";\n        panelXinfo.style.background = \"\";\n        panelYinfo.style.background = \"\";\n        \n        \/\/ Clear all text content\n        AText.innerHTML = \"\";\n        XText.innerHTML = \"\";\n        YText.innerHTML = \"\";\n        \n        \/\/ Remove button containers from all panels\n        if (panelXinfo.contains(buttonContainer)) {\n            panelXinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelAinfo.contains(buttonContainer)) {\n            panelAinfo.removeChild(buttonContainer);\n        }\n        \n        if (panelYinfo.contains(buttonContainer)) {\n            panelYinfo.removeChild(buttonContainer);\n        }\n        \n        \/\/ Reset button states\n        btnYes.disabled = btnNo.disabled = false;\n        btnYes.classList.remove(\"flash\");\n        btnNo.classList.remove(\"flash\");\n        \n        \/\/ Reset state variables\n        xReady = false;\n        colorDisplayed = false;\n        \n        \/\/ Handle panel visibility and styling for different treatments\n        if (causalElicitType === \"AY\") {\n            panelXinfo.style.display = 'none';\n        } else {\n            panelXinfo.style.display = '';\n            panelAinfo.style.display = '';\n            \/\/ For XY treatment, make panel X transparent with no border\n            if (causalElicitType === \"XY\") {\n                panelXinfo.style.backgroundColor = 'transparent';\n                panelXinfo.style.border = 'none';\n            }\n        }\n        \n        \/\/ Force a repaint by temporarily hiding and showing panels\n        const panelsToRepaint = [];\n        if (causalElicitType !== \"AY\") panelsToRepaint.push(panelAinfo);\n        panelsToRepaint.push(panelXinfo);\n        panelsToRepaint.push(panelYinfo);\n        \n        panelsToRepaint.forEach(panel => {\n            const originalDisplay = panel.style.display;\n            panel.style.display = 'none';\n            panel.offsetHeight; \/\/ Force reflow\n            panel.style.display = originalDisplay || '';\n        });\n        \n\n    }\n\n    function updateInstructionTitle() {\n        const instructionElement = document.getElementById('instructionTitle');\n        \n        if (!instructionElement) return;\n        \n        const instructionConfigs = {\n            AX: {\n                forcedText: exoButton == 1\n                    ? \"${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button\"\n                    : \"${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>Your payoff now depends on ${e:\/\/Field\/playerName1}'s choice and \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>You will receive a <u>bonus if <b>${e:\/\/Field\/playerName1}<\/b> presses ${e:\/\/Field\/playerPronoun1} button.<\/u><\/li><li><u>\" + this.forcedText + \".<\/u><\/li><\/ul>\";\n                }\n            },\n            XY: {\n                forcedText: exoButton == 1\n                    ? \"are forced to press your own button\"\n                    : \"are forced NOT to press your own button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong> You can now control ${e:\/\/Field\/playerName1}'s button but you \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li><b>Unlike before, you control ${e:\/\/Field\/playerName1}'s button (the player who usually determines whether pressing your own button is free)<\/b>. You \" + this.forcedText + \".<\/li><li>As before, you will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            AY: {\n                forcedText: exoButton == 1\n                    ? \"${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button\"\n                    : \"${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button\",\n                getTitle: function() { \n                    return \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>\" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return \"<ul><li>\" + this.forcedText + \".<\/li><li>As before, You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if ${e:\/\/Field\/playerName2} presses ${e:\/\/Field\/playerPronoun2} button.<\/li><\/ul>\";\n                }\n            },\n            YX: {\n                forcedText: exoButton == null \n                    ? \" \"\n                    : exoButton == 1\n                    ? \"you are forced to press your own button\"\n                    : \"you are forced NOT to press your own button\",\n                getTitle: function() { \n                    return exoButton == null\n                        ? \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>You control ${e:\/\/Field\/playerName2}'s button and your payoff depends on ${e:\/\/Field\/playerName1}'s choice!<\/strong><\/span><\/div>\"\n                        : \"<div style=\\\"text-align:center\\\"><span style=\\\"font-size:24px;\\\"><strong>You control ${e:\/\/Field\/playerName2}'s button and \" + this.forcedText + \"!<\/strong><\/span><\/div>\";\n                },\n                getContent: function() { \n                    return exoButton == null\n                        ? \"<ul><li>Unlike before, <b>${e:\/\/Field\/playerName1} (the first player) determines your bonus<\/b>, it's no longer ${e:\/\/Field\/playerName2} (the player at the bottom). You will receive a bonus of ${e:\/\/Field\/currency}${e:\/\/Field\/yBonus} if  ${e:\/\/Field\/playerName1} presses ${e:\/\/Field\/playerPronoun1} button. ${e:\/\/Field\/playerName1} decides in the same way as before.<\/li><li>Unlike before, <b>you control ${e:\/\/Field\/playerName2}'s button<\/b>.<\/li><\/ul>\"\n                        : \"<ul><li>You will receive a <u>bonus if <b>${e:\/\/Field\/playerName1}<\/b> presses ${e:\/\/Field\/playerPronoun1} button. ${e:\/\/Field\/playerName1} decides in the same way as before.<\/u><\/li><li><u>\" + this.forcedText + \".<\/u><\/li><\/ul>\";\n                }\n            }\n        };\n\n        \n        const instructionConfig = instructionConfigs[causalElicitType];\n        if (instructionConfig) {\n            const instructionTitle = instructionConfig.getTitle() + instructionConfig.getContent();\n            instructionElement.innerHTML = instructionTitle;\n        }\n    }\n\n    function nextRound() {\n\n        \n        if (roundCounter < nRounds) {\n            roundCounter++;\n\n            \/\/ Update to next metadata\n            currentMetaIndex = roundCounter - 1;\n            metaData = allMetaData[currentMetaIndex];\n            causalElicitType = metaData.causalElicit;\n            exoButton = metaData.exoButton;\n\t\t\tcorrectAnswerList = metaData.correct;\n\n            \/\/ Update instruction title and round number dynamically\n            updateInstructionTitle();\n            document.getElementById('roundNr').textContent = roundCounter;\n\n            \/\/ Set up messages based on causalElicitType\n           const configs = {\n                AX: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"c\" to continue)',\n                    xBackgroundColor: 'lightgray',\n                    yMessage: exoButton == 1 \n                        ? '${e:\/\/Field\/playerName2} is forced to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName2} is forced NOT to press ${e:\/\/Field\/playerPronoun2} button<br>(press \"space\" to continue)',\n                    yBackgroundColor: exoButton == 1 ? \"green\" : \"red\"\n                },\n                AY: {\n                    aMessage: 'Press your button?',\n                    aBackgroundColor: 'white',\n                    xMessage: '', \/\/ Not used in AY treatment since panel X is hidden\n                    xBackgroundColor: 'white',\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                XY: {\n                    aMessage: exoButton == 1\n                        ? 'You are forced to press your button<br>(press \"c\" to continue)'\n                        : 'You are forced NOT to press your button<br>(press \"c\" to continue)',\n                    aBackgroundColor: exoButton == 1 ? \"green\" : \"red\",\n                    xMessage: \"Press ${e:\/\/Field\/playerName1}'s button?\",\n                    xBackgroundColor: \"transparent\",\n                    yMessage: '${e:\/\/Field\/playerName2}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    yBackgroundColor: 'lightgray'\n                },\n                YX: {\n                    aMessage: '', \/\/ Not used in YX null treatment but panel A is still visible\n                    aBackgroundColor: 'white',\n                    xMessage: exoButton == null\n                        ? '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)'\n                        : '${e:\/\/Field\/playerName1}\\'s choice will not be shown in this round. <br>(press \"space\" to continue)',\n                    xBackgroundColor: exoButton == null ? 'transparent' : 'lightgray',\n                    yMessage: \"Press ${e:\/\/Field\/playerName2}'s button?\",\n                    yBackgroundColor: \"white\"\n                }\n            };       \n            \n            const config = configs[causalElicitType];\n            aMessage = config.aMessage;\n            aBackgroundColor = config.aBackgroundColor;\n            xMessage = config.xMessage;\n            xBackgroundColor = config.xBackgroundColor;\n            yMessage = config.yMessage;\n            yBackgroundColor = config.yBackgroundColor;\n\n            \/\/ Add bonus indicator to panel headers\n            document.querySelectorAll('.panel-name').forEach(el => {\n                el.textContent = el.textContent.replace(' (determines your bonus)', '');\n            });\n            \n            if (causalElicitType === \"AX\" || causalElicitType === \"YX\") {\n                const nameElement = document.querySelector('#panelXinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            } else if (causalElicitType === \"AY\" || causalElicitType === \"XY\") {\n                const nameElement = document.querySelector('#panelYinfo .panel-name');\n                if (nameElement) {\n                    nameElement.textContent += \" (determines your bonus)\";\n                }\n            }\n\n            roundDisplay.textContent = \"Round \" + roundCounter + \" of \" + nRounds;\n            initiateRound();\n        }\n    }\n\n    function showActionPanels() {\n        \/\/ For YX null treatment, start with Y panel and make X transparent\n        if (causalElicitType === 'YX' && exoButton == null) {\n            \/\/ Show panel A as normal (empty but visible)\n            AText.innerHTML = '';\n            panelAinfo.style.backgroundColor = 'white';\n            \n            \/\/ Make panel X transparent with no border\n            XText.innerHTML = '';\n            panelXinfo.style.backgroundColor = 'transparent';\n            panelXinfo.style.border = 'none';\n            \n            \/\/ Start with Y panel and buttons\n            YText.innerHTML = yMessage;\n            panelYinfo.style.backgroundColor = yBackgroundColor;\n            panelYinfo.appendChild(buttonContainer);\n        }\n        \/\/ For AY treatment, don't show panel X at all\n        else if (causalElicitType !== 'AY') {\n            XText.innerHTML = xMessage;\n            panelXinfo.style.backgroundColor = xBackgroundColor;\n            if (causalElicitType === \"XY\") {\n                panelXinfo.style.border = \"none\";\n            }\n        }\n        \n        const lockIcon = createLockIcon();\n        \n        \/\/ Add lock icons to appropriate panels\n        if (causalElicitType === 'XY') {\n            panelAinfo.appendChild(lockIcon);\n        }       \n        if (causalElicitType === 'AX') {\n            panelYinfo.appendChild(lockIcon);\n        }\n        \/\/ For AY, no lock icon on panel X since it's hidden\n        \/\/ For YX null, no lock icons needed\n        \n        \/\/ For AY treatment, show X status immediately in Panel A\n        if (causalElicitType === 'AY') {\n            const playerActionText = exoButton === 1 \n                ? \"${e:\/\/Field\/playerName1} pressed ${e:\/\/Field\/playerPronoun1} button\"\n                : \"${e:\/\/Field\/playerName1} did <u>not<\/u> press ${e:\/\/Field\/playerPronoun1} button\";\n            AText.innerHTML = aMessage + \"<br>(\" + playerActionText + \")\";\n            panelAinfo.style.backgroundColor = aBackgroundColor; \/\/ Use white background\n            updateButtonText();\n            panelAinfo.appendChild(buttonContainer);\n            xReady = true; \/\/ Ready to accept decisions immediately\n        }\n    \n        \/\/ Update button text for initial display\n        updateButtonText();\n    \n        if (causalElicitType === \"XY\") {\n            \/\/ For XY, add buttons to X panel immediately\n            panelXinfo.appendChild(buttonContainer);\n        }\n        \n        roundStartTime = Date.now();\n    }\n\n    function showVerbalElicitation() {\n        const verbalSection = document.getElementById('verbalElicitationSection');\n        const questionDiv = document.getElementById('verbalQuestion');\n        const optionsDiv = document.getElementById('verbalOptions');\n        const submitButton = document.getElementById('verbalSubmit');\n\n        \/\/ Determine question text based on treatment\n        const questionConfigs = {\n            AX: {\n                questionText: \"How does pressing your button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName1}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun1}\"\n            },\n            AY: {\n                questionText: exoButton == 1\n                    ? \"If ${e:\/\/Field\/playerName1} is forced to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"If ${e:\/\/Field\/playerName1} is forced NOT to press ${e:\/\/Field\/playerPronoun1} button, how does pressing your own button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName2}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun2}\"\n            },\n            XY: {\n                questionText: exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName1}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName2}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName2}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun2}\"\n            },\n            YX: {\n                questionText: exoButton == null\n                    ? \"How does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : exoButton == 1\n                    ? \"If you are forced to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\"\n                    : \"If you are forced NOT to press your own button, how does pressing ${e:\/\/Field\/playerName2}'s button (\\\"Yes\\\") change ${e:\/\/Field\/playerName1}'s choice?\",\n                affectedPlayer: \"${e:\/\/Field\/playerName1}\",\n                affectedPronoun: \"${e:\/\/Field\/playerPronoun1}\"\n            }\n        };\n        \n        const questionConfig = questionConfigs[causalElicitType];\n        const questionText = questionConfig.questionText;\n        const affectedPlayer = questionConfig.affectedPlayer;\n        const affectedPronoun = questionConfig.affectedPronoun;\n\n        \/\/ Create options array\n        const options = [\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Decreases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"No change in the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 1-19%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 20-39%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 40-59%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 60-79%.\",\n            \"Increases the chance that \" + affectedPlayer + \" presses \" + affectedPronoun + \" button by 80-100%.\"\n        ];\n\n        \/\/ If increasingOrder is 0, reverse the options order\n        const displayOptions = increasingOrder === 1 ? options : [...options].reverse();\n\n        \/\/ Show the section and set question\n        verbalSection.style.display = 'block';\n        questionDiv.textContent = questionText;\n        \n        \/\/ Clear existing options\n        optionsDiv.innerHTML = '';\n        \n        \/\/ Build options\n        displayOptions.forEach(function(option, index) {\n            const optionDiv = document.createElement('div');\n            optionDiv.className = 'verbal-option';\n            optionDiv.setAttribute('data-value', index);\n            \n            const radio = document.createElement('input');\n            radio.type = 'radio';\n            radio.name = 'verbalResponse';\n            radio.value = index;\n            radio.id = 'option' + index;\n            \n            const label = document.createElement('label');\n            label.setAttribute('for', 'option' + index);\n            label.textContent = option;\n            \n            optionDiv.appendChild(radio);\n            optionDiv.appendChild(label);\n            optionsDiv.appendChild(optionDiv);\n        });\n        \n        \/\/ Reset submit button\n        submitButton.disabled = true;\n        \n        \/\/ Add smooth scroll to verbal section after ensuring it's fully rendered\n        \/\/ Use requestAnimationFrame to wait for DOM to be fully painted\n        requestAnimationFrame(() => {\n            requestAnimationFrame(() => {\n                verbalSection.scrollIntoView({ \n                    behavior: 'smooth', \n                    block: 'start' \n                });\n            });\n        });\n        \n        \/\/ Add event listeners to options\n        const optionElements = verbalSection.querySelectorAll('.verbal-option');\n        \n        optionElements.forEach(function(option) {\n            option.addEventListener('click', function() {\n\n                \/\/ Remove selected class from all options\n                optionElements.forEach(function(opt) {\n                    opt.classList.remove('selected');\n                });\n                \n                \/\/ Add selected class to clicked option\n                this.classList.add('selected');\n                \n                \/\/ Check the radio button\n                const radio = this.querySelector('input[type=\"radio\"]');\n                radio.checked = true;\n                \n                \/\/ Enable submit button - get fresh reference\n                const currentSubmitButton = document.getElementById('verbalSubmit');\n                currentSubmitButton.disabled = false;\n            });\n        });\n        \n        \/\/ Also add event listeners to radio buttons directly\n        const radioElements = verbalSection.querySelectorAll('input[type=\"radio\"]');\n        radioElements.forEach(function(radio) {\n            radio.addEventListener('change', function() {\n                if (this.checked) {\n                    const currentSubmitButton = document.getElementById('verbalSubmit');\n                    currentSubmitButton.disabled = false;\n                }\n            });\n        });\n        \n        \/\/ Create the submit handler function\n        const handleSubmit = function() {\n            const selectedOption = verbalSection.querySelector('input[name=\"verbalResponse\"]:checked');\n            if (selectedOption) {\n                const selectedIndex = parseInt(selectedOption.value);\n                const selectedText = displayOptions[selectedIndex];\n\t\t\t\t\n\t\t\t\tconst originalIndex = increasingOrder === 1 ? selectedIndex : (10 - selectedIndex);\n\t\t\t\tbeliefs.push(originalIndex);\n                beliefsText.push(selectedText);\n                \n                \/\/ Store as JSON arrays with id suffix\n                Qualtrics.SurveyEngine.setEmbeddedData('beliefs_' + id, JSON.stringify(beliefs));\n                Qualtrics.SurveyEngine.setEmbeddedData('beliefsText_' + id, JSON.stringify(beliefsText));\n                \n                \/\/ Hide verbal section\n                verbalSection.style.display = 'none';\n                \n                \/\/ Continue to next round or finish\n                if (roundCounter < nRounds) {\n                    nextRound();\n                } else {\n                    beliefPayment = correctAnswers.map((correct, index) => {\n\t\t\t\t\t\tconst absoluteDifference = Math.abs(correct - beliefs[index]);\n\t\t\t\t\t\treturn 25 - (absoluteDifference * 2);\n\t\t\t\t\t});\n\t\t\t\t\t\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefHistory_' + id, JSON.stringify(history));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefRoundTimes_' + id, JSON.stringify(roundTimes));\n                    Qualtrics.SurveyEngine.setEmbeddedData('beliefPayment_' + id, JSON.stringify(beliefPayment));\n\t\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('beliefCorrectAnswer_' + id, JSON.stringify(correctAnswers));\n        \n\t\t\t\t\tconsole.log(\"History:\", history);\n\t\t\t\t\tconsole.log(\"Times:\", roundTimes);\n\t\t\t\t\tconsole.log(\"Beliefs:\", beliefs);\n\t\t\t\t\tconsole.log(\"Beliefs Text:\", beliefsText);\n\t\t\t\t\tconsole.log(\"Correct Answers\", correctAnswers);\n\t\t\t\t\tconsole.log(\"Belief Payment\", beliefPayment);\n                    \/\/ Move to next page\n                    document.getElementById('NextButton').click();\n                }\n            }\n        };\n        \n        \/\/ Remove existing event listener if any, then add new one\n        if (currentSubmitHandler) {\n            submitButton.removeEventListener('click', currentSubmitHandler);\n        }\n        currentSubmitHandler = handleSubmit;\n        submitButton.addEventListener('click', currentSubmitHandler);\n    }\n\n    nextRound();\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Variant of Game Game ${e:\/\/Field\/currentSymbol} ${e:\/\/Field\/playerName1} panel X You panel A ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">current<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> migraines <\/span>","LeftOperand":"current","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"migraines","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<body>\n\t<h1 style=\"text-align:center;display:flex;align-items:center;justify-content:center;gap:.3em;\">\n  Variant <span id=\"roundNr\"> <\/span> of Game\n  <span class=\"miniGame\">\n    <span class=\"label\">Game<\/span>\n    <span class=\"sym\">${e:\/\/Field\/currentSymbol}<\/span>\n  <\/span>\n<\/h1>\n    <div >\n        <div id=\"roundDisplay\" class=\"roundDisplay\"><\/div>\n         <div id=\"instructionTitle\"> <\/div>\n        \n        <div class=\"panel-wrapper\">\n            \n\t\t\t<div id=\"panelXinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon1}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName1}<\/div>\n                <\/div>\n                <div id=\"XText\" class=\"text\">panel X<\/div>\n            <\/div>\n            \n\t\t\t\n            <div id=\"panelAinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                  \n                    <div class=\"panel-name\">You<\/div>\n                <\/div>\n                <div id=\"AText\" class=\"text\">panel A<\/div>\n            <\/div>\n            \n            \n            \n            \n            <div id=\"panelYinfo\" class=\"panel\">\n                <div class=\"panel-header\">\n                    <img src=\"${e:\/\/Field\/playerIcon2}\" class=\"panel-icon\" alt=\"Player\">\n                    <div class=\"panel-name\">${e:\/\/Field\/playerName2}<\/div>\n                <\/div>\n                <div id=\"YText\" class=\"text\">panel Y<\/div>\n            <\/div>\n\t\t\t\t\t\n        <\/div>\n\t\t\n\t<div id=\"verbalElicitationSection\" class=\"verbal-section\" style=\"display: none;\">\n\t\t<div id=\"verbalQuestion\" class=\"verbal-question\"><\/div>\n\t\t<div id=\"verbalOptions\" class=\"verbal-options\"><\/div>\n\t\t<button id=\"verbalSubmit\" class=\"verbal-submit\" disabled>Submit Response<\/button>\n\t<\/div>\n    <\/div>\n<\/body>","DataExportTag":"Q312","QuestionID":"QID312"}},{"SurveyID":"SV_0HtmaLNlwWAwekm","Element":"SQ","PrimaryAttribute":"QID313","SecondaryAttribute":"Belief History 1: ${e:\/\/Field\/beliefHistory_1} Belief Round Times 1: ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p data-end=\"503\" data-start=\"208\">Belief History 1: ${e:\/\/Field\/beliefHistory_1}<br \/>\nBelief Round Times 1: ${e:\/\/Field\/beliefRoundTimes_1}<br \/>\nBelief Payment 1: ${e:\/\/Field\/beliefPayment_1}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_1}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_1}<br \/>\nBeliefs 1: ${e:\/\/Field\/beliefs_1}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_1}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_1}<br \/>\n<br \/>\nBelief History 2: ${e:\/\/Field\/beliefHistory_2}<br \/>\nBelief Round Times 2: ${e:\/\/Field\/beliefRoundTimes_2}<br \/>\nBelief Payment 2: ${e:\/\/Field\/beliefPayment_2}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_2}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_2}<br \/>\nBeliefs 2: ${e:\/\/Field\/beliefs_2}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_2}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_2}<br \/>\n<br \/>\nBelief History 3: ${e:\/\/Field\/beliefHistory_3}<br \/>\nBelief Round Times 3: ${e:\/\/Field\/beliefRoundTimes_3}<br \/>\nBelief Payment 3: ${e:\/\/Field\/beliefPayment_3}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_3}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_3}<br \/>\nBeliefs 3: ${e:\/\/Field\/beliefs_3}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_3}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_3}<br \/>\n<br \/>\nBelief History 4: ${e:\/\/Field\/beliefHistory_4}<br \/>\nBelief Round Times 4: ${e:\/\/Field\/beliefRoundTimes_4}<br \/>\nBelief Payment 4: ${e:\/\/Field\/beliefPayment_4}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_4}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_4}<br \/>\nBeliefs 4: ${e:\/\/Field\/beliefs_4}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_4}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_4}<br \/>\n<br \/>\nBelief History 5: ${e:\/\/Field\/beliefHistory_5}<br \/>\nBelief Round Times 5: ${e:\/\/Field\/beliefRoundTimes_5}<br \/>\nBelief Payment 5: ${e:\/\/Field\/beliefPayment_5}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_5}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_5}<br \/>\nBeliefs 5: ${e:\/\/Field\/beliefs_5}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_5}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_5}<br \/>\n<br \/>\nBelief History 6: ${e:\/\/Field\/beliefHistory_6}<br \/>\nBelief Round Times 6: ${e:\/\/Field\/beliefRoundTimes_6}<br \/>\nBelief Payment 6: ${e:\/\/Field\/beliefPayment_6}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_6}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_6}<br \/>\nBeliefs 6: ${e:\/\/Field\/beliefs_6}<br \/>\nSlider 1: ${e:\/\/Field\/slider1Values_6}<br \/>\nSlider 2: ${e:\/\/Field\/slider2Values_6}<br \/>\n<br \/>\nBelief History 7: ${e:\/\/Field\/beliefHistory_7}<br \/>\nBelief Round Times 7: ${e:\/\/Field\/beliefRoundTimes_7}<br \/>\nBelief Payment 7: ${e:\/\/Field\/beliefPayment_7}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_7}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_7}<br \/>\nBeliefs 7: ${e:\/\/Field\/beliefs_7}<br \/>\nSlider 7: ${e:\/\/Field\/slider1Values_7}<br \/>\nSlider 7: ${e:\/\/Field\/slider2Values_7}<br \/>\n<br \/>\nBelief History 8: ${e:\/\/Field\/beliefHistory_8}<br \/>\nBelief Round Times 8: ${e:\/\/Field\/beliefRoundTimes_8}<br \/>\nBelief Payment 8: ${e:\/\/Field\/beliefPayment_8}<br \/>\nBelief Payment slider 1: ${e:\/\/Field\/beliefPaymentSlider1_8}<br \/>\nBelief Payment slider 2: ${e:\/\/Field\/beliefPaymentSlider2_8}<br \/>\nBeliefs 8: ${e:\/\/Field\/beliefs_8}<br \/>\nSlider 8: ${e:\/\/Field\/slider1Values_8}<br \/>\nSlider 8: ${e:\/\/Field\/slider2Values_8}<br \/>\n<br \/>\n&nbsp;<\/p>\n\n<p data-end=\"701\" data-start=\"272\"><strong data-end=\"293\" data-start=\"272\">Belief History 9:<\/strong> ${e:\/\/Field\/beliefHistory_9}<br data-end=\"325\" data-start=\"322\" \/>\n<strong data-end=\"350\" data-start=\"325\">Belief Round Times 9:<\/strong> ${e:\/\/Field\/beliefRoundTimes_9}<br data-end=\"385\" data-start=\"382\" \/>\n<strong data-end=\"406\" data-start=\"385\">Belief Payment 9:<\/strong> ${e:\/\/Field\/beliefPayment_9}<br data-end=\"438\" data-start=\"435\" \/>\n<strong data-end=\"466\" data-start=\"438\">Belief Payment slider 1:<\/strong> ${e:\/\/Field\/beliefPaymentSlider1_9}<br data-end=\"505\" data-start=\"502\" \/>\n<strong data-end=\"533\" data-start=\"505\">Belief Payment slider 2:<\/strong> ${e:\/\/Field\/beliefPaymentSlider2_9}<br data-end=\"572\" data-start=\"569\" \/>\n<strong data-end=\"586\" data-is-only-node=\"\" data-start=\"572\">Beliefs 9:<\/strong> ${e:\/\/Field\/beliefs_9}<br data-end=\"612\" data-start=\"609\" \/>\n<strong data-end=\"625\" data-start=\"612\">Slider 1:<\/strong> ${e:\/\/Field\/slider1Values_9}<br data-end=\"657\" data-start=\"654\" \/>\n<strong data-end=\"670\" data-start=\"657\">Slider 2:<\/strong> ${e:\/\/Field\/slider2Values_9}<br \/>\n&nbsp;<\/p>\n\n<p data-end=\"1144\" data-start=\"703\"><strong data-end=\"725\" data-start=\"703\">Belief History 10:<\/strong> ${e:\/\/Field\/beliefHistory_10}<br data-end=\"758\" data-start=\"755\" \/>\n<strong data-end=\"784\" data-start=\"758\">Belief Round Times 10:<\/strong> ${e:\/\/Field\/beliefRoundTimes_10}<br data-end=\"820\" data-start=\"817\" \/>\n<strong data-end=\"842\" data-start=\"820\">Belief Payment 10:<\/strong> ${e:\/\/Field\/beliefPayment_10}<br data-end=\"875\" data-start=\"872\" \/>\n<strong data-end=\"903\" data-start=\"875\">Belief Payment slider 1:<\/strong> ${e:\/\/Field\/beliefPaymentSlider1_10}<br data-end=\"943\" data-start=\"940\" \/>\n<strong data-end=\"971\" data-start=\"943\">Belief Payment slider 2:<\/strong> ${e:\/\/Field\/beliefPaymentSlider2_10}<br data-end=\"1011\" data-start=\"1008\" \/>\n<strong data-end=\"1026\" data-is-only-node=\"\" data-start=\"1011\">Beliefs 10:<\/strong> ${e:\/\/Field\/beliefs_10}<br data-end=\"1053\" data-start=\"1050\" \/>\n<strong data-end=\"1066\" data-start=\"1053\">Slider 1:<\/strong> ${e:\/\/Field\/slider1Values_10}<br data-end=\"1099\" data-start=\"1096\" \/>\n<strong data-end=\"